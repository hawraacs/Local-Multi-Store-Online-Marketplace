@page
@model Local_Multi_Store_Online_Marketplace.Pages.PaymentFailedModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Failed</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: #F8F9FA;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .page {
            min-height: 100vh;
            padding: 45px 22px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            width: 100%;
            max-width: 460px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 55px rgba(15, 23, 42, 0.10);
            border: 1px solid #e5e7eb;
            padding: 36px 32px;
            text-align: center;
        }

        .icon {
            width: 72px;
            height: 72px;
            margin: 0 auto 20px;
            border-radius: 50%;
            background: #fee2e2;
            color: #dc2626;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 24px;
            font-weight: 800;
            color: #111827;
        }

        p.subtitle {
            margin: 0 0 26px;
            color: #64748b;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.6;
        }

        .actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .btn {
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            font-size: 14px;
        }

        .primary-btn {
            background: #FF6B35;
            color: white;
        }

        .secondary-btn {
            background: #e5e7eb;
            color: #374151;
        }

        .tertiary-btn {
            background: #111827;
            color: white;
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 13px 14px;
            border-radius: 14px;
            font-weight: 700;
            font-size: 13px;
        }
    </style>
</head>
<body>

    <div class="page">
        <div class="card">

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
            else if (Model.Order != null)
            {
                <div class="icon">✕</div>

                <h1>Payment Failed</h1>
                <p class="subtitle">@Model.Reason</p>

                <div class="actions">
                    <a href="/OnlinePayment?orderId=@Model.Order.OrderID" class="btn primary-btn">
                        Retry Payment
                    </a>
                    <a href="/CustomerOrders" class="btn tertiary-btn">
                        Back to Orders
                    </a>
                </div>
            }

        </div>
    </div>

</body>
</html>
