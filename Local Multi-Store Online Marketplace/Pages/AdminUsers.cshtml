@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminUsersModel
@{
    ViewData["Title"] = "User Management";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ============================================================
                   ADMIN THEME — matches Admin Dashboard (light / indigo+sky)
                   ============================================================ */
        :root {
            /* ── Backgrounds ── */
            --bg-color: #F8FAFC;
            --bg-soft: #F1F5F9;
            --card-bg: #FFFFFF;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --surface-hover: #F1F5F9;
            /* ── Text ── */
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            --text: #0F172A;
            /* ── Borders ── */
            --border-color: #E2E8F0;
            --border: #E2E8F0;
            /* ── Accent (Indigo + Sky) ── */
            --accent-color: #6366F1;
            --accent-hover: #4F46E5;
            --accent-light: #EEF2FF;
            --accent-gradient: linear-gradient(135deg, #6366F1 0%, #0EA5E9 100%);
            --brand: #6366F1;
            --brand-dark: #4338CA;
            --brand-light: #A5B4FC;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --brand-soft-hover: rgba(99, 102, 241, 0.15);
            /* ── Semantic States ── */
            --success: #16A34A;
            --success-bg: #DCFCE7;
            --success-txt: #15803D;
            --warning: #D97706;
            --warning-bg: #FEF3C7;
            --warning-txt: #B45309;
            --danger: #DC2626;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --info: #6366F1;
            --info-bg: #EEF2FF;
            --info-txt: #4338CA;
            /* ── Shadows ── */
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 3px rgba(15, 23, 42, 0.06);
            --shadow-md: 0 4px 12px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 12px 32px rgba(15, 23, 42, 0.10);
            --shadow-hover: 0 16px 40px rgba(15, 23, 42, 0.14);
            /* ── Radius / Font / Transition ── */
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 1.5rem;
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            --navy: #0F172A;
            --navy-light: #1E293B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-color);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Main Card ── */
        .users-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 2rem 2rem 1.5rem;
            margin: 2rem auto;
            max-width: 1400px;
            box-shadow: var(--shadow-sm);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .users-card:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

            .users-card h3 {
                font-size: 1.75rem;
                font-weight: 800;
                letter-spacing: -0.03em;
                background: var(--accent-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin-bottom: 0.25rem;
                display: inline-block;
            }

                .users-card h3 i {
                    -webkit-text-fill-color: initial;
                    color: var(--brand);
                    margin-right: 0.5rem;
                }

        /* ── Filter Bar ── */
        .filter-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin: 1.5rem 0 1.75rem;
            align-items: center;
        }

            .filter-bar input,
            .filter-bar select {
                padding: 0.55rem 1rem;
                border-radius: 999px;
                border: 1px solid var(--border);
                font-size: 0.85rem;
                background: var(--surface);
                color: var(--text-primary);
                font-family: var(--font);
                transition: border-color var(--transition), box-shadow var(--transition);
                min-width: 140px;
            }

                .filter-bar input:focus,
                .filter-bar select:focus {
                    outline: none;
                    border-color: var(--brand);
                    box-shadow: 0 0 0 3px var(--brand-soft);
                }

                .filter-bar input::placeholder {
                    color: var(--text-muted);
                }

        /* ── Export Button ── */
        .btn-export {
            background: var(--brand);
            color: white;
            border: none;
            padding: 0.55rem 1.25rem;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font);
            box-shadow: var(--shadow-sm);
        }

            .btn-export:hover {
                background: var(--brand-dark);
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

            .btn-export i {
                font-size: 0.8rem;
            }

        /* ── Table ── */
        .table-responsive {
            overflow-x: auto;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--surface);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        thead th {
            text-align: left;
            padding: 0.9rem 1rem;
            background: var(--surface-2);
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            border-bottom: 1.5px solid var(--border);
            white-space: nowrap;
        }

        tbody td {
            padding: 0.9rem 1rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            color: var(--text-secondary);
            transition: background var(--transition);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover td {
            background: var(--surface-hover);
        }

        /* ── Checkbox ── */
        input[type="checkbox"] {
            accent-color: var(--brand);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        /* ── Badges ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.2rem 0.8rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid transparent;
            white-space: nowrap;
        }

        .badge-active {
            background: var(--success-bg);
            color: var(--success-txt);
            border-color: #86EFAC;
        }

            .badge-active::before {
                content: "●";
                font-size: 0.6rem;
                color: var(--success);
            }

        .badge-pending {
            background: var(--warning-bg);
            color: var(--warning-txt);
            border-color: #FCD34D;
        }

            .badge-pending::before {
                content: "●";
                font-size: 0.6rem;
                color: var(--warning);
            }

        /* ── Action Buttons ── */
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            align-items: center;
        }

        .btn-approve,
        .btn-deactivate {
            border: none;
            padding: 0.3rem 0.8rem;
            border-radius: 999px;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 600;
            transition: all var(--transition);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            font-family: var(--font);
            box-shadow: var(--shadow-sm);
        }

        .btn-approve {
            background: var(--success);
            color: white;
        }

            .btn-approve:hover {
                background: #0E9F6E;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .btn-deactivate {
            background: var(--danger);
            color: white;
        }

            .btn-deactivate:hover {
                background: #B91C1C;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

            .btn-approve i,
            .btn-deactivate i {
                font-size: 0.7rem;
            }

        /* ── Empty state ── */
        tbody tr td[colspan] {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
            font-style: italic;
            font-size: 0.95rem;
        }

            tbody tr td[colspan] i {
                color: var(--border);
                margin-bottom: 0.5rem;
            }

            tbody tr td[colspan] p {
                margin-top: 0.5rem;
            }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .users-card {
                padding: 1.25rem;
                margin: 1rem;
            }

            .filter-bar {
                gap: 8px;
            }

                .filter-bar input,
                .filter-bar select {
                    min-width: 100px;
                    font-size: 0.8rem;
                    padding: 0.4rem 0.8rem;
                }

            .btn-export {
                padding: 0.4rem 0.9rem;
                font-size: 0.8rem;
            }

            thead th,
            tbody td {
                padding: 0.65rem 0.65rem;
                font-size: 0.8rem;
            }

            .btn-approve,
            .btn-deactivate {
                padding: 0.2rem 0.6rem;
                font-size: 0.7rem;
            }
        }

        @@media (max-width: 480px) {
            .filter-bar {
                flex-direction: column;
                align-items: stretch;
            }

                .filter-bar input,
                .filter-bar select,
                .btn-export {
                    width: 100%;
                }
        }

        button:focus-visible,
        input:focus-visible,
        select:focus-visible {
            outline: 2px solid var(--brand);
            outline-offset: 2px;
        }
    </style>
}

<div class="users-card">
    <h3><i class="fas fa-users"></i> User Management</h3>

    <div class="filter-bar">
        <input type="text" id="searchUser" placeholder="🔍 Name or Email...">
        <select id="roleFilter">
            <option value="">All Roles</option>
            <option>Customer</option>
            <option>StoreOwner</option>
            <option>DeliveryStaff</option>
            <option>Admin</option>
        </select>
        <select id="statusFilter">
            <option value="">All Status</option>
            <option value="true">Active</option>
            <option value="false">Pending/Inactive</option>
        </select>
        <button id="exportCsvBtn" class="btn-export"><i class="fas fa-download"></i> Export CSV</button>
    </div>

    <div class="table-responsive">
        <table id="usersTable">
            <thead>
                <tr>
                    <th style="width:30px"><input type="checkbox" id="selectAll"></th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users != null && Model.Users.Any())
                {
                    foreach (var user in Model.Users)
                    {
                        <tr data-role="@user.Roles" data-active="@user.IsActive.ToString()">
                            <td><input type="checkbox" class="userCheckbox" data-id="@user.UserId"></td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>@user.Roles</td>
                            <td>
                                <span class="badge @(user.IsActive ? "badge-active" : "badge-pending")">
                                    @(user.IsActive ? "Active" : "Pending")
                                </span>
                            </td>
                            <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    @if (!user.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Approve" style="display:inline;">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <button type="submit" class="btn-approve">
                                                <i class="fas fa-check-circle"></i> Approve
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <button type="submit" class="btn-deactivate">
                                                <i class="fas fa-ban"></i> Deactivate
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align:center; padding:40px;">
                            <i class="fas fa-inbox fa-2x" style="color:#cbd5e1;"></i>
                            <p style="margin-top:10px;">No users found.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Filtering logic
    const searchInput = document.getElementById('searchUser');
    const roleFilter = document.getElementById('roleFilter');
    const statusFilter = document.getElementById('statusFilter');
    const rows = document.querySelectorAll('#usersTable tbody tr');

    function filterTable() {
        const term = searchInput.value.toLowerCase();
        const role = roleFilter.value.toLowerCase();
        const status = statusFilter.value; // 'true' or 'false'
        rows.forEach(row => {
            // Skip the "no users" row if it exists
            if (row.cells.length < 8) return;
            const name = row.cells[1]?.innerText.toLowerCase() || '';
            const email = row.cells[2]?.innerText.toLowerCase() || '';
            const roleText = row.cells[4]?.innerText.toLowerCase() || '';
            const isActive = row.dataset.active === 'True';
            let show = (name.includes(term) || email.includes(term));
            if (role && !roleText.includes(role)) show = false;
            if (status === 'true' && !isActive) show = false;
            if (status === 'false' && isActive) show = false;
            row.style.display = show ? '' : 'none';
        });
    }

    searchInput.addEventListener('keyup', filterTable);
    roleFilter.addEventListener('change', filterTable);
    statusFilter.addEventListener('change', filterTable);

    // Export CSV
    document.getElementById('exportCsvBtn').addEventListener('click', () => {
        let csv = "Name,Email,Phone,Role,Status,Joined\n";
        document.querySelectorAll('#usersTable tbody tr:visible').forEach(row => {
            if (row.cells.length < 8) return;
            const cells = row.cells;
            csv += `"${cells[1].innerText}","${cells[2].innerText}","${cells[3].innerText}","${cells[4].innerText}","${cells[5].innerText}","${cells[6].innerText}"\n`;
        });
        const blob = new Blob([csv], {type: 'text/csv'});
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'users_export.csv';
        link.click();
    });

    // Select all checkboxes
    const selectAllCheckbox = document.getElementById('selectAll');
    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', (e) => {
            document.querySelectorAll('.userCheckbox').forEach(cb => cb.checked = e.target.checked);
        });
    }
</script>