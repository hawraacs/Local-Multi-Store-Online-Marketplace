@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreCustomerProfileModel

@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        background: #f5f5f5;
        margin: 0;
    }

    .profile-container {
        max-width: 850px;
        margin: 30px auto;
        background: white;
        border-radius: 15px;
        padding: 20px;
    }

    .header {
        display: flex;
        gap: 20px;
        align-items: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    .logo {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
    }

    .btn {
        padding: 8px 14px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
        display: inline-block;
    }

    .follow-btn {
        background: #2563eb;
        color: white;
    }

    .chat-btn {
        background: #111827;
        color: white;
        margin-left: 10px;
    }

    .stats {
        color: gray;
        margin-top: 6px;
    }

    .products {
        margin-top: 20px;
    }

    .product {
        background: #fff;
        margin-bottom: 15px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

        .product img {
            width: 100%;
            height: 300px;
            object-fit: cover;
        }

    .product-body {
        padding: 12px;
    }

    .price {
        color: #ff6600;
        font-weight: bold;
    }
</style>

<div class="profile-container">

    <!-- HEADER -->
    <div class="header">

        <img class="logo"
             src="@(Model.Store.LogoURL ?? "/images/store.png")" />

        <div>
            <h2>@Model.Store.StoreName</h2>

            <div class="stats">
                Followers: @Model.FollowersCount
            </div>

            <form method="post" asp-page-handler="Follow" style="display:inline;">
                <button class="btn follow-btn">
                    Follow
                </button>
            </form>

            <!-- ✅ CHAT BUTTON ADDED -->
            <a class="btn chat-btn"
               asp-page="/ChatConversation"
               asp-route-userId="@Model.Store.OwnerUserID">
                Chat
            </a>

            <form method="get"
                  asp-page="/CreateReview"
                  asp-route-storeId="@Model.Store.StoreID"
                  style="display:inline; margin-left:10px;">
                <button class="btn follow-btn" style="background:#16a34a;">
                    Review Store
                </button>
            </form>

        </div>

    </div>

    <!-- PRODUCTS -->
    <div class="products">

        @foreach (var p in Model.Products)
        {
            var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

            <div class="product">

                <img src="@img" />

                <div class="product-body">

                    <h3>@p.ProductName</h3>

                    <div class="price">
                        $@p.Price
                    </div>

                    <p>@p.Description</p>

                    <a asp-page="/CreateProductReview"
                       asp-route-productId="@p.ProductID">
                        Review Product
                    </a>

                </div>

            </div>
        }

    </div>

</div>