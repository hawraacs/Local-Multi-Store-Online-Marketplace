@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAssignDeliveryModel
@{
    ViewData["Title"] = "Assign Delivery";
}

<style>
    body {
        background: #f4f6f9;
        font-family: Arial, sans-serif;
    }

    .assign-page {
        max-width: 1100px;
        margin: 40px auto;
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border: 1px solid #e5e7eb;
    }

    h2 {
        text-align: center;
        color: #111827;
        margin-bottom: 25px;
    }

    .message {
        padding: 12px 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        font-weight: 800;
        text-align: center;
    }

    .success {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
    }

    .error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #111827;
        color: white;
        padding: 12px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #e5e7eb;
        color: #374151;
        vertical-align: middle;
    }

    select {
        padding: 8px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        width: 220px;
    }

    button {
        background: #111827;
        color: white;
        border: none;
        padding: 9px 14px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 800;
    }

        button:hover {
            background: #ff6b35;
        }

    .empty {
        text-align: center;
        color: #6b7280;
        padding: 35px;
        font-weight: 700;
    }

    .top-links {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .link-btn {
        background: #111827;
        color: white;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 800;
    }

        .link-btn:hover {
            background: #ff6b35;
        }

    @@media (max-width: 850px) {
        .assign-page {
            overflow-x: auto;
            margin: 20px;
        }

        table {
            min-width: 900px;
        }
    }
</style>

<div class="assign-page">
    <h2>Assign Delivery Person to Order</h2>

    <div class="top-links">
        <a href="/AdminDelivery" class="link-btn">Delivery Requests</a>
        <a href="/CustomerOrders" class="link-btn">View Orders</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="message success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="message error">@TempData["Error"]</div>
    }

    @if (Model.DeliveryPeople == null || !Model.DeliveryPeople.Any())
    {
        <div class="empty">
            No approved delivery persons found. Approve a delivery request first.
        </div>
    }
    else if (Model.Orders == null || !Model.Orders.Any())
    {
        <div class="empty">
            No unassigned orders available for delivery assignment.
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Order Number</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Assign Delivery Person</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@order.Status</td>
                        <td>$@order.TotalAmount.ToString("N2")</td>

                        <td>
                            <form method="post" asp-page-handler="Assign" id="assignForm_@order.OrderID">
                                <input type="hidden" name="orderId" value="@order.OrderID" />

                                <select name="deliveryPersonId" required>
                                    <option value="">Select delivery</option>

                                    @foreach (var d in Model.DeliveryPeople)
                                    {
                                        <option value="@d.DeliveryPersonID">
                                            @d.FullName - @d.Area - @d.VehicleType
                                        </option>
                                    }
                                </select>
                            </form>
                        </td>

                        <td>
                            <button type="submit" form="assignForm_@order.OrderID">
                                Assign
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>