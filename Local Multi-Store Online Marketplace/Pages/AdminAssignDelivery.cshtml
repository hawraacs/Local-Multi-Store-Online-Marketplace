@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAssignDeliveryModel

@{
    ViewData["Title"] = "Assign Delivery";
}

<style>
    body {
        background: #f4f6f9;
        font-family: Arial, sans-serif;
    }

    .assign-page {
        max-width: 1100px;
        margin: 40px auto;
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border: 1px solid #e5e7eb;
    }

    h2 {
        text-align: center;
        color: #111827;
        margin-bottom: 25px;
    }

    .message {
        padding: 12px 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        font-weight: 800;
        text-align: center;
    }

    .success {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
    }

    .error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    .top-links {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .link-btn {
        background: #111827;
        color: white;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 800;
    }

        .link-btn:hover {
            background: #ff6b35;
            color: white;
        }

    .table-responsive {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #111827;
        color: white;
        padding: 12px;
        text-align: left;
        font-size: 14px;
        white-space: nowrap;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #e5e7eb;
        color: #374151;
        vertical-align: middle;
    }

    tbody tr:hover {
        background: #f9fafb;
    }

    select {
        padding: 9px 10px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        width: 240px;
        max-width: 100%;
        background: white;
        outline: none;
    }

        select:focus {
            border-color: #111827;
            box-shadow: 0 0 0 3px rgba(17, 24, 39, 0.10);
        }

    button {
        background: #111827;
        color: white;
        border: none;
        padding: 9px 14px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 800;
    }

        button:hover:not(:disabled) {
            background: #ff6b35;
        }

        button:disabled {
            background: #9ca3af;
            cursor: not-allowed;
            opacity: 0.75;
        }

    .empty {
        text-align: center;
        color: #6b7280;
        padding: 35px;
        font-weight: 700;
    }

    .no-delivery {
        display: inline-block;
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 10px;
        padding: 8px 10px;
        font-size: 13px;
        font-weight: 700;
    }

    .customer-info {
        display: block;
        color: #6b7280;
        font-size: 12px;
        margin-top: 5px;
    }

    .order-number {
        font-weight: 800;
        color: #111827;
    }

    @@media (max-width: 850px) {
        .assign-page {
            margin: 20px;
            padding: 18px;
        }

        table {
            min-width: 900px;
        }
    }
</style>

<div class="assign-page">

    <h2>Assign Delivery Person to Order</h2>

    <div class="top-links">
        <a href="/AdminDelivery" class="link-btn">
            Delivery Requests
        </a>

        <a href="/AdminOrders" class="link-btn">
            View Orders
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="message success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="message error">
            @TempData["Error"]
        </div>
    }

    @if (Model.Orders == null || !Model.Orders.Any())
    {
        <div class="empty">
            No unassigned orders available for delivery assignment.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Order Number</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Assign Delivery Person</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        var formId = $"assignForm_{order.OrderID}";

                        <tr>
                            <td>
                                <span class="order-number">
                                    @order.OrderNumber
                                </span>

                                <span class="customer-info">
                                    Customer ID: @order.CustomerID
                                </span>
                            </td>

                            <td>
                                @order.OrderDate.ToString("dd MMM yyyy HH:mm")
                            </td>

                            <td>
                                @order.Status
                            </td>

                            <td>
                                $@order.TotalAmount.ToString("N2")
                            </td>

                            <td>
                                @if (order.AvailableDeliveryPeople != null &&
                               order.AvailableDeliveryPeople.Any())
                                {
                                    <form method="post"
                                          asp-page-handler="Assign"
                                          id="@formId">

                                        <input type="hidden"
                                               name="orderId"
                                               value="@order.OrderID" />

                                        <select name="deliveryPersonId" required>
                                            <option value="">
                                                Select delivery
                                            </option>

                                            @foreach (var delivery in order.AvailableDeliveryPeople)
                                            {
                                                <option value="@delivery.DeliveryPersonID">
                                                    @delivery.FullName - @delivery.Area - @delivery.VehicleType
                                                </option>
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="no-delivery">
                                        No eligible delivery person
                                    </span>
                                }
                            </td>

                            <td>
                                @if (order.AvailableDeliveryPeople != null &&
                               order.AvailableDeliveryPeople.Any())
                                {
                                    <button type="submit"
                                            form="@formId">
                                        Assign
                                    </button>
                                }
                                else
                                {
                                    <button type="button" disabled>
                                        Unavailable
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>