@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAssignDeliveryModel

@{
    ViewData["Title"] = "Assign Delivery";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #6366F1;
            --brand-dark: #4F46E5;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --navy: #0F172A;
            --bg: #F8FAFC;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --border: #E2E8F0;
            --text: #0F172A;
            --muted: #64748B;
            --positive: #16A34A;
            --positive-bg: #DCFCE7;
            --positive-txt: #15803D;
            --danger: #DC2626;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 22px;
            --shadow: 0 1px 3px rgba(15,23,42,0.06), 0 6px 20px -8px rgba(15,23,42,0.10);
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        .assign-page {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 4px 48px;
            color: var(--text);
            font-family: var(--font);
        }

        /* ── Header ── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px;
            padding: 28px 4px 24px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

            .page-header h1 {
                font-size: 24px;
                font-weight: 800;
                letter-spacing: -0.03em;
                margin: 0 0 4px;
            }

            .page-header p {
                font-size: 13.5px;
                color: var(--muted);
                margin: 0;
            }

        /* ── Top links ── */
        .top-links {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .link-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--surface);
            color: var(--text);
            border: 1px solid var(--border);
            padding: 9px 16px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 600;
            font-size: 13.5px;
            transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
        }

            .link-btn:hover {
                border-color: var(--brand);
                color: var(--brand);
                background: var(--brand-soft);
            }

        /* ── Messages ── */
        .message {
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            margin-bottom: 20px;
            font-weight: 600;
            font-size: 13.5px;
            text-align: center;
        }

        .success {
            background: var(--positive-bg);
            color: var(--positive-txt);
            border: 1px solid #86efac;
        }

        .error {
            background: var(--danger-bg);
            color: var(--danger-txt);
            border: 1px solid #fca5a5;
        }

        /* ── Panel / Table ── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 8px;
            box-shadow: var(--shadow);
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            padding: 12px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

            thead th:first-child {
                border-radius: var(--radius-sm) 0 0 0;
            }

            thead th:last-child {
                border-radius: 0 var(--radius-sm) 0 0;
            }

        tbody td {
            padding: 14px 16px;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-weight: 500;
            vertical-align: middle;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover td {
            background: var(--surface-2);
        }

        .order-number {
            font-weight: 700;
            color: var(--navy);
            display: block;
        }

        .customer-info {
            display: block;
            color: var(--muted);
            font-size: 12px;
            margin-top: 3px;
        }

        /* ── Select + Button ── */
        select {
            padding: 9px 12px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            width: 240px;
            max-width: 100%;
            background: var(--surface);
            color: var(--text);
            font-family: var(--font);
            font-size: 13px;
            outline: none;
            cursor: pointer;
        }

            select:focus {
                border-color: var(--brand);
                box-shadow: 0 0 0 3px var(--brand-soft);
            }

        button {
            background: var(--brand);
            color: #fff;
            border: none;
            padding: 9px 18px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-weight: 700;
            font-size: 13px;
            font-family: var(--font);
            transition: background 0.18s ease;
        }

            button:hover:not(:disabled) {
                background: var(--brand-dark);
            }

            button:disabled {
                background: #cbd5e1;
                color: #64748b;
                cursor: not-allowed;
                opacity: 1;
            }

        .no-delivery {
            display: inline-block;
            background: var(--danger-bg);
            color: var(--danger-txt);
            border: 1px solid #fca5a5;
            border-radius: var(--radius-sm);
            padding: 8px 12px;
            font-size: 12.5px;
            font-weight: 600;
        }

        .empty {
            text-align: center;
            color: var(--muted);
            padding: 48px 16px;
            font-weight: 500;
            font-size: 14px;
        }

        @@media (max-width: 850px) {
            .assign-page {
                padding: 0 12px 32px;
            }

            table {
                min-width: 900px;
            }
        }
    </style>
}

<div class="assign-page">

    <div class="page-header">
        <div>
            <h1>Assign Delivery Person</h1>
            <p>Match unassigned orders with available delivery staff</p>
        </div>
        <div class="top-links">
            <a href="/AdminDelivery" class="link-btn">
                <i class="fas fa-truck"></i> Delivery Requests
            </a>
            <a href="/AdminOrders" class="link-btn">
                <i class="fas fa-shopping-cart"></i> View Orders
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="message success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="message error">
            @TempData["Error"]
        </div>
    }

    @if (Model.Orders == null || !Model.Orders.Any())
    {
        <div class="panel">
            <div class="empty">
                No unassigned orders available for delivery assignment.
            </div>
        </div>
    }
    else
    {
        <div class="panel">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Assign Delivery Person</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            var formId = $"assignForm_{order.OrderID}";

                            <tr>
                                <td>
                                    <span class="order-number">
                                        @order.OrderNumber
                                    </span>

                                    <span class="customer-info">
                                        Customer ID: @order.CustomerID
                                    </span>
                                </td>

                                <td>
                                    @order.OrderDate.ToString("dd MMM yyyy HH:mm")
                                </td>

                                <td>
                                    @order.Status
                                </td>

                                <td>
                                    $@order.TotalAmount.ToString("N2")
                                </td>

                                <td>
                                    @if (order.AvailableDeliveryPeople != null &&
                                   order.AvailableDeliveryPeople.Any())
                                    {
                                        <form method="post"
                                              asp-page-handler="Assign"
                                              id="@formId">

                                            <input type="hidden"
                                                   name="orderId"
                                                   value="@order.OrderID" />

                                            <select name="deliveryPersonId" required>
                                                <option value="">
                                                    Select delivery
                                                </option>

                                                @foreach (var delivery in order.AvailableDeliveryPeople)
                                                {
                                                    <option value="@delivery.DeliveryPersonID">
                                                        @delivery.FullName - @delivery.Area - @delivery.VehicleType
                                                    </option>
                                                }
                                            </select>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="no-delivery">
                                            No eligible delivery person
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (order.AvailableDeliveryPeople != null &&
                                   order.AvailableDeliveryPeople.Any())
                                    {
                                        <button type="submit"
                                                form="@formId">
                                            Assign
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" disabled>
                                            Unavailable
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
