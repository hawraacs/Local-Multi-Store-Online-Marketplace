@page
@model Local_Multi_Store_Online_Marketplace.Pages.OnlinePaymentModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Secure Online Payment</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --color-primary: #2563EB;
            --color-secondary: #3B82F6;
            --color-light-blue: #DBEAFE;
            --color-extra-light-blue: #EFF6FF;
            --color-bg: #F8FAFC;
            --color-white: #FFFFFF;
            --color-border: #E2E8F0;
            --color-text-primary: #0F172A;
            --color-text-secondary: #64748B;
            --color-success: #10B981;
            --color-error: #EF4444;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-extra-light-blue) 100%);
            font-family: "Inter", Arial, sans-serif;
            color: var(--color-text-primary);
        }

        .payment-page {
            min-height: 100vh;
            padding: 56px 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

            .payment-page::before,
            .payment-page::after {
                content: "";
                position: absolute;
                border-radius: 50%;
                filter: blur(60px);
                opacity: 0.35;
                pointer-events: none;
                z-index: 0;
            }

            .payment-page::before {
                width: 420px;
                height: 420px;
                background: var(--color-light-blue);
                top: -140px;
                left: -120px;
            }

            .payment-page::after {
                width: 380px;
                height: 380px;
                background: var(--color-extra-light-blue);
                bottom: -160px;
                right: -100px;
            }

        .payment-shell {
            width: 100%;
            max-width: 1200px;
            display: grid;
            grid-template-columns: 2fr 3fr;
            gap: 32px;
            align-items: stretch;
            position: relative;
            z-index: 1;
        }

        /* ===================== LEFT PANEL ===================== */

        .payment-info {
            background: linear-gradient(160deg, #FFFFFF, var(--color-bg));
            border: 1px solid var(--color-border);
            color: var(--color-text-primary);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.06);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .payment-info-content {
            position: relative;
            z-index: 2;
        }

        .secure-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--color-light-blue);
            padding: 9px 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            color: var(--color-primary);
            margin-bottom: 24px;
        }

            .secure-badge i {
                font-size: 14px;
            }

        .payment-info h1 {
            margin: 0;
            font-size: 40px;
            line-height: 1.15;
            letter-spacing: -0.5px;
            font-weight: 800;
            color: var(--color-text-primary);
        }

        .payment-info p {
            color: var(--color-text-secondary);
            line-height: 1.6;
            font-weight: 500;
            margin: 16px 0 28px 0;
            font-size: 16px;
        }

        .mini-card {
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            border-radius: 20px;
            padding: 24px;
            min-height: 170px;
            box-shadow: 0 16px 35px rgba(37, 99, 235, 0.28);
            margin-top: 4px;
            transition: transform 0.25s ease;
        }

            .mini-card:hover {
                transform: translateY(-3px);
            }

        .mini-card-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            font-weight: 800;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

        .chip {
            width: 42px;
            height: 30px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.6);
        }

        .card-number-preview {
            margin-top: 28px;
            color: white;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 3px;
        }

        .card-bottom {
            margin-top: 22px;
            display: flex;
            justify-content: space-between;
            color: white;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.5px;
            opacity: 0.95;
        }

        .feature-list {
            margin-top: 32px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .feature-icon {
            flex: 0 0 44px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--color-light-blue);
            color: var(--color-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .feature-text-title {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: var(--color-text-primary);
        }

        .feature-text-sub {
            margin: 2px 0 0 0;
            font-size: 13px;
            font-weight: 500;
            color: var(--color-text-secondary);
        }

        /* ===================== RIGHT PANEL ===================== */

        .payment-card {
            background: var(--color-white);
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
            overflow: hidden;
            border: 1px solid var(--color-border);
            display: flex;
            flex-direction: column;
        }

        .payment-card-header {
            padding: 40px 40px 20px 40px;
        }

            .payment-card-header h2 {
                margin: 0;
                font-size: 30px;
                color: var(--color-primary);
                font-weight: 800;
                letter-spacing: -0.5px;
            }

            .payment-card-header p {
                margin: 8px 0 0 0;
                color: var(--color-text-secondary);
                font-size: 14px;
                font-weight: 500;
            }

        .payment-body {
            padding: 8px 40px 40px 40px;
            flex: 1;
        }

        /* ===================== STATUS MESSAGES ===================== */

        .status-banner {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: var(--color-extra-light-blue);
            border: 1px solid var(--color-light-blue);
            color: var(--color-primary);
            padding: 16px 18px;
            border-radius: 16px;
            font-size: 13px;
            font-weight: 600;
            line-height: 1.55;
            margin-bottom: 20px;
        }

            .status-banner i {
                font-size: 18px;
                margin-top: 1px;
            }

        .message {
            padding: 16px 18px;
            border-radius: 16px;
            margin-bottom: 16px;
            font-weight: 700;
            text-align: center;
            line-height: 1.5;
            font-size: 13px;
        }

        .error {
            background: #FEF2F2;
            color: #991B1B;
            border: 1px solid #FCA5A5;
        }

        /* ===================== ORDER SUMMARY ===================== */

        .summary {
            background: var(--color-bg);
            border: 1px solid var(--color-border);
            border-radius: 18px;
            padding: 18px 20px;
            margin-bottom: 20px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            padding: 11px 0;
            border-bottom: 1px solid var(--color-border);
            font-weight: 600;
            color: var(--color-text-secondary);
            font-size: 14px;
        }

            .summary-row:last-child {
                border-bottom: none;
                padding-bottom: 2px;
            }

            .summary-row span:last-child {
                color: var(--color-text-primary);
                text-align: right;
                font-weight: 700;
            }

        .summary-total span:first-child {
            color: var(--color-text-primary);
            font-size: 15px;
            font-weight: 700;
        }

        .summary-total span:last-child {
            font-size: 22px;
            color: var(--color-primary);
            font-weight: 800;
        }

        .hint {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--color-text-secondary);
            font-size: 13px;
            font-weight: 500;
            line-height: 1.5;
            margin-bottom: 22px;
        }

            .hint i {
                color: var(--color-primary);
                font-size: 16px;
                flex: 0 0 auto;
            }

        /* ===================== FORM ===================== */

        .field {
            margin-bottom: 20px;
        }

            .field label {
                display: block;
                margin-bottom: 8px;
                font-size: 13px;
                font-weight: 600;
                color: #334155;
            }

            .field input {
                width: 100%;
                height: 54px;
                padding: 0 16px;
                border: 1px solid var(--color-border);
                border-radius: 14px;
                font-weight: 600;
                font-family: "Inter", Arial, sans-serif;
                font-size: 15px;
                color: var(--color-text-primary);
                outline: none;
                background: var(--color-white);
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
            }

                .field input::placeholder {
                    color: #94A3B8;
                    font-weight: 500;
                }

                .field input:focus {
                    border-color: var(--color-primary);
                    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
                }

                .field input.input-error {
                    border-color: var(--color-error);
                    box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.10);
                }

        #card-element {
            padding: 17px 16px;
            border: 1px solid var(--color-border);
            border-radius: 14px;
            background: var(--color-white);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

            #card-element.StripeElement--focus {
                border-color: var(--color-primary);
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
            }

            #card-element.StripeElement--invalid {
                border-color: var(--color-error);
            }

        .card-errors {
            margin-top: 8px;
            color: var(--color-error);
            font-size: 12px;
            font-weight: 600;
            min-height: 16px;
        }

        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 22px;
        }

        .btn {
            flex: 1;
            border: none;
            border-radius: 14px;
            padding: 0 16px;
            height: 56px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
            font-family: "Inter", Arial, sans-serif;
        }

        .pay-btn {
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            color: white;
            box-shadow: 0 14px 30px rgba(37, 99, 235, 0.30);
        }

            .pay-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 18px 36px rgba(37, 99, 235, 0.36);
            }

            .pay-btn:disabled {
                cursor: wait;
                opacity: 0.70;
                transform: none;
            }

        .back-btn {
            background: var(--color-white);
            color: var(--color-primary);
            border: 1.5px solid var(--color-primary);
            box-shadow: none;
        }

            .back-btn:hover {
                background: var(--color-extra-light-blue);
                transform: translateY(-2px);
            }

        .locked {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 12px;
            color: var(--color-text-secondary);
            text-align: center;
            margin-top: 20px;
            font-weight: 600;
        }

        /* ===================== TOAST ===================== */

        .payment-toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000001;
            pointer-events: none;
        }

        .payment-toast {
            width: min(400px, calc(100vw - 40px));
            padding: 16px 18px;
            border-radius: 16px;
            color: white;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: linear-gradient(135deg, #DC2626, var(--color-error));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.28);
            opacity: 0;
            transform: translateX(45px);
            transition: opacity 0.28s ease, transform 0.28s ease;
            pointer-events: auto;
        }

            .payment-toast.show {
                opacity: 1;
                transform: translateX(0);
            }

        .payment-toast-icon {
            width: 34px;
            height: 34px;
            flex: 0 0 34px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
        }

        .payment-toast-content {
            flex: 1;
            min-width: 0;
        }

        .payment-toast-title {
            display: block;
            margin-bottom: 3px;
            font-size: 14px;
            font-weight: 700;
        }

        .payment-toast-message {
            display: block;
            font-size: 13px;
            font-weight: 500;
            line-height: 1.5;
        }

        .payment-toast-close {
            border: none;
            background: transparent;
            color: white;
            font-size: 23px;
            line-height: 1;
            padding: 0;
            cursor: pointer;
        }

        /* ===================== MODAL ===================== */

        .payment-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            padding: 20px;
            background: rgba(15, 23, 42, 0.55);
            backdrop-filter: blur(5px);
            align-items: center;
            justify-content: center;
            z-index: 1000000;
        }

            .payment-modal-overlay.show {
                display: flex;
            }

        .payment-modal-card {
            width: min(450px, 100%);
            background: white;
            border-radius: 24px;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.30);
            overflow: hidden;
            animation: paymentModalOpen 0.22s ease;
        }

        @@keyframes paymentModalOpen {
            from {
                opacity: 0;
                transform: translateY(18px) scale(0.96);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .payment-modal-header {
            padding: 30px 26px 14px;
            text-align: center;
        }

        .payment-modal-icon {
            width: 60px;
            height: 60px;
            margin: 0 auto 16px;
            border-radius: 50%;
            background: var(--color-extra-light-blue);
            color: var(--color-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
        }

        .payment-modal-title {
            margin: 0;
            color: var(--color-text-primary);
            font-size: 21px;
            font-weight: 800;
        }

        .payment-modal-body {
            padding: 0 26px 22px;
            text-align: center;
        }

        .payment-modal-message {
            margin: 0;
            color: var(--color-text-secondary);
            font-size: 14px;
            line-height: 1.6;
        }

        .payment-modal-total {
            display: block;
            margin-top: 12px;
            color: var(--color-primary);
            font-size: 22px;
            font-weight: 800;
        }

        .payment-modal-note {
            display: block;
            margin-top: 8px;
            color: var(--color-text-secondary);
            font-size: 12px;
            font-weight: 600;
        }

        .payment-modal-actions {
            display: flex;
            gap: 10px;
            padding: 18px 26px 26px;
        }

        .payment-modal-button {
            flex: 1;
            border: none;
            border-radius: 14px;
            padding: 14px 16px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            font-family: "Inter", Arial, sans-serif;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

            .payment-modal-button:hover {
                transform: translateY(-1px);
            }

        .payment-modal-cancel {
            background: var(--color-bg);
            color: #334155;
            border: 1px solid var(--color-border);
        }

        .payment-modal-confirm {
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            color: white;
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.28);
        }

            .payment-modal-confirm:disabled {
                cursor: wait;
                opacity: 0.70;
            }

        /* ===================== RESPONSIVE ===================== */

        @@media (max-width: 900px) {
            .payment-shell {
                grid-template-columns: 1fr;
                max-width: 560px;
            }

            .payment-info {
                display: none;
            }

            .payment-card-header,
            .payment-body {
                padding-left: 32px;
                padding-right: 32px;
            }
        }

        @@media (max-width: 520px) {
            .payment-page {
                padding: 24px 14px;
            }

            .payment-card-header,
            .payment-body {
                padding-left: 22px;
                padding-right: 22px;
            }

            .payment-card-header {
                padding-top: 28px;
            }

            .row {
                grid-template-columns: 1fr;
            }

            .actions,
            .payment-modal-actions {
                flex-direction: column;
            }

            .payment-toast-container {
                top: 12px;
                right: 12px;
                left: 12px;
            }

            .payment-toast {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <div id="paymentToastContainer"
         class="payment-toast-container"
         aria-live="assertive"
         aria-atomic="true">
    </div>

    <div class="payment-page">

        <div class="payment-shell">

            <div class="payment-info">

                <div class="payment-info-content">

                    <div class="secure-badge">
                        <i class="bi bi-shield-lock-fill"></i>
                        Secure Payment Gateway
                    </div>

                    <h1>
                        Complete your payment securely
                    </h1>

                    <p>
                        Your payment is encrypted and processed securely
                        using industry-standard technologies.
                    </p>

                    <div class="mini-card">

                        <div class="mini-card-top">

                            <span id="cardBrandPreview">
                                LOCAL STORE CARD
                            </span>

                            <span class="chip"></span>

                        </div>

                        <div class="card-number-preview"
                             id="cardNumberPreview">
                            •••• •••• •••• ••••
                        </div>

                        <div class="card-bottom">

                            <span id="cardholderPreview">
                                CARDHOLDER
                            </span>

                            <span id="expiryPreview">
                                MM/YY
                            </span>

                        </div>

                    </div>

                    <div class="feature-list">

                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-lock-fill"></i>
                            </div>
                            <div>
                                <p class="feature-text-title">100% Secure</p>
                                <p class="feature-text-sub">Your payment is encrypted.</p>
                            </div>
                        </div>

                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-lightning-charge-fill"></i>
                            </div>
                            <div>
                                <p class="feature-text-title">Instant Confirmation</p>
                                <p class="feature-text-sub">Receive payment confirmation immediately.</p>
                            </div>
                        </div>

                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <p class="feature-text-title">Trusted Protection</p>
                                <p class="feature-text-sub">Protected using secure payment infrastructure.</p>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <div class="payment-card">

                <div class="payment-card-header">

                    <h2>
                        Secure Online Payment
                    </h2>

                    <p>
                        Enter your payment details to complete your purchase.
                    </p>

                </div>

                <div class="payment-body">

                    @if (!string.IsNullOrWhiteSpace(
                    Model.ErrorMessage))
                    {
                        <div class="status-banner"
                             id="serverPaymentError"
                             data-message="@Model.ErrorMessage">
                            <i class="bi bi-info-circle-fill"></i>
                            <span>@Model.ErrorMessage</span>
                        </div>
                    }

                    @if (Model.Order == null)
                    {
                        <div class="message error">
                            Payment order not found or you are not
                            allowed to access it.
                        </div>

                        <div class="actions">

                            <a href="/CustomerOrders"
                               class="btn back-btn">
                                Back to Orders
                            </a>

                        </div>
                    }
                    else
                    {
                        <div class="summary">

                            <div class="summary-row">

                                <span>
                                    Order Number
                                </span>

                                <span>
                                    @Model.Order.OrderNumber
                                </span>

                            </div>

                            <div class="summary-row">

                                <span>
                                    Payment Method
                                </span>

                                <span>
                                    @Model.Order.PaymentMethod
                                </span>

                            </div>

                            <div class="summary-row summary-total">

                                <span>
                                    Total Amount
                                </span>

                                <span>
                                    $@Model.Order.TotalAmount.ToString("N2")
                                </span>

                            </div>

                        </div>

                        <div class="hint">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>
                                Your card is processed securely by Stripe.
                                This site never sees or stores your card number or CVC.
                            </span>
                        </div>

                        <form method="post"
                              id="paymentForm"
                              novalidate>

                            <input type="hidden"
                                   asp-for="OrderId" />

                            <input type="hidden"
                                   asp-for="StripePaymentMethodId"
                                   id="StripePaymentMethodId" />

                            <div class="field">

                                <label for="CardholderName">
                                    Cardholder Name
                                </label>

                                <input id="CardholderName"
                                       maxlength="100"
                                       placeholder="Name on card"
                                       autocomplete="cc-name" />

                            </div>

                            <div class="field">

                                <label for="card-element">
                                    Card Details
                                </label>

                                <div id="card-element"></div>

                                <div id="card-errors"
                                     class="card-errors"
                                     role="alert"></div>

                            </div>

                            <div class="actions">

                                <a href="/CustomerOrders"
                                   class="btn back-btn">
                                    Cancel
                                </a>

                                <button type="button"
                                        id="payNowButton"
                                        class="btn pay-btn">
                                    <i class="bi bi-lock-fill"></i>
                                    Pay Now
                                </button>

                            </div>

                            <div class="locked">
                                <i class="bi bi-shield-check"></i>
                                Your payment is processed securely.
                            </div>

                        </form>
                    }

                </div>
            </div>

        </div>
    </div>

    @if (Model.Order != null)
    {
        <div id="paymentConfirmationModal"
             class="payment-modal-overlay"
             role="dialog"
             aria-modal="true"
             aria-labelledby="paymentModalTitle">

            <div class="payment-modal-card">

                <div class="payment-modal-header">

                    <div class="payment-modal-icon">
                        <i class="bi bi-lock-fill"></i>
                    </div>

                    <h3 id="paymentModalTitle"
                        class="payment-modal-title">
                        Confirm Online Payment
                    </h3>

                </div>

                <div class="payment-modal-body">

                    <p class="payment-modal-message">
                        Confirm the payment
                        for order
                        <strong>
                            @Model.Order.OrderNumber
                        </strong>.

                        <span class="payment-modal-total">
                            $@Model.Order.TotalAmount.ToString("N2")
                        </span>

                        <span class="payment-modal-note">
                            This is a test transaction. No real
                            amount will be charged.
                        </span>
                    </p>

                </div>

                <div class="payment-modal-actions">

                    <button type="button"
                            class="payment-modal-button payment-modal-cancel"
                            onclick="closePaymentModal()">
                        Cancel
                    </button>

                    <button type="button"
                            id="confirmPaymentButton"
                            class="payment-modal-button payment-modal-confirm"
                            onclick="submitPayment()">
                        Confirm Payment
                    </button>

                </div>

            </div>
        </div>
    }

    <script src="https://js.stripe.com/v3/"></script>

    <script>
        const stripe = Stripe("@Model.StripePublishableKey");
        const elements = stripe.elements();

        const cardElement = elements.create("card", {
            style: {
                base: {
                    fontSize: "15px",
                    color: "#111827",
                    fontFamily: "Arial, sans-serif",
                    "::placeholder": { color: "#9ca3af" }
                },
                invalid: {
                    color: "#dc2626"
                }
            }
        });

        const cardElementContainer = document.getElementById("card-element");

        if (cardElementContainer) {
            cardElement.mount("#card-element");

            cardElement.on("change", function (event) {
                const displayError = document.getElementById("card-errors");
                if (displayError) {
                    displayError.textContent = event.error ? event.error.message : "";
                }

                // Brand can be reflected in the mini-card preview since
                // Stripe exposes it via this event. The card number and
                // expiry digits themselves are never exposed to page JS
                // by design (that's what keeps raw card data off this
                // server), so those two preview fields stay generic
                // placeholders rather than live-updating.
                const brandPreview = document.getElementById("cardBrandPreview");
                if (brandPreview) {
                    const knownBrands = {
                        visa: "VISA",
                        mastercard: "MASTERCARD",
                        amex: "AMEX",
                        discover: "DISCOVER"
                    };
                    brandPreview.textContent = knownBrands[event.brand] || "CARD";
                }
            });
        }

        const paymentForm = document.getElementById("paymentForm");
        const payNowButton = document.getElementById("payNowButton");
        const cardholderInput = document.getElementById("CardholderName");
        const paymentMethodIdInput = document.getElementById("StripePaymentMethodId");
        const paymentModal = document.getElementById("paymentConfirmationModal");

        let paymentSubmitting = false;

        function showPaymentToast(message, title = "Unable to continue") {
            const container = document.getElementById("paymentToastContainer");
            if (!container || !message) return;

            const oldToast = container.querySelector(".payment-toast");
            if (oldToast) oldToast.remove();

            const toast = document.createElement("div");
            toast.className = "payment-toast";
            toast.setAttribute("role", "alert");

            toast.innerHTML = `
                <span class="payment-toast-icon">!</span>
                <span class="payment-toast-content">
                    <span class="payment-toast-title"></span>
                    <span class="payment-toast-message"></span>
                </span>
                <button type="button" class="payment-toast-close" aria-label="Close notification">&times;</button>
            `;

            toast.querySelector(".payment-toast-title").textContent = title;
            toast.querySelector(".payment-toast-message").textContent = message;

            const closeButton = toast.querySelector(".payment-toast-close");
            container.appendChild(toast);

            window.requestAnimationFrame(function () {
                toast.classList.add("show");
            });

            const timer = window.setTimeout(removeToast, 6000);

            function removeToast() {
                toast.classList.remove("show");
                window.setTimeout(function () { toast.remove(); }, 300);
            }

            closeButton.addEventListener("click", function () {
                window.clearTimeout(timer);
                removeToast();
            });
        }

        function openPaymentModal() {
            const cardholder = cardholderInput?.value.trim() ?? "";

            if (cardholder.length < 3) {
                cardholderInput?.classList.add("input-error");
                showPaymentToast("Enter the name on the card.", "Cardholder name required");
                return;
            }

            if (!paymentModal) return;

            paymentModal.classList.add("show");
            document.body.style.overflow = "hidden";
        }

        function closePaymentModal() {
            if (paymentSubmitting) return;

            paymentModal?.classList.remove("show");
            document.body.style.overflow = "";
        }

        async function submitPayment() {
            if (!paymentForm || paymentSubmitting) return;

            paymentSubmitting = true;

            const confirmButton = document.getElementById("confirmPaymentButton");
            if (confirmButton) {
                confirmButton.disabled = true;
                confirmButton.textContent = "Processing...";
            }

            if (payNowButton) {
                payNowButton.disabled = true;
                payNowButton.textContent = "Processing...";
            }

            const cardholder = cardholderInput?.value.trim() ?? "";

            const result = await stripe.createPaymentMethod({
                type: "card",
                card: cardElement,
                billing_details: { name: cardholder }
            });

            if (result.error) {
                const displayError = document.getElementById("card-errors");
                if (displayError) displayError.textContent = result.error.message;

                showPaymentToast(result.error.message, "Card was not accepted");

                paymentSubmitting = false;

                if (confirmButton) {
                    confirmButton.disabled = false;
                    confirmButton.textContent = "Confirm Payment";
                }

                if (payNowButton) {
                    payNowButton.disabled = false;
                    payNowButton.textContent = "Pay Now";
                }

                closePaymentModal();
                return;
            }

            if (paymentMethodIdInput) {
                paymentMethodIdInput.value = result.paymentMethod.id;
            }

            paymentForm.submit();
        }

        payNowButton?.addEventListener("click", openPaymentModal);

        paymentModal?.addEventListener("click", function (event) {
            if (event.target === paymentModal) closePaymentModal();
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") closePaymentModal();
        });

        cardholderInput?.addEventListener("input", function () {
            this.classList.remove("input-error");

            const preview = document.getElementById("cardholderPreview");
            if (preview) {
                preview.textContent = this.value.trim().toUpperCase() || "CARDHOLDER";
            }
        });

        document.addEventListener("DOMContentLoaded", function () {
            const serverError = document.getElementById("serverPaymentError");
            const errorMessage = serverError?.dataset.message;

            if (errorMessage) {
                showPaymentToast(errorMessage, "Payment was not completed");
            }
        });
    </script>

</body>
</html>
