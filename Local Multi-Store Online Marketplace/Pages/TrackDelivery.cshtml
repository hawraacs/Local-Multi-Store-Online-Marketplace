@page
@model Local_Multi_Store_Online_Marketplace.Pages.TrackDeliveryModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Track Delivery</title>

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .tracking-page {
            min-height: 100vh;
            padding: 35px;
        }

        .tracking-box {
            max-width: 1100px;
            margin: auto;
            background: white;
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
        }

        .tracking-header {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .tracking-header h2 {
            margin: 0;
            color: #111827;
        }

        .tracking-header p {
            margin: 8px 0 0;
            color: #6b7280;
        }

        .back-link {
            background: #111827;
            color: white;
            padding: 11px 16px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 800;
        }

        .back-link:hover {
            background: #ff6b35;
        }

        .status-card {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
            margin-bottom: 18px;
        }

        .status-item {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            padding: 14px;
            border-radius: 14px;
        }

        .status-item span {
            display: block;
            font-size: 12px;
            color: #6b7280;
            margin-bottom: 5px;
            font-weight: 700;
        }

        .status-item strong {
            color: #111827;
            font-size: 16px;
        }

        #trackingMap {
            width: 100%;
            height: 520px;
            border-radius: 16px;
            border: 1px solid #d1d5db;
            background: #e5e7eb;
        }

        .warning {
            margin-top: 14px;
            background: #fff7ed;
            border: 1px solid #fed7aa;
            color: #9a3412;
            padding: 12px;
            border-radius: 12px;
            font-weight: 700;
            display: none;
        }

        .arrived {
            margin-top: 14px;
            background: #dcfce7;
            border: 1px solid #86efac;
            color: #166534;
            padding: 12px;
            border-radius: 12px;
            font-weight: 700;
            display: none;
        }

        .emoji-marker {
            background: transparent;
            border: none;
        }

        .emoji-circle {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: white;
            border: 3px solid #111827;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 25px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.25);
        }

        .delivery-circle {
            border-color: #2563eb;
        }

        .customer-circle {
            border-color: #16a34a;
        }

        @@media (max-width: 1000px) {
            .status-card {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 650px) {
            .tracking-page {
                padding: 18px;
            }

            .status-card {
                grid-template-columns: 1fr;
            }

            #trackingMap {
                height: 420px;
            }
        }
    </style>
</head>

<body>
    <div class="tracking-page">
        <div class="tracking-box">
            <div class="tracking-header">
                <div>
                    <h2>Live Delivery Tracking</h2>
                    <p>Order: <strong>@Model.OrderNumber</strong></p>
                </div>

                <a href="/CustomerOrders" class="back-link">
                    Back to Orders
                </a>
            </div>

            <div class="status-card">
                <div class="status-item">
                    <span>Status</span>
                    <strong id="orderStatus">@Model.OrderStatus</strong>
                </div>

                <div class="status-item">
                    <span>ETA</span>
                    <strong id="etaText">Calculating...</strong>
                </div>

                <div class="status-item">
                    <span>Distance</span>
                    <strong id="distanceText">Calculating...</strong>
                </div>

                <div class="status-item">
                    <span>Last Update</span>
                    <strong id="lastUpdateText">Waiting...</strong>
                </div>

                <div class="status-item">
                    <span>Tracking Mode</span>
                    <strong id="trackingModeText">Waiting...</strong>
                </div>
            </div>

            <div id="trackingMap"></div>

            <div id="trackingWarning" class="warning">
                Location update temporarily unavailable.
            </div>

            <div id="arrivedMessage" class="arrived">
                Your order has arrived.
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        const orderId = @Model.OrderId;

        let map;
        let deliveryMarker;
        let customerMarker;
        let routeLine;
        let firstZoomDone = false;

        document.addEventListener("DOMContentLoaded", function () {
            initMap();
            loadTrackingData();
            setInterval(loadTrackingData, 3000);
        });

        function initMap() {
            map = L.map("trackingMap").setView([33.8938, 35.5018], 12);

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "&copy; OpenStreetMap contributors"
            }).addTo(map);
        }

        async function loadTrackingData() {
            try {
                const response = await fetch(`/api/delivery-tracking/${orderId}`, {
                    method: "GET",
                    credentials: "same-origin"
                });

                let data = null;

                try {
                    data = await response.json();
                } catch {
                    data = null;
                }

                if (!response.ok || !data || !data.success) {
                    showWarning(data?.message || "Location update temporarily unavailable.");
                    return;
                }

                hideWarning();

                document.getElementById("orderStatus").innerText =
                    data.orderStatus || "Unknown";

                document.getElementById("lastUpdateText").innerText =
                    data.lastLocationUpdateText || "Unknown";

                document.getElementById("etaText").innerText =
                    data.etaText || "Calculating...";

                document.getElementById("distanceText").innerText =
                    data.distanceKm !== undefined && data.distanceKm !== null
                        ? data.distanceKm + " km"
                        : "Calculating...";

                document.getElementById("trackingModeText").innerText =
                    data.trackingMode || "Live";

                if (data.orderStatus === "Delivered") {
                    document.getElementById("arrivedMessage").style.display = "block";
                } else {
                    document.getElementById("arrivedMessage").style.display = "none";
                }

                updateMarkers(
                    data.deliveryLatitude,
                    data.deliveryLongitude,
                    data.customerLatitude,
                    data.customerLongitude
                );

                if (data.routeCoordinates && data.routeCoordinates.length > 1) {
                    drawRouteFromApi(data.routeCoordinates);
                } else {
                    drawRoute(
                        data.deliveryLatitude,
                        data.deliveryLongitude,
                        data.customerLatitude,
                        data.customerLongitude
                    );
                }
            } catch {
                showWarning("Location update temporarily unavailable.");
            }
        }

        function updateMarkers(deliveryLat, deliveryLng, customerLat, customerLng) {
            if (!isValidCoordinate(deliveryLat, deliveryLng) ||
                !isValidCoordinate(customerLat, customerLng)) {
                showWarning("Map coordinates are missing.");
                return;
            }

            const deliveryPosition = [deliveryLat, deliveryLng];
            const customerPosition = [customerLat, customerLng];

            const deliveryIcon = L.divIcon({
                className: "emoji-marker",
                html: '<div class="emoji-circle delivery-circle">🚗</div>',
                iconSize: [42, 42],
                iconAnchor: [21, 21],
                popupAnchor: [0, -20]
            });

            const customerIcon = L.divIcon({
                className: "emoji-marker",
                html: '<div class="emoji-circle customer-circle">📍</div>',
                iconSize: [42, 42],
                iconAnchor: [21, 21],
                popupAnchor: [0, -20]
            });

            if (!deliveryMarker) {
                deliveryMarker = L.marker(deliveryPosition, {
                    icon: deliveryIcon
                })
                    .addTo(map)
                    .bindPopup("Delivery Person");
            } else {
                deliveryMarker.setLatLng(deliveryPosition);
            }

            if (!customerMarker) {
                customerMarker = L.marker(customerPosition, {
                    icon: customerIcon
                })
                    .addTo(map)
                    .bindPopup("Your Address");
            } else {
                customerMarker.setLatLng(customerPosition);
            }

            if (!firstZoomDone) {
                const bounds = L.latLngBounds([deliveryPosition, customerPosition]);
                map.fitBounds(bounds, { padding: [50, 50] });
                firstZoomDone = true;
            }
        }

        function drawRouteFromApi(routeCoordinates) {
            const coordinates = routeCoordinates
                .filter(p => p && p.length === 2 && isValidCoordinate(p[0], p[1]))
                .map(p => [p[0], p[1]]);

            if (coordinates.length < 2) {
                return;
            }

            if (routeLine) {
                routeLine.setLatLngs(coordinates);
            } else {
                routeLine = L.polyline(coordinates, {
                    weight: 5,
                    opacity: 0.85
                }).addTo(map);
            }
        }

        async function drawRoute(deliveryLat, deliveryLng, customerLat, customerLng) {
            try {
                if (!isValidCoordinate(deliveryLat, deliveryLng) ||
                    !isValidCoordinate(customerLat, customerLng)) {
                    return;
                }

                const url =
                    `https://router.project-osrm.org/route/v1/driving/${deliveryLng},${deliveryLat};${customerLng},${customerLat}?overview=full&geometries=geojson`;

                const response = await fetch(url);
                const data = await response.json();

                if (!data.routes || data.routes.length === 0) {
                    drawStraightLine(deliveryLat, deliveryLng, customerLat, customerLng);
                    return;
                }

                const coordinates = data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);

                if (routeLine) {
                    routeLine.setLatLngs(coordinates);
                } else {
                    routeLine = L.polyline(coordinates, {
                        weight: 5,
                        opacity: 0.85
                    }).addTo(map);
                }
            } catch {
                drawStraightLine(deliveryLat, deliveryLng, customerLat, customerLng);
            }
        }

        function drawStraightLine(deliveryLat, deliveryLng, customerLat, customerLng) {
            const coordinates = [
                [deliveryLat, deliveryLng],
                [customerLat, customerLng]
            ];

            if (routeLine) {
                routeLine.setLatLngs(coordinates);
            } else {
                routeLine = L.polyline(coordinates, {
                    weight: 5,
                    opacity: 0.85
                }).addTo(map);
            }
        }

        function isValidCoordinate(lat, lng) {
            return lat !== undefined &&
                   lng !== undefined &&
                   lat !== null &&
                   lng !== null &&
                   !isNaN(lat) &&
                   !isNaN(lng) &&
                   lat >= -90 &&
                   lat <= 90 &&
                   lng >= -180 &&
                   lng <= 180;
        }

        function showWarning(message) {
            const warning = document.getElementById("trackingWarning");
            warning.style.display = "block";
            warning.innerText = message;
        }

        function hideWarning() {
            const warning = document.getElementById("trackingWarning");
            warning.style.display = "none";
        }
    </script>
</body>
</html>