@page
@model Local_Multi_Store_Online_Marketplace.Pages.ReportUpdatesModel

@{
    Layout = Model.IsStoreOwner ? "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml" : null;
    var backUrl = Model.IsStoreOwner ? "/StoreOwner/Home"
                : Model.IsDeliveryPerson ? "/DeliveryProfile"
                : "/CustomerProfile";
}

@if (Model.IsStoreOwner)
{
    @* StoreOwner branch: _StoreOwnerLayout already provides <html>/<head>/<body>
       and its own nav/sidebar, so we only render styles + content here. *@
    <style>
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --radius-md: 16px;
            --radius-lg: 24px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .page-container {
            max-width: 800px;
            margin: 32px auto;
            padding: 0 20px 100px 20px;
        }

        .page-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 28px;
        }

        .back-btn-plain {
            width: 44px;
            height: 44px;
            background: var(--accent-light);
            border: 1px solid var(--border-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-color);
            text-decoration: none;
            transition: var(--transition);
            flex-shrink: 0;
        }

            .back-btn-plain:hover {
                background: var(--accent-color);
                color: #ffffff;
            }

        .page-header h2 {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--accent-color);
            margin: 0;
        }

        .notification-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 8px;
            box-shadow: var(--shadow-sm);
        }

        .ig-notif-form {
            margin: 0;
        }

        .ig-notif-row-wrap {
            position: relative;
        }

        .ig-notif-row {
            width: 100%;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            background: none;
            border: none;
            border-bottom: 1px solid var(--border-color);
            padding: 20px 56px 20px 20px;
            cursor: pointer;
            text-align: left;
            transition: var(--transition);
            border-radius: 12px;
        }

        .ig-notif-delete-form {
            margin: 0;
            position: absolute;
            top: 14px;
            right: 14px;
            z-index: 2;
        }

        .ig-notif-remove-btn {
            width: 34px;
            height: 34px;
            border: none;
            border-radius: 10px;
            background: transparent;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

            .ig-notif-remove-btn:hover {
                background: #fef2f2;
                color: #dc2626;
            }

        .ig-notif-row:last-child {
            border-bottom: none;
        }

        .ig-notif-row:hover {
            background-color: var(--accent-light);
            transform: translateX(4px);
        }

        .ig-notif-row.unread {
            background-color: #fdfcff;
            border-left: 4px solid var(--accent-color);
        }

        .ig-notif-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: var(--accent-light);
            color: var(--accent-color);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: var(--transition);
        }

        .ig-notif-row:hover .ig-notif-icon {
            background: var(--accent-color);
            color: #fff;
        }

        .ig-notif-body {
            flex-grow: 1;
            min-width: 0;
        }

        .ig-notif-text strong {
            display: block;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .ig-notif-text span {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .ig-notif-time {
            font-size: 12px;
            font-weight: 500;
            color: var(--text-muted);
            margin-top: 8px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .ig-notif-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--accent-color);
            flex-shrink: 0;
            margin-top: 10px;
            box-shadow: 0 0 10px rgba(109, 40, 217, 0.4);
        }

        .empty-state {
            text-align: center;
            padding: 80px 24px;
        }

        .empty-icon {
            font-size: 60px;
            margin-bottom: 20px;
            background: var(--accent-light);
            width: 100px;
            height: 100px;
            line-height: 100px;
            border-radius: 50%;
            display: inline-block;
            color: var(--accent-color);
        }

        .empty-state h3 {
            font-weight: 800;
            font-size: 20px;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: var(--text-secondary);
            font-size: 14px;
        }

        @@media (max-width: 768px) {
            .page-header h2 {
                font-size: 20px;
            }
        }
    </style>

    <div class="page-container">
        <div class="page-header">
            <a href="@backUrl" class="back-btn-plain">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2><i class="fas fa-bell" style="margin-right:10px;"></i>Notifications</h2>
        </div>

        <div class="notification-card">
            @if (Model.NotificationsList.Any())
            {
                <div class="ig-notif-list">
                    @foreach (var n in Model.NotificationsList)
                    {
                        <div class="ig-notif-row-wrap">
                            <form method="post" asp-page-handler="OpenNotification" class="ig-notif-form">
                                <input type="hidden" name="notificationId" value="@n.NotificationID" />
                                <button type="submit" class="ig-notif-row @(n.IsRead ? "" : "unread")">
                                    <div class="ig-notif-icon">
                                        <i class="fas fa-flag"></i>
                                    </div>
                                    <div class="ig-notif-body">
                                        <div class="ig-notif-text">
                                            <strong>@n.Title</strong>
                                            <span>@n.Message</span>
                                        </div>
                                        <div class="ig-notif-time">
                                            <i class="far fa-clock"></i>
                                            @n.SentAt.ToString("MMM d, yyyy 'at' h:mm tt")
                                        </div>
                                    </div>
                                    @if (!n.IsRead)
                                    {
                                        <span class="ig-notif-dot"></span>
                                    }
                                </button>
                            </form>
                            <form method="post" asp-page-handler="DeleteNotification" class="ig-notif-delete-form">
                                <input type="hidden" name="notificationId" value="@n.NotificationID" />
                                <button type="submit" class="ig-notif-remove-btn" title="Remove notification">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-bell-slash"></i></div>
                    <h3>No notifications yet</h3>
                    <p>You're all caught up. New notifications will show up here as they arrive.</p>
                </div>
            }
        </div>
    </div>
}
else
{
    @* Delivery / Customer branch: this page is fully standalone (Layout = null),
       so it owns the whole document, including the correct bottom nav for the role. *@
