    <body>

        @if (Model.IsDeliveryPerson)
        {
            <partial name="_DeliveryNav" />
        }
        else
        {
            <partial name="_CustomerBottomNav" />
        }

        <div class="page-container">
            <div class="page-header">
                <a href="@backUrl" class="back-btn-plain">
