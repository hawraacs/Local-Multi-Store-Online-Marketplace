@page
@model Local_Multi_Store_Online_Marketplace.Pages.ReportUpdatesModel

@{
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
    var backUrl = Model.IsStoreOwner ? "/StoreOwner/Home" : "/CustomerProfile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Report Updates | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            :root {
                /* Dashboard Brand Colors */
                --accent-color: #6d28d9;
                --accent-hover: #5b21b6;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --bg-color: #f8f7fc;
                --card-bg: #ffffff;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                --text-muted: #9691a4;
                --border-color: #ece8f6;
                --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
                --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
                --radius-md: 16px;
                --radius-lg: 24px;
                --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                background: var(--bg-color);
                color: var(--text-primary);
                min-height: 100vh;
                padding-bottom: 100px;
                -webkit-font-smoothing: antialiased;
            }

            .page-container {
                max-width: 800px;
                margin: 32px auto;
                padding: 0 20px;
            }

            /* Replicating the Welcome Banner Style */
            .welcome-banner {
                background: var(--accent-gradient);
                color: #ffffff;
                padding: 32px 40px;
                border-radius: var(--radius-lg);
                margin-bottom: 32px;
                box-shadow: var(--shadow-md), 0 8px 32px rgba(109, 40, 217, 0.20);
                display: flex;
                align-items: center;
                gap: 20px;
                position: relative;
                overflow: hidden;
            }

                .welcome-banner::after {
                    content: '';
                    position: absolute;
                    top: -40%;
                    right: -10%;
                    width: 250px;
                    height: 250px;
                    background: rgba(255, 255, 255, 0.08);
                    border-radius: 50%;
                }

            .back-btn-circle {
                width: 48px;
                height: 48px;
                background: rgba(255, 255, 255, 0.2);
                border: 1px solid rgba(255, 255, 255, 0.3);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                text-decoration: none;
                backdrop-filter: blur(8px);
                transition: var(--transition);
                z-index: 2;
            }

                .back-btn-circle:hover {
                    background: rgba(255, 255, 255, 0.3);
                    transform: scale(1.05);
                }

            .welcome-text {
                z-index: 2;
            }

                .welcome-text h2 {
                    font-family: 'Plus Jakarta Sans', sans-serif;
                    font-size: 26px;
                    font-weight: 800;
                    margin-bottom: 4px;
                    letter-spacing: -0.5px;
                }

                .welcome-text p {
                    font-size: 15px;
                    opacity: 0.9;
                    margin: 0;
                }

            /* Notification Card/List Style */
            .notification-card {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-md);
                padding: 8px;
                box-shadow: var(--shadow-sm);
            }

            .ig-notif-form {
                margin: 0;
            }

            .ig-notif-row {
                width: 100%;
                display: flex;
                align-items: flex-start;
                gap: 16px;
                background: none;
                border: none;
                border-bottom: 1px solid var(--border-color);
                padding: 20px;
                cursor: pointer;
                text-align: left;
                transition: var(--transition);
                border-radius: 12px;
            }

                .ig-notif-row:last-child {
                    border-bottom: none;
                }

                .ig-notif-row:hover {
                    background-color: var(--accent-light);
                    transform: translateX(4px);
                }

                .ig-notif-row.unread {
                    background-color: #fdfcff;
                    border-left: 4px solid var(--accent-color);
                }

            .ig-notif-icon {
                width: 48px;
                height: 48px;
                border-radius: 14px;
                background: var(--accent-light);
                color: var(--accent-color);
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
                transition: var(--transition);
            }

            .ig-notif-row:hover .ig-notif-icon {
                background: var(--accent-color);
                color: #fff;
            }

            .ig-notif-body {
                flex-grow: 1;
                min-width: 0;
            }

            .ig-notif-text strong {
                display: block;
                font-size: 15px;
                font-weight: 700;
                color: var(--text-primary);
                margin-bottom: 4px;
            }

            .ig-notif-text span {
                font-size: 14px;
                color: var(--text-secondary);
                line-height: 1.5;
            }

            .ig-notif-time {
                font-size: 12px;
                font-weight: 500;
                color: var(--text-muted);
                margin-top: 8px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .ig-notif-dot {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--accent-color);
                flex-shrink: 0;
                margin-top: 10px;
                box-shadow: 0 0 10px rgba(109, 40, 217, 0.4);
            }

            /* Empty State */
            .empty-state {
                text-align: center;
                padding: 80px 24px;
            }

            .empty-icon {
                font-size: 60px;
                margin-bottom: 20px;
                background: var(--accent-light);
                width: 100px;
                height: 100px;
                line-height: 100px;
                border-radius: 50%;
                display: inline-block;
                color: var(--accent-color);
            }

            .empty-state h3 {
                font-weight: 800;
                font-size: 20px;
                margin-bottom: 8px;
            }

            .empty-state p {
                color: var(--text-secondary);
                font-size: 14px;
            }

            @@media (max-width: 768px) {
                .welcome-banner {
                    padding: 24px;
                    flex-direction: row;
                }

                .welcome-text h2 {
                    font-size: 20px;
                }
            }
    </style>
</head>
<body>

    @if (!Model.IsStoreOwner)
    {
        <partial name="_CustomerBottomNav" />
    }

    <div class="page-container">
        <!-- Dashboard Style Banner -->
        <div class="welcome-banner">
            <a href="@backUrl" class="back-btn-circle">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="welcome-text">
                <h2>Report Updates</h2>
                <p>Track the status of your reports and our team's responses.</p>
            </div>
        </div>

        <!-- Dashboard Style Card Container -->
        <div class="notification-card">
            @if (Model.NotificationsList.Any())
            {
                <div class="ig-notif-list">
                    @foreach (var n in Model.NotificationsList)
                    {
                        <form method="post" asp-page-handler="OpenNotification" class="ig-notif-form">
                            <input type="hidden" name="notificationId" value="@n.NotificationID" />
                            <button type="submit" class="ig-notif-row @(n.IsRead ? "" : "unread")">
                                <div class="ig-notif-icon">
                                    <i class="fas fa-flag"></i>
                                </div>
                                <div class="ig-notif-body">
                                    <div class="ig-notif-text">
                                        <strong>@n.Title</strong>
                                        <span>@n.Message</span>
                                    </div>
                                    <div class="ig-notif-time">
                                        <i class="far fa-clock"></i>
                                        @n.SentAt.ToString("MMM d, yyyy 'at' h:mm tt")
                                    </div>
                                </div>
                                @if (!n.IsRead)
                                {
                                    <span class="ig-notif-dot"></span>
                                }
                            </button>
                        </form>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-bell-slash"></i></div>
                    <h3>Inbox is empty</h3>
                    <p>When our team reviews a report you've filed, you'll see the update here.</p>
                </div>
            }
        </div>
    </div>

</body>
</html>