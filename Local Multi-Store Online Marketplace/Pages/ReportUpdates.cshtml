@page
@model Local_Multi_Store_Online_Marketplace.Pages.ReportUpdatesModel

@{
    Layout = null;
    var backUrl = Model.IsStoreOwner ? "/StoreOwner/Home" : "/CustomerProfile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Report Updates | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            :root {
                --bg-color: #faf9fc;
                --card-bg: #ffffff;
                --border-color: #ece8f6;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                --accent-color: #6d28d9;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.04);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: var(--font-family);
                background: var(--bg-color);
                color: var(--text-primary);
                min-height: 100vh;
                padding-bottom: 100px;
            }

            .page-container {
                max-width: 720px;
                margin: 30px auto;
                padding: 0 20px;
            }

            .page-header {
                display: flex;
                align-items: center;
                gap: 14px;
                margin-bottom: 24px;
            }

            .back-btn {
                width: 38px;
                height: 38px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 50%;
                color: var(--accent-color);
                text-decoration: none;
                flex-shrink: 0;
            }

            .page-title {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 24px;
                font-weight: 800;
            }

            .page-subtitle {
                font-size: 13.5px;
                color: var(--text-secondary);
                margin-top: 2px;
            }

            .feed-card {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                overflow: hidden;
                box-shadow: var(--shadow-sm);
            }

            .ig-notif-list {
                display: flex;
                flex-direction: column;
            }

            .ig-notif-form {
                margin: 0;
            }

            .ig-notif-row {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 14px;
                background: none;
                border: none;
                border-bottom: 1px solid var(--border-color);
                padding: 18px 20px;
                cursor: pointer;
                text-align: left;
                transition: background-color 0.15s ease;
            }

                .ig-notif-row:last-child {
                    border-bottom: none;
                }

                .ig-notif-row:hover {
                    background-color: var(--bg-color);
                }

                .ig-notif-row.unread {
                    background-color: var(--accent-light);
                }

            .ig-notif-icon {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                background: var(--accent-gradient);
                color: #fff;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 17px;
            }

            .ig-notif-body {
                flex-grow: 1;
                min-width: 0;
            }

            .ig-notif-text {
                font-size: 14px;
                line-height: 1.5;
                color: var(--text-primary);
            }

                .ig-notif-text strong {
                    font-weight: 800;
                    margin-right: 4px;
                    display: block;
                    margin-bottom: 2px;
                }

                .ig-notif-text span {
                    color: var(--text-secondary);
                }

            .ig-notif-time {
                font-size: 12px;
                color: var(--text-secondary);
                margin-top: 5px;
            }

            .ig-notif-dot {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--accent-color);
                flex-shrink: 0;
            }

            .empty-state {
                text-align: center;
                padding: 70px 24px;
            }

            .empty-icon {
                font-size: 50px;
                margin-bottom: 16px;
                color: var(--border-color);
            }

            .empty-state h3 {
                font-size: 20px;
                font-weight: 800;
                margin-bottom: 8px;
            }

            .empty-state p {
                font-size: 14px;
                color: var(--text-secondary);
                max-width: 360px;
                margin: 0 auto;
                line-height: 1.5;
            }
    </style>
</head>
<body>

    @if (!Model.IsStoreOwner)
    {
        <partial name="_CustomerBottomNav" />
    }

    <div class="page-container">
        <div class="page-header">
            <a href="@backUrl" class="back-btn"><i class="fas fa-arrow-left"></i></a>
            <div>
                <div class="page-title">Report Updates</div>
                <div class="page-subtitle">Responses from our team about reports you've filed</div>
            </div>
        </div>

        <div class="feed-card">
            @if (Model.NotificationsList.Any())
            {
                <div class="ig-notif-list">
                    @foreach (var n in Model.NotificationsList)
                    {
                        <form method="post" asp-page-handler="OpenNotification" class="ig-notif-form">
                            <input type="hidden" name="notificationId" value="@n.NotificationID" />
                            <button type="submit" class="ig-notif-row @(n.IsRead ? "" : "unread")">
                                <div class="ig-notif-icon"><i class="fas fa-flag"></i></div>
                                <div class="ig-notif-body">
                                    <div class="ig-notif-text">
                                        <strong>@n.Title</strong>
                                        <span>@n.Message</span>
                                    </div>
                                    <div class="ig-notif-time">@n.SentAt.ToString("MMM d, yyyy 'at' h:mm tt")</div>
                                </div>
                                @if (!n.IsRead)
                                {
                                    <span class="ig-notif-dot"></span>
                                }
                            </button>
                        </form>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-flag"></i></div>
                    <h3>No Report Updates Yet</h3>
                    <p>When our team reviews a report you've filed, the response will appear here.</p>
                </div>
            }
        </div>
    </div>

</body>
</html>