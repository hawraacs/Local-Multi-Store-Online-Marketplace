@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerOrdersModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>My Orders</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .orders-page {
            min-height: 100vh;
            padding: 40px;
        }

        .orders-box {
            max-width: 1250px;
            margin: auto;
            padding: 25px;
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        }

        h2 {
            margin-top: 0;
            margin-bottom: 25px;
            color: #111827;
            text-align: center;
        }

        .table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 1150px;
            border-collapse: collapse;
        }

        th {
            padding: 12px;
            background: #111827;
            color: white;
            font-size: 14px;
            text-align: left;
            vertical-align: middle;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            color: #374151;
            font-size: 14px;
            vertical-align: middle;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        .order-number {
            min-width: 150px;
            color: #1d4ed8;
            font-weight: 700;
            word-break: break-word;
        }

        .products-cell {
            min-width: 190px;
            max-width: 250px;
        }

        .product-line {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 7px;
            padding-bottom: 7px;
            border-bottom: 1px dashed #d1d5db;
        }

            .product-line:last-child {
                margin-bottom: 0;
                padding-bottom: 0;
                border-bottom: none;
            }

        .product-name {
            color: #111827;
            font-weight: 700;
            line-height: 1.35;
            word-break: break-word;
        }

        .product-quantity {
            flex-shrink: 0;
            padding: 2px 7px;
            background: #f3f4f6;
            color: #4b5563;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .no-products {
            color: #9ca3af;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 10px;
            background: #fef3c7;
            color: #92400e;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .paid-badge {
            display: inline-block;
            padding: 6px 10px;
            background: #dcfce7;
            color: #166534;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .pending-badge {
            display: inline-block;
            padding: 6px 10px;
            background: #fef3c7;
            color: #92400e;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .track-btn,
        .invoice-btn {
            display: inline-block;
            margin-bottom: 5px;
            padding: 8px 12px;
            background: #111827;
            color: white;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
        }

        .invoice-btn {
            background: #2563eb;
        }

            .track-btn:hover,
            .invoice-btn:hover {
                background: #ff6b35;
                color: white;
            }

        .disabled-track {
            color: #9ca3af;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.4;
        }

        .empty-box {
            padding: 35px;
            color: #6b7280;
            text-align: center;
        }

        .shop-link {
            display: inline-block;
            margin-top: 15px;
            padding: 12px 18px;
            background: #111827;
            color: white;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 800;
        }

            .shop-link:hover {
                background: #ff6b35;
            }

        .message {
            max-width: 700px;
            margin: 0 auto 25px auto;
            padding: 14px 18px;
            border-radius: 12px;
            font-weight: 700;
            text-align: center;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        @@media (max-width: 850px) {
            .orders-page {
                padding: 20px;
            }

            .orders-box {
                padding: 18px;
            }

            table {
                min-width: 1150px;
            }
        }
    </style>
</head>

<body>
    <div class="orders-page">
        <div class="orders-box">

            <h2>My Orders</h2>

            @if (TempData["Success"] != null)
            {
                <div class="message success-message">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message error-message">
                    @TempData["Error"]
                </div>
            }

            @if (Model.Orders == null || !Model.Orders.Any())
            {
                <div class="empty-box">
                    <h3>No orders yet</h3>

                    <p>
                        Your orders will appear here after checkout.
                    </p>

                    <a href="/CustomerProducts"
                       class="shop-link">
                        Start Shopping
                    </a>
                </div>
            }
            else
            {
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Order Number</th>
                                <th>Products</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Payment Method</th>
                                <th>Payment Status</th>
                                <th>Total</th>
                                <th>Tracking</th>
                                <th>Invoice</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                var paymentClass =
                                string.Equals(
                                order.PaymentStatus,
                                "Paid",
                                StringComparison.OrdinalIgnoreCase)
                                ? "paid-badge"
                                : "pending-badge";

                                <tr>
                                    <td class="order-number">
                                        @order.OrderNumber
                                    </td>

                                    <td class="products-cell">
                                        @if (order.Products != null &&
                                       order.Products.Count > 0)
                                        {
                                            @foreach (var product in order.Products)
                                            {
                                                <div class="product-line">
                                                    <span class="product-name">
                                                        @product.ProductName
                                                    </span>

                                                    <span class="product-quantity">
                                                        ×@product.Quantity
                                                    </span>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="no-products">
                                                No products
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @order.OrderDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        <span class="status-badge">
                                            @order.Status
                                        </span>
                                    </td>

                                    <td>
                                        @order.PaymentMethod
                                    </td>

                                    <td>
                                        <span class="@paymentClass">
                                            @order.PaymentStatus
                                        </span>
                                    </td>

                                    <td>
                                        $@order.TotalAmount.ToString("N2")
                                    </td>

                                    <td>
                                        @if (order.CanTrack)
                                        {
                                            <a class="track-btn"
                                               href="/TrackDelivery?OrderId=@order.OrderID">
                                                Track Delivery
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="disabled-track">
                                                @order.TrackingMessage
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (order.CanViewInvoice)
                                        {
                                            <a class="invoice-btn"
                                               href="/Invoice?orderId=@order.OrderID">
                                                View Invoice
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="disabled-track">
                                                Available after payment
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</body>
</html>