@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerOrdersModel

<h2>My Orders</h2>

<table border="1" cellpadding="10">
    <tr>
        <th>Order Number</th>
        <th>Date</th>
        <th>Status</th>
        <th>Payment</th>
        <th>Total</th>
    </tr>

    @foreach (var order in Model.Orders)
    {
        <tr>
            <td>@order.OrderNumber</td>
            <td>@order.OrderDate</td>
            <td>@order.Status</td>
            <td>@order.PaymentStatus</td>
            <td>@order.TotalAmount</td>
        </tr>
    }
</table>