@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerOrdersModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>My Orders | realnest</title>

    <!-- Google Fonts & FontAwesome Icons (Consistent with Customer Feed/Cart) -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            :root {
                --bg-color: #faf9fc;
                --card-bg: #ffffff;
                --border-color: #ece8f6;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                /* Purple / Indigo palette */
                --accent-color: #6d28d9;
                --accent-hover: #5b21b6;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --like-color: #ef4444;
                --success-color: #10b981;
                --error-color: #dc2626;
                --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.04);
                --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.08);
                --shadow-lg: 0 20px 40px rgba(109, 40, 217, 0.12);
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: var(--font-family);
                background-color: var(--bg-color);
                color: var(--text-primary);
                line-height: 1.6;
                -webkit-font-smoothing: antialiased;
                padding-bottom: 100px; /* Offset to prevent overlap with the bottom nav */
            }

            /* ============================================================
                       BOTTOM NAV — now rendered by the shared _CustomerBottomNav
                       partial. Styles below match Customer1/Chat/Feed/Cart exactly
                       (same class names), so the partial renders identically here.
                       ============================================================ */
            .mobile-bottom-nav {
                display: flex !important;
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: 200;
                background: #ffffff;
                border-top: 1px solid #ece8f6;
                justify-content: space-between;
                gap: 2px;
                padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
                overflow-x: auto;
                box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
            }

                .mobile-bottom-nav a {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 2px;
                    font-size: 10.5px;
                    color: #6b6478;
                    text-decoration: none;
                    padding: 4px 6px;
                    flex-shrink: 0;
                    position: relative;
                    border-radius: 12px;
                    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
                }

                    .mobile-bottom-nav a i {
                        font-size: 17px;
                        transition: transform 0.2s ease;
                    }

                    .mobile-bottom-nav a:hover {
                        background: var(--accent-light);
                        color: var(--accent-color);
                    }

                    .mobile-bottom-nav a.active {
                        color: var(--accent-color) !important;
                        background: var(--accent-light) !important;
                        font-weight: 700;
                        transform: translateY(-2px);
                    }

                        .mobile-bottom-nav a.active i {
                            transform: scale(1.12);
                        }

            /* Cart badge (used by _CartCountBadge partial inside _CustomerBottomNav) */
            .unread-nav-badge {
                position: absolute;
                top: 2px;
                right: 18px;
                background: var(--accent-gradient);
                color: #fff;
                font-size: 10px;
                font-weight: 800;
                min-width: 16px;
                height: 16px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                box-shadow: 0 3px 8px rgba(109, 40, 217, 0.3);
            }

            /* Chat unread dot (used inside _CustomerBottomNav) */
            .chat-icon-wrap {
                position: relative;
                display: inline-flex;
            }

                .chat-icon-wrap .chat-nav-dot {
                    position: absolute;
                    top: -2px;
                    right: -4px;
                    width: 9px;
                    height: 9px;
                    background: #ed4956;
                    border: 2px solid #fff;
                    border-radius: 50%;
                    box-sizing: content-box;
                }

            /* PAGE CONTENT */
            .orders-page {
                min-height: 100vh;
                padding: 40px 16px;
            }

            .orders-box {
                max-width: 1250px;
                margin: auto;
                padding: 30px;
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                box-shadow: var(--shadow-md);
            }

            h2 {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 34px;
                font-weight: 800;
                margin-top: 0;
                margin-bottom: 30px;
                color: var(--text-primary);
                text-align: center;
            }

            /* TABLES */
            .table-wrapper {
                width: 100%;
                overflow-x: auto;
                border-radius: 12px;
                border: 1px solid var(--border-color);
            }

            table {
                width: 100%;
                min-width: 1150px;
                border-collapse: collapse;
            }

            th {
                padding: 16px;
                background: var(--text-primary);
                color: white;
                font-size: 13px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                text-align: left;
                vertical-align: middle;
            }

            td {
                padding: 16px;
                border-bottom: 1px solid var(--border-color);
                color: var(--text-secondary);
                font-size: 14px;
                vertical-align: middle;
            }

            tbody tr:hover {
                background: var(--accent-light);
            }

            .order-number {
                min-width: 150px;
                color: var(--accent-color);
                font-weight: 800;
                word-break: break-word;
            }

            .products-cell {
                min-width: 190px;
                max-width: 250px;
            }

            .product-line {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 10px;
                margin-bottom: 7px;
                padding-bottom: 7px;
                border-bottom: 1px dashed var(--border-color);
            }

                .product-line:last-child {
                    margin-bottom: 0;
                    padding-bottom: 0;
                    border-bottom: none;
                }

            .product-name {
                color: var(--text-primary);
                font-weight: 700;
                line-height: 1.35;
                word-break: break-word;
            }

            .product-quantity {
                flex-shrink: 0;
                padding: 2px 8px;
                background: var(--accent-light);
                color: var(--accent-color);
                border-radius: 999px;
                font-size: 11px;
                font-weight: 800;
                white-space: nowrap;
            }

            .no-products {
                color: var(--text-secondary);
                font-size: 12px;
                font-weight: 600;
            }

            /* BADGES */
            .status-badge {
                display: inline-block;
                padding: 6px 12px;
                background: #fff7ed;
                color: #c2410c;
                border: 1px solid #ffedd5;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

            .paid-badge {
                display: inline-block;
                padding: 6px 12px;
                background: #ecfdf5;
                color: var(--success-color);
                border: 1px solid #d1fae5;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

            .pending-badge {
                display: inline-block;
                padding: 6px 12px;
                background: #fef2f2;
                color: var(--error-color);
                border: 1px solid #fee2e2;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

            /* ACTIONS */
            .track-btn,
            .invoice-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 5px;
                padding: 8px 14px;
                background: var(--accent-light);
                color: var(--accent-color);
                border: 1px solid var(--border-color);
                border-radius: 50px;
                text-decoration: none;
                font-size: 13px;
                font-weight: 700;
                white-space: nowrap;
                transition: all 0.2s ease;
            }

            .invoice-btn {
                background: var(--accent-gradient);
                color: white;
                border: none;
                box-shadow: 0 4px 10px rgba(109, 40, 217, 0.15);
            }

            .track-btn:hover {
                background: var(--accent-color);
                color: white;
                border-color: var(--accent-color);
            }

            .invoice-btn:hover {
                opacity: 0.95;
                box-shadow: 0 6px 14px rgba(109, 40, 217, 0.25);
            }

            .disabled-track {
                color: var(--text-secondary);
                font-size: 12px;
                font-weight: 700;
                line-height: 1.4;
            }

            /* EMPTY STATES */
            .empty-box {
                padding: 60px 40px;
                color: var(--text-secondary);
                text-align: center;
                border: 2px dashed #ded4f5;
                border-radius: 20px;
            }

                .empty-box h3 {
                    color: var(--text-primary);
                    font-size: 22px;
                    font-weight: 800;
                    margin-bottom: 10px;
                }

            .shop-link {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 28px;
                background: var(--accent-gradient);
                color: white;
                border-radius: 50px;
                text-decoration: none;
                font-weight: 800;
                box-shadow: 0 4px 12px rgba(109, 40, 217, 0.25);
                transition: all 0.25s ease;
            }

                .shop-link:hover {
                    opacity: 0.95;
                    box-shadow: 0 6px 15px rgba(109, 40, 217, 0.35);
                }

            /* ALERTS */
            .message {
                max-width: 700px;
                margin: 0 auto 25px auto;
                padding: 14px 18px;
                border-radius: 12px;
                font-weight: 700;
                text-align: center;
                font-size: 14px;
            }

            .success-message {
                background: #ecfdf5;
                color: var(--success-color);
                border: 1px solid #d1fae5;
            }

            .error-message {
                background: #fef2f2;
                color: var(--error-color);
                border: 1px solid #fee2e2;
            }

            @@media (max-width: 850px) {
                .orders-page {
                    padding: 20px 12px;
                }

                .orders-box {
                    padding: 18px;
                }

                table {
                    min-width: 1150px;
                }
            }
    </style>
</head>

<body>

    <partial name="_CustomerBottomNav" />

    <div class="orders-page">
        <div class="orders-box">

            <h2>My Orders</h2>

            @if (TempData["Success"] != null)
            {
                <div class="message success-message">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message error-message">
                    @TempData["Error"]
                </div>
            }

            @if (Model.Orders == null || !Model.Orders.Any())
            {
                <div class="empty-box">
                    <h3>No orders yet</h3>

                    <p>
                        Your orders will appear here after checkout.
                    </p>

                    <a href="/CustomerProducts"
                       class="shop-link">
                        Start Shopping
                    </a>
                </div>
            }
            else
            {
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Order Number</th>
                                <th>Products</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Payment Method</th>
                                <th>Payment Status</th>
                                <th>Total</th>
                                <th>Tracking</th>
                                <th>Invoice</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                var paymentClass =
                                string.Equals(
                                order.PaymentStatus,
                                "Paid",
                                StringComparison.OrdinalIgnoreCase)
                                ? "paid-badge"
                                : "pending-badge";

                                <tr>
                                    <td class="order-number">
                                        @order.OrderNumber
                                    </td>

                                    <td class="products-cell">
                                        @if (order.Products != null &&
                                       order.Products.Count > 0)
                                        {
                                            @foreach (var product in order.Products)
                                            {
                                                <div class="product-line">
                                                    <span class="product-name">
                                                        @product.ProductName
                                                    </span>

                                                    <span class="product-quantity">
                                                        ×@product.Quantity
                                                    </span>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="no-products">
                                                No products
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @order.OrderDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        <span class="status-badge">
                                            @order.Status
                                        </span>
                                    </td>

                                    <td>
                                        @order.PaymentMethod
                                    </td>

                                    <td>
                                        <span class="@paymentClass">
                                            @order.PaymentStatus
                                        </span>
                                    </td>

                                    <td>
                                        $@order.TotalAmount.ToString("N2")
                                    </td>

                                    <td>
                                        @if (order.CanTrack)
                                        {
                                            <a class="track-btn"
                                               href="/TrackDelivery?OrderId=@order.OrderID">
                                                Track Delivery
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="disabled-track">
                                                @order.TrackingMessage
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (order.CanViewInvoice)
                                        {
                                            <a class="invoice-btn"
                                               href="/Invoice?orderId=@order.OrderID">
                                                View Invoice
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="disabled-track">
                                                Available after payment
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</body>
</html>