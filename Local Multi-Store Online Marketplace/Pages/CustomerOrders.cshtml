@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerOrdersModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>My Orders</title>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .orders-page {
            padding: 40px;
            min-height: 100vh;
        }

        .orders-box {
            max-width: 1000px;
            margin: auto;
            background: white;
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
        }

        h2 {
            text-align: center;
            color: #111827;
            margin-bottom: 25px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #111827;
            color: white;
            padding: 12px;
            text-align: left;
            font-size: 14px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            color: #374151;
            font-size: 14px;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            background: #fef3c7;
            color: #92400e;
            white-space: nowrap;
        }

        .track-btn {
            display: inline-block;
            background: #111827;
            color: white;
            padding: 8px 12px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 800;
            font-size: 13px;
            white-space: nowrap;
        }

            .track-btn:hover {
                background: #ff6b35;
                color: white;
            }

        .disabled-track {
            color: #9ca3af;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
        }

        .empty-box {
            text-align: center;
            color: #6b7280;
            padding: 35px;
        }

        .shop-link {
            display: inline-block;
            margin-top: 15px;
            background: #111827;
            color: white;
            padding: 12px 18px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 800;
        }

            .shop-link:hover {
                background: #ff6b35;
            }

        .message {
            max-width: 700px;
            margin: 0 auto 25px auto;
            padding: 14px 18px;
            border-radius: 12px;
            font-weight: 700;
            text-align: center;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        @@media (max-width: 750px) {
            .orders-page {
                padding: 20px;
            }

            .orders-box {
                overflow-x: auto;
            }

            table {
                min-width: 850px;
            }
        }
    </style>
</head>

<body>
    <div class="orders-page">
        <div class="orders-box">
            <h2>My Orders</h2>

            @if (TempData["Success"] != null)
            {
                <div class="message success-message">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message error-message">
                    @TempData["Error"]
                </div>
            }

            @if (Model.Orders == null || !Model.Orders.Any())
            {
                <div class="empty-box">
                    <h3>No orders yet</h3>
                    <p>Your orders will appear here after checkout.</p>

                    <a href="/CustomerProducts" class="shop-link">
                        Start Shopping
                    </a>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Total</th>
                            <th>Tracking</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td>@order.OrderNumber</td>

                                <td>@order.OrderDate.ToString("dd MMM yyyy")</td>

                                <td>
                                    <span class="status-badge">
                                        @order.Status
                                    </span>
                                </td>

                                <td>@order.PaymentMethod</td>

                                <td>$@order.TotalAmount.ToString("N2")</td>

                                <td>
                                    @if (order.CanTrack)
                                    {
                                        <a class="track-btn" href="/TrackDelivery?OrderId=@order.OrderID">
                                            Track Delivery
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="disabled-track">
                                            Available when out for delivery
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>