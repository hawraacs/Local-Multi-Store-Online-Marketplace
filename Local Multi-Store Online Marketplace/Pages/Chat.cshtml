@page
@model Local_Multi_Store_Online_Marketplace.Pages.ChatModel

<h3 style="text-align:center;">Chat</h3>

<!-- 🔍 SEARCH -->
<form method="get" action="/Chat" style="text-align:center;margin-bottom:15px;">
    <input type="text"
           name="searchText"
           value="@Model.SearchText"
           placeholder="Search users, stores, email..."
           style="width:260px;padding:7px;border:1px solid #ccc;border-radius:6px;" />

    <button type="submit">Search</button>
</form>

<!-- 🔍 SEARCH MODE -->
@if (!string.IsNullOrWhiteSpace(Model.SearchText))
{
    <h4 style="text-align:center;">Search Results</h4>

    <div style="width:420px;margin:auto;border:1px solid #ddd;border-radius:10px;">
        @if (Model.SearchUsers.Any())
        {
            @foreach (var u in Model.SearchUsers)
            {
                <a href="/ChatConversation?userId=@u.Id"
                   style="display:block;padding:10px;border-bottom:1px solid #eee;text-decoration:none;color:black">

                    <b>@(u.FullName ?? u.UserName)</b><br />
                    <small style="color:gray;">@u.Email</small>
                </a>
            }
        }
        else
        {
            <div style="padding:10px;text-align:center;color:gray;">
                No users found
            </div>
        }
    </div>
}
else
{
    <h4 style="text-align:center;">Recent Chats</h4>

    <div style="width:420px;margin:auto;border:1px solid #ddd;border-radius:10px;">
        @foreach (var c in Model.Inbox)
        {
            <a href="/ChatConversation?userId=@c.UserId"
               style="display:block;padding:10px;border-bottom:1px solid #eee;text-decoration:none;color:black">

                <b>@c.UserName</b><br />
                <small style="color:gray;">@c.LastMessage</small>
            </a>
        }
    </div>
}