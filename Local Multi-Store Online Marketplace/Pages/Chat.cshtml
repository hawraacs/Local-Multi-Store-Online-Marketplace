@page
@model Local_Multi_Store_Online_Marketplace.Pages.ChatModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Messages | realnest</title>

    <!-- Google Fonts & FontAwesome Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #faf9fc;
            --card-bg: #ffffff;
            --border-color: #ece8f6;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            /* Purple / Indigo palette matching Feed & Cart */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --online-color: #10b981;
            --offline-color: #94a3b8;
            --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.04);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.08);
            --shadow-lg: 0 20px 40px rgba(109, 40, 217, 0.12);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            padding-bottom: 100px; /* Offset to clear space for the bottom nav */
        }

        /* BOTTOM NAV - identical to previous pages, with 'Chat' set to active */
        .bottom-nav {
            display: flex !important;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 68px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(15px);
            border-top: 1px solid var(--border-color);
            z-index: 1000;
            justify-content: space-around;
            align-items: center;
            box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
            padding-bottom: env(safe-area-inset-bottom);
        }

            .bottom-nav a {
                color: var(--text-secondary);
                text-decoration: none;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 4px;
                font-size: 10px;
                font-weight: 600;
                flex: 1;
                border-radius: 12px;
                transition: color 0.2s ease, background-color 0.2s ease;
            }

                .bottom-nav a i {
                    font-size: 20px;
                    transition: transform 0.2s ease;
                }

                .bottom-nav a:hover {
                    color: var(--accent-color);
                    background: var(--accent-light);
                }

                .bottom-nav a:active i {
                    transform: scale(0.85);
                }

                .bottom-nav a.active {
                    color: var(--accent-color);
                    font-weight: 700;
                }

                    .bottom-nav a.active i {
                        transform: scale(1.1);
                    }

        /* MAIN CONTENT CONTAINER */
        .container {
            max-width: 650px;
            margin: 40px auto 40px auto;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* HEADER SECTION */
        .header {
            padding: 24px;
            border-bottom: 1px solid var(--border-color);
            background: var(--card-bg);
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

            .header h2 {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 26px;
                font-weight: 800;
                color: var(--text-primary);
                letter-spacing: -0.5px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .header h2 i {
                    background: var(--accent-gradient);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

        /* SEARCH BOX */
        .search-box {
            display: flex;
            gap: 12px;
            width: 100%;
        }

            .search-box input {
                flex: 1;
                padding: 12px 20px;
                border: 1px solid var(--border-color);
                border-radius: 50px;
                font-family: var(--font-family);
                font-size: 14px;
                color: var(--text-primary);
                background-color: var(--bg-color);
                outline: none;
                transition: all 0.25s ease;
            }

                .search-box input:focus {
                    border-color: var(--accent-color);
                    background-color: #ffffff;
                    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.1);
                }

            .search-box button {
                border: none;
                background: var(--accent-gradient);
                color: white;
                padding: 12px 24px;
                border-radius: 50px;
                font-weight: 700;
                font-size: 14px;
                cursor: pointer;
                transition: all 0.25s ease;
                box-shadow: 0 4px 12px rgba(109, 40, 217, 0.2);
            }

                .search-box button:hover {
                    opacity: 0.95;
                    transform: translateY(-1px);
                    box-shadow: 0 6px 15px rgba(109, 40, 217, 0.3);
                }

        /* SECTION TITLE */
        .section-title {
            padding: 14px 24px;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-secondary);
            background: #faf9fc;
            border-bottom: 1px solid var(--border-color);
        }

        /* CHAT INBOX LIST ITEMS */
        .chat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-decoration: none;
            color: var(--text-primary);
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color);
            transition: all 0.25s ease;
        }

            .chat-item:last-of-type {
                border-bottom: none;
            }

            .chat-item:hover {
                background: var(--accent-light);
            }

        .left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* AVATAR SYSTEM */
        .avatar-container {
            position: relative;
        }

        .avatar {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            background: var(--accent-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 18px;
            box-shadow: 0 4px 12px rgba(109, 40, 217, 0.15);
            border: 2px solid white;
        }

        /* Badge status indicators */
        .status-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            position: absolute;
            bottom: 2px;
            right: 2px;
            border: 2.5px solid white;
        }

            .status-dot.dot-online {
                background-color: var(--online-color);
                box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.3);
            }

            .status-dot.dot-offline {
                background-color: var(--offline-color);
            }

        .name {
            font-weight: 700;
            font-size: 15px;
            color: var(--text-primary);
        }

        .last-message {
            color: var(--text-secondary);
            font-size: 13px;
            margin-top: 3px;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 320px;
        }

        /* RIGHT SIDE INDICATORS */
        .right-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 700;
        }

        .online {
            color: var(--online-color);
            background: #ecfdf5;
            padding: 4px 10px;
            border-radius: 30px;
        }

        .offline {
            color: var(--text-secondary);
            background: #f1eef8;
            padding: 4px 10px;
            border-radius: 30px;
        }

        /* EMPTY MESSAGES AND LOADING */
        .empty {
            text-align: center;
            padding: 60px 24px;
            color: var(--text-secondary);
        }

        .empty-icon {
            font-size: 48px;
            color: var(--border-color);
            margin-bottom: 16px;
        }

        .empty h3 {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .empty p {
            font-size: 14px;
        }

        .unread-badge {
            background: var(--accent-gradient);
            color: #fff;
            font-size: 11px;
            font-weight: 800;
            min-width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
            box-shadow: 0 3px 8px rgba(109, 40, 217, 0.25);
        }

        .chat-item.unread .name,
        .chat-item.unread .last-message {
            font-weight: 800;
            color: var(--text-primary);
        }

        /* RESPONSIVE DESIGN */
        @@media (max-width: 768px) {
            .container {
                margin: 20px 12px 100px 12px;
                border-radius: 16px;
            }

            .chat-item {
                padding: 16px;
            }

            .last-message {
                max-width: 200px;
            }
        }
    </style>
</head>
<body>

    <!-- BOTTOM NAVIGATION -->
    <div class="bottom-nav">
        <a href="/Customer1"><i class="fa-solid fa-compass"></i><span>Explore</span></a>
        <a href="/CustomerFeed"><i class="fa-solid fa-house"></i><span>Feed</span></a>
        <a href="/CustomerProducts"><i class="fa-solid fa-bag-shopping"></i><span>Shop</span></a>
        <a href="/CustomerCart"><i class="fa-solid fa-cart-shopping"></i><span>Cart</span></a>
        <a href="/CustomerOrders"><i class="fa-solid fa-receipt"></i><span>Orders</span></a>
        <a href="/Chat" class="active"><i class="fa-solid fa-paper-plane"></i><span>Chat</span></a>
        <a href="/CustomerProfile"><i class="fa-solid fa-user"></i><span>Profile</span></a>
    </div>

    <!-- INBOX CONTAINER -->
    <div class="container">

        <div class="header">
            <h2><i class="fa-solid fa-comments"></i> Messages</h2>

            <form method="get" class="search-box">
                <input type="text"
                       name="SearchText"
                       value="@Model.SearchText"
                       placeholder="Search by username or email..." />

                <button type="submit">
                    Search
                </button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SearchText))
        {
            <div class="section-title">
                Search Results
            </div>

            @if (Model.SearchUsers.Any())
            {
                @foreach (var user in Model.SearchUsers)
                {
                    var online = await Model.IsOnline(user.Id);

                    <a class="chat-item"
                       asp-page="/ChatConversation"
                       asp-route-userId="@user.Id">

                        <div class="left">
                            <div class="avatar-container">
                                <div class="avatar">
                                    @(user.UserName?.Substring(0, 1).ToUpper())
                                </div>
                                <div class="status-dot @(online ? "dot-online" : "dot-offline")"></div>
                            </div>

                            <div>
                                <div class="name">
                                    @user.UserName
                                </div>

                                <div class="last-message">
                                    @user.Email
                                </div>
                            </div>
                        </div>

                        <div class="right-status @(online ? "online" : "offline")">
                            <i class="fa-solid fa-circle" style="font-size: 8px;"></i>
                            @(online ? "Online" : "Offline")
                        </div>

                    </a>
                }
            }
            else
            {
                <div class="empty">
                    <div class="empty-icon">
                        <i class="fa-regular fa-face-frown"></i>
                    </div>
                    <h3>No Users Found</h3>
                    <p>Try searching for a different username or email address.</p>
                </div>
            }
        }
        else
        {
            <div class="section-title">
                Recent Chats
            </div>

            @if (Model.Inbox.Any())
            {
                @foreach (var chat in Model.Inbox)
                {
                    var online = await Model.IsOnline(chat.UserId);

                    <a class="chat-item @(chat.UnreadCount > 0 ? "unread" : "")"
                       asp-page="/ChatConversation"
                       asp-route-userId="@chat.UserId">

                        <div class="left">
                            <div class="avatar-container">
                                <div class="avatar">
                                    @(chat.UserName?.Substring(0, 1).ToUpper())
                                </div>
                                <div class="status-dot @(online ? "dot-online" : "dot-offline")"></div>
                            </div>

                            <div>
                                <div class="name">
                                    @chat.UserName
                                </div>

                                <div class="last-message">
                                    @chat.LastMessage
                                </div>
                            </div>
                        </div>

                        <div style="display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
                            <div class="right-status @(online ? "online" : "offline")">
                                <i class="fa-solid fa-circle" style="font-size: 8px;"></i>
                                @(online ? "Online" : "Offline")
                            </div>
                            @if (chat.UnreadCount > 0)
                            {
                                <div class="unread-badge">@chat.UnreadCount</div>
                            }
                        </div>

                    </a>
                }
            }
            else
            {
                <div class="empty">
                    <div class="empty-icon">
                        <i class="fa-regular fa-paper-plane"></i>
                    </div>
                    <h3>No conversations yet</h3>
                    <p>Search for stores or users above to start a conversation.</p>
                </div>
            }
        }

    </div>

</body>
</html>