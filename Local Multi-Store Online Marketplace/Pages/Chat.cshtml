@page
@model Local_Multi_Store_Online_Marketplace.Pages.ChatModel
@{
    var isStoreOwner = User.IsInRole("StoreOwner");
    var isCustomer = User.IsInRole("Customer");

    Layout = isStoreOwner ? "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml" : null;

    if (isStoreOwner)
    {
        ViewData["Title"] = "Messages";
    }

    var hasUnread = Model.Inbox != null && Model.Inbox.Sum(c => c.UnreadCount) > 0;
}

@if (isStoreOwner)
{
    @section Styles {
        <style>
            .chat-page-wrapper {
                max-width: 650px;
                margin: 0 auto;
            }

            .container {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 24px;
                box-shadow: var(--shadow-md);
                overflow: hidden;
                display: flex;
                flex-direction: column;
            }

            .header {
                padding: 24px;
                border-bottom: 1px solid var(--border-color);
                background: var(--card-bg);
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

                .header h2 {
                    font-family: 'Playfair Display', Georgia, serif;
                    font-size: 26px;
                    font-weight: 800;
                    color: var(--text-primary);
                    letter-spacing: -0.5px;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                    .header h2 i {
                        background: var(--accent-gradient);
                        -webkit-background-clip: text;
                        -webkit-text-fill-color: transparent;
                    }

            .search-box {
                display: flex;
                gap: 12px;
                width: 100%;
            }

                .search-box input {
                    flex: 1;
                    padding: 12px 20px;
                    border: 1px solid var(--border-color);
                    border-radius: 50px;
                    font-size: 14px;
                    color: var(--text-primary);
                    background-color: var(--bg-color);
                    outline: none;
                    transition: all 0.25s ease;
                }

                    .search-box input:focus {
                        border-color: var(--accent-color);
                        background-color: #ffffff;
                        box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.1);
                    }

                .search-box button {
                    border: none;
                    background: var(--accent-gradient);
                    color: white;
                    padding: 12px 24px;
                    border-radius: 50px;
                    font-weight: 700;
                    font-size: 14px;
                    cursor: pointer;
                    transition: all 0.25s ease;
                    box-shadow: 0 4px 12px rgba(109, 40, 217, 0.2);
                }

                    .search-box button:hover {
                        opacity: 0.95;
                        transform: translateY(-1px);
                        box-shadow: 0 6px 15px rgba(109, 40, 217, 0.3);
                    }

            .section-title {
                padding: 14px 24px;
                font-size: 12px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                color: var(--text-secondary);
                background: var(--bg-color);
                border-bottom: 1px solid var(--border-color);
            }

            .chat-item {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-decoration: none;
                color: var(--text-primary);
                padding: 18px 24px;
                border-bottom: 1px solid var(--border-color);
                transition: all 0.25s ease;
            }

                .chat-item:last-of-type {
                    border-bottom: none;
                }

                .chat-item:hover {
                    background: var(--accent-light);
                }

            .left {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .avatar-container {
                position: relative;
            }

            .avatar {
                width: 54px;
                height: 54px;
                border-radius: 50%;
                background: var(--accent-gradient);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                font-size: 18px;
                box-shadow: 0 4px 12px rgba(109, 40, 217, 0.15);
                border: 2px solid white;
            }

            .status-dot {
                width: 14px;
                height: 14px;
                border-radius: 50%;
                position: absolute;
                bottom: 2px;
                right: 2px;
                border: 2.5px solid white;
            }

                .status-dot.dot-online {
                    background-color: var(--online-color, #10b981);
                    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.3);
                }

                .status-dot.dot-offline {
                    background-color: var(--offline-color, #94a3b8);
                }

            .name {
                font-weight: 700;
                font-size: 15px;
                color: var(--text-primary);
            }

            .last-message {
                color: var(--text-secondary);
                font-size: 13px;
                margin-top: 3px;
                display: -webkit-box;
                -webkit-line-clamp: 1;
                -webkit-box-orient: vertical;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 320px;
            }

            .right-status {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 12px;
                font-weight: 700;
            }

            .online {
                color: var(--online-color, #10b981);
                background: #ecfdf5;
                padding: 4px 10px;
                border-radius: 30px;
            }

            .offline {
                color: var(--text-secondary);
                background: #f1eef8;
                padding: 4px 10px;
                border-radius: 30px;
            }

            .empty {
                text-align: center;
                padding: 60px 24px;
                color: var(--text-secondary);
            }

            .empty-icon {
                font-size: 48px;
                color: var(--border-color);
                margin-bottom: 16px;
            }

            .empty h3 {
                font-size: 18px;
                font-weight: 800;
                color: var(--text-primary);
                margin-bottom: 6px;
            }

            .empty p {
                font-size: 14px;
            }

            .unread-badge {
                background: var(--accent-gradient);
                color: #fff;
                font-size: 11px;
                font-weight: 800;
                min-width: 20px;
                height: 20px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 6px;
                box-shadow: 0 3px 8px rgba(109, 40, 217, 0.25);
            }

            .chat-item.unread .name, .chat-item.unread .last-message {
                font-weight: 800;
                color: var(--text-primary);
            }

            @@media (max-width: 768px) {
                .chat-item {
                    padding: 16px;
                }

                .last-message {
                    max-width: 200px;
                }
            }
        </style>
    }

    <div class="chat-page-wrapper">
        <div class="container">

            <div class="header">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h2><i class="fa-solid fa-comments"></i> Messages</h2>
                    <partial name="_MessageBell" />
                </div>

                <form method="get" class="search-box">
                    <input type="text" name="SearchText" value="@Model.SearchText" placeholder="Search by username or email..." />
                    <button type="submit">Search</button>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.SearchText))
            {
                <div class="section-title">Search Results</div>

                @if (Model.SearchUsers.Any())
                {
                    @foreach (var user in Model.SearchUsers)
                    {
                        var online = await Model.IsOnline(user.Id);

                        <a class="chat-item" asp-page="/ChatConversation" asp-route-userId="@user.Id">
                            <div class="left">
                                <div class="avatar-container">
                                    <div class="avatar">@(user.UserName?.Substring(0, 1).ToUpper())</div>
                                    <div class="status-dot @(online ? "dot-online" : "dot-offline")"></div>
                                </div>
                                <div>
                                    <div class="name">@user.UserName</div>
                                    <div class="last-message">@user.Email</div>
                                </div>
                            </div>
                            <div class="right-status @(online ? "online" : "offline")">
                                <i class="fa-solid fa-circle" style="font-size: 8px;"></i>
                                @(online ? "Online" : "Offline")
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty">
                        <div class="empty-icon"><i class="fa-regular fa-face-frown"></i></div>
                        <h3>No Users Found</h3>
                        <p>Try searching for a different username or email address.</p>
                    </div>
                }
            }
            else
            {
                <div class="section-title">Recent Chats</div>

                @if (Model.Inbox.Any())
                {
                    @foreach (var chat in Model.Inbox)
                    {
                        var online = await Model.IsOnline(chat.UserId);

                        <a class="chat-item @(chat.UnreadCount > 0 ? "unread" : "")" asp-page="/ChatConversation" asp-route-userId="@chat.UserId">
                            <div class="left">
                                <div class="avatar-container">
                                    <div class="avatar">@(chat.UserName?.Substring(0, 1).ToUpper())</div>
                                    <div class="status-dot @(online ? "dot-online" : "dot-offline")"></div>
                                </div>
                                <div>
                                    <div class="name">@chat.UserName</div>
                                    <div class="last-message">@chat.LastMessage</div>
                                </div>
                            </div>
                            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
                                <div class="right-status @(online ? "online" : "offline")">
                                    <i class="fa-solid fa-circle" style="font-size: 8px;"></i>
                                    @(online ? "Online" : "Offline")
                                </div>
                                @if (chat.UnreadCount > 0)
                                {
                                    <div class="unread-badge">@chat.UnreadCount</div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty">
                        <div class="empty-icon"><i class="fa-regular fa-paper-plane"></i></div>
                        <h3>No conversations yet</h3>
                        <p>Search for stores or users above to start a conversation.</p>
                    </div>
                }
            }

        </div>
    </div>
}
