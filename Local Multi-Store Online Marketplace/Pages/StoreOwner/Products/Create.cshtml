@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.CreateModel
@{
    ViewData["Title"] = "Add New Product";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
           ROOT VARIABLES — consistent brand palette
           ============================================================ */
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --input-bg: #f8f7fc;
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
            --radius-md: 12px;
            --radius-lg: 20px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
           PAGE WRAPPER
           ============================================================ */
        .page-wrapper {
            max-width: 820px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        /* ============================================================
           HEADER
           ============================================================ */
        .page-header {
            margin-bottom: 28px;
        }

        .page-header h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.4px;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header h2 i {
            color: var(--accent-color);
        }

        .page-header p {
            margin: 6px 0 0;
            color: var(--text-secondary);
            font-size: 15px;
        }

        /* ============================================================
           FORM CARD — matches dashboard/orders card style
           ============================================================ */
        .form-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 32px 36px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .form-card:hover {
            box-shadow: var(--shadow-md);
        }

        /* ============================================================
           FORM ELEMENTS
           ============================================================ */
        .form-section-title {
            font-size: 12px;
            font-weight: 800;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin: 28px 0 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

        .form-section-title:first-of-type {
            margin-top: 4px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-group:last-child {
            margin-bottom: 0;
        }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 700;
            font-size: 13px;
            color: var(--text-primary);
            letter-spacing: 0.2px;
        }

        .form-group label .required {
            color: var(--error-color);
            margin-left: 2px;
        }

        .form-group input:not([type="checkbox"]),
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 11px 15px;
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-md);
            font-size: 14px;
            font-family: inherit;
            background: var(--input-bg);
            color: var(--text-primary);
            transition: var(--transition);
        }

        .form-group input:not([type="checkbox"])::placeholder,
        .form-group textarea::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        .form-group input:not([type="checkbox"]):focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--accent-color);
            background: var(--card-bg);
            box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
        }

        .form-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--accent-color);
            cursor: pointer;
            margin-right: 8px;
            vertical-align: middle;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .text-danger {
            color: var(--error-color);
            font-size: 13px;
            font-weight: 600;
            margin-top: 4px;
            display: block;
        }

        .help-text {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
            display: block;
        }

        /* ============================================================
           IMAGE UPLOAD
           ============================================================ */
        .image-upload-area {
            border: 2px dashed var(--border-color);
            border-radius: var(--radius-md);
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: var(--bg-color);
            margin-top: 6px;
        }

        .image-upload-area:hover {
            border-color: var(--accent-color);
            background: var(--accent-light);
        }

        .image-upload-area i {
            font-size: 40px;
            color: var(--accent-color);
            opacity: 0.5;
            margin-bottom: 10px;
            display: block;
        }

        .image-upload-area p {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            margin: 0;
        }

        .image-upload-area .sub-text {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .image-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 18px;
        }

        .preview-item {
            position: relative;
            width: 110px;
            height: 110px;
            border-radius: var(--radius-md);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
            transition: var(--transition);
        }

        .preview-item:hover {
            box-shadow: var(--shadow-md);
            border-color: var(--accent-color);
        }

        .preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .preview-item .remove-preview {
            position: absolute;
            top: 6px;
            right: 6px;
            background: var(--error-color);
            color: #fff;
            border: none;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            box-shadow: 0 2px 8px rgba(0,0,0,0.25);
            transition: transform 0.15s ease;
            line-height: 1;
        }

        .preview-item .remove-preview:hover {
            transform: scale(1.1);
        }

        /* ============================================================
           BUTTONS
           ============================================================ */
        .form-actions {
            display: flex;
            gap: 14px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid var(--border-color);
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--accent-gradient);
            color: #fff;
            border: none;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: var(--transition);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
            color: #fff;
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            transition: var(--transition);
        }

        .btn-secondary:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: var(--accent-light);
        }

        /* ============================================================
           RESPONSIVE
           ============================================================ */
        @@media (max-width: 768px) {
            .page-wrapper {
                padding: 20px 16px 40px;
            }

            .form-card {
                padding: 24px 20px;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary,
            .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .image-upload-area {
                padding: 24px 16px;
            }

            .preview-item {
                width: 90px;
                height: 90px;
            }
        }
    </style>
}

<div class="page-wrapper">

    <!-- ========== HEADER ========== -->
    <div class="page-header">
        <h2><i class="fas fa-plus-circle"></i> Add New Product</h2>
        <p>Fill in the details below to add a new product to your store.</p>
    </div>

    <!-- ========== FORM CARD ========== -->
    <div class="form-card">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom:20px;"></div>

            <!-- ===== PRODUCT DETAILS ===== -->
            <div class="form-section-title"><i class="fas fa-info-circle"></i> Product Details</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.ProductName">Product Name <span class="required">*</span></label>
                    <input asp-for="ProductVM.ProductName" placeholder="e.g., iPhone 15 Pro" />
                    <span asp-validation-for="ProductVM.ProductName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.CategoryID">Category <span class="required">*</span></label>
                    <select asp-for="ProductVM.CategoryID" asp-items="Model.CategoriesSelectList">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="ProductVM.CategoryID" class="text-danger"></span>
                    <span class="help-text">Categories are managed by the administrator.</span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ProductVM.Description">Description <span class="required">*</span></label>
                <textarea asp-for="ProductVM.Description" rows="5" placeholder="Describe your product in detail..."></textarea>
                <span asp-validation-for="ProductVM.Description" class="text-danger"></span>
            </div>

            <!-- ===== PRICING ===== -->
            <div class="form-section-title"><i class="fas fa-tags"></i> Pricing</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.Price">Selling Price ($) <span class="required">*</span></label>
                    <input asp-for="ProductVM.Price" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="ProductVM.Price" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.CompareAtPrice">Compare at Price ($)</label>
                    <input asp-for="ProductVM.CompareAtPrice" type="number" step="0.01" placeholder="0.00" />
                    <span class="help-text">Original price for discount display (e.g., $99.99)</span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.OriginalPrice">Your Cost Price ($) <span class="required">*</span></label>
                    <input asp-for="ProductVM.OriginalPrice" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="ProductVM.OriginalPrice" class="text-danger"></span>
                    <span class="help-text">What you paid per unit – used for profit calculation</span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.Quantity">Stock Quantity <span class="required">*</span></label>
                    <input asp-for="ProductVM.Quantity" type="number" min="0" />
                    <span asp-validation-for="ProductVM.Quantity" class="text-danger"></span>
                </div>
            </div>

            <!-- ===== INVENTORY & SHIPPING ===== -->
            <div class="form-section-title"><i class="fas fa-warehouse"></i> Inventory &amp; Shipping</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.LowStockThreshold">Low Stock Threshold</label>
                    <input asp-for="ProductVM.LowStockThreshold" type="number" min="0" placeholder="e.g., 10" />
                    <span class="help-text">You'll be notified when stock reaches this level</span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.Weight">Weight (kg)</label>
                    <input asp-for="ProductVM.Weight" type="number" step="0.01" placeholder="0.00" />
                </div>
            </div>

            <div class="form-group">
                <label>
                    <input asp-for="ProductVM.IsActive" type="checkbox" /> Active
                </label>
                <span class="help-text">Inactive products won't be visible to customers.</span>
            </div>

            <!-- ===== IMAGES ===== -->
            <div class="form-section-title"><i class="fas fa-images"></i> Images</div>

            <div class="form-group">
                <label>Product Images</label>
                <div class="image-upload-area" id="imageUploadArea">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <p>Click or drag images here to upload</p>
                    <span class="sub-text">Supports JPG, PNG, WEBP (max 5 images)</span>
                    <input asp-for="ProductVM.UploadedImages" type="file" id="imageInput" multiple accept="image/*" style="display: none;" />
                </div>
                <div class="image-preview" id="imagePreview"></div>
                <span class="help-text">First image will be used as the primary image.</span>
            </div>

            <!-- ===== ACTIONS ===== -->
            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i> Create Product
                </button>
                <a href="/StoreOwner/Products/Index" class="btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            const uploadArea = document.getElementById('imageUploadArea');
            const imageInput = document.getElementById('imageInput');
            const preview = document.getElementById('imagePreview');

            function handleFiles(files) {
                preview.innerHTML = '';
                for (let file of files) {
                    if (!file.type.startsWith('image/')) continue;
                    const reader = new FileReader();
                    reader.onload = function(ev) {
                        const div = document.createElement('div');
                        div.className = 'preview-item';
                        div.innerHTML = `
                            <img src="${ev.target.result}" alt="Preview" />
                            <button type="button" class="remove-preview" onclick="this.parentElement.remove()">×</button>
                        `;
                        preview.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                }
            }

            uploadArea.addEventListener('click', () => imageInput.click());

            uploadArea.addEventListener('dragover', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--accent-color)';
                uploadArea.style.background = 'var(--accent-light)';
            });

            uploadArea.addEventListener('dragleave', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--border-color)';
                uploadArea.style.background = 'var(--bg-color)';
            });

            uploadArea.addEventListener('drop', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--border-color)';
                uploadArea.style.background = 'var(--bg-color)';
                const files = e.dataTransfer.files;
                imageInput.files = files;
                handleFiles(files);
            });

            imageInput.addEventListener('change', e => {
                handleFiles(e.target.files);
            });
        })();
    </script>
}