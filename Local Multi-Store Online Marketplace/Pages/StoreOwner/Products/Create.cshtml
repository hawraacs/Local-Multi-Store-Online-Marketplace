@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.CreateModel
@{
    ViewData["Title"] = "Add New Product";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --input-bg: #f8f7fc;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
        }

        .form-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 22px;
            padding: 36px 40px;
            box-shadow: var(--shadow-md);
        }

            .form-container h2 {
                font-size: 24px;
                font-weight: 800;
                color: var(--text-primary);
                letter-spacing: -0.4px;
            }

        .form-section-title {
            font-size: 12px;
            font-weight: 800;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin: 30px 0 14px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

            .form-section-title:first-of-type {
                margin-top: 8px;
            }

        .form-group {
            margin-bottom: 22px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: 600;
                font-size: 13px;
                color: var(--text-primary);
                letter-spacing: 0.2px;
            }

                .form-group label .required {
                    color: var(--error-color);
                }

            .form-group input:not([type="checkbox"]),
            .form-group textarea,
            .form-group select {
                width: 100%;
                padding: 12px 15px;
                border: 1.5px solid var(--border-color);
                border-radius: 12px;
                font-size: 14px;
                font-family: inherit;
                background: var(--input-bg);
                color: var(--text-primary);
                transition: all 0.2s ease;
            }

                .form-group input:not([type="checkbox"])::placeholder,
                .form-group textarea::placeholder {
                    color: var(--text-muted);
                }

                .form-group input:not([type="checkbox"]):focus,
                .form-group textarea:focus,
                .form-group select:focus {
                    outline: none;
                    border-color: var(--accent-color);
                    background: var(--card-bg);
                    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
                }

            .form-group input[type="checkbox"] {
                width: 17px;
                height: 17px;
                accent-color: var(--accent-color);
                cursor: pointer;
                margin-right: 6px;
                vertical-align: middle;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .image-upload-area {
            border: 2px dashed var(--border-color);
            border-radius: 16px;
            padding: 34px;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s ease;
            background: var(--bg-color);
            margin-top: 15px;
        }

            .image-upload-area:hover {
                border-color: var(--accent-color);
                background: var(--accent-light);
            }

            .image-upload-area i {
                font-size: 44px;
                color: var(--accent-color);
                margin-bottom: 12px;
                opacity: 0.7;
            }

            .image-upload-area p {
                color: var(--text-secondary);
                font-size: 14px;
                font-weight: 500;
            }

        .image-preview {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .preview-item {
            position: relative;
            width: 120px;
            height: 120px;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
        }

            .preview-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .remove-preview {
            position: absolute;
            top: 6px;
            right: 6px;
            background: var(--error-color);
            color: white;
            border: none;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.25);
            transition: transform 0.15s ease;
        }

            .remove-preview:hover {
                transform: scale(1.1);
            }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 30px;
            padding-top: 22px;
            border-top: 1px solid var(--border-color);
        }

        .text-danger {
            color: var(--error-color);
            font-size: 12px;
            margin-top: 5px;
            display: block;
            font-weight: 500;
        }

        .help-text {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 5px;
            display: block;
        }

        .btn-primary {
            background: var(--accent-gradient);
            color: white;
            border: none;
            padding: 14px 26px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
            }

        .btn-secondary {
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            padding: 14px 26px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s ease;
        }

            .btn-secondary:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                background: var(--accent-light);
            }

        @@media (max-width: 700px) {
            .form-container {
                padding: 26px 22px;
            }

            .form-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="form-container">
    <h2 style="margin: 0 0 5px 0;">Add New Product</h2>
    <p style="color: var(--text-secondary); margin-bottom: 25px; font-size: 14px;">Fill in the details below to add a new product to your store</p>

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 20px;"></div>

        <div class="form-section-title">Product Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="ProductVM.ProductName">Product Name <span class="required">*</span></label>
                <input asp-for="ProductVM.ProductName" placeholder="e.g., iPhone 15 Pro" />
                <span asp-validation-for="ProductVM.ProductName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductVM.CategoryID">
                    Category <span class="required">*</span>
                </label>

                <select asp-for="ProductVM.CategoryID"
                        asp-items="Model.CategoriesSelectList">

                    <option value="">
                        -- Select Category --
                    </option>

                </select>

                <span asp-validation-for="ProductVM.CategoryID"
                      class="text-danger"></span>

                <span class="help-text">
                    Categories are managed by the administrator.
                </span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="ProductVM.Description">Description <span class="required">*</span></label>
            <textarea asp-for="ProductVM.Description" rows="5" placeholder="Describe your product in detail..."></textarea>
            <span asp-validation-for="ProductVM.Description" class="text-danger"></span>
        </div>

        <div class="form-section-title">Pricing</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="ProductVM.Price">Selling Price ($) <span class="required">*</span></label>
                <input asp-for="ProductVM.Price" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="ProductVM.Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductVM.CompareAtPrice">Compare at Price ($)</label>
                <input asp-for="ProductVM.CompareAtPrice" type="number" step="0.01" placeholder="0.00" />
                <span class="help-text">Original price for discount display (e.g., $99.99)</span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="ProductVM.OriginalPrice">Your Cost Price ($) <span class="required">*</span></label>
                <input asp-for="ProductVM.OriginalPrice" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="ProductVM.OriginalPrice" class="text-danger"></span>
                <span class="help-text">What you paid per unit – used for profit calculation</span>
            </div>
            <div class="form-group">
                <label asp-for="ProductVM.Quantity">Stock Quantity <span class="required">*</span></label>
                <input asp-for="ProductVM.Quantity" type="number" min="0" />
                <span asp-validation-for="ProductVM.Quantity" class="text-danger"></span>
            </div>
        </div>

        <div class="form-section-title">Inventory & Shipping</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="ProductVM.LowStockThreshold">Low Stock Threshold</label>
                <input asp-for="ProductVM.LowStockThreshold" type="number" min="0" />
                <span class="help-text">You'll be notified when stock reaches this level</span>
            </div>
            <div class="form-group">
                <label asp-for="ProductVM.Weight">Weight (kg)</label>
                <input asp-for="ProductVM.Weight" type="number" step="0.01" placeholder="0.00" />
            </div>
        </div>

        <div class="form-group">
            <label>
                <input asp-for="ProductVM.IsActive" type="checkbox" /> Active
            </label>
            <span class="help-text">Inactive products won't be visible to customers</span>
        </div>

        <div class="form-section-title">Images</div>

        <!-- Image Upload Area -->
        <div class="form-group">
            <label>Product Images</label>
            <div class="image-upload-area" id="imageUploadArea">
                <i class="fas fa-cloud-upload-alt"></i>
                <p>Click or drag images here to upload</p>
                <input asp-for="ProductVM.UploadedImages" type="file" id="imageInput" multiple accept="image/*" style="display: none;" />
            </div>
            <div class="image-preview" id="imagePreview"></div>
            <span class="help-text">Upload up to 5 images. First image will be the primary image.</span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Create Product</button>
            <a href="/StoreOwner/Products/Index" class="btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const uploadArea = document.getElementById('imageUploadArea');
        const imageInput = document.getElementById('imageInput');
        const preview = document.getElementById('imagePreview');

        uploadArea.addEventListener('click', () => imageInput.click());
        uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.style.borderColor = '#6d28d9'; });
        uploadArea.addEventListener('dragleave', e => { e.preventDefault(); uploadArea.style.borderColor = '#ece8f6'; });
        uploadArea.addEventListener('drop', e => {
            e.preventDefault();
            uploadArea.style.borderColor = '#ece8f6';
            const files = e.dataTransfer.files;
            imageInput.files = files;
            handleFiles(files);
        });
        imageInput.addEventListener('change', e => handleFiles(e.target.files));

        function handleFiles(files) {
            preview.innerHTML = '';
            for (let file of files) {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(ev) {
                        const div = document.createElement('div');
                        div.className = 'preview-item';
                        div.innerHTML = `<img src="${ev.target.result}" /><button type="button" class="remove-preview" onclick="this.parentElement.remove()">×</button>`;
                        preview.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                }
            }
        }
    </script>
}
