@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
           ROOT VARIABLES — consistent brand palette
           ============================================================ */
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
            --radius-md: 12px;
            --radius-lg: 20px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
           PAGE WRAPPER
           ============================================================ */
        .page-wrapper {
            max-width: 640px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        /* ============================================================
           BREADCRUMB
           ============================================================ */
        .breadcrumb-wrap {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 12px 20px;
            border-radius: var(--radius-md);
            margin-bottom: 24px;
            box-shadow: var(--shadow-sm);
        }

        .breadcrumb {
            margin: 0;
            padding: 0;
            background: transparent;
            font-size: 14px;
            display: flex;
            flex-wrap: wrap;
            list-style: none;
        }

        .breadcrumb-item + .breadcrumb-item::before {
            content: "/";
            padding: 0 8px;
            color: var(--text-muted);
        }

        .breadcrumb-item a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
        }

        .breadcrumb-item a:hover {
            color: var(--accent-hover);
            text-decoration: underline;
        }

        .breadcrumb-item.active {
            color: var(--text-secondary);
            font-weight: 600;
        }

        /* ============================================================
           DELETE CARD
           ============================================================ */
        .delete-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 36px 40px 32px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            text-align: center;
        }

        .delete-card:hover {
            box-shadow: var(--shadow-md);
        }

        /* ----- Warning icon ----- */
        .warning-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: #fef2f2;
            margin-bottom: 20px;
        }

        .warning-icon i {
            font-size: 38px;
            color: var(--error-color);
        }

        .delete-card h2 {
            margin: 0 0 6px;
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }

        .delete-card > .subtitle {
            margin: 0 0 20px;
            color: var(--text-secondary);
            font-size: 15px;
        }

        /* ============================================================
           ALERT BOXES
           ============================================================ */
        .alert-box {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            border-radius: var(--radius-md);
            padding: 14px 18px;
            margin-bottom: 20px;
            text-align: left;
            font-size: 13px;
            line-height: 1.5;
            border: 1px solid transparent;
        }

        .alert-box i {
            font-size: 18px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .alert-box p {
            margin: 0;
        }

        .alert-box strong {
            font-weight: 700;
        }

        .alert-warning {
            background: #fffbeb;
            border-color: #fde68a;
            color: #92400e;
        }

        .alert-warning i {
            color: var(--warning-color);
        }

        .alert-info {
            background: var(--accent-light);
            border-color: #e0d4fb;
            color: var(--accent-hover);
        }

        .alert-info i {
            color: var(--accent-color);
        }

        /* ============================================================
           PRODUCT DETAILS CARD
           ============================================================ */
        .product-details-card {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 24px 22px 20px;
            margin: 20px 0 24px;
            transition: var(--transition);
        }

        .product-details-card:hover {
            border-color: var(--accent-color);
        }

        .product-image-wrap {
            width: 130px;
            height: 130px;
            border-radius: var(--radius-md);
            overflow: hidden;
            margin: 0 auto 16px;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
            background: var(--card-bg);
        }

        .product-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .product-name {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .product-price {
            font-size: 24px;
            font-weight: 800;
            color: var(--accent-color);
            margin-bottom: 6px;
        }

        .product-category {
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 500;
        }

        .product-category i {
            color: var(--accent-color);
        }

        .product-divider {
            border: none;
            border-top: 1px solid var(--border-color);
            margin: 14px 0 12px;
        }

        .product-meta-row {
            display: flex;
            justify-content: center;
            gap: 28px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .product-meta-row strong {
            color: var(--text-primary);
            font-weight: 700;
        }

        /* ============================================================
           ACTIONS
           ============================================================ */
        .form-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .btn-danger {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--error-color);
            color: #fff;
            border: none;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(220, 38, 38, 0.20);
            transition: var(--transition);
            text-decoration: none;
        }

        .btn-danger:hover {
            background: #b91c1c;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(220, 38, 38, 0.28);
            color: #fff;
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            transition: var(--transition);
        }

        .btn-secondary:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: var(--accent-light);
        }

        /* ============================================================
           RESPONSIVE
           ============================================================ */
        @@media (max-width: 600px) {
            .page-wrapper {
                padding: 20px 16px 40px;
            }

            .delete-card {
                padding: 28px 20px 24px;
            }

            .warning-icon {
                width: 72px;
                height: 72px;
            }

            .warning-icon i {
                font-size: 30px;
            }

            .delete-card h2 {
                font-size: 20px;
            }

            .product-details-card {
                padding: 18px 16px;
            }

            .product-image-wrap {
                width: 100px;
                height: 100px;
            }

            .product-price {
                font-size: 20px;
            }

            .product-meta-row {
                flex-direction: column;
                gap: 6px;
                align-items: center;
            }

            .form-actions {
                flex-direction: column;
                align-items: center;
            }

            .btn-danger,
            .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="page-wrapper">

    <!-- ========== BREADCRUMB ========== -->
    <div class="breadcrumb-wrap">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/StoreOwner/Dashboard"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/StoreOwner/Products/Index">Products</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </div>

    <!-- ========== DELETE CARD ========== -->
    <div class="delete-card">

        <!-- Warning Icon -->
        <div class="warning-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>

        <h2>Delete Product</h2>
        <p class="subtitle">Are you sure you want to delete this product?</p>

        <!-- Alert Box -->
        @if (Model.HasOrders)
        {
            <div class="alert-box alert-info">
                <i class="fas fa-info-circle"></i>
                <p><strong>Note:</strong> This product has existing orders. Instead of deleting, it will be <strong>deactivated</strong>. Existing orders will remain unaffected.</p>
            </div>
        }
        else
        {
            <div class="alert-box alert-warning">
                <i class="fas fa-exclamation-circle"></i>
                <p><strong>Warning:</strong> This action cannot be undone. The product and all its images will be permanently deleted.</p>
            </div>
        }

        <!-- Product Details -->
        <div class="product-details-card">
            <div class="product-image-wrap">
                <img src="@Model.PrimaryImageUrl" alt="@Model.Product.ProductName" onerror="this.onerror=null; this.src='/images/no-image.png';" />
            </div>

            <div class="product-name">@Model.Product.ProductName</div>
            <div class="product-price">$@Model.Product.Price.ToString("N2")</div>
            <div class="product-category">
                <i class="fas fa-tag"></i> @(Model.Product.Category?.CategoryName ?? "Uncategorized")
            </div>

            <hr class="product-divider" />

            <div class="product-meta-row">
                <div>
                    <strong>Stock:</strong> @Model.Product.Quantity units
                </div>
                <div>
                    <strong>Status:</strong> @(Model.Product.IsActive ? "Active" : "Inactive")
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="form-actions">
            <form method="post">
                <input type="hidden" asp-for="Product.ProductID" />
                <button type="submit" class="btn-danger">
                    <i class="fas fa-trash"></i> @(Model.HasOrders ? "Deactivate Product" : "Delete Permanently")
                </button>
            </form>
            <a href="/StoreOwner/Products/Index" class="btn-secondary">
                <i class="fas fa-times"></i> Cancel
            </a>
        </div>
    </div>
</div>