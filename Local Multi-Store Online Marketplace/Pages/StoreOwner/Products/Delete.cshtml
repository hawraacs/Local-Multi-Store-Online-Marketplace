@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
        }

        .delete-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 22px;
            padding: 36px 40px;
            box-shadow: var(--shadow-md);
            max-width: 600px;
            margin: 0 auto;
        }

        .warning-icon {
            text-align: center;
            margin-bottom: 20px;
        }

            .warning-icon i {
                font-size: 60px;
                color: var(--error-color);
                background: #fef2f2;
                width: 100px;
                height: 100px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 42px;
            }

        .delete-container h2 {
            text-align: center;
            margin-bottom: 8px;
            font-size: 22px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }

        .delete-container > p {
            text-align: center;
            color: var(--text-secondary);
            font-size: 14px;
        }

        .product-details {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 22px;
            margin: 22px 0;
        }

        .product-image {
            width: 140px;
            height: 140px;
            border-radius: 14px;
            overflow: hidden;
            margin: 0 auto 15px;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
        }

            .product-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .product-info {
            text-align: center;
        }

        .product-name {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .product-price {
            font-size: 24px;
            font-weight: 800;
            color: var(--accent-color);
            margin-bottom: 10px;
        }

        .product-category {
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 500;
        }

            .product-category i {
                color: var(--accent-color);
            }

        .warning-box {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 14px;
            padding: 16px 18px;
            margin: 20px 0;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

            .warning-box i {
                color: var(--warning-color);
                margin-top: 2px;
            }

            .warning-box p {
                margin: 0;
                color: #92400e;
                font-size: 13px;
                line-height: 1.5;
            }

        .info-box {
            background: var(--accent-light);
            border: 1px solid #e0d4fb;
            border-radius: 14px;
            padding: 16px 18px;
            margin: 20px 0;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

            .info-box i {
                color: var(--accent-color);
                margin-top: 2px;
            }

            .info-box p {
                margin: 0;
                color: var(--accent-hover);
                font-size: 13px;
                line-height: 1.5;
            }

        .form-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 28px;
        }

        .btn-danger {
            background: var(--error-color);
            color: white;
            border: none;
            padding: 13px 26px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            box-shadow: 0 4px 16px rgba(220, 38, 38, 0.20);
            transition: all 0.25s ease;
        }

            .btn-danger:hover {
                background: #b91c1c;
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(220, 38, 38, 0.28);
            }

        .btn-secondary {
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            padding: 13px 26px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

            .btn-secondary:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                background: var(--accent-light);
            }

        hr {
            margin: 18px 0;
            border: none;
            border-top: 1px solid var(--border-color);
        }

        .product-meta-row {
            display: flex;
            justify-content: center;
            gap: 24px;
            font-size: 13px;
            color: var(--text-secondary);
        }

            .product-meta-row strong {
                color: var(--text-primary);
            }
    </style>
}

<div class="delete-container">
    <div class="warning-icon">
        <i class="fas fa-exclamation-triangle"></i>
    </div>

    <h2>Delete Product</h2>
    <p>Are you sure you want to delete this product?</p>

    @if (Model.HasOrders)
    {
        <div class="info-box">
            <i class="fas fa-info-circle"></i>
            <p><strong>Note:</strong> This product has existing orders. Instead of deleting, it will be deactivated. Existing orders will remain unaffected.</p>
        </div>
    }
    else
    {
        <div class="warning-box">
            <i class="fas fa-exclamation-circle"></i>
            <p><strong>Warning:</strong> This action cannot be undone. The product and all its images will be permanently deleted.</p>
        </div>
    }

    <div class="product-details">
        <div class="product-image">
            <img src="@Model.PrimaryImageUrl" alt="@Model.Product.ProductName" onerror="this.src='/images/no-image.png'" />
        </div>
        <div class="product-info">
            <div class="product-name">@Model.Product.ProductName</div>
            <div class="product-price">$@Model.Product.Price.ToString("N2")</div>
            <div class="product-category">
                <i class="fas fa-tag"></i> @(Model.Product.Category?.CategoryName ?? "Uncategorized")
            </div>
            <hr />
            <div class="product-meta-row">
                <div>
                    <strong>Stock:</strong> @Model.Product.Quantity units
                </div>
                <div>
                    <strong>Status:</strong> @(Model.Product.IsActive ? "Active" : "Inactive")
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <form method="post">
            <input type="hidden" asp-for="Product.ProductID" />
            <button type="submit" class="btn-danger">
                <i class="fas fa-trash"></i> @(Model.HasOrders ? "Deactivate Product" : "Delete Permanently")
            </button>
        </form>
        <a href="/StoreOwner/Products/Index" class="btn-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
    </div>
</div>
