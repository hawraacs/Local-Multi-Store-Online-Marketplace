@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.IndexModel
@{
    ViewData["Title"] = "Products";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/store-owner-products.css" />
}

<div class="products-header">
    <div>
        <h1 style="margin: 0; font-size: 24px;">Products</h1>
        <p style="margin: 5px 0 0; color: #6c757d;">Manage your store's product inventory</p>
    </div>
    <a href="/StoreOwner/Products/Create" class="btn-primary">
        <i class="fas fa-plus"></i> Add New Product
    </a>
</div>

<!-- Search and Filter Bar -->
<div class="search-filter-bar">
    <form method="get" id="filterForm">
        <div class="filter-group">
            <div class="filter-input">
                <input type="text" name="SearchTerm" id="SearchTerm" 
                       placeholder="Search products by name or description..."
                       value="@Model.SearchTerm" />
            </div>
            <div class="filter-input">
                <select name="CategoryFilter" id="CategoryFilter">
                    <option value="">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryID" selected="@(Model.CategoryFilter == category.CategoryID)">
                            @category.CategoryName
                        </option>
                    }
                </select>
            </div>
            <div class="filter-input">
                <select name="StatusFilter" id="StatusFilter">
                    <option value="">All Status</option>
                    <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
                    <option value="inactive" selected="@(Model.StatusFilter == "inactive")">Inactive</option>
                    <option value="outofstock" selected="@(Model.StatusFilter == "outofstock")">Out of Stock</option>
                </select>
            </div>
            <div class="filter-input" style="flex: 0 0 auto;">
                <button type="submit" class="btn-primary">
                    <i class="fas fa-search"></i> Search
                </button>
            </div>
        </div>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
    </div>
}

@if (Model.Products.Any())
{
    <div class="products-grid">
        @foreach (var product in Model.Products)
        {
            <div class="product-card">
                <div class="product-image">
                    @if (!string.IsNullOrEmpty(product.PrimaryImageUrl))
                    {
                        <img src="@product.PrimaryImageUrl" alt="@product.ProductName" 
                             onerror="this.src='/images/no-image.png'">
                    }
                    else
                    {
                        <img src="/images/no-image.png" alt="No image">
                    }
                    
                    @if (product.DiscountPercentage.HasValue)
                    {
                        <span class="product-badge badge-discount">-@product.DiscountPercentage%</span>
                    }
                    @if (product.IsOutOfStock)
                    {
                        <span class="product-badge badge-outstock">Out of Stock</span>
                    }
                </div>
                
                <div class="product-info">
                    <div class="product-category">@product.CategoryName</div>
                    <h3 class="product-title">@product.ProductName</h3>
                    <p class="product-description">@(product.Description.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)</p>
                    
                    <div class="price-section">
                        <span class="current-price">$@product.Price.ToString("N2")</span>
                        @if (product.CompareAtPrice.HasValue && product.CompareAtPrice > product.Price)
                        {
                            <span class="original-price">$@product.CompareAtPrice.Value.ToString("N2")</span>
                        }
                    </div>
                    
                    <div>
                        <span class="stock-status stock-@product.StockStatusClass">
                            @product.StockStatus (@product.Quantity left)
                        </span>
                    </div>
                    
                    <div class="product-actions">
                        <a href="/StoreOwner/Products/Edit?id=@product.ProductID" class="btn-edit">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        <button onclick="deleteProduct(@product.ProductID)" class="btn-delete">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                        <button onclick="toggleStatus(@product.ProductID, @(!product.IsActive).ToString().ToLower())" 
                                class="btn-toggle @(product.IsActive ? "active" : "")">
                            <i class="fas @(product.IsActive ? "fa-eye" : "fa-eye-slash")"></i>
                            @(product.IsActive ? "Active" : "Inactive")
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-box-open"></i>
        <h3>No Products Found</h3>
        <p>You haven't added any products yet.</p>
        <a href="/StoreOwner/Products/Create" class="btn-primary" style="display: inline-block; margin-top: 15px;">
            <i class="fas fa-plus"></i> Add Your First Product
        </a>
    </div>
}

@section Scripts {
    <script>
        // Auto-submit form on filter change
        document.getElementById('CategoryFilter')?.addEventListener('change', function() {
            document.getElementById('filterForm').submit();
        });
        
        document.getElementById('StatusFilter')?.addEventListener('change', function() {
            document.getElementById('filterForm').submit();
        });

        function toggleStatus(productId) {
            fetch('/StoreOwner/Products/Index?handler=ToggleStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ productId: productId })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        function deleteProduct(productId) {
            if (confirm('Are you sure you want to delete this product? This action cannot be undone.')) {
                window.location.href = `/StoreOwner/Products/Delete?id=${productId}`;
            }
        }
    </script>
}