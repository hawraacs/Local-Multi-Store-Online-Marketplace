@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Products.EditModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
                   ROOT VARIABLES — consistent brand palette
                   ============================================================ */
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
            --radius-md: 12px;
            --radius-lg: 20px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
                   PAGE WRAPPER
                   ============================================================ */
        .page-wrapper {
            max-width: 820px;
            margin: 0 auto;
            padding: 32px 20px 60px;
        }

        /* ============================================================
                   BREADCRUMB
                   ============================================================ */
        .breadcrumb-wrap {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 12px 20px;
            border-radius: var(--radius-md);
            margin-bottom: 24px;
            box-shadow: var(--shadow-sm);
        }

        .breadcrumb {
            margin: 0;
            padding: 0;
            background: transparent;
            font-size: 14px;
            display: flex;
            flex-wrap: wrap;
            list-style: none;
        }

        .breadcrumb-item + .breadcrumb-item::before {
            content: "/";
            padding: 0 8px;
            color: var(--text-muted);
        }

        .breadcrumb-item a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
        }

            .breadcrumb-item a:hover {
                color: var(--accent-hover);
                text-decoration: underline;
            }

        .breadcrumb-item.active {
            color: var(--text-secondary);
            font-weight: 600;
        }

        /* ============================================================
                   HEADER
                   ============================================================ */
        .page-header {
            margin-bottom: 28px;
        }

            .page-header h2 {
                margin: 0;
                font-size: 26px;
                font-weight: 800;
                letter-spacing: -0.4px;
                color: var(--text-primary);
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .page-header h2 i {
                    color: var(--accent-color);
                }

            .page-header p {
                margin: 6px 0 0;
                color: var(--text-secondary);
                font-size: 15px;
            }

        /* ============================================================
                   FORM CARD
                   ============================================================ */
        .form-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 32px 36px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

            .form-card:hover {
                box-shadow: var(--shadow-md);
            }

        /* ============================================================
                   FORM ELEMENTS
                   ============================================================ */
        .form-section-title {
            font-size: 12px;
            font-weight: 800;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin: 28px 0 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .form-section-title:first-of-type {
                margin-top: 4px;
            }

            .form-section-title i {
                font-size: 14px;
            }

        .form-group {
            margin-bottom: 22px;
        }

            .form-group:last-child {
                margin-bottom: 0;
            }

            .form-group label {
                display: block;
                margin-bottom: 6px;
                font-weight: 700;
                font-size: 13px;
                color: var(--text-primary);
                letter-spacing: 0.2px;
            }

                .form-group label .required {
                    color: var(--error-color);
                    margin-left: 2px;
                }

            .form-group input:not([type="checkbox"]),
            .form-group textarea,
            .form-group select {
                width: 100%;
                padding: 11px 15px;
                border: 1.5px solid var(--border-color);
                border-radius: var(--radius-md);
                font-size: 14px;
                font-family: inherit;
                background: var(--bg-color);
                color: var(--text-primary);
                transition: var(--transition);
            }

                .form-group input:not([type="checkbox"])::placeholder,
                .form-group textarea::placeholder {
                    color: var(--text-muted);
                    opacity: 0.7;
                }

                .form-group input:not([type="checkbox"]):focus,
                .form-group textarea:focus,
                .form-group select:focus {
                    outline: none;
                    border-color: var(--accent-color);
                    background: var(--card-bg);
                    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
                }

            .form-group input[type="checkbox"] {
                width: 18px;
                height: 18px;
                accent-color: var(--accent-color);
                cursor: pointer;
                margin-right: 8px;
                vertical-align: middle;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .text-danger {
            color: var(--error-color);
            font-size: 13px;
            font-weight: 600;
            margin-top: 4px;
            display: block;
        }

        .help-text {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
            display: block;
        }

        /* ============================================================
                   IMAGE SECTION
                   ============================================================ */
        .alert-info {
            background: var(--accent-light);
            color: var(--accent-hover);
            border: 1px solid #e0d4fb;
            padding: 12px 16px;
            border-radius: var(--radius-md);
            margin-bottom: 18px;
            font-size: 13px;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

            .alert-info i {
                color: var(--accent-color);
                margin-top: 2px;
            }

        .existing-images {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 20px;
        }

        .existing-image-item {
            position: relative;
            width: 120px;
            height: 120px;
            border-radius: var(--radius-md);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 2px solid var(--border-color);
            transition: var(--transition);
            background: var(--bg-color);
        }

            .existing-image-item.primary {
                border-color: var(--accent-color);
            }

            .existing-image-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .primary-badge {
            position: absolute;
            top: 6px;
            left: 6px;
            background: var(--accent-gradient);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            box-shadow: var(--shadow-sm);
        }

        .image-actions {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(30, 27, 46, 0.80);
            display: flex;
            justify-content: space-around;
            padding: 6px;
            transform: translateY(100%);
            transition: transform 0.3s ease;
            backdrop-filter: blur(4px);
        }

        .existing-image-item:hover .image-actions {
            transform: translateY(0);
        }

        .image-actions button {
            background: none;
            border: none;
            color: #fff;
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .image-actions .btn-primary-img:hover {
            background: var(--accent-color);
        }

        .image-actions .btn-delete-img:hover {
            background: var(--error-color);
        }

        .image-upload-area {
            border: 2px dashed var(--border-color);
            border-radius: var(--radius-md);
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: var(--bg-color);
            margin-top: 6px;
        }

            .image-upload-area:hover {
                border-color: var(--accent-color);
                background: var(--accent-light);
            }

            .image-upload-area i {
                font-size: 40px;
                color: var(--accent-color);
                opacity: 0.5;
                margin-bottom: 10px;
                display: block;
            }

            .image-upload-area p {
                color: var(--text-secondary);
                font-size: 14px;
                font-weight: 500;
                margin: 0;
            }

            .image-upload-area .sub-text {
                font-size: 12px;
                color: var(--text-muted);
                margin-top: 4px;
            }

        .image-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 18px;
        }

        .preview-item {
            position: relative;
            width: 110px;
            height: 110px;
            border-radius: var(--radius-md);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
            transition: var(--transition);
        }

            .preview-item:hover {
                box-shadow: var(--shadow-md);
                border-color: var(--accent-color);
            }

            .preview-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .preview-item .remove-preview {
                position: absolute;
                top: 6px;
                right: 6px;
                background: var(--error-color);
                color: #fff;
                border: none;
                border-radius: 50%;
                width: 24px;
                height: 24px;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                font-weight: 700;
                box-shadow: 0 2px 8px rgba(0,0,0,0.25);
                transition: transform 0.15s ease;
                line-height: 1;
            }

                .preview-item .remove-preview:hover {
                    transform: scale(1.1);
                }

        /* ============================================================
                   BUTTONS
                   ============================================================ */
        .form-actions {
            display: flex;
            gap: 14px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid var(--border-color);
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--accent-gradient);
            color: #fff;
            border: none;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: var(--transition);
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
                color: #fff;
            }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            transition: var(--transition);
        }

            .btn-secondary:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                background: var(--accent-light);
            }

        /* ============================================================
                   TOAST — consistent with other pages
                   ============================================================ */
        .product-toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 999999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
            max-width: 420px;
            width: 100%;
        }

        .product-toast {
            width: 100%;
            padding: 16px 18px;
            border-radius: var(--radius-md);
            color: #fff;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            background: linear-gradient(135deg, #b91c1c, #dc2626);
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateX(30px) scale(0.96);
            transition: opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1), transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            pointer-events: auto;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

            .product-toast.show {
                opacity: 1;
                transform: translateX(0) scale(1);
            }

        .product-toast-icon {
            width: 32px;
            height: 32px;
            flex: 0 0 32px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
        }

        .product-toast-content {
            flex: 1;
            min-width: 0;
        }

        .product-toast-title {
            display: block;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: 0.2px;
            margin-bottom: 2px;
        }

        .product-toast-message {
            display: block;
            font-size: 12px;
            font-weight: 500;
            line-height: 1.5;
            opacity: 0.90;
        }

        .product-toast-close {
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.60);
            font-size: 22px;
            line-height: 1;
            padding: 0 0 0 6px;
            cursor: pointer;
            transition: color 0.2s;
        }

            .product-toast-close:hover {
                color: #fff;
            }

        /* ============================================================
                   RESPONSIVE
                   ============================================================ */
        @@media (max-width: 768px) {
            .page-wrapper {
                padding: 20px 16px 40px;
            }

            .form-card {
                padding: 24px 20px;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary,
            .btn-secondary {
                width: 100%;
                justify-content: center;
            }

            .product-toast-container {
                top: 12px;
                right: 12px;
                left: 12px;
                max-width: none;
            }

            .existing-images {
                gap: 12px;
            }

            .existing-image-item {
                width: 100px;
                height: 100px;
            }

            .preview-item {
                width: 90px;
                height: 90px;
            }

            .image-upload-area {
                padding: 24px 16px;
            }
        }

        @@media (max-width: 480px) {
            .existing-image-item {
                width: 80px;
                height: 80px;
            }

            .preview-item {
                width: 80px;
                height: 80px;
            }

            .image-actions button {
                font-size: 10px;
                padding: 2px 6px;
            }
        }
    </style>
}

<div class="page-wrapper">

    <!-- ========== BREADCRUMB ========== -->
    <div class="breadcrumb-wrap">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/StoreOwner/Dashboard"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/StoreOwner/Products/Index">Products</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </div>

    <!-- ========== HEADER ========== -->
    <div class="page-header">
        <h2><i class="fas fa-pen"></i> Edit Product</h2>
        <p>Update your product information and images.</p>
    </div>

    <!-- ========== FORM CARD ========== -->
    <div class="form-card">
        <form method="post" enctype="multipart/form-data" id="editForm" asp-antiforgery="true">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:20px;"></div>
            <input type="hidden" asp-for="ProductVM.ProductID" />

            <!-- ===== PRODUCT DETAILS ===== -->
            <div class="form-section-title"><i class="fas fa-info-circle"></i> Product Details</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.ProductName">Product Name <span class="required">*</span></label>
                    <input asp-for="ProductVM.ProductName" placeholder="e.g., iPhone 15 Pro" />
                    <span asp-validation-for="ProductVM.ProductName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.CategoryID">Category <span class="required">*</span></label>
                    <select asp-for="ProductVM.CategoryID" asp-items="Model.CategoriesSelectList" class="form-control">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="ProductVM.CategoryID" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ProductVM.Description">Description <span class="required">*</span></label>
                <textarea asp-for="ProductVM.Description" rows="5" placeholder="Describe your product in detail..."></textarea>
                <span asp-validation-for="ProductVM.Description" class="text-danger"></span>
            </div>

            <!-- ===== PRICING ===== -->
            <div class="form-section-title"><i class="fas fa-tags"></i> Pricing</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.Price">Selling Price ($) <span class="required">*</span></label>
                    <input asp-for="ProductVM.Price" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="ProductVM.Price" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.CompareAtPrice">Compare at Price ($)</label>
                    <input asp-for="ProductVM.CompareAtPrice" type="number" step="0.01" placeholder="0.00" />
                    <span class="help-text">Original price for discount display (e.g., $99.99)</span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.OriginalPrice">Your Cost Price ($) <span class="required">*</span></label>
                    <input asp-for="ProductVM.OriginalPrice" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="ProductVM.OriginalPrice" class="text-danger"></span>
                    <span class="help-text">What you paid per unit – used for profit calculation</span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.Quantity">Stock Quantity <span class="required">*</span></label>
                    <input asp-for="ProductVM.Quantity" type="number" min="0" />
                    <span asp-validation-for="ProductVM.Quantity" class="text-danger"></span>
                </div>
            </div>

            <!-- ===== INVENTORY & SHIPPING ===== -->
            <div class="form-section-title"><i class="fas fa-warehouse"></i> Inventory &amp; Shipping</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProductVM.LowStockThreshold">Low Stock Threshold</label>
                    <input asp-for="ProductVM.LowStockThreshold" type="number" min="0" placeholder="e.g., 10" />
                    <span class="help-text">You'll be notified when stock reaches this level</span>
                </div>
                <div class="form-group">
                    <label asp-for="ProductVM.Weight">Weight (kg)</label>
                    <input asp-for="ProductVM.Weight" type="number" step="0.01" placeholder="0.00" />
                </div>
            </div>

            <div class="form-group">
                <label>
                    <input asp-for="ProductVM.IsActive" type="checkbox" /> Active
                </label>
                <span class="help-text">Inactive products won't be visible to customers.</span>
            </div>

            <!-- ===== IMAGES ===== -->
            <div class="form-section-title"><i class="fas fa-images"></i> Product Images</div>

            @if (Model.ProductVM.ExistingImages != null && Model.ProductVM.ExistingImages.Any())
            {
                <div class="alert-info">
                    <i class="fas fa-info-circle"></i>
                    <span>Click <strong>"Set Primary"</strong> to choose the main image. Click <strong>"Delete"</strong> to remove an image.</span>
                </div>

                <div class="existing-images">
                    @foreach (var img in Model.ProductVM.ExistingImages.OrderBy(i => i.DisplayOrder))
                    {
                        <div class="existing-image-item @(img.IsPrimary ? "primary" : "")" data-id="@img.ImageID">
                            @if (img.IsPrimary)
                            {
                                <div class="primary-badge">Primary</div>
                            }
                            <img src="@img.ImageUrl" alt="Product image" onerror="this.onerror=null;this.src='/images/no-image.png';" />
                            <div class="image-actions">
                                @if (!img.IsPrimary)
                                {
                                    <button type="button" class="btn-primary-img" onclick="setPrimaryImage(@img.ImageID, @Model.ProductVM.ProductID)">
                                        <i class="fas fa-star"></i> Set Primary
                                    </button>
                                }
                                <button type="button" class="btn-delete-img" onclick="markImageForDelete(@img.ImageID, this)">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                            <input type="hidden" name="ImagesToDelete" value="@img.ImageID" class="delete-checkbox" disabled />
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: var(--text-secondary); margin-bottom:16px;">No images uploaded yet.</p>
            }

            <div class="image-upload-area" id="imageUploadArea">
                <i class="fas fa-cloud-upload-alt"></i>
                <p>Click or drag images here to add more</p>
                <span class="sub-text">Supports JPG, PNG, WEBP (max 5 new images)</span>
                <!--
                    FIX: this input's name must be prefixed with "ProductVM." to match
                    the bound property ProductVM.UploadedImages. It was previously just
                    name="UploadedImages", so the model binder never attached the
                    selected files to ProductVM, and OnPostAsync's
                    "if (ProductVM.UploadedImages != null && ...)" check was always
                    false — new images were silently dropped even though every other
                    field saved correctly.
                -->
                <input type="file" id="imageInput" name="ProductVM.UploadedImages" multiple accept="image/*" style="display: none;" />
            </div>

            <div class="image-preview" id="imagePreview"></div>
            <span class="help-text">Upload up to 5 new images (optional).</span>

            <!-- ===== ACTIONS ===== -->
            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a href="/StoreOwner/Products/Index" class="btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ========== TOAST CONTAINER ========== -->
<div id="productToastContainer" class="product-toast-container" aria-live="polite" aria-atomic="true"></div>

@section Scripts {
    <script>
        // ----- Toast -----
        function showProductToast(message, title) {
            title = title || 'Unable to continue';
            const container = document.getElementById('productToastContainer');
            if (!container || !message) return;

            const existing = container.querySelector('.product-toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.className = 'product-toast';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <span class="product-toast-icon">!</span>
                <span class="product-toast-content">
                    <span class="product-toast-title">${title}</span>
                    <span class="product-toast-message">${message}</span>
                </span>
                <button type="button" class="product-toast-close" aria-label="Close notification">&times;</button>
            `;
            const closeBtn = toast.querySelector('.product-toast-close');
            container.appendChild(toast);

            requestAnimationFrame(() => toast.classList.add('show'));

            let timer = setTimeout(removeToast, 5000);

            function removeToast() {
                clearTimeout(timer);
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }

            closeBtn.addEventListener('click', removeToast);
        }

        // ----- Image management -----
        let imagesToDelete = [];

        function markImageForDelete(imageId, button) {
            if (!confirm('Delete this image?')) return;
            const container = button.closest('.existing-image-item');
            if (!container) return;
            container.style.opacity = '0.5';
            container.style.pointerEvents = 'none';
            const hiddenInput = container.querySelector('.delete-checkbox');
            if (hiddenInput) hiddenInput.disabled = false;
            imagesToDelete.push(imageId);
        }

        async function setPrimaryImage(imageId, productId) {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const response = await fetch('/StoreOwner/Products/Edit?handler=SetPrimaryImage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ imageId, productId })
                });

                if (!response.ok) {
                    showProductToast('The server could not update the primary image.', 'Primary image update failed');
                    return;
                }

                const data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    showProductToast(data.message || 'The primary image could not be updated.', 'Primary image update failed');
                }
            } catch (error) {
                console.error('Set primary image failed:', error);
                showProductToast('An unexpected error occurred while updating the primary image.', 'Primary image update failed');
            }
        }

        // ----- Image upload (drag & drop) -----
        const uploadArea = document.getElementById('imageUploadArea');
        const imageInput = document.getElementById('imageInput');
        const preview = document.getElementById('imagePreview');

        if (uploadArea && imageInput) {
            uploadArea.addEventListener('click', () => imageInput.click());

            uploadArea.addEventListener('dragover', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--accent-color)';
                uploadArea.style.background = 'var(--accent-light)';
            });

            uploadArea.addEventListener('dragleave', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--border-color)';
                uploadArea.style.background = 'var(--bg-color)';
            });

            uploadArea.addEventListener('drop', e => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--border-color)';
                uploadArea.style.background = 'var(--bg-color)';
                const files = e.dataTransfer.files;
                imageInput.files = files;
                handleFiles(files);
            });

            imageInput.addEventListener('change', e => {
                handleFiles(e.target.files);
            });
        }

        function handleFiles(files) {
            if (!preview) return;
            preview.innerHTML = '';
            for (const file of files) {
                if (!file.type.startsWith('image/')) continue;
                const reader = new FileReader();
                reader.onload = function(ev) {
                    const div = document.createElement('div');
                    div.className = 'preview-item';
                    div.innerHTML = `
                        <img src="${ev.target.result}" alt="New product image preview" />
                        <button type="button" class="remove-preview" onclick="this.parentElement.remove()">×</button>
                    `;
                    preview.appendChild(div);
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
}
