@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.StoreOwnerPaymentModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Store Owner Payment · Secure Checkout</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet">

    <!-- Stripe.js — required for client-side card tokenization. Card data is
         sent directly from the browser to Stripe; it never reaches our server. -->
    <script src="https://js.stripe.com/v3/"></script>

    <style>
        /* ============================================================
        ROOT VARIABLES — consistent brand palette
        ============================================================ */
        :root {
        --accent-color: #6d28d9;
        --accent-hover: #5b21b6;
        --accent-light: #f3effe;
        --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
        --bg-color: #f8f7fc;
        --card-bg: #ffffff;
        --text-primary: #1e1b2e;
        --text-secondary: #6b6478;
        --text-muted: #9691a4;
        --border-color: #ece8f6;
        --success-color: #10b981;
        --error-color: #dc2626;
        --warning-color: #f59e0b;
        --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
        --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
        --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
        --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        *,
        *::before,
        *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        }

        body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        background: var(--bg-color);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        color: var(--text-primary);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        }

        body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse at 20% 50%, rgba(109, 40, 217, 0.08), transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(30, 27, 46, 0.04), transparent 50%), radial-gradient(ellipse at 60% 80%, rgba(109, 40, 217, 0.05), transparent 45%), var(--bg-color);
        }

        .payment-shell {
        width: 100%;
        max-width: 1120px;
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: 28px;
        align-items: stretch;
        }

        .payment-info {
        background: linear-gradient(145deg, #1a1625 0%, #2f2650 100%);
        color: #ffffff;
        border-radius: var(--radius-xl);
        padding: 36px 32px 30px;
        box-shadow: var(--shadow-lg);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        }

        .payment-info::before {
        content: '';
        position: absolute;
        width: 340px;
        height: 340px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.22), transparent 70%);
        right: -120px;
        top: -100px;
        pointer-events: none;
        }

        .payment-info::after {
        content: '';
        position: absolute;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.03);
        left: -70px;
        bottom: -60px;
        pointer-events: none;
        }

        .payment-info-content {
        position: relative;
        z-index: 2;
        flex: 1;
        display: flex;
        flex-direction: column;
        }

        .secure-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.10);
        padding: 7px 14px 7px 12px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.3px;
        color: #d8c8fb;
        text-transform: uppercase;
        width: fit-content;
        margin-bottom: 28px;
        }

        .secure-badge svg {
        width: 14px;
        height: 14px;
        fill: none;
        stroke: currentColor;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        }

        .payment-info h1 {
        margin: 0 0 6px;
        font-size: 32px;
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.02em;
        background: linear-gradient(to right, #ffffff, #d4dce8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        }

        .payment-info .subhead {
        font-size: 14px;
        font-weight: 500;
        color: #b0a8ce;
        margin-bottom: 28px;
        line-height: 1.6;
        max-width: 90%;
        }

        .mini-card {
        background: var(--accent-gradient);
        border-radius: var(--radius-lg);
        padding: 20px 22px 22px;
        box-shadow: 0 18px 35px rgba(109, 40, 217, 0.35);
        margin-top: auto;
        position: relative;
        overflow: hidden;
        }

        .mini-card::after {
        content: '';
        position: absolute;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.07);
        right: -50px;
        bottom: -50px;
        pointer-events: none;
        }

        .mini-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: rgba(255, 255, 255, 0.85);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        }

        .chip {
        width: 38px;
        height: 26px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.70);
        border: 1px solid rgba(255, 255, 255, 0.35);
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .card-number-preview {
        margin-top: 22px;
        color: #ffffff;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 2.5px;
        font-family: 'Inter', monospace;
        }

        .card-bottom {
        margin-top: 16px;
        display: flex;
        justify-content: space-between;
        color: rgba(255, 255, 255, 0.80);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        }

        .card-bottom span:last-child {
        font-family: 'Inter', monospace;
        letter-spacing: 1px;
        }

        .payment-card {
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        overflow: hidden;
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        transition: var(--transition);
        }

        .payment-card:hover {
        box-shadow: var(--shadow-lg);
        }

        .payment-card-header {
        padding: 28px 32px 14px;
        border-bottom: 1px solid var(--border-color);
        }

        .payment-card-header h2 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.02em;
        }

        .payment-card-header p {
        margin: 4px 0 0;
        color: var(--text-secondary);
        font-size: 14px;
        font-weight: 500;
        }

        .payment-body {
        padding: 22px 32px 30px;
        flex: 1;
        display: flex;
        flex-direction: column;
        }

        .summary {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 14px 18px;
        margin-bottom: 18px;
        }

        .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 7px 0;
        border-bottom: 1px solid var(--border-color);
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        }

        .summary-row:last-child {
        border-bottom: none;
        }

        .summary-row span:last-child {
        color: var(--text-primary);
        text-align: right;
        font-weight: 700;
        }

        .summary-total {
        font-size: 20px !important;
        font-weight: 900 !important;
        color: var(--text-primary) !important;
        padding-top: 4px;
        }

        .summary-total span:last-child {
        font-size: 22px;
        color: var(--accent-color) !important;
        }

        .summary .balance-row {
        border-bottom: none;
        padding-top: 8px;
        margin-top: 2px;
        border-top: 2px dashed #dcd3f5;
        }

        .summary .balance-row span:last-child {
        font-weight: 800;
        color: var(--success-color);
        }

        .summary .balance-row .insufficient {
        color: var(--error-color) !important;
        }

        .hint {
        background: var(--accent-light);
        border: 1px solid #e0d4fb;
        color: var(--accent-hover);
        padding: 12px 16px;
        border-radius: var(--radius-md);
        font-size: 12px;
        font-weight: 600;
        line-height: 1.6;
        margin-bottom: 18px;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        }

        .hint svg {
        flex: 0 0 18px;
        width: 18px;
        height: 18px;
        margin-top: 1px;
        fill: none;
        stroke: var(--accent-color);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        }

        .message {
        padding: 12px 16px;
        border-radius: var(--radius-md);
        margin-bottom: 16px;
        font-weight: 600;
        text-align: center;
        font-size: 13px;
        line-height: 1.5;
        }

        .message.error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
        }

        .message.success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
        }

        .field {
        margin-bottom: 16px;
        }

        .field label {
        display: block;
        margin-bottom: 5px;
        font-size: 12px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.3px;
        text-transform: uppercase;
        }

        .field input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-md);
        font-size: 15px;
        font-weight: 500;
        color: var(--text-primary);
        background: var(--card-bg);
        outline: none;
        transition: var(--transition);
        font-family: 'Inter', monospace;
        }

        .field input::placeholder {
        color: var(--text-muted);
        font-weight: 400;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        }

        .field input:focus {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.12);
        }

        .field input.input-error {
        border-color: var(--error-color);
        box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.08);
        }

        /* Stripe Card Element container — styled to match our other inputs */
        #card-element {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--card-bg);
        transition: var(--transition);
        }

        #card-element.StripeElement--focus {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.12);
        }

        #card-element.StripeElement--invalid {
        border-color: var(--error-color);
        box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.08);
        }

        #card-errors {
        margin-top: 8px;
        font-size: 12px;
        font-weight: 600;
        color: var(--error-color);
        min-height: 16px;
        }

        .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        }

        .actions {
        display: flex;
        gap: 14px;
        margin-top: 20px;
        }

        .btn {
        flex: 1;
        border: none;
        border-radius: var(--radius-md);
        padding: 14px 18px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Inter', sans-serif;
        }

        .btn:active {
        transform: scale(0.97);
        }

        .pay-btn {
        background: var(--accent-gradient);
        color: #ffffff;
        box-shadow: 0 12px 28px rgba(109, 40, 217, 0.30);
        border: 1px solid rgba(255, 255, 255, 0.10);
        }

        .pay-btn:hover:not(:disabled) {
        box-shadow: 0 16px 35px rgba(109, 40, 217, 0.38);
        transform: translateY(-2px);
        }

        .pay-btn:disabled {
        cursor: wait;
        opacity: 0.65;
        transform: none;
        box-shadow: 0 8px 20px rgba(109, 40, 217, 0.18);
        }

        .back-btn {
        background: var(--bg-color);
        color: var(--text-primary);
        border: 1.5px solid var(--border-color);
        }

        .back-btn:hover {
        background: var(--accent-light);
        border-color: var(--accent-color);
        transform: translateY(-2px);
        }

        .locked {
        font-size: 11px;
        color: var(--text-muted);
        text-align: center;
        margin-top: 16px;
        font-weight: 600;
        letter-spacing: 0.2px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        }

        .locked svg {
        width: 14px;
        height: 14px;
        stroke: var(--text-muted);
        stroke-width: 2;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        }

        .payment-toast-container {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 1000001;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 420px;
        width: 100%;
        }

        .payment-toast {
        width: 100%;
        padding: 16px 18px;
        border-radius: var(--radius-md);
        color: #ffffff;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        background: linear-gradient(135deg, #b91c1c, #991b1b);
        box-shadow: var(--shadow-lg);
        opacity: 0;
        transform: translateX(30px) scale(0.96);
        transition: opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1), transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        pointer-events: auto;
        border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .payment-toast.show {
        opacity: 1;
        transform: translateX(0) scale(1);
        }

        .payment-toast-icon {
        width: 32px;
        height: 32px;
        flex: 0 0 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 800;
        }

        .payment-toast-content {
        flex: 1;
        min-width: 0;
        }

        .payment-toast-title {
        display: block;
        font-weight: 800;
        font-size: 13px;
        letter-spacing: 0.2px;
        margin-bottom: 2px;
        }

        .payment-toast-message {
        display: block;
        font-size: 12px;
        font-weight: 500;
        line-height: 1.5;
        opacity: 0.90;
        }

        .payment-toast-close {
        border: none;
        background: transparent;
        color: rgba(255, 255, 255, 0.60);
        font-size: 22px;
        line-height: 1;
        padding: 0 0 0 6px;
        cursor: pointer;
        transition: color 0.2s;
        }

        .payment-toast-close:hover {
        color: #ffffff;
        }

        .payment-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        padding: 20px;
        background: rgba(30, 27, 46, 0.60);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
        z-index: 1000000;
        }

        .payment-modal-overlay.show {
        display: flex;
        }

        .payment-modal-card {
        width: min(440px, 100%);
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        animation: modalIn 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        border: 1px solid var(--border-color);
        }

        @@keyframes modalIn {
        from {
        opacity: 0;
        transform: translateY(20px) scale(0.96);
        }

        to {
        opacity: 1;
        transform: translateY(0) scale(1);
        }
        }

        .payment-modal-header {
        padding: 28px 28px 12px;
        text-align: center;
        }

        .payment-modal-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 14px;
        border-radius: 50%;
        background: var(--accent-light);
        color: var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        }

        .payment-modal-title {
        margin: 0;
        color: var(--text-primary);
        font-size: 20px;
        font-weight: 800;
        }

        .payment-modal-body {
        padding: 4px 28px 18px;
        text-align: center;
        }

        .payment-modal-message {
        margin: 0;
        color: var(--text-secondary);
        font-size: 14px;
        line-height: 1.7;
        font-weight: 500;
        }

        .payment-modal-total {
        display: block;
        margin-top: 10px;
        color: var(--text-primary);
        font-size: 22px;
        font-weight: 900;
        }

        .payment-modal-note {
        display: block;
        margin-top: 6px;
        color: var(--accent-hover);
        font-size: 12px;
        font-weight: 600;
        }

        .payment-modal-actions {
        display: flex;
        gap: 12px;
        padding: 14px 28px 28px;
        }

        .payment-modal-button {
        flex: 1;
        border: none;
        border-radius: var(--radius-md);
        padding: 14px 18px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        transition: var(--transition);
        }

        .payment-modal-button:active {
        transform: scale(0.97);
        }

        .payment-modal-cancel {
        background: var(--bg-color);
        color: var(--text-primary);
        border: 1.5px solid var(--border-color);
        }

        .payment-modal-cancel:hover {
        background: var(--accent-light);
        border-color: var(--accent-color);
        }

        .payment-modal-confirm {
        background: var(--accent-gradient);
        color: #ffffff;
        box-shadow: 0 12px 28px rgba(109, 40, 217, 0.25);
        }

        .payment-modal-confirm:hover:not(:disabled) {
        box-shadow: 0 16px 35px rgba(109, 40, 217, 0.32);
        transform: translateY(-2px);
        }

        .payment-modal-confirm:disabled {
        cursor: wait;
        opacity: 0.65;
        transform: none;
        }

        @@media (max-width: 920px) {
        .payment-shell {
        grid-template-columns: 1fr;
        max-width: 560px;
        }

        .payment-info {
        display: none;
        }

        .payment-card-header {
        padding: 24px 24px 14px;
        }

        .payment-body {
        padding: 18px 24px 24px;
        }

        .payment-card-header h2 {
        font-size: 22px;
        }
        }

        @@media (max-width: 500px) {
        body {
        padding: 12px;
        }

        .payment-card-header {
        padding: 20px 18px 12px;
        }

        .payment-body {
        padding: 14px 18px 20px;
        }

        .row {
        grid-template-columns: 1fr;
        gap: 0;
        }

        .actions {
        flex-direction: column;
        gap: 10px;
        }

        .payment-modal-actions {
        flex-direction: column;
        gap: 10px;
        }

        .payment-toast-container {
        top: 12px;
        right: 12px;
        left: 12px;
        max-width: none;
        }

        .payment-toast {
        border-radius: var(--radius-md);
        padding: 14px 16px;
        }

        .summary-total {
        font-size: 18px !important;
        }

        .payment-card {
        border-radius: var(--radius-lg);
        }
        }
    </style>
</head>
<body>

    <!-- ===== TOAST CONTAINER ===== -->
    <div id="paymentToastContainer" class="payment-toast-container" aria-live="assertive" aria-atomic="true"></div>

    <!-- ===== PAGE ===== -->
    <div class="payment-page">

        <div class="payment-shell">

            <!-- ===== LEFT PANEL: BRANDING & INFO ===== -->
            <div class="payment-info" aria-label="Payment information">
                <div class="payment-info-content">
                    <div class="secure-badge">
                        <svg viewBox="0 0 24 24"><path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" /><path d="M12 12m-3 0a3 3 0 1 0 6 0 3 3 0 1 0-6 0" /><path d="M12 12v5" /></svg>
                        Stripe Balance Check
                    </div>
                    <h1>Secure store<br />fee payment</h1>
                    <p class="subhead">Verify your card with Stripe and pay outstanding fees using your Stripe balance. Your card number never touches our servers — Stripe handles it directly.</p>

                    <!-- mini card preview (display-only, no real card data) -->
                    <div class="mini-card">
                        <div class="mini-card-top">
                            <span id="cardBrandPreview">STORE CARD</span>
                            <span class="chip"></span>
                        </div>
                        <div class="card-number-preview" id="cardNumberPreview">•••• •••• •••• ••••</div>
                        <div class="card-bottom">
                            <span id="cardholderPreview">CARDHOLDER</span>
                            <span id="expiryPreview">MM/YY</span>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ===== RIGHT PANEL: PAYMENT FORM ===== -->
            <div class="payment-card">

                <div class="payment-card-header">
                    <h2>Complete payment</h2>
                    <p>Verify your card with Stripe &amp; check your Stripe balance</p>
                </div>

                <div class="payment-body">

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="message error" id="serverPaymentError" data-message="@Model.ErrorMessage">
                            @Model.ErrorMessage
                        </div>
                    }

                    @if (Model.Payment == null)
                    {
                        <div class="message error">Payment request not found.</div>
                        <div class="actions">
                            <a href="/StoreOwner/Dashboard" class="btn back-btn">← Back to Dashboard</a>
                        </div>
                    }
                    else
                    {
                        <!-- SUMMARY -->
                        <div class="summary">
                            <div class="summary-row">
                                <span>Reference</span>
                                <span>#@Model.Payment.StorePaymentId</span>
                            </div>
                            <div class="summary-row">
                                <span>Description</span>
                                <span>@Model.Payment.Description</span>
                            </div>
                            <div class="summary-row">
                                <span>Due date</span>
                                <span>@Model.Payment.DueDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="summary-row summary-total">
                                <span>Amount</span>
                                <span>$@Model.Payment.Amount.ToString("N2")</span>
                            </div>
                            @if (Model.CurrentBalance >= 0)
                            {
                                var sufficient = Model.CurrentBalance >= Model.Payment.Amount;
                                <div class="summary-row balance-row">
                                    <span>Your Stripe balance</span>
                                    <span class="@(sufficient ? "" : "insufficient")">$@Model.CurrentBalance.ToString("N2")</span>
                                </div>
                            }
                            else
                            {
                                <div class="summary-row balance-row">
                                    <span>Balance check</span>
                                    <span style="color:var(--error-color);">Unavailable</span>
                                </div>
                            }
                        </div>

                        <!-- HINT -->
                        <div class="hint">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="12" x2="12" y2="16" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                            <span>Stripe verifies your card directly with your bank, then we check your Stripe balance. No charge is made, and your card number is never sent to or stored by us.</span>
                        </div>

                        @if (string.IsNullOrWhiteSpace(Model.StripePublishableKey) || string.IsNullOrWhiteSpace(Model.ClientSecret))
                        {
                            <div class="message error">Card verification is temporarily unavailable. Please try again shortly.</div>
                        }
                        else
                        {
                            <!-- FORM -->
                            <form method="post" id="paymentForm" novalidate>
                                <input type="hidden" asp-for="PaymentId" />
                                <!-- Populated only after Stripe confirms the card with the issuer -->
                                <input type="hidden" asp-for="SetupIntentId" id="SetupIntentId" />

                                <div class="field">
                                    <label for="CardholderName">Cardholder name</label>
                                    <input asp-for="CardholderName" id="CardholderName" maxlength="100" placeholder="John Doe" autocomplete="cc-name" />
                                </div>

                                <div class="field">
                                    <label for="card-element">Card details</label>
                                    <!-- Stripe Elements mounts a secure iframe here. We never see or handle the raw card number. -->
                                    <div id="card-element"></div>
                                    <div id="card-errors" role="alert"></div>
                                </div>

                                <div class="actions">
                                    <a href="/StoreOwner/Dashboard" class="btn back-btn">Cancel</a>
                                    <button type="button" id="payNowButton" class="btn pay-btn">
                                        <span>Pay now</span>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
                                    </button>
                                </div>

                                <div class="locked">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                                    Card verified directly by Stripe. Your card number is never stored on our servers.
                                </div>
                            </form>
                        }
                    }

                </div>
            </div>
        </div>
    </div>

    <!-- ===== CONFIRMATION MODAL ===== -->
    @if (Model.Payment != null)
    {
        <div id="paymentConfirmationModal" class="payment-modal-overlay" role="dialog" aria-modal="true">
            <div class="payment-modal-card">
                <div class="payment-modal-header">
                    <div class="payment-modal-icon">🔒</div>
                    <h3 id="paymentModalTitle" class="payment-modal-title">Confirm payment</h3>
                </div>
                <div class="payment-modal-body">
                    <p class="payment-modal-message">
                        Confirm payment of
                        <span class="payment-modal-total">$@Model.Payment.Amount.ToString("N2")</span>
                        from your Stripe balance.
                        <span class="payment-modal-note">Stripe will verify your card with your bank, then we'll check your Stripe balance. No charge is made.</span>
                    </p>
                </div>
                <div class="payment-modal-actions">
                    <button type="button" class="payment-modal-button payment-modal-cancel" onclick="closePaymentModal()">Cancel</button>
                    <button type="button" id="confirmPaymentButton" class="payment-modal-button payment-modal-confirm" onclick="submitPayment()">Confirm payment</button>
                </div>
            </div>
        </div>
    }

    <!-- ============================================================
    JAVASCRIPT
    ============================================================ -->
    @if (Model.Payment != null && !string.IsNullOrWhiteSpace(Model.StripePublishableKey) && !string.IsNullOrWhiteSpace(Model.ClientSecret))
    {
        <script>
            (function() {
            'use strict';

            // ---- Stripe setup ----
            // The publishable key is safe to expose in the browser.
            // The client secret authorizes THIS SetupIntent only and is single-use.
            const stripe = Stripe('@Model.StripePublishableKey');
            const elements = stripe.elements();
            const clientSecret = '@Model.ClientSecret';

            const cardElementStyle = {
            base: {
            color: '#1e1b2e',
            fontFamily: '"Inter", monospace',
            fontSize: '15px',
            fontWeight: '500',
            '::placeholder': { color: '#9691a4' }
            },
            invalid: {
            color: '#dc2626'
            }
            };

            const cardElement = elements.create('card', { style: cardElementStyle, hidePostalCode: true });
            cardElement.mount('#card-element');

            const cardErrorsEl = document.getElementById('card-errors');
            cardElement.on('change', function(event) {
            cardErrorsEl.textContent = event.error ? event.error.message : '';

            // live brand preview (display only — no real data)
            var brandPreview = document.getElementById('cardBrandPreview');
            if (brandPreview) {
            if (event.brand && event.brand !== 'unknown') {
            brandPreview.textContent = event.brand.toUpperCase();
            } else {
            brandPreview.textContent = 'STORE CARD';
            }
            }
            var numberPreview = document.getElementById('cardNumberPreview');
            if (numberPreview) {
            numberPreview.textContent = event.complete ? '•••• •••• •••• ••••' : '•••• •••• •••• ••••';
            }
            });

            // DOM refs
            const paymentForm = document.getElementById('paymentForm');
            const payNowButton = document.getElementById('payNowButton');
            const cardholderInput = document.getElementById('CardholderName');
            const setupIntentInput = document.getElementById('SetupIntentId');
            const paymentModal = document.getElementById('paymentConfirmationModal');
            let paymentSubmitting = false;

            // ---- toast ----
            function showPaymentToast(message, title) {
            title = title || 'Unable to continue';
            const container = document.getElementById('paymentToastContainer');
            if (!container || !message) return;

            const old = container.querySelector('.payment-toast');
            if (old) old.remove();

            const toast = document.createElement('div');
            toast.className = 'payment-toast';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
            <span class="payment-toast-icon">!</span>
            <span class="payment-toast-content">
            <span class="payment-toast-title">${title}</span>
            <span class="payment-toast-message">${message}</span>
            </span>
            <button type="button" class="payment-toast-close" aria-label="Close notification">&times;</button>
            `;
            const closeBtn = toast.querySelector('.payment-toast-close');
            container.appendChild(toast);

            requestAnimationFrame(function() {
            toast.classList.add('show');
            });

            let timer = setTimeout(removeToast, 5500);

            function removeToast() {
            clearTimeout(timer);
            toast.classList.remove('show');
            setTimeout(function() { toast.remove(); }, 300);
            }

            closeBtn.addEventListener('click', removeToast);
            }

            function setInputError(inp) {
            if (inp) {
            inp.classList.add('input-error');
            inp.focus();
            }
            }

            // ---- client-side check before opening the modal ----
            // Only the cardholder name is validated here; the card itself
            // is validated by Stripe when confirmCardSetup is called.
            function validatePaymentForm() {
            if (cardholderInput) cardholderInput.classList.remove('input-error');

            var cardholder = (cardholderInput ? cardholderInput.value.trim() : '');
            if (cardholder.length < 3) {
            setInputError(cardholderInput);
            showPaymentToast('Enter a valid cardholder name.', 'Cardholder name required');
            return false;
            }
            return true;
            }

            // ---- modal ----
            function openPaymentModal() {
            if (!validatePaymentForm()) return;
            if (paymentModal) {
            paymentModal.classList.add('show');
            document.body.style.overflow = 'hidden';
            }
            }

            window.closePaymentModal = function() {
            if (paymentSubmitting) return;
            if (paymentModal) {
            paymentModal.classList.remove('show');
            document.body.style.overflow = '';
            }
            };

            // ---- confirm & verify card with Stripe, then submit ----
            window.submitPayment = function() {
            if (!paymentForm || paymentSubmitting) return;
            paymentSubmitting = true;

            var confirmBtn = document.getElementById('confirmPaymentButton');
            if (confirmBtn) {
            confirmBtn.disabled = true;
            confirmBtn.textContent = 'Verifying card…';
            }
            if (payNowButton) {
            payNowButton.disabled = true;
            payNowButton.innerHTML = 'Verifying card…';
            }

            stripe.confirmCardSetup(clientSecret, {
            payment_method: {
            card: cardElement,
            billing_details: {
            name: cardholderInput ? cardholderInput.value.trim() : ''
            }
            }
            }).then(function(result) {
            if (result.error) {
            // Card was invalid, declined, or verification failed.
            paymentSubmitting = false;
            if (confirmBtn) {
            confirmBtn.disabled = false;
            confirmBtn.textContent = 'Confirm payment';
            }
            if (payNowButton) {
            payNowButton.disabled = false;
            payNowButton.innerHTML = '<span>Pay now</span>';
            }
            showPaymentToast(result.error.message || 'Your card could not be verified.', 'Card verification failed');
            return;
            }

            // Success — Stripe has verified the card with the issuer.
            // Only the SetupIntent ID (a token) is sent to our server.
            setupIntentInput.value = result.setupIntent.id;
            if (confirmBtn) confirmBtn.textContent = 'Processing…';
            if (payNowButton) payNowButton.innerHTML = 'Processing…';
            paymentForm.submit();
            }).catch(function() {
            paymentSubmitting = false;
            if (confirmBtn) {
            confirmBtn.disabled = false;
            confirmBtn.textContent = 'Confirm payment';
            }
            showPaymentToast('Something went wrong verifying your card. Please try again.', 'Verification error');
            });
            };

            // ---- event binding ----
            if (payNowButton) {
            payNowButton.addEventListener('click', openPaymentModal);
            }

            if (paymentForm) {
            paymentForm.addEventListener('submit', function(e) {
            if (!paymentSubmitting) {
            e.preventDefault();
            openPaymentModal();
            }
            });
            }

            if (paymentModal) {
            paymentModal.addEventListener('click', function(e) {
            if (e.target === paymentModal) closePaymentModal();
            });
            }

            document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePaymentModal();
            });

            if (cardholderInput) {
            cardholderInput.addEventListener('input', function() {
            var preview = document.getElementById('cardholderPreview');
            if (preview) preview.textContent = this.value.trim().toUpperCase() || 'CARDHOLDER';
            this.classList.remove('input-error');
            });
            }

            // ---- init ----
            document.addEventListener('DOMContentLoaded', function() {
            var serverError = document.getElementById('serverPaymentError');
            if (serverError) {
            var msg = serverError.dataset.message || serverError.textContent.trim();
            if (msg) showPaymentToast(msg, 'Payment was not completed');
            }
            if (cardholderInput) cardholderInput.dispatchEvent(new Event('input'));
            });

            })();
        </script>
    }
    else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <script>
            (function() {
            document.addEventListener('DOMContentLoaded', function() {
            var container = document.getElementById('paymentToastContainer');
            if (!container) return;
            var toast = document.createElement('div');
            toast.className = 'payment-toast';
            toast.innerHTML = '<span class="payment-toast-icon">!</span><span class="payment-toast-content"><span class="payment-toast-title">Payment was not completed</span><span class="payment-toast-message">@Html.Raw(System.Text.Json.JsonEncodedText.Encode(Model.ErrorMessage ?? string.Empty))</span></span>';
            container.appendChild(toast);
            requestAnimationFrame(function() { toast.classList.add('show'); });
            });
            })();
        </script>
    }

</body>
</html>
