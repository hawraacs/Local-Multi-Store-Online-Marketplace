@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.AnalyticsModel
@{
    ViewData["Title"] = "Store Analytics";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";

}

<style>
    :root {
        /* -------- Brand colors (Purple / Indigo) -------- */
        --accent-color: #6d28d9;
        --accent-hover: #5b21b6;
        --accent-light: #f3effe;
        --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
        /* -------- Neutral palette -------- */
        --bg-color: #f8f7fc;
        --card-bg: #ffffff;
        --text-primary: #1e1b2e;
        --text-secondary: #6b6478;
        --text-muted: #9691a4;
        --border-color: #ece8f6;
        /* -------- Semantic -------- */
        --success-color: #10b981;
        --error-color: #dc2626;
        --warning-color: #f59e0b;
        /* -------- Shadows -------- */
        --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
        --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
        --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
    }

    .analytics-page {
        background: var(--bg-color);
        min-height: calc(100vh - 120px);
        padding: 35px 0 60px;
    }

    .analytics-wrapper {
        max-width: 1180px;
        margin: auto;
    }

    .analytics-hero {
        background: var(--accent-gradient);
        border-radius: 24px;
        color: white;
        padding: 30px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-lg);
        position: relative;
        overflow: hidden;
    }

        .analytics-hero::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
            right: -70px;
            top: -80px;
        }

        .analytics-hero h2 {
            margin: 0 0 8px;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.4px;
            position: relative;
            z-index: 1;
        }

        .analytics-hero p {
            margin: 0;
            opacity: 0.92;
            font-size: 14px;
            position: relative;
            z-index: 1;
        }

    .period-text {
        margin-top: 14px;
        display: inline-block;
        background: rgba(255,255,255,0.18);
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 12px;
        position: relative;
        z-index: 1;
    }

    .accounting-note {
        margin-top: 14px;
        background: rgba(255,255,255,0.14);
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 12px;
        font-weight: 500;
        max-width: 760px;
        position: relative;
        z-index: 1;
    }

    .filter-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr auto;
        gap: 14px;
        align-items: end;
    }

    .filter-group label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 7px;
    }

    .filter-group select,
    .filter-group input {
        width: 100%;
        border: 1.5px solid var(--border-color);
        border-radius: 12px;
        padding: 11px 15px;
        font-weight: 500;
        color: var(--text-primary);
        background: var(--bg-color);
        outline: none;
        transition: all 0.2s ease;
    }

        .filter-group select:focus,
        .filter-group input:focus {
            border-color: var(--accent-color);
            background: var(--card-bg);
            box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
        }

    .filter-btn {
        border: none;
        border-radius: 12px;
        background: var(--accent-gradient);
        color: white;
        padding: 12px 22px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
        transition: all 0.25s ease;
    }

        .filter-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(109, 40, 217, 0.32);
        }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .metric-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 22px;
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
        transition: all 0.25s ease;
    }

        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .metric-card::after {
            content: "";
            position: absolute;
            width: 72px;
            height: 72px;
            background: var(--accent-light);
            border-radius: 18px;
            right: -20px;
            top: -20px;
        }

    .metric-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: var(--accent-light);
        color: var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 14px;
        position: relative;
        z-index: 1;
    }

    .metric-label {
        color: var(--text-secondary);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 9px;
        position: relative;
        z-index: 1;
    }

    .metric-value {
        color: var(--text-primary);
        font-size: 27px;
        font-weight: 800;
        letter-spacing: -0.4px;
        position: relative;
        z-index: 1;
    }

    .metric-note {
        color: var(--text-muted);
        font-size: 12px;
        margin-top: 7px;
        font-weight: 500;
        position: relative;
        z-index: 1;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 22px;
        margin-bottom: 22px;
    }

    .data-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 22px;
        padding: 24px;
        box-shadow: var(--shadow-sm);
    }

        .data-card h3 {
            margin: 0 0 18px;
            color: var(--text-primary);
            font-size: 18px;
            font-weight: 800;
        }

    .bar-item {
        margin-bottom: 14px;
    }

    .bar-info {
        display: flex;
        justify-content: space-between;
        color: var(--text-primary);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 7px;
    }

    .bar-track {
        height: 11px;
        background: var(--bg-color);
        border-radius: 999px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: var(--accent-gradient);
        border-radius: 999px;
    }

    .status-grid {
        display: grid;
        gap: 12px;
    }

    .status-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 13px 16px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .status-count {
        background: var(--accent-light);
        color: var(--accent-color);
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
    }

    .table-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 22px;
        padding: 24px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 22px;
    }

        .table-card h3 {
            margin: 0 0 18px;
            color: var(--text-primary);
            font-size: 18px;
            font-weight: 800;
        }

    .analytics-table {
        width: 100%;
        border-collapse: collapse;
    }

        .analytics-table th {
            text-align: left;
            color: var(--accent-color);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            padding: 11px 8px;
            border-bottom: 1px solid var(--border-color);
            font-weight: 700;
            background: var(--accent-light);
        }

            .analytics-table th:first-child {
                border-top-left-radius: 10px;
                padding-left: 14px;
            }

            .analytics-table th:last-child {
                border-top-right-radius: 10px;
                padding-right: 14px;
            }

        .analytics-table td {
            color: var(--text-primary);
            font-size: 13px;
            padding: 13px 8px;
            border-bottom: 1px solid var(--border-color);
            font-weight: 600;
        }

            .analytics-table td:first-child {
                padding-left: 14px;
            }

            .analytics-table td:last-child {
                padding-right: 14px;
            }

    .status-badge {
        display: inline-block;
        background: var(--accent-light);
        color: var(--accent-color);
        border: 1px solid #e0d4fb;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
    }

    .payment-badge {
        display: inline-block;
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
    }

    .empty-box {
        background: var(--bg-color);
        border: 1px dashed var(--border-color);
        color: var(--text-muted);
        border-radius: 16px;
        padding: 28px;
        text-align: center;
        font-weight: 600;
    }

    @@media (max-width: 1000px) {
        .metric-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .main-grid {
            grid-template-columns: 1fr;
        }

        .filter-form {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 600px) {
        .analytics-page {
            padding: 20px 12px;
        }

        .metric-grid {
            grid-template-columns: 1fr;
        }

        .filter-form {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="analytics-page">
    <div class="analytics-wrapper">

        <div class="analytics-hero">
            <h2>Store Analytics</h2>
            <p>Track revenue, orders, customers, and product performance for @Model.StoreName.</p>

            <span class="period-text">
                Period: @Model.ReportStartDate.ToString("MMM dd, yyyy") - @Model.ReportEndDate.ToString("MMM dd, yyyy")
            </span>

            <div class="accounting-note">
                Accounting rule: revenue and net earnings are calculated from delivered orders only. Active orders are shown separately for operational tracking.
            </div>
        </div>

        <div class="filter-card">
            <form method="get" class="filter-form">
                <div class="filter-group">
                    <label>Report Range</label>
                    <select asp-for="Range" id="rangeSelect">
                        <option value="7">Last 7 Days</option>
                        <option value="30">Last 30 Days</option>
                        <option value="90">Last 90 Days</option>
                        <option value="custom">Custom Range</option>
                    </select>
                </div>

                <div class="filter-group custom-date-group">
                    <label>From Date</label>
                    <input asp-for="FromDate" type="date" />
                </div>

                <div class="filter-group custom-date-group">
                    <label>To Date</label>
                    <input asp-for="ToDate" type="date" />
                </div>

                <button type="submit" class="filter-btn">
                    Apply
                </button>
            </form>
        </div>

        <div class="metric-grid">
            <div class="metric-card">
                <div class="metric-icon">💰</div>
                <div class="metric-label">Recognized Revenue</div>
                <div class="metric-value">$@Model.TotalRevenue.ToString("N2")</div>
                <div class="metric-note">Delivered orders only</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">⏳</div>
                <div class="metric-label">Pending Revenue</div>
                <div class="metric-value">$@Model.PendingRevenue.ToString("N2")</div>
                <div class="metric-note">Pending, preparing, and delivery orders</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">🧾</div>
                <div class="metric-label">Total Orders</div>
                <div class="metric-value">@Model.TotalOrders</div>
                <div class="metric-note">All orders in selected period</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">✅</div>
                <div class="metric-label">Delivered Orders</div>
                <div class="metric-value">@Model.DeliveredOrdersCount</div>
                <div class="metric-note">Orders counted as completed sales</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">📦</div>
                <div class="metric-label">Items Sold</div>
                <div class="metric-value">@Model.TotalItemsSold</div>
                <div class="metric-note">Delivered items only</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">👥</div>
                <div class="metric-label">Unique Customers</div>
                <div class="metric-value">@Model.UniqueCustomers</div>
                <div class="metric-note">Customers who ordered from you</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">📊</div>
                <div class="metric-label">Average Order Value</div>
                <div class="metric-value">$@Model.AverageOrderValue.ToString("N2")</div>
                <div class="metric-note">Recognized revenue / delivered orders</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">🏦</div>
                <div class="metric-label">Estimated Commission</div>
                <div class="metric-value">$@Model.EstimatedCommission.ToString("N2")</div>
                <div class="metric-note">Based on store commission rate</div>
            </div>

            <div class="metric-card">
                <div class="metric-icon">💵</div>
                <div class="metric-label">Net Earnings</div>
                <div class="metric-value">$@Model.EstimatedNetEarnings.ToString("N2")</div>
                <div class="metric-note">Revenue after estimated commission</div>
            </div>
        </div>

        <div class="main-grid">
            <div class="data-card">
                <h3>Daily Recognized Revenue</h3>

                @if (Model.DailyRevenue.Any())
                {
                    var maxRevenue = Model.DailyRevenue.Max(x => x.Revenue);

                    foreach (var day in Model.DailyRevenue)
                    {
                        var width = maxRevenue > 0
                        ? (int)((day.Revenue / maxRevenue) * 100)
                        : 0;

                        <div class="bar-item">
                            <div class="bar-info">
                                <span>@day.Date.ToString("MMM dd")</span>
                                <span>$@day.Revenue.ToString("N2") · @day.Orders delivered orders · @day.ItemsSold items</span>
                            </div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:@width%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-box">
                        No delivered sales data for this selected period.
                    </div>
                }
            </div>

            <div class="data-card">
                <h3>Order Status Overview</h3>

                <div class="status-grid">
                    <div class="status-row">
                        <span>Pending</span>
                        <span class="status-count">@Model.PendingOrders</span>
                    </div>

                    <div class="status-row">
                        <span>Preparing</span>
                        <span class="status-count">@Model.PreparingOrders</span>
                    </div>

                    <div class="status-row">
                        <span>Out for Delivery</span>
                        <span class="status-count">@Model.OutForDeliveryOrders</span>
                    </div>

                    <div class="status-row">
                        <span>Delivered</span>
                        <span class="status-count">@Model.DeliveredOrders</span>
                    </div>

                    <div class="status-row">
                        <span>Cancelled</span>
                        <span class="status-count">@Model.CancelledOrders</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-card">
            <h3>Best-Selling Products</h3>

            @if (Model.BestSellingProducts.Any())
            {
                <table class="analytics-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity Sold</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var product in Model.BestSellingProducts)
                        {
                            <tr>
                                <td>@product.ProductName</td>
                                <td>@product.QuantitySold</td>
                                <td>$@product.Revenue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-box">
                    No delivered product sales yet.
                </div>
            }
        </div>

        <div class="table-card">
            <h3>Recent Orders</h3>

            @if (Model.RecentOrders.Any())
            {
                <table class="analytics-table">
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Store Amount</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td>@order.OrderNumber</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="status-badge">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <span class="payment-badge">
                                        @order.PaymentStatus
                                    </span>
                                </td>
                                <td>$@order.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-box">
                    No recent orders for this selected period.
                </div>
            }
        </div>

    </div>
</div>

<script>
    const rangeSelect = document.getElementById("rangeSelect");
    const customDateGroups = document.querySelectorAll(".custom-date-group");

    function toggleCustomDates() {
        if (!rangeSelect) {
            return;
        }

        const isCustom = rangeSelect.value === "custom";

        customDateGroups.forEach(group => {
            group.style.display = isCustom ? "block" : "none";
        });
    }

    if (rangeSelect) {
        rangeSelect.addEventListener("change", toggleCustomDates);
        toggleCustomDates();
    }
</script>
