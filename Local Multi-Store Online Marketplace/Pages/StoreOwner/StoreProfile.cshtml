@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.StoreProfileModel
@{
    ViewData["Title"] = "Store Profile";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --input-bg: #f8f7fc;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
        }

        .profile-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 22px;
            padding: 36px 40px;
            box-shadow: var(--shadow-md);
            max-width: 950px;
            margin: 0 auto;
        }

            .profile-container h2 {
                font-size: 24px;
                font-weight: 800;
                color: var(--text-primary);
                letter-spacing: -0.4px;
            }

        .page-subtitle {
            color: var(--text-secondary);
            margin-bottom: 26px;
            font-size: 14px;
            line-height: 1.6;
        }

        .message {
            padding: 14px 18px;
            border-radius: 14px;
            margin-bottom: 20px;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .success-message {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .error-message {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .form-section-title {
            font-size: 12px;
            font-weight: 800;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin: 30px 0 14px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

            .form-section-title:first-of-type {
                margin-top: 8px;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: 600;
                font-size: 13px;
                color: var(--text-primary);
                letter-spacing: 0.2px;
            }

            .form-group input:not([type="checkbox"]),
            .form-group textarea {
                width: 100%;
                padding: 12px 15px;
                border: 1.5px solid var(--border-color);
                border-radius: 12px;
                font-size: 14px;
                font-family: inherit;
                background: var(--input-bg);
                color: var(--text-primary);
                transition: all 0.2s ease;
            }

                .form-group input:not([type="checkbox"])::placeholder,
                .form-group textarea::placeholder {
                    color: var(--text-muted);
                }

                .form-group input:not([type="checkbox"]):focus,
                .form-group textarea:focus {
                    outline: none;
                    border-color: var(--accent-color);
                    background: var(--card-bg);
                    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
                }

            .form-group input[type="file"] {
                width: 100%;
                padding: 10px 0;
                font-size: 13px;
                color: var(--text-secondary);
            }

        .text-danger {
            color: var(--error-color);
            font-size: 12px;
            margin-top: 5px;
            display: block;
            font-weight: 500;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 999px;
            background: var(--accent-light);
            color: var(--accent-color);
            font-weight: 700;
            font-size: 13px;
            margin-bottom: 24px;
        }

        .logo-box {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 26px;
            padding: 20px;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 16px;
        }

            .logo-box img {
                width: 92px;
                height: 92px;
                border-radius: 14px;
                object-fit: cover;
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                box-shadow: var(--shadow-sm);
            }

        .logo-placeholder {
            width: 92px;
            height: 92px;
            border-radius: 14px;
            background: var(--accent-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            flex-shrink: 0;
            box-shadow: var(--shadow-sm);
        }

        .checkbox-line {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-primary);
            cursor: pointer;
        }

            .checkbox-line input {
                width: 17px;
                height: 17px;
                accent-color: var(--accent-color);
                cursor: pointer;
                margin: 0;
            }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 26px;
            padding-top: 22px;
            border-top: 1px solid var(--border-color);
        }

        .btn-save {
            background: var(--accent-gradient);
            color: white;
            border: none;
            padding: 14px 26px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
            }

        .btn-cancel {
            background: var(--card-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            padding: 14px 26px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.25s ease;
        }

            .btn-cancel:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                background: var(--accent-light);
            }

        @@media (max-width: 700px) {
            .profile-container {
                padding: 26px 22px;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .logo-box {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<div class="profile-container">
    <h2 style="margin: 0 0 6px 0;">Store Profile</h2>
    <p class="page-subtitle">Update your store information, location, contact details, and logo.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message success-message">
            <i class="fas fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="message error-message">
            <i class="fas fa-circle-exclamation"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="status-badge">
        <i class="fas fa-circle-dot"></i> Status: @Model.StoreVM.Status
    </div>

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger"></div>

        <input type="hidden" asp-for="StoreVM.StoreID" />

        <div class="logo-box">
            @if (!string.IsNullOrWhiteSpace(Model.StoreVM.LogoURL))
            {
                <img src="@Model.StoreVM.LogoURL"
                     alt="Store Logo"
                     onerror="this.style.display='none';" />
            }
            else
            {
                <div class="logo-placeholder">
                    <i class="fas fa-store"></i>
                </div>
            }

            <div class="form-group" style="flex: 1; margin-bottom: 0;">
                <label asp-for="StoreVM.LogoFile">Store Logo</label>
                <input asp-for="StoreVM.LogoFile" type="file" accept="image/*" />
                <span asp-validation-for="StoreVM.LogoFile" class="text-danger"></span>
            </div>
        </div>

        <div class="form-section-title">Basic Information</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="StoreVM.StoreName">Store Name</label>
                <input asp-for="StoreVM.StoreName" placeholder="Store name" />
                <span asp-validation-for="StoreVM.StoreName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StoreVM.Email">Email</label>
                <input asp-for="StoreVM.Email" placeholder="store@example.com" />
                <span asp-validation-for="StoreVM.Email" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="StoreVM.PhoneNumber">Phone Number</label>
                <input asp-for="StoreVM.PhoneNumber" placeholder="Phone number" />
                <span asp-validation-for="StoreVM.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StoreVM.BusinessLicenseNumber">Business License Number</label>
                <input asp-for="StoreVM.BusinessLicenseNumber" placeholder="Business license number" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="StoreVM.Description">Description</label>
            <textarea asp-for="StoreVM.Description"
                      rows="5"
                      placeholder="Describe your store..."></textarea>
        </div>

        <div class="form-section-title">Location</div>

        <div class="form-group">
            <label asp-for="StoreVM.AddressLine1">Address Line 1</label>
            <input asp-for="StoreVM.AddressLine1" placeholder="Main address" />
            <span asp-validation-for="StoreVM.AddressLine1" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="StoreVM.AddressLine2">Address Line 2</label>
            <input asp-for="StoreVM.AddressLine2" placeholder="Optional address details" />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="StoreVM.City">City</label>
                <input asp-for="StoreVM.City" placeholder="City" />
                <span asp-validation-for="StoreVM.City" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StoreVM.Area">Area</label>
                <input asp-for="StoreVM.Area" placeholder="Area" />
                <span asp-validation-for="StoreVM.Area" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="StoreVM.Latitude">Latitude</label>
                <input asp-for="StoreVM.Latitude" type="number" step="0.000001" />
            </div>

            <div class="form-group">
                <label asp-for="StoreVM.Longitude">Longitude</label>
                <input asp-for="StoreVM.Longitude" type="number" step="0.000001" />
            </div>
        </div>

        <div class="form-section-title">Payment Settings</div>

        <div class="form-row">
            <div class="form-group">
                <label class="checkbox-line">
                    <input asp-for="StoreVM.CODSupported" type="checkbox" />
                    COD Supported
                </label>
            </div>

            <div class="form-group">
                <label asp-for="StoreVM.CODMaxLimit">COD Max Limit</label>
                <input asp-for="StoreVM.CODMaxLimit" type="number" step="0.01" min="0" />
                <span asp-validation-for="StoreVM.CODMaxLimit" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">
                <i class="fas fa-save"></i> Save Changes
            </button>

            <a href="/StoreOwner/Dashboard" class="btn-cancel">
                Cancel
            </a>
        </div>
    </form>
</div>
