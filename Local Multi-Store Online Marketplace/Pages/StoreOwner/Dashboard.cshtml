@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 18px;
            padding: 22px;
            box-shadow: var(--shadow-sm);
            transition: all 0.25s ease;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md);
                border-color: var(--accent-color);
            }

        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .stat-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            letter-spacing: 0.2px;
        }

        .stat-icon {
            width: 42px;
            height: 42px;
            background: var(--accent-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .stat-icon i {
                color: var(--accent-color);
                font-size: 16px;
            }

        .stat-value {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .stat-change {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .change-positive {
            color: var(--success-color);
        }

        .change-negative {
            color: var(--error-color);
        }

        .dashboard-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 30px;
        }

        .dashboard-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 22px;
            border-radius: 18px;
            box-shadow: var(--shadow-sm);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 14px;
        }

            .card-header h3 {
                font-size: 16px;
                font-weight: 700;
                color: var(--text-primary);
            }

        .dashboard-card .row-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

            .dashboard-card .row-item:last-child {
                border-bottom: none;
            }

            .dashboard-card .row-item strong {
                color: var(--text-primary);
                font-size: 14px;
                font-weight: 700;
            }

            .dashboard-card .row-item small {
                color: var(--text-muted);
                font-size: 12px;
            }

            .dashboard-card .row-item span:first-child {
                color: var(--text-primary);
                font-size: 14px;
                font-weight: 500;
            }

            .dashboard-card .row-item span.amount,
            .dashboard-card .row-item > div:last-child {
                color: var(--accent-color);
                font-weight: 700;
                font-size: 14px;
            }

        .empty-row {
            padding: 20px 0;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

        .welcome-banner {
            background: var(--accent-gradient);
            color: #ffffff;
            padding: 28px 32px;
            border-radius: 20px;
            margin-bottom: 28px;
            box-shadow: var(--shadow-md);
        }

            .welcome-banner h2 {
                font-size: 22px;
                font-weight: 800;
                margin-bottom: 6px;
                letter-spacing: -0.3px;
            }

            .welcome-banner p {
                font-size: 14px;
                opacity: 0.92;
            }
    </style>
}

<!-- Welcome -->
<div class="welcome-banner">
    <h2>Welcome back, @Model.Store.StoreName!</h2>
    <p>Here's what's happening with your store today.</p>
</div>

<!-- STATS GRID 1 -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Revenue</span>
            <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TotalRevenue.ToString("N2")</div>
        <div class="stat-change @(Model.Stats.RevenueGrowth >= 0 ? "change-positive" : "change-negative")">
            @Math.Abs(Model.Stats.RevenueGrowth).ToString("F1")% from last week
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Orders</span>
            <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.TotalOrders</div>
        <div class="stat-change">@Model.Stats.TodayOrders today</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Products</span>
            <div class="stat-icon"><i class="fas fa-box"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.TotalProducts</div>
        <div class="stat-change">
            @Model.Stats.LowStockCount low / @Model.Stats.OutOfStockCount out
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Rating</span>
            <div class="stat-icon"><i class="fas fa-star"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.AverageRating.ToString("F1")</div>
        <div class="stat-change">Customer rating</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Outstanding Balance</span>
            <div class="stat-icon"><i class="fas fa-file-invoice-dollar"></i></div>
        </div>

        <div class="stat-value">
            $@Model.Stats.OutstandingBalance.ToString("N2")
        </div>

        <div class="stat-change">
            @Model.Stats.SubscriptionStatus
        </div>
    </div>

</div>

<!-- STATS GRID 2 (INCLUDING PROFIT) -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Pending Orders</span>
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.PendingOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Preparing</span>
            <div class="stat-icon"><i class="fas fa-utensils"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.PreparingOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Out for Delivery</span>
            <div class="stat-icon"><i class="fas fa-truck"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.OutForDeliveryOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Today's Revenue</span>
            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TodayRevenue.ToString("N2")</div>
    </div>

    <!-- PROFIT SECTION -->
    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Profit</span>
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TotalProfit.ToString("N2")</div>
        <div class="stat-change">From delivered orders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Avg Margin</span>
            <div class="stat-icon"><i class="fas fa-percentage"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.AverageMarginPercent.ToString("F1")%</div>
        <div class="stat-change">
            @Model.Stats.LowMarginProductsCount low margin products
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Low Margin Products</span>
            <div class="stat-icon"><i class="fas fa-arrow-down"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.LowMarginProductsCount</div>
    </div>

</div>

<!-- RECENT ORDERS -->
<div class="dashboard-row">
    <div class="dashboard-card">
        <div class="card-header">
            <h3>Recent Orders</h3>
        </div>

        @if (Model.RecentOrders.Any())
        {
            foreach (var order in Model.RecentOrders)
            {
                <div class="row-item">
                    <div>
                        <strong>#@order.OrderNumber</strong><br />
                        <small>@order.CustomerName</small>
                    </div>
                    <div>$@order.TotalAmount.ToString("N2")</div>
                </div>
            }
        }
        else
        {
            <div class="empty-row">No recent orders yet.</div>
        }
    </div>

    <div class="dashboard-card">
        <div class="card-header">
            <h3>Top Products</h3>
        </div>

        @if (Model.TopProducts.Any())
        {
            foreach (var p in Model.TopProducts)
            {
                <div class="row-item">
                    <span>@p.ProductName</span>
                    <span>$@p.Revenue.ToString("N2")</span>
                </div>
            }
        }
        else
        {
            <div class="empty-row">No product data yet.</div>
        }
    </div>
</div>
