@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
           ROOT VARIABLES — matches brand palette
           ============================================================ */
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
            --radius-md: 16px;
            --radius-lg: 24px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
           WELCOME BANNER — upgraded with icon & gradient glow
           ============================================================ */
        .welcome-banner {
            background: var(--accent-gradient);
            color: #ffffff;
            padding: 32px 40px;
            border-radius: var(--radius-lg);
            margin-bottom: 32px;
            box-shadow: var(--shadow-md), 0 8px 32px rgba(109, 40, 217, 0.20);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            top: -40%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 50%;
            pointer-events: none;
        }

        .welcome-text h2 {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 4px;
            letter-spacing: -0.4px;
        }

        .welcome-text p {
            font-size: 15px;
            opacity: 0.92;
            margin: 0;
        }

        .welcome-icon {
            font-size: 40px;
            opacity: 0.25;
            background: rgba(255,255,255,0.15);
            width: 64px;
            height: 64px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
            flex-shrink: 0;
        }

        /* ============================================================
           STATS GRID — responsive, elevated cards
           ============================================================ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 20px 22px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--accent-gradient);
            opacity: 0;
            transition: var(--transition);
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
            border-color: var(--accent-color);
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 14px;
        }

        .stat-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            letter-spacing: 0.3px;
            text-transform: uppercase;
        }

        .stat-icon {
            width: 40px;
            height: 40px;
            background: var(--accent-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: var(--transition);
        }

        .stat-card:hover .stat-icon {
            background: var(--accent-color);
        }

        .stat-icon i {
            color: var(--accent-color);
            font-size: 16px;
            transition: var(--transition);
        }

        .stat-card:hover .stat-icon i {
            color: #fff;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            margin-bottom: 4px;
            line-height: 1.2;
        }

        .stat-change {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .change-positive {
            color: var(--success-color);
        }

        .change-negative {
            color: var(--error-color);
        }

        /* ============================================================
           DASHBOARD ROW — two columns
           ============================================================ */
        .dashboard-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 30px;
        }

        .dashboard-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 20px 22px 22px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .dashboard-card:hover {
            box-shadow: var(--shadow-md);
            border-color: var(--accent-color);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
        }

        .card-header h3 {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-header h3 i {
            color: var(--accent-color);
            font-size: 18px;
        }

        .card-header .view-all {
            font-size: 12px;
            font-weight: 600;
            color: var(--accent-color);
            text-decoration: none;
            transition: var(--transition);
        }

        .card-header .view-all:hover {
            color: var(--accent-hover);
            text-decoration: underline;
        }

        .row-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
            transition: var(--transition);
        }

        .row-item:last-child {
            border-bottom: none;
        }

        .row-item:hover {
            background: var(--accent-light);
            margin: 0 -8px;
            padding-left: 8px;
            padding-right: 8px;
            border-radius: 8px;
        }

        .row-item strong {
            color: var(--text-primary);
            font-size: 14px;
            font-weight: 700;
        }

        .row-item small {
            color: var(--text-muted);
            font-size: 12px;
            display: block;
        }

        .row-item .amount {
            color: var(--accent-color);
            font-weight: 700;
            font-size: 14px;
        }

        .empty-row {
            padding: 24px 0;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

        /* ============================================================
           RESPONSIVE
           ============================================================ */
        @@media (max-width: 992px) {
            .dashboard-row {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 14px;
            }
            .stat-card {
                padding: 16px 18px;
            }
            .stat-value {
                font-size: 22px;
            }
            .welcome-banner {
                padding: 24px 20px;
                flex-direction: column;
                align-items: flex-start;
            }
            .welcome-icon {
                align-self: flex-end;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<!-- ========== WELCOME BANNER ========== -->
<div class="welcome-banner">
    <div class="welcome-text">
        <h2>👋 Welcome back, @Model.Store.StoreName!</h2>
        <p>Here's a snapshot of your store's performance today.</p>
    </div>
    <div class="welcome-icon">
        <i class="fas fa-store-alt"></i>
    </div>
</div>

<!-- ========== STATS GRID 1 ========== -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Revenue</span>
            <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TotalRevenue.ToString("N2")</div>
        <div class="stat-change @(Model.Stats.RevenueGrowth >= 0 ? "change-positive" : "change-negative")">
            @Math.Abs(Model.Stats.RevenueGrowth).ToString("F1")% from last week
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Orders</span>
            <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.TotalOrders</div>
        <div class="stat-change">@Model.Stats.TodayOrders today</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Products</span>
            <div class="stat-icon"><i class="fas fa-box"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.TotalProducts</div>
        <div class="stat-change">
            @Model.Stats.LowStockCount low / @Model.Stats.OutOfStockCount out
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Rating</span>
            <div class="stat-icon"><i class="fas fa-star"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.AverageRating.ToString("F1")</div>
        <div class="stat-change">Customer rating</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Outstanding Balance</span>
            <div class="stat-icon"><i class="fas fa-file-invoice-dollar"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.OutstandingBalance.ToString("N2")</div>
        <div class="stat-change">@Model.Stats.SubscriptionStatus</div>
    </div>

</div>

<!-- ========== STATS GRID 2 (order status + profit) ========== -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Pending Orders</span>
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.PendingOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Preparing</span>
            <div class="stat-icon"><i class="fas fa-utensils"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.PreparingOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Out for Delivery</span>
            <div class="stat-icon"><i class="fas fa-truck"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.OutForDeliveryOrders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Today's Revenue</span>
            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TodayRevenue.ToString("N2")</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Total Profit</span>
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
        </div>
        <div class="stat-value">$@Model.Stats.TotalProfit.ToString("N2")</div>
        <div class="stat-change">From delivered orders</div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-title">Avg Margin</span>
            <div class="stat-icon"><i class="fas fa-percentage"></i></div>
        </div>
        <div class="stat-value">@Model.Stats.AverageMarginPercent.ToString("F1")%</div>
        <div class="stat-change">
            @Model.Stats.LowMarginProductsCount low margin products
        </div>
    </div>

</div>

<!-- ========== RECENT ORDERS & TOP PRODUCTS ========== -->
<div class="dashboard-row">

    <!-- Recent Orders -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3><i class="fas fa-list-ul"></i> Recent Orders</h3>
            <a href="/StoreOwner/Orders" class="view-all">View All</a>
        </div>

        @if (Model.RecentOrders.Any())
        {
            foreach (var order in Model.RecentOrders)
            {
                <div class="row-item">
                    <div>
                        <strong>#@order.OrderNumber</strong>
                        <small>@order.CustomerName</small>
                    </div>
                    <div class="amount">$@order.TotalAmount.ToString("N2")</div>
                </div>
            }
        }
        else
        {
            <div class="empty-row">No recent orders yet.</div>
        }
    </div>

    <!-- Top Products -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3><i class="fas fa-crown"></i> Top Products</h3>
            <a href="/StoreOwner/Products" class="view-all">View All</a>
        </div>

        @if (Model.TopProducts.Any())
        {
            foreach (var p in Model.TopProducts)
            {
                <div class="row-item">
                    <span>@p.ProductName</span>
                    <span class="amount">$@p.Revenue.ToString("N2")</span>
                </div>
            }
        }
        else
        {
            <div class="empty-row">No product data yet.</div>
        }
    </div>

</div>