@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Explore.IndexModel

@{
    ViewData["Title"] = "Explore Content";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        .explore-page {
            max-width: 1200px;
            margin: 0 auto;
        }

        .explore-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 25px;
        }

            .explore-page-header h1 {
                margin: 0 0 7px;
                color: #111827;
                font-size: 28px;
            }

            .explore-page-header p {
                margin: 0;
                color: #6b7280;
            }

        .create-post-btn {
            min-height: 46px;
            padding: 0 19px;
            border-radius: 13px;
            background: linear-gradient(135deg, #ff7a45, #ff5a1f);
            color: white;
            text-decoration: none;
            font-weight: 900;
            display: inline-flex;
            align-items: center;
            gap: 9px;
            box-shadow: 0 10px 24px rgba(255, 107, 53, 0.25);
            white-space: nowrap;
        }

        .filter-card {
            margin-bottom: 25px;
            padding: 18px;
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(15, 23, 42, 0.05);
        }

        .filter-form {
            display: grid;
            grid-template-columns: 1fr 1fr auto;
            gap: 14px;
        }

        .filter-select {
            width: 100%;
            min-height: 44px;
            padding: 9px 13px;
            border: 1px solid #d1d5db;
            border-radius: 11px;
            background: white;
            font: inherit;
        }

        .filter-btn {
            min-height: 44px;
            padding: 0 20px;
            border: none;
            border-radius: 11px;
            background: #111827;
            color: white;
            font-weight: 800;
            cursor: pointer;
        }

        .message {
            margin-bottom: 20px;
            padding: 14px 17px;
            border-radius: 13px;
            font-weight: 700;
        }

        .message-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .message-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .explore-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 22px;
        }

        .explore-card {
            overflow: hidden;
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
            transition: 0.2s ease;
        }

            .explore-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 18px 38px rgba(15, 23, 42, 0.11);
            }

        .media-box {
            position: relative;
            height: 290px;
            overflow: hidden;
            background: #f3f4f6;
        }

            .media-box img,
            .media-box video {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .type-badge,
        .status-badge,
        .media-count {
            position: absolute;
            z-index: 2;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
            backdrop-filter: blur(8px);
        }

        .type-badge {
            top: 12px;
            left: 12px;
            padding: 7px 10px;
            background: rgba(17, 24, 39, 0.82);
            color: white;
        }

        .status-badge {
            top: 12px;
            right: 12px;
            padding: 7px 10px;
        }

        .status-active {
            color: #166534;
            background: rgba(220, 252, 231, 0.95);
        }

        .status-inactive {
            color: #991b1b;
            background: rgba(254, 226, 226, 0.95);
        }

        .media-count {
            right: 12px;
            bottom: 12px;
            padding: 6px 9px;
            background: rgba(17, 24, 39, 0.78);
            color: white;
        }

        .card-content {
            padding: 17px;
        }

        .post-caption {
            min-height: 46px;
            margin: 0 0 14px;
            color: #374151;
            font-size: 14px;
            line-height: 1.55;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .empty-caption {
            color: #9ca3af;
            font-style: italic;
        }

        .linked-product {
            margin-bottom: 14px;
            padding: 11px 12px;
            border-radius: 11px;
            background: #fff7ed;
            color: #9a3412;
            font-size: 12px;
            font-weight: 800;
        }

        .post-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            margin-bottom: 14px;
            padding: 12px 0;
            border-top: 1px solid #f3f4f6;
            border-bottom: 1px solid #f3f4f6;
        }

        .stat-item {
            text-align: center;
            color: #6b7280;
            font-size: 12px;
        }

            .stat-item strong {
                display: block;
                margin-bottom: 2px;
                color: #111827;
                font-size: 15px;
            }

        .post-date {
            margin-bottom: 15px;
            color: #9ca3af;
            font-size: 11px;
        }

        .card-actions {
            display: grid;
            grid-template-columns: 1fr 1fr 44px;
            gap: 9px;
        }

        .action-btn {
            min-height: 42px;
            border: none;
            border-radius: 11px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .edit-btn {
            background: #111827;
            color: white;
        }

        .status-btn {
            background: #fff7ed;
            color: #ea580c;
        }

        .delete-btn {
            width: 44px;
            background: #fee2e2;
            color: #b91c1c;
        }

        .delete-form {
            margin: 0;
        }

        .empty-state {
            padding: 65px 25px;
            border: 1px dashed #d1d5db;
            border-radius: 22px;
            background: white;
            text-align: center;
        }

            .empty-state i {
                margin-bottom: 16px;
                color: #ff6b35;
                font-size: 55px;
            }

            .empty-state h2 {
                margin: 0 0 9px;
                color: #111827;
            }

            .empty-state p {
                margin: 0 0 20px;
                color: #6b7280;
            }

        @@media (max-width: 1050px) {
            .explore-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 700px) {
            .explore-page-header {
                flex-direction: column;
            }

            .filter-form {
                grid-template-columns: 1fr;
            }

            .explore-grid {
                grid-template-columns: 1fr;
            }

            .create-post-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="explore-page">

    <div class="explore-page-header">
        <div>
            <h1>Explore Content</h1>

            <p>
                Manage the images, carousels and reels published
                by @Model.StoreName.
            </p>
        </div>

        <a asp-page="/StoreOwner/Explore/Create"
           class="create-post-btn">
            <i class="fas fa-plus"></i>
            Create New Post
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message message-success">
            <i class="fas fa-circle-check"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="message message-error">
            <i class="fas fa-circle-exclamation"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="filter-card">
        <form method="get" class="filter-form">

            <select asp-for="TypeFilter"
                    class="filter-select">
                <option value="">All post types</option>
                <option value="Image">Images</option>
                <option value="Carousel">Carousels</option>
                <option value="Reel">Reels</option>
            </select>

            <select asp-for="StatusFilter"
                    class="filter-select">
                <option value="">All statuses</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>

            <button type="submit" class="filter-btn">
                <i class="fas fa-filter"></i>
                Filter
            </button>
        </form>
    </div>

    @if (Model.Posts.Any())
    {
        <div class="explore-grid">

            @foreach (var post in Model.Posts)
            {
                <article class="explore-card">

                    <div class="media-box">

                        @if (post.MediaType == "Video")
                        {
                            <video muted
                                   playsinline
                                   preload="metadata"
                                   poster="@post.ThumbnailUrl">
                                <source src="@post.MediaUrl" />
                            </video>
                        }
                        else
                        {
                            <img src="@post.MediaUrl"
                                 alt="Explore post"
                                 loading="lazy"
                                 onerror="this.onerror=null;this.src='/images/no-image.png';" />
                        }

                        <span class="type-badge">
                            @if (post.PostType == "Reel")
                            {
                                <i class="fas fa-video"></i>
                            }
                            else if (post.PostType == "Carousel")
                            {
                                <i class="fas fa-images"></i>
                            }
                            else
                            {
                                <i class="fas fa-image"></i>
                            }

                            @post.PostType
                        </span>

                        <span class="status-badge @(post.IsActive ? "status-active" : "status-inactive")">
                            @(post.IsActive ? "Active" : "Inactive")
                        </span>

                        @if (post.MediaCount > 1)
                        {
                            <span class="media-count">
                                <i class="fas fa-layer-group"></i>
                                @post.MediaCount
                            </span>
                        }
                    </div>

                    <div class="card-content">

                        @if (string.IsNullOrWhiteSpace(post.Caption))
                        {
                            <p class="post-caption empty-caption">
                                No caption added.
                            </p>
                        }
                        else
                        {
                            <p class="post-caption">
                                @post.Caption
                            </p>
                        }

                        @if (post.ProductID.HasValue)
                        {
                            <div class="linked-product">
                                <i class="fas fa-bag-shopping"></i>

                                @post.ProductName

                                @if (post.ProductPrice.HasValue)
                                {
                                    <span>
                                        — $@post.ProductPrice.Value.ToString("N2")
                                    </span>
                                }
                            </div>
                        }

                        <div class="post-stats">

                            <div class="stat-item">
                                <strong>@post.ViewCount</strong>
                                Views
                            </div>

                            <div class="stat-item">
                                <strong>@post.LikeCount</strong>
                                Likes
                            </div>

                            <div class="stat-item">
                                <strong>@post.CommentCount</strong>
                                Comments
                            </div>

                        </div>

                        <div class="post-date">
                            Published @post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                        </div>

                        <div class="card-actions">

                            <a asp-page="/StoreOwner/Explore/Edit"
                               asp-route-id="@post.ExplorePostID"
                               class="action-btn edit-btn">
                                <i class="fas fa-pen"></i>
                                Edit
                            </a>

                            <form method="post"
                                  asp-page-handler="ToggleStatus"
                                  asp-route-postId="@post.ExplorePostID">

                                <button type="submit"
                                        class="action-btn status-btn">
                                    <i class="fas @(post.IsActive ? "fa-eye-slash" : "fa-eye")"></i>

                                    @(post.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>

                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-postId="@post.ExplorePostID"
                                  class="delete-form"
                                  onsubmit="return confirm('Delete this Explore post permanently?');">

                                <button type="submit"
                                        class="action-btn delete-btn"
                                        title="Delete post">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>

                        </div>
                    </div>

                </article>
            }

        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-photo-film"></i>

            <h2>No Explore posts yet</h2>

            <p>
                Create an image post, carousel, or reel for customers.
            </p>

            <a asp-page="/StoreOwner/Explore/Create"
               class="create-post-btn">
                <i class="fas fa-plus"></i>
                Create First Post
            </a>
        </div>
    }

</div>