@using Microsoft.AspNetCore.Identity
@using Multi_Store.Core.Entities
@using Multi_Store.Services.Dtos
@using Multi_Store.Services.Managers
@inject UserManager<User> UserManager
@inject StoreManager StoreManager
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var currentUser = await UserManager.GetUserAsync(User);
    string ActiveIf(string pageName) =>
        string.Equals(currentPage, pageName, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var storeId = ViewData["StoreId"]?.ToString();

    // ----- Fetch store logo, name and ID from database -----
    string storeLogoUrl = null;
    string storeName = null;
    int? currentStoreId = null;
    if (currentUser != null)
    {
        var store = await StoreManager.GetByUserIdAsync(currentUser.Id);
        if (store != null)
        {
            currentStoreId = store.StoreID;
            storeLogoUrl = store.LogoURL;
            storeName = store.StoreName;
        }
    }
    storeLogoUrl ??= ViewData["StoreLogoUrl"]?.ToString() ?? "~/images/default-avatar.png";
    storeName ??= ViewData["StoreName"]?.ToString() ?? "My Store";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Store Owner Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/store-owner.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
            :root {
                --accent-color: #6d28d9;
                --accent-hover: #5b21b6;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --bg-color: #f8f7fc;
                --card-bg: #ffffff;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                --text-muted: #9691a4;
                --border-color: #ece8f6;
                --rail-icon: #7A73A0;
                --error-color: #dc2626;
                --error-light: #fef2f2;
                --shadow-sm: 0 1px 2px rgba(109, 40, 217, 0.04), 0 1px 3px rgba(109, 40, 217, 0.06);
                --shadow-md: 0 4px 6px rgba(109, 40, 217, 0.05), 0 2px 4px rgba(109, 40, 217, 0.04);
                --shadow-lg: 0 10px 24px rgba(109, 40, 217, 0.10), 0 2px 6px rgba(109, 40, 217, 0.05);
                --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                --rail-height: 72px;
                --ease: cubic-bezier(.4, 0, .2, 1);
            }

            * {
                box-sizing: border-box;
            }

            body.store-owner-body {
                font-family: var(--font-family);
                background: var(--bg-color);
                color: var(--text-primary);
                margin: 0;
                padding-top: 24px;
                padding-bottom: calc(var(--rail-height) + 32px);
                -webkit-font-smoothing: antialiased;
            }

            .pro-rail {
                position: fixed;
                left: 50%;
                bottom: 16px;
                transform: translateX(-50%);
                width: 90%;
                max-width: 1180px;
                min-width: 600px;
                height: var(--rail-height);
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                display: flex;
                align-items: center;
                padding: 0 10px 0 18px;
                z-index: 1000;
                box-shadow: var(--shadow-lg);
                gap: 4px;
            }

            .rail-brand {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--accent-gradient);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 17px;
                flex-shrink: 0;
                text-decoration: none;
                box-shadow: 0 3px 8px rgba(109, 40, 217, 0.18);
                transition: transform 0.2s var(--ease);
                margin-right: 8px;
            }

                .rail-brand:hover {
                    transform: scale(1.05);
                }
            /* Scrollable nav zone with edge fade so overflow is obvious, not cramped */
            .rail-scroll-wrap {
                position: relative;
                flex: 1 1 auto;
                min-width: 0;
                height: 100%;
                mask-image: linear-gradient(to right, transparent 0, #000 14px, #000 calc(100% - 14px), transparent 100%);
                -webkit-mask-image: linear-gradient(to right, transparent 0, #000 14px, #000 calc(100% - 14px), transparent 100%);
            }

            .rail-nav {
                display: flex;
                flex-direction: row;
                gap: 4px;
                height: 100%;
                align-items: center;
                justify-content: center;
                min-width: min-content;
                margin: 0 auto;
                overflow-x: auto;
                scrollbar-width: none;
                padding: 0 14px;
                scroll-behavior: smooth;
            }

                .rail-nav::-webkit-scrollbar {
                    display: none;
                }

            .rail-item {
                position: relative;
                min-width: 60px;
                height: 54px;
                border-radius: 10px;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 3px;
                color: var(--rail-icon);
                text-decoration: none;
                flex-shrink: 0;
                padding: 6px 8px;
                border: none;
                background: none;
                font-family: inherit;
                cursor: pointer;
                transition: background 0.15s var(--ease), color 0.15s var(--ease);
            }

                .rail-item i {
                    font-size: 17px;
                    line-height: 1;
                }

            .rail-label {
                font-size: 9.5px;
                font-weight: 600;
                line-height: 1;
                letter-spacing: 0.1px;
                white-space: nowrap;
            }

            .rail-item:hover {
                background: var(--accent-light);
                color: var(--accent-color);
            }

            .rail-item.active {
                background: var(--accent-gradient);
                color: #fff;
            }

            .rail-item.danger {
                color: var(--error-color);
            }

                .rail-item.danger:hover {
                    background: var(--error-light);
                    color: var(--error-color);
                }

            .rail-divider {
                width: 1px;
                height: 24px;
                background: var(--border-color);
                flex-shrink: 0;
            }
            /* Fixed action zone — always visible, never scrolls away */
            .rail-actions {
                display: flex;
                align-items: center;
                gap: 2px;
                flex-shrink: 0;
                height: 100%;
                padding-left: 8px;
                border-left: 1px solid var(--border-color);
            }

            .store-main-content {
                padding: 0 40px 60px;
                max-width: 1200px;
                margin: 0 auto;
            }

            .content-body {
                animation: content-enter 0.3s var(--ease) both;
            }

            @@keyframes content-enter {
                from {
                    opacity: 0;
                    transform: translateY(6px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@media (max-width: 768px) {
                .store-main-content {
                    padding: 0 16px 40px;
                }

                .pro-rail {
                    width: 94%;
                    min-width: unset;
                    bottom: 10px;
                    padding: 0 6px 0 10px;
                }

                .rail-item {
                    min-width: 50px;
                    height: 48px;
                    padding: 4px 6px;
                }

                    .rail-item i {
                        font-size: 15px;
                    }

                .rail-label {
                    font-size: 8px;
                }

                .rail-brand {
                    width: 36px;
                    height: 36px;
                    font-size: 14px;
                }
            }
    </style>
</head>
<body class="store-owner-body">
    <div class="store-owner-wrapper">

        <!-- Persistent bottom rail -->
        <aside class="pro-rail" aria-label="Store owner navigation">
            <a href="/StoreOwner/Dashboard" class="rail-brand" aria-label="Store Owner Panel">
                <i class="fas fa-store"></i>
            </a>

            <div class="rail-scroll-wrap">
                <nav class="rail-nav" aria-label="Main navigation">
                    <a href="/StoreOwner/Home" class="rail-item @ActiveIf("Home")" aria-current="@(ActiveIf("Home") == "active" ? "page" : null)" title="Home">
                        <i class="fas fa-home"></i>
                        <span class="rail-label">Home</span>
                    </a>
                    <a href="/StoreOwner/Dashboard" class="rail-item @ActiveIf("Dashboard")" aria-current="@(ActiveIf("Dashboard") == "active" ? "page" : null)" title="Dashboard">
                        <i class="fas fa-tachometer-alt"></i>
                        <span class="rail-label">Dashboard</span>
                    </a>
                    <div class="rail-divider"></div>
                    <a href="/StoreOwner/Products/Index" class="rail-item @ActiveIf("Products")" aria-current="@(ActiveIf("Products") == "active" ? "page" : null)" title="Products">
                        <i class="fas fa-box"></i>
                        <span class="rail-label">Products</span>
                    </a>
                    <a href="/StoreOwner/Order/Index" class="rail-item @ActiveIf("Order")" aria-current="@(ActiveIf("Order") == "active" ? "page" : null)" title="Orders">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="rail-label">Orders</span>
                    </a>
                    <a href="/StoreOwner/Promotions/Index" class="rail-item @ActiveIf("Promotions")" aria-current="@(ActiveIf("Promotions") == "active" ? "page" : null)" title="Promotions">
                        <i class="fas fa-tags"></i>
                        <span class="rail-label">Promotions</span>
                    </a>
                    <a href="/StoreReviews/@currentStoreId"
                       class="rail-item @ActiveIf("StoreReviews")"
                       title="Reviews">
                        <i class="fas fa-star"></i>
                        <span class="rail-label">Reviews</span>
                    </a>
                    <a href="/StoreOwner/Analytics" class="rail-item @ActiveIf("Analytics")" aria-current="@(ActiveIf("Analytics") == "active" ? "page" : null)" title="Analytics">
                        <i class="fas fa-chart-line"></i>
                        <span class="rail-label">Analytics</span>
                    </a>
                    <a href="/StoreOwner/AccountStatement" class="rail-item @ActiveIf("AccountStatement")" aria-current="@(ActiveIf("AccountStatement") == "active" ? "page" : null)" title="Account Statement">
                        <i class="fas fa-file-invoice-dollar"></i>
                        <span class="rail-label">Statement</span>
                    </a>
                    <div class="rail-divider"></div>
                    <a href="/Chat" class="rail-item @ActiveIf("Chat")" aria-current="@(ActiveIf("Chat") == "active" ? "page" : null)" title="Chat">
                        <i class="fas fa-comment-dots"></i>
                        <span class="rail-label">Chat</span>
                    </a>
                    <a href="/ReportUpdates" class="rail-item @ActiveIf("ReportUpdates")" aria-current="@(ActiveIf("ReportUpdates") == "active" ? "page" : null)" title="Notifications">
                        <i class="fas fa-bell"></i>
                        <span class="rail-label">Notifications</span>
                    </a>
                </nav>
            </div>

            <!-- Settings & Logout: always visible, never scrolled out of view -->
            <div class="rail-actions">
                <a href="/StoreOwner/Settings" class="rail-item @ActiveIf("Settings")" aria-current="@(ActiveIf("Settings") == "active" ? "page" : null)" title="Settings">
                    <i class="fas fa-cog"></i>
                    <span class="rail-label">Settings</span>
                </a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" style="display:contents;">
                    <button type="submit" class="rail-item danger" title="Log out">
                        <i class="fas fa-sign-out-alt"></i>
                        <span class="rail-label">Logout</span>
                    </button>
                </form>
            </div>
        </aside>
        <!-- Main Content -->
        <main class="store-main-content">
            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/js/store-owner.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>