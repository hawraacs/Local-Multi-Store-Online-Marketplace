@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Store Owner Panel</title>
    <link rel="stylesheet" href="~/css/store-owner.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="store-owner-body">
    <div class="store-owner-wrapper">
        <!-- Top Navigation Bar -->
        <nav class="store-top-nav">
            <div class="nav-container">
                <div class="nav-brand">
                    <a href="/StoreOwner/Dashboard">
                        <i class="fas fa-store"></i>
                        <span>Store Owner Panel</span>
                    </a>
                </div>
                <div class="nav-search">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search orders, products..." id="globalSearch" />
                </div>
                <div class="nav-actions">
                    <div class="notification-bell">
                        <i class="fas fa-bell"></i>
                        <span class="badge">3</span>
                    </div>
                    <div class="user-dropdown">
                        <img src="~/images/default-avatar.png" alt="Avatar" class="user-avatar" />
                        <span>@User.Identity?.Name</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                </div>
            </div>
        </nav>

        <div class="store-main-container">
            <!-- Sidebar -->
            <aside class="store-sidebar">
                <div class="sidebar-menu">
                    <div class="menu-item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")">
                        <a href="/StoreOwner/Dashboard">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </div>
                    <div class="menu-item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Products") == true ? "active" : "")">
                        <a href="/StoreOwner/Products/Index">
                            <i class="fas fa-box"></i>
                            <span>Products</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Orders/Index">
                            <i class="fas fa-shopping-cart"></i>
                            <span>Orders</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Analytics/Index">
                            <i class="fas fa-chart-line"></i>
                            <span>Analytics</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Promotions/Index">
                            <i class="fas fa-tags"></i>
                            <span>Promotions</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Chat/Index">
                            <i class="fas fa-comment-dots"></i>
                            <span>Chat</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Reviews/Index">
                            <i class="fas fa-star"></i>
                            <span>Reviews</span>
                        </a>
                    </div>
                    <div class="menu-item">
                        <a href="/StoreOwner/Settings/Index">
                            <i class="fas fa-cog"></i>
                            <span>Settings</span>
                        </a>
                    </div>
                </div>

                <!-- Store Info Card - Use ViewData instead of ViewBag -->
                <div class="store-info-card">
                    <div class="store-logo">
                        <i class="fas fa-store"></i>
                    </div>
                    <div class="store-details">
                        <h4>@ViewData["StoreName"]</h4>
                        <span class="store-status active">Active</span>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="store-main-content">
                <div class="content-header">
                    <h1>@ViewData["Title"]</h1>
                    <div class="breadcrumb">
                        <a href="/StoreOwner/Dashboard">Dashboard</a>
                        <i class="fas fa-chevron-right"></i>
                        <span>@ViewData["Title"]</span>
                    </div>
                </div>
                <div class="content-body">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/js/store-owner.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>