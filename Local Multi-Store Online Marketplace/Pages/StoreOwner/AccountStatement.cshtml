@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.AccountStatementModel
@{
    ViewData["Title"] = "Account Statement";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
        }

        h2 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.4px;
        }

            h2 + p {
                color: var(--text-secondary);
                font-size: 14px;
                margin-top: -4px;
                margin-bottom: 24px;
            }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .summary-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 20px;
            border-radius: 18px;
            box-shadow: var(--shadow-sm);
            transition: all 0.25s ease;
        }

            .summary-card:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
            }

            .summary-card .label {
                font-size: 13px;
                font-weight: 600;
                color: var(--text-secondary);
                margin-bottom: 8px;
            }

            .summary-card .value {
                font-size: 24px;
                font-weight: 800;
                color: var(--text-primary);
                letter-spacing: -0.4px;
            }

        .statement-table {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 18px;
            padding: 22px;
            box-shadow: var(--shadow-sm);
        }

            .statement-table h4 {
                font-size: 16px;
                font-weight: 800;
                color: var(--text-primary);
                margin-bottom: 16px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        th, td {
            padding: 12px 10px;
            border-bottom: 1px solid var(--border-color);
            text-align: left;
        }

        th {
            background: var(--accent-light);
            color: var(--accent-color);
            font-weight: 700;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

            th:first-child {
                border-top-left-radius: 10px;
            }

            th:last-child {
                border-top-right-radius: 10px;
            }

        tbody tr:hover td {
            background: var(--bg-color);
        }

        .positive {
            color: var(--success-color);
        }

        .negative {
            color: var(--error-color);
        }

        .badge-order {
            background: var(--accent-light);
            color: var(--accent-color);
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
        }

        .badge-subscription {
            background: #eef2ff;
            color: #4338ca;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
        }

        .subscription-box {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 20px 24px;
            border-radius: 18px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-sm);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }

        .subscription-status {
            font-weight: 800;
        }

            .subscription-status.active {
                color: var(--success-color);
            }

            .subscription-status.expired {
                color: var(--error-color);
            }

        .btn-renew {
            background: var(--accent-gradient);
            color: white;
            border: none;
            padding: 12px 26px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .btn-renew:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 26px rgba(109, 40, 217, 0.32);
            }
    </style>
}

<h2>Account Statement</h2>
<p>@Model.Store?.StoreName</p>

<!-- Subscription Renewal Box -->
<div class="subscription-box">
    <div>
        <strong>Subscription Status:</strong>
        <span class="subscription-status @(Model.Store.SubscriptionExpiryDate >= DateTime.Now ? "active" : "expired")">
            @(Model.Store.SubscriptionExpiryDate >= DateTime.Now ? "Active" : "Expired")
        </span>
        <br />
        <span>Expires: @(Model.Store.SubscriptionExpiryDate?.ToString("dd MMM yyyy") ?? "Not Available")</span>
    </div>
    <form method="post" asp-page-handler="Renew">
        <button type="submit" class="btn-renew">Renew Subscription ($20)</button>
    </form>
</div>

<!-- Summary Cards -->
<div class="summary-grid">
    <div class="summary-card">
        <div class="label">Gross Revenue</div>
        <div class="value">$@Model.Summary.TotalGrossRevenue.ToString("N2")</div>
    </div>
    <div class="summary-card">
        <div class="label">Commission (5%)</div>
        <div class="value negative">-$@Model.Summary.TotalCommission.ToString("N2")</div>
    </div>
    <div class="summary-card">
        <div class="label">Subscription Fees</div>
        <div class="value negative">-$@Model.Summary.TotalSubscriptionFees.ToString("N2")</div>
    </div>
    <div class="summary-card">
        <div class="label">Net Revenue</div>
        <div class="value @(Model.Summary.NetRevenue >= 0 ? "positive" : "negative")">
            $@Model.Summary.NetRevenue.ToString("N2")
        </div>
    </div>
    <div class="summary-card">
        <div class="label">Outstanding Balance</div>
        <div class="value @(Model.Summary.OutstandingBalance >= 0 ? "positive" : "negative")">
            $@Model.Summary.OutstandingBalance.ToString("N2")
        </div>
    </div>
</div>

<!-- Transaction History -->
<div class="statement-table">
    <h4>Transaction History</h4>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th style="text-align:right;">Gross</th>
                <th style="text-align:right;">Commission</th>
                <th style="text-align:right;">Subscription</th>
                <th style="text-align:right;">Net Effect</th>
                <th>Type</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Lines.Any())
            {
                <tr><td colspan="7" style="text-align:center; padding:30px;">No transactions yet.</td></tr>
            }
            else
            {
                foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.Date.ToString("dd MMM yyyy")</td>
                        <td>@line.Description</td>
                        <td style="text-align:right;">$@line.GrossRevenue.ToString("N2")</td>
                        <td class="negative" style="text-align:right;">$@line.Commission.ToString("N2")</td>
                        <td class="negative" style="text-align:right;">$@line.SubscriptionFee.ToString("N2")</td>
                        <td class="@(line.NetEffect >= 0 ? "positive" : "negative")" style="text-align:right;">
                            $@line.NetEffect.ToString("N2")
                        </td>
                        <td>
                            @if (line.Type == LineType.Order)
                            {
                                <span class="badge-order">Order</span>
                            }
                            else
                            {
                                <span class="badge-subscription">Subscription</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
