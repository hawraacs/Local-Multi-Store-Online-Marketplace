@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.CheckoutSettlementModel

<style>
    :root {
        /* -------- Brand colors (Purple / Indigo) -------- */
        --accent-color: #6d28d9;
        --accent-hover: #5b21b6;
        --accent-light: #f3effe;
        --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
        /* -------- Neutral palette -------- */
        --bg-color: #f8f7fc;
        --card-bg: #ffffff;
        --text-primary: #1e1b2e;
        --text-secondary: #6b6478;
        --border-color: #ece8f6;
        /* -------- Shadows -------- */
        --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
    }

    body {
        background: var(--bg-color);
    }

    h2 {
        font-size: 22px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.4px;
        margin: 24px 0 18px;
        text-align: center;
    }

    .card {
        max-width: 460px;
        margin: 0 auto 40px;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 22px;
        box-shadow: var(--shadow-md);
        padding: 28px !important;
    }

        .card h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.4px;
            background: var(--accent-light);
            display: inline-block;
            padding: 6px 14px;
            border-radius: 999px;
            margin-bottom: 16px;
        }

        .card p {
            font-size: 15px;
            color: var(--text-secondary);
            margin-bottom: 22px;
        }

            .card p strong {
                color: var(--text-primary);
            }

    .btn-success {
        width: 100%;
        background: var(--accent-gradient);
        border: none;
        color: white;
        padding: 13px 22px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 14px;
        box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
        transition: all 0.25s ease;
    }

        .btn-success:hover,
        .btn-success:focus {
            background: var(--accent-gradient);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(109, 40, 217, 0.32);
            color: white;
        }
</style>

<h2>Settlement Checkout</h2>

<div class="card p-3">
    <h4>@Model.Direction</h4>

    <p><strong>Amount:</strong> $@Model.Amount.ToString("N2")</p>

    <form method="post">
        <button class="btn btn-success">
            Confirm &amp; Process Payment
        </button>
    </form>
</div>
