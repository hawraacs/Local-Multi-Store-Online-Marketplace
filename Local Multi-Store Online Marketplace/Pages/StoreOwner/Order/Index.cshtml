@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Order.IndexModel
@{
    ViewData["Title"] = "Orders";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
        }

        .container-fluid h1 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.4px;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 18px;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .card-header {
            background: var(--bg-color);
            border-bottom: 1px solid var(--border-color);
            padding: 14px 20px;
            font-weight: 700;
            font-size: 14px;
            color: var(--text-primary);
        }

            .card-header i {
                color: var(--accent-color);
            }

        .card-body {
            padding: 20px;
        }

        .table {
            font-size: 14px;
            color: var(--text-primary);
            margin-bottom: 0;
        }

            .table thead th {
                background: var(--accent-light);
                color: var(--accent-color);
                font-weight: 700;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.4px;
                border-bottom: none;
                padding: 12px 14px;
            }

            .table td {
                padding: 12px 14px;
                vertical-align: middle;
                border-bottom: 1px solid var(--border-color);
            }

        .table-striped > tbody > tr:nth-of-type(odd) > td {
            background-color: var(--bg-color);
        }

        .table tbody tr:hover td {
            background-color: var(--accent-light);
        }

        /* -------- Status dropdown -------- */
        .table select {
            padding: 8px 12px;
            border: 1.5px solid var(--border-color);
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            background-color: var(--card-bg);
            color: var(--text-primary);
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .table select:focus {
                outline: none;
                border-color: var(--accent-color);
                box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
            }

        /* -------- Buttons -------- */
        .btn-primary,
        .btn.btn-primary {
            background: var(--accent-gradient);
            border: none;
            color: white;
            font-weight: 700;
            border-radius: 30px;
            transition: all 0.25s ease;
        }

            .btn-primary:hover,
            .btn.btn-primary:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(109, 40, 217, 0.30);
                color: white;
            }

        .btn-sm {
            padding: 7px 16px;
            font-size: 13px;
        }
    </style>
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Orders</h1>
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            Order List
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td>@order.OrderNumber</td>
                                <td>@order.CustomerName</td>
                                <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@order.ItemCount</td>
                                <td>$@order.TotalAmount.ToString("N2")</td>
                                <td>
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="orderId" value="@order.OrderID" />
                                        <select name="newStatus" onchange="this.form.submit()">
                                            <option value="Pending" selected="@(order.Status == "Pending")">Pending</option>
                                            <option value="Confirmed" selected="@(order.Status == "Confirmed")">Confirmed</option>
                                            <option value="Preparing" selected="@(order.Status == "Preparing")">Preparing</option>
                                            <option value="OutForDelivery" selected="@(order.Status == "OutForDelivery")">Out for Delivery</option>
                                            <option value="Delivered" selected="@(order.Status == "Delivered")">Delivered</option>
                                            <option value="Cancelled" selected="@(order.Status == "Cancelled")">Cancelled</option>
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    <a href="/StoreOwner/Order/Details?id=@order.OrderID" class="btn btn-sm btn-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
