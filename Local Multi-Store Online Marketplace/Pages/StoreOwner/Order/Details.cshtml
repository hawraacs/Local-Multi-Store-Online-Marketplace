@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Order.DetailsModel
@{
    ViewData["Title"] = $"Order #{Model.Order?.OrderNumber}";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
        }

        .container-fluid h1 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.4px;
        }

        /* -------- Breadcrumb -------- */
        .breadcrumb {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 12px 18px;
            border-radius: 14px;
            font-size: 13px;
        }

        .breadcrumb-item a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
        }

            .breadcrumb-item a:hover {
                text-decoration: underline;
            }

        .breadcrumb-item.active {
            color: var(--text-secondary);
        }

        .breadcrumb-item + .breadcrumb-item::before {
            color: var(--text-muted);
        }

        /* -------- Alerts -------- */
        .alert {
            border-radius: 14px;
            padding: 13px 18px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid transparent;
        }

        .alert-success {
            background: #ecfdf5;
            color: #065f46;
            border-color: #a7f3d0;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
            border-color: #fecaca;
        }

        /* -------- Cards -------- */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 18px;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .card-header {
            background: var(--bg-color);
            border-bottom: 1px solid var(--border-color);
            padding: 14px 20px;
            font-weight: 700;
            font-size: 14px;
            color: var(--text-primary);
        }

            .card-header i {
                color: var(--accent-color);
            }

        .card-body {
            padding: 20px;
            color: var(--text-primary);
        }

            .card-body p {
                font-size: 14px;
                margin-bottom: 10px;
                color: var(--text-secondary);
            }

                .card-body p strong {
                    color: var(--text-primary);
                }

        /* -------- Table -------- */
        .table {
            font-size: 14px;
            color: var(--text-primary);
            margin-bottom: 0;
        }

        .table-bordered {
            border: 1px solid var(--border-color);
        }

            .table-bordered th,
            .table-bordered td {
                border: 1px solid var(--border-color);
                padding: 12px 14px;
                vertical-align: middle;
            }

        .table thead th {
            background: var(--accent-light);
            color: var(--accent-color);
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            border-bottom: none;
        }

        .table tfoot th {
            background: var(--bg-color);
            font-weight: 700;
            color: var(--text-primary);
        }

        .table tfoot tr:last-child th {
            background: var(--accent-light);
            color: var(--accent-color);
            font-size: 15px;
        }

        .text-end {
            text-align: right;
        }

        /* -------- Form controls -------- */
        .form-select {
            padding: 11px 14px;
            border: 1.5px solid var(--border-color);
            border-radius: 12px;
            font-size: 14px;
            background-color: var(--bg-color);
            color: var(--text-primary);
            transition: all 0.2s ease;
        }

            .form-select:focus {
                outline: none;
                border-color: var(--accent-color);
                background-color: var(--card-bg);
                box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
            }

        /* -------- Buttons -------- */
        .btn-primary {
            background: var(--accent-gradient);
            border: none;
            color: white;
            padding: 11px 22px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .btn-primary:hover,
            .btn-primary:focus {
                background: var(--accent-gradient);
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
                color: white;
            }

        .btn-secondary {
            background: var(--card-bg);
            border: 1.5px solid var(--border-color);
            color: var(--text-secondary);
            padding: 11px 22px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.25s ease;
        }

            .btn-secondary:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                background: var(--accent-light);
            }
    </style>
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Order Details</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/StoreOwner/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/StoreOwner/Order/Index">Orders</a></li>
        <li class="breadcrumb-item active">@Model.Order?.OrderNumber</li>
    </ol>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-xl-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-user me-1"></i>
                    Customer Information
                </div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.Order?.CustomerName</p>
                    <p><strong>Email:</strong> @Model.Order?.CustomerEmail</p>
                    <p><strong>Phone:</strong> @(Model.Order?.CustomerPhone ?? "Not provided")</p>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-truck me-1"></i>
                    Shipping Address
                </div>
                <div class="card-body">
                    <p>@(Model.Order?.ShippingAddress ?? "No address provided")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-boxes me-1"></i>
            Order Items
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>$@item.Price.ToString("N2")</td>
                                <td>$@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Subtotal:</th>
                            <th>$@Model.Order?.Subtotal.ToString("N2")</th>
                        </tr>
                        <tr>
                            <th colspan="3" class="text-end">Delivery Fee:</th>
                            <th>$@Model.Order?.DeliveryFee.ToString("N2")</th>
                        </tr>
                        <tr>
                            <th colspan="3" class="text-end">Total:</th>
                            <th>$@Model.Order?.TotalAmount.ToString("N2")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-cog me-1"></i>
            Update Status
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="UpdateStatus">
                <input type="hidden" name="orderId" value="@Model.Order?.OrderID" />
                <div class="row">
                    <div class="col-md-4">
                        <select name="newStatus" class="form-select">
                            <option value="Pending" selected="@(Model.Order?.Status == "Pending")">Pending</option>
                            <option value="Confirmed" selected="@(Model.Order?.Status == "Confirmed")">Confirmed</option>
                            <option value="Preparing" selected="@(Model.Order?.Status == "Preparing")">Preparing</option>
                            <option value="OutForDelivery" selected="@(Model.Order?.Status == "OutForDelivery")">Out for Delivery</option>
                            <option value="Delivered" selected="@(Model.Order?.Status == "Delivered")">Delivered</option>
                            <option value="Cancelled" selected="@(Model.Order?.Status == "Cancelled")">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary">Update Status</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-2">
        <a href="/StoreOwner/Order/Index" class="btn btn-secondary">Back to Orders</a>
    </div>
</div>
