@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.HomeModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(Model.Store?.StoreName ?? "Store Profile") | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --border-color: #ece8f6;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* Topbar */
        .topbar {
            background: #ffffff;
            border-bottom: 1px solid var(--border-color);
            padding: 12px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .topbar > div:first-child {
                font-size: 24px;
                font-weight: 700;
                letter-spacing: -0.5px;
                color: var(--accent-color);
                font-style: italic;
            }

            .topbar > div:last-child {
                display: flex;
                gap: 20px;
                flex-wrap: wrap;
                align-items: center;
            }

            .topbar a {
                color: var(--text-primary);
                text-decoration: none;
                font-weight: 500;
                padding: 8px 12px;
                border-radius: 4px;
                transition: all 0.2s ease;
                font-size: 14px;
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .topbar a:hover {
                    color: var(--accent-color);
                    background: var(--accent-light);
                }

                .topbar a.messages-link {
                    background: var(--accent-gradient);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 14px rgba(109, 40, 217, 0.28);
                }

                    .topbar a.messages-link:hover {
                        color: #ffffff;
                        background: linear-gradient(135deg, #5b21b6 0%, #6d28d9 55%, #4338ca 100%);
                        transform: translateY(-1px);
                    }

        /* Instagram Layout Grid */
        .profile-container {
            max-width: 935px;
            width: 100%;
            margin: 30px auto;
            padding: 0 20px;
        }

        /* Header Section */
        .profile-header {
            display: flex;
            align-items: center;
            gap: 60px;
            padding-bottom: 44px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .profile-avatar-container {
            flex-shrink: 0;
        }

        .profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--accent-light);
            box-shadow: 0 6px 20px rgba(109, 40, 217, 0.15);
        }

        .profile-avatar-fallback {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: var(--accent-gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 70px;
            color: #ffffff;
            border: 3px solid var(--accent-light);
            box-shadow: 0 6px 20px rgba(109, 40, 217, 0.2);
        }

        .profile-details {
            flex-grow: 1;
        }

        .profile-username-row {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .profile-username {
            font-size: 28px;
            font-weight: 300;
            color: var(--text-primary);
            display: flex;
            align-items: center;
        }

        .edit-profile-btn {
            background-color: transparent;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-primary);
            padding: 5px 14px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
        }

            .edit-profile-btn:hover {
                background-color: var(--accent-light);
                border-color: var(--accent-color);
                color: var(--accent-color);
            }

        .profile-stats-row {
            display: flex;
            gap: 40px;
            margin-bottom: 20px;
        }

        .stat-item {
            font-size: 16px;
            color: var(--text-primary);
        }

        .stat-count {
            font-weight: 700;
            color: var(--accent-color);
        }

        .stats-message-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-light);
            color: var(--accent-color);
            border: none;
            padding: 8px 18px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            margin-bottom: 18px;
            transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
        }

            .stats-message-btn:hover {
                background: var(--accent-color);
                color: #ffffff;
                transform: translateY(-1px);
            }

        .profile-bio {
            font-size: 14px;
            line-height: 1.5;
            color: var(--text-primary);
        }

            .profile-bio h1 {
                font-size: 16px;
                font-weight: 600;
                margin-bottom: 4px;
                color: var(--accent-color);
            }

        .bio-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
        }

        .bio-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--accent-light);
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            color: var(--accent-color);
        }

        /* Instagram Navigation Tabs */
        .profile-tabs {
            display: flex;
            justify-content: center;
            border-top: 1px solid var(--border-color);
            gap: 60px;
            margin-bottom: 20px;
        }

        .tab-btn {
            background: transparent;
            border: none;
            border-top: 1px solid transparent;
            color: var(--text-primary);
            cursor: default;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            padding: 16px 0;
            text-transform: uppercase;
            margin-top: -1px;
            border-top: 2px solid var(--accent-color);
            color: var(--accent-color);
        }

        /* Instagram grid (3 columns) */
        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            margin-top: 20px;
        }

        /* Product Cards */
        .product-grid-item {
            background: #ffffff;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

            .product-grid-item:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 26px rgba(109, 40, 217, 0.14);
                border-color: var(--accent-steel);
            }

            .product-grid-item img {
                width: 100%;
                height: 200px;
                object-fit: cover;
                border-bottom: 1px solid var(--border-color);
            }

        .product-details {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

            .product-details h4 {
                font-size: 15px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 6px;
                height: 40px;
                overflow: hidden;
            }

            .product-details .price {
                font-size: 16px;
                font-weight: 700;
                color: var(--accent-color);
                margin-bottom: 4px;
            }

            .product-details .review-count {
                font-size: 12px;
                color: var(--text-secondary);
            }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
        }

        .empty-icon {
            font-size: 50px;
            margin-bottom: 16px;
            color: var(--border-color);
        }

        .empty-state h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
            max-width: 350px;
            margin: 0 auto 20px;
            line-height: 1.5;
        }

        /* Reviews inside modal */
        .review-row {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 12px;
        }

        .review-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .reviewer-link {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            text-decoration: none;
        }

            .reviewer-link:hover {
                color: var(--accent-color);
                text-decoration: underline;
            }

        .stars-row {
            display: flex;
            gap: 2px;
            font-size: 12px;
        }

        .review-row p {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.5;
            margin-bottom: 10px;
        }

        .delete-review-btn {
            width: 100%;
            background: #fee2e2;
            color: #991b1b;
            border: none;
            font-size: 11px;
            font-weight: 700;
            padding: 7px;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.15s ease;
        }

            .delete-review-btn:hover {
                background: #fecaca;
            }

        /* Modals (same overlay style as customer profile) */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(30, 27, 46, 0.65);
            backdrop-filter: blur(4px);
        }

            .modal.flex {
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px;
            }

        .product-modal-content {
            background-color: #ffffff;
            border-radius: 16px;
            width: 100%;
            max-width: 470px;
            height: auto;
            max-height: 90vh;
            box-shadow: 0 20px 60px rgba(30, 27, 46, 0.35);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            cursor: grab;
            transition: transform 0.32s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.32s ease;
            transform: translateY(0);
            opacity: 1;
        }

            .product-modal-content.dragging {
                cursor: grabbing;
            }

            .product-modal-content.modal-enter {
                opacity: 0;
                transform: translateY(24px) scale(0.98);
            }

            .product-modal-content.slide-up-out {
                transform: translateY(-6%);
                opacity: 0;
            }

            .product-modal-content.slide-down-out {
                transform: translateY(6%);
                opacity: 0;
            }

            .product-modal-content.slide-up-in-start {
                transform: translateY(100%);
                opacity: 0;
            }

            .product-modal-content.slide-down-in-start {
                transform: translateY(-100%);
                opacity: 0;
            }

        /* Media always on top, info/reviews always stacked below - no side-by-side layout.
                   Square aspect ratio, matching a classic Instagram post. */

        .product-modal-media {
            background: #1e1b2e;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            aspect-ratio: 1 / 1;
            flex-shrink: 0;
            position: relative;
        }

            .product-modal-media img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .product-modal-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .product-modal-header {
            padding: 16px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .product-modal-store {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .product-modal-store img {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                object-fit: cover;
                border: 1px solid var(--border-color);
            }

            .product-modal-store span {
                font-size: 13px;
                font-weight: 600;
                color: var(--text-primary);
            }

        .close-modal {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 20px;
            font-weight: bold;
            color: var(--text-secondary);
            background: var(--bg-color);
            cursor: pointer;
            line-height: 1;
            transition: color 0.15s ease, background-color 0.15s ease;
        }

            .close-modal:hover {
                color: #ffffff;
                background: var(--accent-color);
            }

        .product-modal-meta {
            padding: 16px;
            border-bottom: 1px solid var(--border-color);
            background: var(--bg-color);
        }

            .product-modal-meta h3 {
                font-size: 15px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 6px;
            }

            .product-modal-meta .price {
                font-size: 17px;
                font-weight: 700;
                color: var(--accent-color);
                margin-bottom: 8px;
            }

            .product-modal-meta p {
                font-size: 13px;
                color: var(--text-secondary);
                line-height: 1.5;
            }

        .product-modal-reviews {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }

            .product-modal-reviews > span {
                font-size: 11px;
                font-weight: 700;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 1px;
                display: block;
                margin-bottom: 10px;
            }

        /* Lightbox nav arrows removed - navigation is swipe/drag/scroll/keyboard only */

        footer {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-secondary);
            font-size: 12px;
            border-top: 1px solid var(--border-color);
            margin-top: 40px;
        }

        @@media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
                gap: 24px;
                padding-bottom: 24px;
            }

            .profile-stats-row {
                justify-content: center;
            }

            .instagram-grid {
                grid-template-columns: repeat(1, 1fr);
                gap: 16px;
            }

            .profile-tabs {
                gap: 20px;
            }
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div>realnest</div>

        <div>
            <a href="/StoreOwner/Dashboard">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <a href="/StoreOwner/Products">
                <i class="fas fa-boxes-stacked"></i> Products
            </a>
            <a href="/StoreOwner/Orders">
                <i class="fas fa-truck"></i> Orders
            </a>
            <a href="/StoreOwner/Home">
                <i class="fas fa-store"></i> Profile
            </a>
            <a href="/StoreOwner/Messages" class="messages-link">
                <i class="fas fa-comments"></i> Messages
            </a>
        </div>
    </div>

    <div class="profile-container">

        <!-- Instagram Profile Header -->
        <div class="profile-header">
            <div class="profile-avatar-container">
                @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
                {
                    <img class="profile-avatar" src="@Model.Store.LogoURL" alt="@Model.Store.StoreName Logo" />
                }
                else
                {
                    <div class="profile-avatar-fallback">
                        <i class="fas fa-store"></i>
                    </div>
                }
            </div>

            <div class="profile-details">
                <div class="profile-username-row">
                    <h2 class="profile-username">
                        @Model.Store?.StoreName
                    </h2>
                    <a asp-page="/StoreOwner/StoreProfile" class="edit-profile-btn">Edit Profile</a>
                </div>

                <div class="profile-stats-row">
                    <div class="stat-item">
                        <span class="stat-count">@Model.Products.Count</span> products
                    </div>
                    <div class="stat-item">
                        <span class="stat-count">@Model.FollowersCount</span> followers
                    </div>
                    <div class="stat-item">
                        <span class="stat-count">@Model.Products.Sum(p => p.Reviews?.Count ?? 0)</span> reviews
                    </div>
                </div>

                <a href="/StoreOwner/Messages" class="stats-message-btn">
                    <i class="fas fa-comment-dots"></i> Messages
                </a>

                <div class="profile-bio">
                    <h1>Official Store Account</h1>
                    <p>@Model.Store?.Description</p>
                </div>
            </div>
        </div>

        <!-- Tabs (single Products tab, kept for visual consistency) -->
        <div class="profile-tabs">
            <button class="tab-btn">
                <i class="fas fa-table-cells"></i> Products
            </button>
        </div>

        <!-- Products Grid -->
        @if (Model.Products.Any())
        {
            <div class="instagram-grid">
                @foreach (var p in Model.Products)
                {
                    var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

                    <div class="product-grid-item" onclick="openProductModal(@p.ProductID)">
                        <img src="@img" alt="@p.ProductName" />
                        <div class="product-details">
                            <h4>@p.ProductName</h4>
                            <span class="price">$@p.Price</span>
                            <span class="review-count"><i class="fas fa-star" style="color:#FFC107;"></i> @(p.Reviews?.Count ?? 0) reviews</span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                <h3>No Products Yet</h3>
                <p>Once you add products to your store, they'll show up here just like an Instagram feed.</p>
            </div>
        }

    </div>

    <!-- Products now open full-page; navigation is via swipe, mouse drag, scroll wheel, or arrow keys -->
    <!-- One modal per product -->
    @foreach (var p in Model.Products)
    {
        var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

        <div id="modal-@p.ProductID" class="modal" data-product-id="@p.ProductID" onclick="handleOutsideClick(event, @p.ProductID)">
            <div class="product-modal-content" onclick="event.stopPropagation()">

                <div class="product-modal-media">
                    <img src="@img" alt="@p.ProductName" />
                </div>

                <div class="product-modal-info">
                    <div class="product-modal-header">
                        <div class="product-modal-store">
                            @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
                            {
                                <img src="@Model.Store.LogoURL" alt="@Model.Store.StoreName" />
                            }
                            <span>@Model.Store?.StoreName</span>
                        </div>
                        <span class="close-modal" onclick="closeProductModal(@p.ProductID)">&times;</span>
                    </div>

                    <div class="product-modal-meta">
                        <h3>@p.ProductName</h3>
                        <div class="price">$@p.Price</div>
                        <p>@p.Description</p>
                    </div>

                    <div class="product-modal-reviews">
                        <span>Feedback Section</span>

                        @if (p.Reviews != null && p.Reviews.Any())
                        {
                            @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="review-row">
                                    <div class="review-top">
                                        <a href="/StoreViewCustomer/@review.CustomerID" class="reviewer-link">
                                            @review.Customer?.User?.FullName
                                        </a>
                                        <div class="stars-row">
                                            @for (int i = 0; i < review.Rating; i++)
                                            {
                                                <i class="fas fa-star" style="color:#FFC107;"></i>
                                            }
                                        </div>
                                    </div>
                                    <p>@review.Comment</p>

                                    <form method="post" asp-page-handler="DeleteReview" asp-route-reviewId="@review.ReviewID">
                                        <button type="submit" class="delete-review-btn">
                                            <i class="fa-solid fa-trash-can"></i> Remove Review
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state" style="padding:30px 10px;">
                                <div class="empty-icon" style="font-size:32px; margin-bottom:8px;"><i class="far fa-comment"></i></div>
                                <p style="margin:0;">No reviews posted for this item yet.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <footer>
        <span>✨ Realnest — your local marketplace companion ✨</span>
    </footer>

    <script>
        // Ordered list of product IDs, in the same order they appear in the grid.
        // Used to figure out "next" and "previous" when navigating like an Instagram lightbox.
        const productOrder = [@Html.Raw(string.Join(",", Model.Products.Select(p => p.ProductID)))];
        let currentProductId = null;

        function openProductModal(id) {
            const modal = document.getElementById('modal-' + id);
            if (!modal) return;

            const content = modal.querySelector('.product-modal-content');
            modal.classList.add('flex');
            if (content) {
                content.classList.add('modal-enter');
                // Force reflow so the transition actually plays
                void content.offsetWidth;
                content.classList.remove('modal-enter');
            }
            document.body.style.overflow = 'hidden';
            currentProductId = id;
        }

        function closeProductModal(id) {
            const modal = document.getElementById('modal-' + id);
            if (modal) {
                modal.classList.remove('flex');
                document.body.style.overflow = '';
                currentProductId = null;
            }
        }

        function handleOutsideClick(event, id) {
            const modal = document.getElementById('modal-' + id);
            if (event.target === modal) {
                closeProductModal(id);
            }
        }

        // direction: -1 for previous post, 1 for next post.
        // Slides the current post out and the next one in over the same beat, instead of
        // instantly closing/reopening, so it reads as one continuous motion.
        let navigating = false;

        function goToAdjacentProduct(direction) {
            if (currentProductId === null || navigating) return;

            const index = productOrder.indexOf(currentProductId);
            const newIndex = index + direction;

            if (newIndex < 0 || newIndex >= productOrder.length) return;

            const oldId = currentProductId;
            const newId = productOrder[newIndex];

            const oldModal = document.getElementById('modal-' + oldId);
            const newModal = document.getElementById('modal-' + newId);
            if (!oldModal || !newModal) return;

            const oldContent = oldModal.querySelector('.product-modal-content');
            const newContent = newModal.querySelector('.product-modal-content');

            navigating = true;

            // Stack the incoming post above the outgoing one while both are visible
            newModal.classList.add('flex');
            newModal.style.zIndex = '1050';
            newContent.classList.add(direction > 0 ? 'slide-up-in-start' : 'slide-down-in-start');

            // Force reflow so the starting position is applied before we animate away from it
            void newContent.offsetWidth;

            oldContent.classList.add(direction > 0 ? 'slide-up-out' : 'slide-down-out');
            newContent.classList.remove('slide-up-in-start', 'slide-down-in-start');

            currentProductId = newId;

            setTimeout(function () {
                oldModal.classList.remove('flex');
                oldContent.classList.remove('slide-up-out', 'slide-down-out');
                newModal.style.zIndex = '';
                navigating = false;
            }, 340);
        }

        // Keyboard navigation: Down/Right = next post, Up/Left = previous post, Escape closes
        document.addEventListener('keydown', function (e) {
            if (currentProductId === null) return;

            if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
                goToAdjacentProduct(1);
            } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
                goToAdjacentProduct(-1);
            } else if (e.key === 'Escape') {
                closeProductModal(currentProductId);
            }
        });

        // Vertical swipe navigation for touch devices, Instagram/Reels style:
        // swipe up -> next post, swipe down -> previous post
        let touchStartY = 0;
        let touchEndY = 0;
        const SWIPE_THRESHOLD = 50;

        document.addEventListener('touchstart', function (e) {
            if (currentProductId === null) return;
            touchStartY = e.changedTouches[0].screenY;
        }, { passive: true });

        document.addEventListener('touchend', function (e) {
            if (currentProductId === null) return;
            touchEndY = e.changedTouches[0].screenY;
            const diff = touchEndY - touchStartY;

            if (Math.abs(diff) < SWIPE_THRESHOLD) return;

            if (diff < 0) {
                // swiped up -> next post
                goToAdjacentProduct(1);
            } else {
                // swiped down -> previous post
                goToAdjacentProduct(-1);
            }
        }, { passive: true });

        // Mouse drag navigation (click and drag up/down), same feel as the touch swipe.
        // Ignored if the drag starts on a button, link, form, or input so clicks still work normally.
        let isDragging = false;
        let dragStartY = 0;

        function isInteractiveTarget(target) {
            return !!target.closest('button, a, input, textarea, select, form, .close-modal');
        }

        document.addEventListener('mousedown', function (e) {
            if (currentProductId === null) return;
            if (isInteractiveTarget(e.target)) return;

            isDragging = true;
            dragStartY = e.clientY;

            const content = document.querySelector('#modal-' + currentProductId + ' .product-modal-content');
            if (content) content.classList.add('dragging');
        });

        document.addEventListener('mouseup', function (e) {
            if (!isDragging) return;
            isDragging = false;

            const content = currentProductId !== null
                ? document.querySelector('#modal-' + currentProductId + ' .product-modal-content')
                : null;
            if (content) content.classList.remove('dragging');

            if (currentProductId === null) return;

            const diff = e.clientY - dragStartY;
            if (Math.abs(diff) < SWIPE_THRESHOLD) return;

            if (diff < 0) {
                // dragged up -> next post
                goToAdjacentProduct(1);
            } else {
                // dragged down -> previous post
                goToAdjacentProduct(-1);
            }
        });

        document.addEventListener('mouseleave', function () {
            if (!isDragging) return;
            isDragging = false;
            const content = currentProductId !== null
                ? document.querySelector('#modal-' + currentProductId + ' .product-modal-content')
                : null;
            if (content) content.classList.remove('dragging');
        });

        // Mouse wheel navigation for desktop, same up/down feel
        let wheelLocked = false;
        document.addEventListener('wheel', function (e) {
            if (currentProductId === null) return;
            if (wheelLocked) return;

            if (Math.abs(e.deltaY) < 30) return;

            wheelLocked = true;
            if (e.deltaY > 0) {
                goToAdjacentProduct(1);
            } else {
                goToAdjacentProduct(-1);
            }
            setTimeout(() => { wheelLocked = false; }, 500);
        }, { passive: true });

        window.onload = function () {
            const params = new URLSearchParams(window.location.search);
            const productId = params.get('productId');

            if (productId) {
                const productCard = document.getElementById('modal-' + productId)
                    ? document.querySelector('[onclick*="openProductModal(' + productId + ')"]')
                    : null;

                if (productCard) {
                    productCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    setTimeout(() => openProductModal(productId), 800);
                }
            }
        };
    </script>

</body>
</html>