@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.HomeModel
@{
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
    ViewData["Title"] = Model.Store?.StoreName ?? "Store Profile";
    ViewData["HideNavbar"] = true;   // Hides the top navbar, shows only sidebar
}

<!-- Tailwind CSS and FontAwesome Icons -->
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>
    /* Premium Orange & White Styling Details */
    .instagram-avatar-ring {
        background: linear-gradient(45deg, #FF5722, #FF9800);
        padding: 3px;
    }

    .text-brand-orange {
        color: #FF5722;
    }

    .bg-brand-orange {
        background-color: #FF5722;
    }

    .bg-brand-orange-hover:hover {
        background-color: #E64A19;
    }

    .border-brand-orange {
        border-color: #FF5722;
    }
</style>

<div class="bg-white min-h-screen pb-12">
    <div class="max-w-4xl mx-auto px-4 pt-8">

        <!-- INSTAGRAM-STYLE PROFILE HEADER -->
        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-16 border-b border-gray-200 pb-10 mb-8">

            <!-- Left: Avatar Ring (Styled like an Active IG Story) -->
            <div class="flex-shrink-0">
                <div class="instagram-avatar-ring rounded-full shadow-md">
                    <div class="bg-white rounded-full p-1">
                        <img class="w-24 h-24 md:w-36 md:h-36 rounded-full object-cover"
                             src="@(Model.Store.LogoURL ?? "/images/store.png")"
                             alt="@Model.Store.StoreName Logo" />
                    </div>
                </div>
            </div>

            <!-- Right: Details, Buttons, Stats & Bio -->
            <div class="flex-1 text-center md:text-left">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-5">
                    <h2 class="text-2xl font-light text-gray-800 tracking-tight">@Model.Store.StoreName</h2>

                    <a asp-page="/StoreOwner/StoreProfile"
                       class="inline-block px-6 py-1.5 border border-gray-300 text-gray-700 hover:text-orange-500 hover:border-orange-500 font-bold text-xs rounded-md transition-all">
                        Edit Profile
                    </a>
                </div>

                <!-- Stats Row -->
                <div class="flex justify-center md:justify-start gap-8 text-sm text-gray-600 mb-5">
                    <div>
                        <span class="font-bold text-gray-900">@Model.Products.Count</span> products
                    </div>
                    <div>
                        <span class="font-bold text-gray-900">@Model.FollowersCount</span> followers
                    </div>
                </div>

                <!-- Bio / Description Area -->
                <div class="text-sm text-gray-800 space-y-1 max-w-lg">
                    <span class="font-bold block text-orange-500">Official Store Account</span>
                    <p class="leading-relaxed text-gray-600">@Model.Store.Description</p>
                </div>
            </div>

        </div>

        <!-- PROFILE TABS SELECTOR (Instagram Style) -->
        <div class="flex justify-center border-t border-gray-200 mb-6">
            <div class="flex items-center space-x-12">
                <button class="flex items-center space-x-1.5 border-t-2 border-orange-500 py-3 text-xs font-bold tracking-widest text-orange-500 uppercase focus:outline-none">
                    <i class="fa-solid fa-table-cells text-sm"></i>
                    <span>Products</span>
                </button>
            </div>
        </div>

        <!-- INSTAGRAM EXPLORE-STYLE PRODUCT THUMBNAIL GRID -->
        <div class="grid grid-cols-3 gap-1 md:gap-4">
            @foreach (var p in Model.Products)
            {
                var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

                <!-- Interactive Instagram Square Card -->
                <div id="product-@p.ProductID"
                     onclick="openProductModal(@p.ProductID)"
                     class="aspect-square relative group overflow-hidden bg-gray-50 cursor-pointer rounded shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md">

                    <img src="@img"
                         alt="@p.ProductName"
                         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />

                    <!-- Dark Hover Overlay showing Price & Interaction details -->
                    <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center justify-center text-white space-y-1">
                        <span class="font-extrabold text-sm md:text-lg tracking-tight">$@p.Price</span>
                        <div class="flex items-center space-x-2 text-xs opacity-90">
                            <i class="fa-solid fa-star text-orange-400"></i>
                            <span>@(p.Reviews?.Count ?? 0) Reviews</span>
                        </div>
                    </div>

                    <!-- Highlight marker for query-selected item -->
                    <div id="highlight-border-@p.ProductID" class="absolute inset-0 border-4 border-transparent pointer-events-none transition-all duration-300"></div>
                </div>
            }
        </div>

    </div>
</div>

<!-- INSTAGRAM-STYLE DETAIL MODALS (ONE FOR EACH PRODUCT) -->
@foreach (var p in Model.Products)
{
    var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

    <div id="modal-@p.ProductID"
         class="hidden fixed inset-0 z-50 overflow-y-auto bg-black bg-opacity-70 flex items-center justify-center p-4 transition-opacity duration-300"
         onclick="handleOutsideClick(event, @p.ProductID)">

        <!-- Modal Wrapper Content Container -->
        <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full overflow-hidden flex flex-col md:flex-row max-h-[90vh] md:max-h-[80vh]">

            <!-- Left Side: Product Media Panel -->
            <div class="w-full md:w-3/5 bg-black flex items-center justify-center relative aspect-square md:aspect-auto">
                <img src="@img" alt="@p.ProductName" class="max-w-full max-h-full object-contain" />
                <button onclick="closeProductModal(@p.ProductID)" class="absolute top-4 left-4 md:hidden text-white bg-black bg-opacity-50 w-8 h-8 rounded-full flex items-center justify-center">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
            </div>

            <!-- Right Side: Details & Interactive Review Thread -->
            <div class="w-full md:w-2/5 flex flex-col bg-white border-l border-gray-100">

                <!-- Inner Header: Store Profile metadata -->
                <div class="p-4 border-b border-gray-100 flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <img class="w-8 h-8 rounded-full object-cover"
                             src="@(Model.Store.LogoURL ?? "/images/store.png")"
                             alt="@Model.Store.StoreName Logo" />
                        <div>
                            <span class="font-bold text-xs text-gray-800">@Model.Store.StoreName</span>
                            <span class="text-[10px] text-gray-400 block font-medium">Store Owner View</span>
                        </div>
                    </div>
                    <button onclick="closeProductModal(@p.ProductID)" class="hidden md:inline-block text-gray-400 hover:text-gray-600">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>

                <!-- Product General Meta Summary -->
                <div class="p-4 border-b border-gray-50 bg-gray-50/50">
                    <h3 class="font-bold text-sm text-gray-900 mb-1">@p.ProductName</h3>
                    <div class="text-base font-extrabold text-orange-500 mb-2">$@p.Price</div>
                    <p class="text-xs text-gray-600 leading-relaxed">@p.Description</p>
                </div>

                <!-- Scrolling Section: Customer Reviews -->
                <div class="flex-1 overflow-y-auto p-4 space-y-4 max-h-[350px]">
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Feedback Section</span>

                    @if (p.Reviews != null && p.Reviews.Any())
                    {
                        @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="bg-gray-50 rounded-xl p-3 border border-gray-100 relative group/review">
                                <div class="flex items-center justify-between mb-1.5">
                                    <span class="font-bold text-xs text-gray-800">
                                        @review.Customer?.User?.FullName
                                    </span>
                                    <span class="text-xs text-orange-400">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="fa-solid fa-star"></i>
                                        }
                                    </span>
                                </div>
                                <p class="text-xs text-gray-600 leading-relaxed mb-3">@review.Comment</p>

                                <!-- Delete Action Form -->
                                <form method="post"
                                      asp-page-handler="DeleteReview"
                                      asp-route-reviewId="@review.ReviewID"
                                      class="m-0">
                                    <button type="submit"
                                            class="w-full bg-red-50 hover:bg-red-100 text-red-600 text-[10px] font-bold py-1.5 rounded-lg transition-colors flex items-center justify-center space-x-1">
                                        <i class="fa-solid fa-trash-can"></i>
                                        <span>Remove Review</span>
                                    </button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-6 text-gray-400 text-xs">
                            <i class="fa-solid fa-message text-lg mb-2 block opacity-30"></i>
                            No reviews posted for this item yet.
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
}

<!-- DIALOG TOGGLE SCRIPTS & AUTO-HIGHLIGHT ROUTINE -->
<script>
    function openProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (modal) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        }
    }

    function closeProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }
    }

    function handleOutsideClick(event, id) {
        const modal = document.getElementById('modal-' + id);
        if (event.target === modal) {
            closeProductModal(id);
        }
    }

    window.onload = function () {
        const params = new URLSearchParams(window.location.search);
        const productId = params.get('productId');

        if (productId) {
            const productCard = document.getElementById('product-' + productId);
            const borderIndicator = document.getElementById('highlight-border-' + productId);

            if (productCard) {
                // Instantly scroll smoothly to view the targeted product
                productCard.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });

                // Apply active orange pulse border styling to the target
                if (borderIndicator) {
                    borderIndicator.style.borderColor = '#FF5722';
                }

                // Programmatically pop open its corresponding IG modal drawer
                setTimeout(() => {
                    openProductModal(productId);
                }, 800);

                // Auto-clear active highlights after 4 seconds
                setTimeout(() => {
                    if (borderIndicator) {
                        borderIndicator.style.borderColor = 'transparent';
                    }
                }, 4000);
            }
        }
    };
</script>