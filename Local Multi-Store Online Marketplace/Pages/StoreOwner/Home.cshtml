@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.HomeModel
@{
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
           ROOT VARIABLES — premium brand palette
           ============================================================ */
        :root {
            /* Brand colors */
            --accent: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-dark: #4c1d95;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --accent-glow: 0 8px 32px rgba(109, 40, 217, 0.25);

            /* Neutrals */
            --bg: #f6f5fa;
            --surface: #ffffff;
            --surface-hover: #faf9fe;
            --text-primary: #1a1625;
            --text-secondary: #6b6478;
            --text-muted: #a5a0b4;
            --border: #edeaf5;
            --border-focus: #d4cee8;

            /* Semantic */
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;

            /* Shadows */
            --shadow-xs: 0 1px 3px rgba(30, 27, 46, 0.04);
            --shadow-sm: 0 4px 16px rgba(109, 40, 217, 0.07);
            --shadow-md: 0 12px 40px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 24px 60px rgba(30, 27, 46, 0.15);
            --shadow-xl: 0 32px 80px rgba(30, 27, 46, 0.20);

            /* Radius */
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;

            /* Transitions */
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
            --duration: 0.35s;
        }

        /* ============================================================
           BASE
           ============================================================ */
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
           CONTAINER
           ============================================================ */
        .profile-container {
            max-width: 1010px;
            width: 100%;
            margin: 28px auto;
            padding: 0 24px;
        }

        /* ============================================================
           PROFILE HEADER — premium card with subtle gradient border
           ============================================================ */
        .profile-header {
            display: flex;
            align-items: center;
            gap: 48px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 32px 40px;
            position: relative;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            transition: box-shadow var(--duration) var(--ease);
            margin-bottom: 32px;
        }

        .profile-header::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: var(--radius-lg);
            padding: 1.5px;
            background: var(--accent-gradient);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            opacity: 0.4;
        }

        .profile-header:hover {
            box-shadow: var(--shadow-md);
        }

        /* ----- Avatar ----- */
        .profile-avatar-container {
            flex-shrink: 0;
            position: relative;
        }

        .profile-avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--surface);
            box-shadow: var(--shadow-sm), 0 0 0 4px var(--accent-light);
            transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
        }

        .profile-avatar:hover {
            transform: scale(1.02);
            box-shadow: var(--shadow-md), 0 0 0 6px var(--accent-light);
        }

        .profile-avatar-fallback {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            background: var(--accent-gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 52px;
            color: #fff;
            box-shadow: var(--shadow-sm), 0 0 0 4px var(--accent-light);
        }

        /* Status dot on avatar */
        .avatar-status {
            position: absolute;
            bottom: 6px;
            right: 6px;
            width: 20px;
            height: 20px;
            background: var(--success);
            border-radius: 50%;
            border: 3px solid var(--surface);
            box-shadow: var(--shadow-xs);
        }

        /* ----- Details ----- */
        .profile-details {
            flex: 1;
            min-width: 0;
        }

        .profile-username-row {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 14px;
        }

        .profile-username {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.6px;
            color: var(--text-primary);
            background: var(--accent-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .edit-profile-btn {
            background: var(--accent-light);
            border: none;
            border-radius: 40px;
            color: var(--accent);
            padding: 8px 22px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            -webkit-text-fill-color: var(--accent);
        }

        .edit-profile-btn:hover {
            background: var(--accent);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: var(--accent-glow);
            -webkit-text-fill-color: #fff;
        }

        .edit-profile-btn i {
            font-size: 13px;
        }

        /* ----- Stats Row ----- */
        .profile-stats-row {
            display: flex;
            gap: 40px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .stat-item {
            display: flex;
            align-items: baseline;
            gap: 6px;
            font-size: 14px;
            color: var(--text-secondary);
        }

        .stat-count {
            font-weight: 800;
            font-size: 18px;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }

        .stat-item .stat-icon {
            color: var(--accent);
            opacity: 0.6;
            font-size: 15px;
            margin-right: 2px;
        }

        /* ----- Message Button ----- */
        .stats-message-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-gradient);
            color: #fff;
            padding: 10px 24px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            margin-bottom: 16px;
            transition: all var(--duration) var(--ease);
            box-shadow: var(--accent-glow);
            border: none;
            cursor: pointer;
        }

        .stats-message-btn:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 12px 40px rgba(109, 40, 217, 0.35);
            color: #fff;
        }

        .stats-message-btn i {
            font-size: 15px;
        }

        /* ----- Bio ----- */
        .profile-bio {
            font-size: 14px;
            line-height: 1.7;
            color: var(--text-secondary);
            max-width: 500px;
        }

        .profile-bio .bio-label {
            display: inline-block;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--accent);
            background: var(--accent-light);
            padding: 2px 12px;
            border-radius: 20px;
            margin-bottom: 6px;
        }

        .profile-bio p {
            margin: 0;
        }

        .bio-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }

        .bio-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--accent-light);
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
        }

        .bio-badge i {
            font-size: 11px;
        }

        /* ============================================================
           TABS
           ============================================================ */
        .profile-tabs {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 28px;
        }

        .tab-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            cursor: default;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.5px;
            padding: 10px 28px;
            text-transform: uppercase;
            border-radius: 40px;
            box-shadow: var(--shadow-xs);
            transition: all var(--duration) var(--ease);
        }

        .tab-btn.active {
            background: var(--accent-gradient);
            color: #fff;
            border-color: transparent;
            box-shadow: var(--accent-glow);
        }

        .tab-btn i {
            font-size: 14px;
        }

        /* ============================================================
           PRODUCT GRID — with masonry feel & hover effects
           ============================================================ */
        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 4px;
        }

        .product-grid-item {
            background: var(--surface);
            border-radius: var(--radius-md);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            border: 1px solid var(--border);
            transition: all var(--duration) var(--ease);
            position: relative;
        }

        .product-grid-item:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
            border-color: var(--accent);
        }

        .product-grid-item .image-wrap {
            position: relative;
            overflow: hidden;
            background: var(--bg);
            aspect-ratio: 1 / 1;
        }

        .product-grid-item .image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s var(--ease);
        }

        .product-grid-item:hover .image-wrap img {
            transform: scale(1.05);
        }

        /* Badge on image */
        .product-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: var(--accent-gradient);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 14px;
            border-radius: 20px;
            box-shadow: var(--shadow-sm);
            backdrop-filter: blur(4px);
        }

        /* Quick action overlay */
        .product-quick-actions {
            position: absolute;
            inset: 0;
            background: rgba(26, 22, 37, 0.3);
            backdrop-filter: blur(2px);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            opacity: 0;
            transition: opacity var(--duration) var(--ease);
        }

        .product-grid-item:hover .product-quick-actions {
            opacity: 1;
        }

        .product-quick-actions button {
            background: var(--surface);
            border: none;
            border-radius: 50%;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            color: var(--text-primary);
            cursor: pointer;
            transition: all 0.2s var(--ease);
            box-shadow: var(--shadow-md);
        }

        .product-quick-actions button:hover {
            background: var(--accent);
            color: #fff;
            transform: scale(1.1);
        }

        /* Product details */
        .product-details {
            padding: 16px 18px 18px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-details .product-name {
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-details .product-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 10px;
            border-top: 1px solid var(--border);
        }

        .product-details .price {
            font-size: 17px;
            font-weight: 800;
            color: var(--accent);
        }

        .product-details .review-count {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .product-details .review-count i {
            color: var(--warning);
        }

        /* ============================================================
           EMPTY STATE — elevated & friendly
           ============================================================ */
        .empty-state {
            text-align: center;
            padding: 72px 24px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 2px dashed var(--border);
            transition: all var(--duration) var(--ease);
        }

        .empty-state:hover {
            border-color: var(--accent-light);
            background: var(--surface-hover);
        }

        .empty-icon {
            font-size: 52px;
            margin-bottom: 20px;
            color: var(--accent);
            opacity: 0.3;
            display: inline-block;
        }

        .empty-state h3 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 15px;
            color: var(--text-secondary);
            max-width: 380px;
            margin: 0 auto 24px;
            line-height: 1.7;
        }

        .empty-state .empty-action-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-gradient);
            color: #fff;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            box-shadow: var(--accent-glow);
            transition: all var(--duration) var(--ease);
            border: none;
            cursor: pointer;
        }

        .empty-state .empty-action-btn:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 16px 48px rgba(109, 40, 217, 0.35);
            color: #fff;
        }

        /* ============================================================
           MODAL — premium product detail overlay
           ============================================================ */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            inset: 0;
            background: rgba(26, 22, 37, 0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            animation: modalFadeIn 0.3s var(--ease);
        }

        .modal.flex {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        @@keyframes modalFadeIn {
            from {
                opacity: 0;
                transform: scale(0.96);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .product-modal-content {
            background: var(--surface);
            border-radius: var(--radius-lg);
            width: 100%;
            max-width: 880px;
            max-height: 90vh;
            box-shadow: var(--shadow-xl);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: modalContentIn 0.35s var(--ease);
        }

        @@keyframes modalContentIn {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.97);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@media (min-width: 768px) {
            .product-modal-content {
                flex-direction: row;
                max-height: 85vh;
            }
        }

        /* ----- Modal Media ----- */
        .product-modal-media {
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            position: relative;
            min-height: 260px;
        }

        .product-modal-media img {
            width: 100%;
            height: 100%;
            max-height: 360px;
            object-fit: contain;
            padding: 12px;
        }

        @@media (min-width: 768px) {
            .product-modal-media {
                width: 50%;
                min-height: 420px;
            }
            .product-modal-media img {
                max-height: 100%;
                padding: 24px;
            }
        }

        .product-modal-media .image-counter {
            position: absolute;
            bottom: 16px;
            right: 16px;
            background: rgba(26, 22, 37, 0.6);
            backdrop-filter: blur(4px);
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 14px;
            border-radius: 20px;
        }

        /* ----- Modal Info ----- */
        .product-modal-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
            background: var(--surface);
        }

        /* Header */
        .product-modal-header {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .product-modal-store {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .product-modal-store img {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 1.5px solid var(--border);
        }

        .product-modal-store .store-name {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .product-modal-store .store-badge {
            font-size: 10px;
            font-weight: 600;
            color: var(--accent);
            background: var(--accent-light);
            padding: 1px 10px;
            border-radius: 12px;
            margin-left: 4px;
        }

        .close-modal {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--bg);
            border: none;
            font-size: 20px;
            font-weight: 300;
            color: var(--text-secondary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s var(--ease);
        }

        .close-modal:hover {
            background: var(--accent);
            color: #fff;
            transform: rotate(90deg);
        }

        /* Meta */
        .product-modal-meta {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .product-modal-meta h3 {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 4px;
            letter-spacing: -0.3px;
        }

        .product-modal-meta .price-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }

        .product-modal-meta .price {
            font-size: 22px;
            font-weight: 800;
            color: var(--accent);
        }

        .product-modal-meta .price-badge {
            font-size: 11px;
            font-weight: 600;
            color: var(--success);
            background: #ecfdf5;
            padding: 2px 14px;
            border-radius: 20px;
        }

        .product-modal-meta .description {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.7;
            margin: 0;
        }

        /* Reviews */
        .product-modal-reviews {
            flex: 1;
            overflow-y: auto;
            padding: 18px 22px 22px;
        }

        .product-modal-reviews .reviews-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .product-modal-reviews .reviews-header span {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-muted);
        }

        .product-modal-reviews .reviews-header .review-count-badge {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            background: var(--bg);
            padding: 2px 14px;
            border-radius: 20px;
        }

        /* Review row */
        .review-row {
            background: var(--bg);
            border-radius: var(--radius-sm);
            padding: 14px 16px;
            margin-bottom: 12px;
            transition: all 0.2s var(--ease);
            border: 1px solid transparent;
        }

        .review-row:hover {
            border-color: var(--border);
            background: var(--surface-hover);
        }

        .review-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .reviewer-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--accent-gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .reviewer-link {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
        }

        .reviewer-link:hover {
            color: var(--accent);
        }

        .review-date {
            font-size: 11px;
            color: var(--text-muted);
        }

        .stars-row {
            display: flex;
            gap: 2px;
            font-size: 12px;
            color: var(--warning);
        }

        .review-row .review-comment {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.6;
            margin: 6px 0 10px;
            padding-left: 40px;
        }

        .delete-review-btn {
            width: 100%;
            background: #fef2f2;
            color: var(--error);
            border: none;
            font-size: 11px;
            font-weight: 700;
            padding: 8px 0;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all 0.2s var(--ease);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .delete-review-btn:hover {
            background: #fee2e2;
            transform: scale(1.01);
        }

        /* Empty reviews in modal */
        .empty-reviews {
            text-align: center;
            padding: 32px 12px;
            color: var(--text-muted);
        }

        .empty-reviews i {
            font-size: 32px;
            opacity: 0.3;
            margin-bottom: 8px;
            display: block;
        }

        .empty-reviews p {
            font-size: 13px;
            margin: 0;
        }

        /* ============================================================
           MODAL NAV ARROWS
           ============================================================ */
        .modal-nav-arrow {
            position: fixed;
            top: 50%;
            transform: translateY(-50%);
            z-index: 1100;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-primary);
            font-size: 18px;
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: var(--shadow-md);
            transition: all 0.2s var(--ease);
        }

        .modal-nav-arrow:hover {
            background: var(--accent);
            color: #fff;
            transform: translateY(-50%) scale(1.06);
            box-shadow: var(--accent-glow);
        }

        .modal-nav-arrow.prev {
            left: 20px;
        }
        .modal-nav-arrow.next {
            right: 20px;
        }

        .modal-nav-arrow.disabled {
            opacity: 0.25;
            pointer-events: none;
        }

        @@media (max-width: 640px) {
            .modal-nav-arrow {
                width: 40px;
                height: 40px;
                font-size: 15px;
            }
            .modal-nav-arrow.prev {
                left: 8px;
            }
            .modal-nav-arrow.next {
                right: 8px;
            }
        }

        /* ============================================================
           RESPONSIVE
           ============================================================ */
        @@media (max-width: 900px) {
            .instagram-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }
        }

        @@media (max-width: 768px) {
            .profile-container {
                padding: 0 16px;
                margin: 16px auto;
            }

            .profile-header {
                flex-direction: column;
                text-align: center;
                gap: 20px;
                padding: 28px 20px;
            }

            .profile-stats-row {
                justify-content: center;
                gap: 24px;
            }

            .profile-username-row {
                justify-content: center;
            }

            .profile-bio {
                max-width: 100%;
                text-align: center;
            }

            .bio-badges {
                justify-content: center;
            }

            .profile-tabs {
                gap: 8px;
            }
            .tab-btn {
                padding: 8px 18px;
                font-size: 11px;
            }

            .product-modal-content {
                max-height: 95vh;
                border-radius: var(--radius-md);
            }
            .product-modal-media {
                min-height: 180px;
            }
            .product-modal-media img {
                max-height: 220px;
            }
            .product-modal-header {
                padding: 14px 16px;
            }
            .product-modal-meta {
                padding: 14px 16px;
            }
            .product-modal-meta h3 {
                font-size: 16px;
            }
            .product-modal-meta .price {
                font-size: 18px;
            }
            .product-modal-reviews {
                padding: 14px 16px 16px;
            }
            .review-row .review-comment {
                padding-left: 0;
            }
            .review-top {
                flex-wrap: wrap;
                gap: 4px;
            }
            .reviewer-info {
                flex-wrap: wrap;
            }
        }

        @@media (max-width: 480px) {
            .instagram-grid {
                grid-template-columns: 1fr;
                gap: 14px;
            }

            .profile-avatar,
            .profile-avatar-fallback {
                width: 100px;
                height: 100px;
            }
            .profile-avatar-fallback {
                font-size: 40px;
            }
            .profile-username {
                font-size: 22px;
            }
            .stat-item {
                font-size: 12px;
            }
            .stat-count {
                font-size: 15px;
            }
            .stats-message-btn {
                padding: 8px 18px;
                font-size: 12px;
            }
        }

        /* ============================================================
           FOOTER
           ============================================================ */
        footer {
            text-align: center;
            padding: 36px 20px 20px;
            color: var(--text-muted);
            font-size: 12px;
            border-top: 1px solid var(--border);
            margin-top: 40px;
        }

        /* ============================================================
           SCROLLBAR STYLING
           ============================================================ */
        .product-modal-reviews::-webkit-scrollbar {
            width: 4px;
        }
        .product-modal-reviews::-webkit-scrollbar-track {
            background: transparent;
        }
        .product-modal-reviews::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 10px;
        }
        .product-modal-reviews::-webkit-scrollbar-thumb:hover {
            background: var(--text-muted);
        }
    </style>
}

<div class="profile-container">

    <!-- ========== PROFILE HEADER ========== -->
    <div class="profile-header">
        <div class="profile-avatar-container">
            @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
            {
                <img class="profile-avatar" src="@Model.Store.LogoURL" alt="@Model.Store.StoreName Logo" />
            }
            else
            {
                <div class="profile-avatar-fallback">
                    <i class="fas fa-store"></i>
                </div>
            }
            <div class="avatar-status"></div>
        </div>

        <div class="profile-details">
            <div class="profile-username-row">
                <h2 class="profile-username">@Model.Store?.StoreName</h2>
                <a asp-page="/StoreOwner/StoreProfile" class="edit-profile-btn">
                    <i class="fas fa-pen"></i> Edit Profile
                </a>
            </div>

            <div class="profile-stats-row">
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-box"></i></span>
                    <span class="stat-count">@Model.Products.Count</span> products
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-user-friends"></i></span>
                    <span class="stat-count">@Model.FollowersCount</span> followers
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-star"></i></span>
                    <span class="stat-count">@Model.Products.Sum(p => p.Reviews?.Count ?? 0)</span> reviews
                </div>
            </div>

            <a href="/Chat" class="stats-message-btn">
                <i class="fas fa-comment-dots"></i> Messages
            </a>

            <div class="profile-bio">
                <span class="bio-label"><i class="fas fa-store-alt"></i> Official Store</span>
                <p>@Model.Store?.Description</p>
                <div class="bio-badges">
                    <span class="bio-badge"><i class="fas fa-check-circle"></i> Verified</span>
                    <span class="bio-badge"><i class="fas fa-clock"></i> Active</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== TABS ========== -->
    <div class="profile-tabs">
        <button class="tab-btn active">
            <i class="fas fa-table-cells"></i> Products
        </button>
    </div>

    <!-- ========== PRODUCT GRID ========== -->
    @if (Model.Products.Any())
    {
        <div class="instagram-grid">
            @foreach (var p in Model.Products)
            {
                var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
                var reviewCount = p.Reviews?.Count ?? 0;

                <div class="product-grid-item" data-product-id="@p.ProductID" onclick="openProductModal(@p.ProductID)">
                    <div class="image-wrap">
                        <img src="@img" alt="@p.ProductName" loading="lazy" />
                        <span class="product-badge">For Sale</span>
                        <div class="product-quick-actions">
                            <button onclick="event.stopPropagation(); openProductModal(@p.ProductID)" title="Quick view">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="product-details">
                        <span class="product-name">@p.ProductName</span>
                        <div class="product-meta">
                            <span class="price">$@p.Price</span>
                            <span class="review-count">
                                <i class="fas fa-star"></i> @reviewCount review@(reviewCount != 1 ? "s" : "")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-store"></i></div>
            <h3>Your store is empty</h3>
            <p>Start adding products to your store and they'll appear here in a beautiful grid for your customers to browse.</p>
            <a asp-page="/StoreOwner/AddProduct" class="empty-action-btn">
                <i class="fas fa-plus-circle"></i> Add Your First Product
            </a>
        </div>
    }

</div>

<!-- ========== MODAL NAV ARROWS ========== -->
<button id="navPrev" class="modal-nav-arrow prev" onclick="goToAdjacentProduct(-1)">
    <i class="fas fa-chevron-left"></i>
</button>
<button id="navNext" class="modal-nav-arrow next" onclick="goToAdjacentProduct(1)">
    <i class="fas fa-chevron-right"></i>
</button>

<!-- ========== PRODUCT MODALS ========== -->
@foreach (var p in Model.Products)
{
    var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
    var reviewCount = p.Reviews?.Count ?? 0;

    <div id="modal-@p.ProductID" class="modal" data-product-id="@p.ProductID" onclick="handleOutsideClick(event, @p.ProductID)">
        <div class="product-modal-content" onclick="event.stopPropagation()">

            <!-- Media -->
            <div class="product-modal-media">
                <img src="@img" alt="@p.ProductName" />
                <span class="image-counter">1 / 1</span>
            </div>

            <!-- Info -->
            <div class="product-modal-info">
                <div class="product-modal-header">
                    <div class="product-modal-store">
                        @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
                        {
                            <img src="@Model.Store.LogoURL" alt="@Model.Store.StoreName" />
                        }
                        else
                        {
                            <div style="width:34px;height:34px;border-radius:50%;background:var(--accent-gradient);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;">
                                <i class="fas fa-store"></i>
                            </div>
                        }
                        <span class="store-name">@Model.Store?.StoreName</span>
                        <span class="store-badge">Store</span>
                    </div>
                    <button class="close-modal" onclick="closeProductModal(@p.ProductID)">&times;</button>
                </div>

                <div class="product-modal-meta">
                    <h3>@p.ProductName</h3>
                    <div class="price-row">
                        <span class="price">$@p.Price</span>
                        <span class="price-badge"><i class="fas fa-check-circle"></i> In Stock</span>
                    </div>
                    <p class="description">@p.Description</p>
                </div>

                <div class="product-modal-reviews">
                    <div class="reviews-header">
                        <span><i class="fas fa-comment"></i> Feedback</span>
                        <span class="review-count-badge">@reviewCount review@(reviewCount != 1 ? "s" : "")</span>
                    </div>

                    @if (p.Reviews != null && p.Reviews.Any())
                    {
                        @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            var initial = review.Customer?.User?.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? "?";
                            <div class="review-row">
                                <div class="review-top">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar">@initial</div>
                                        <a href="/StoreViewCustomer/@review.CustomerID" class="reviewer-link">
                                            @review.Customer?.User?.FullName
                                        </a>
                                        <span class="review-date">· @review.CreatedAt.ToString("MMM d, yyyy")</span>
                                    </div>
                                    <div class="stars-row">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        @for (int i = review.Rating; i < 5; i++)
                                        {
                                            <i class="far fa-star" style="color:var(--border-focus);"></i>
                                        }
                                    </div>
                                </div>
                                <p class="review-comment">@review.Comment</p>
                                <form method="post" asp-page-handler="DeleteReview" asp-route-reviewId="@review.ReviewID">
                                    <button type="submit" class="delete-review-btn">
                                        <i class="fa-solid fa-trash-can"></i> Remove Review
                                    </button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-reviews">
                            <i class="far fa-comment-dots"></i>
                            <p>No reviews yet for this product.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ========== SCRIPTS ========== -->
<script>
    // Ordered list of product IDs (same order as grid)
    const productOrder = [@Html.Raw(string.Join(",", Model.Products.Select(p => p.ProductID)))];
    let currentProductId = null;

    // ----- Open / Close -----
    function openProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (!modal) return;
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        currentProductId = id;
        updateNavArrows();
    }

    function closeProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (!modal) return;
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        currentProductId = null;
        hideNavArrows();
    }

    function handleOutsideClick(event, id) {
        const modal = document.getElementById('modal-' + id);
        if (event.target === modal) {
            closeProductModal(id);
        }
    }

    // ----- Navigation arrows -----
    function updateNavArrows() {
        const prev = document.getElementById('navPrev');
        const next = document.getElementById('navNext');
        if (currentProductId === null) {
            hideNavArrows();
            return;
        }
        const idx = productOrder.indexOf(currentProductId);
        prev.style.display = 'flex';
        next.style.display = 'flex';
        prev.classList.toggle('disabled', idx <= 0);
        next.classList.toggle('disabled', idx >= productOrder.length - 1);
    }

    function hideNavArrows() {
        document.getElementById('navPrev').style.display = 'none';
        document.getElementById('navNext').style.display = 'none';
    }

    function goToAdjacentProduct(direction) {
        if (currentProductId === null) return;
        const idx = productOrder.indexOf(currentProductId);
        const newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= productOrder.length) return;
        const newId = productOrder[newIdx];
        closeProductModal(currentProductId);
        openProductModal(newId);
    }

    // ----- Keyboard -----
    document.addEventListener('keydown', function (e) {
        if (currentProductId === null) return;
        if (e.key === 'ArrowRight') { e.preventDefault(); goToAdjacentProduct(1); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); goToAdjacentProduct(-1); }
        else if (e.key === 'Escape') { closeProductModal(currentProductId); }
    });

    // ----- Touch swipe -----
    let touchStartX = 0;
    const SWIPE_THRESHOLD = 50;

    document.addEventListener('touchstart', function (e) {
        if (currentProductId === null) return;
        touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    document.addEventListener('touchend', function (e) {
        if (currentProductId === null) return;
        const diff = e.changedTouches[0].screenX - touchStartX;
        if (Math.abs(diff) < SWIPE_THRESHOLD) return;
        goToAdjacentProduct(diff < 0 ? 1 : -1);
    }, { passive: true });

    // ----- Auto-open from URL param -----
    window.onload = function () {
        hideNavArrows();
        const params = new URLSearchParams(window.location.search);
        const productId = params.get('productId');
        if (productId) {
            const card = document.querySelector(`[data-product-id="${productId}"]`);
            if (card) {
                card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => openProductModal(Number(productId)), 700);
            }
        }
    };
</script>