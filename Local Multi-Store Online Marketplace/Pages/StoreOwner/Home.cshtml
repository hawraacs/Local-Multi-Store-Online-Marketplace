@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.HomeModel
@{
    ViewData["Title"] = "Home";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
    var totalReviews = Model.Products.Sum(p => p.Reviews?.Count ?? 0);
    var totalRatingSum = Model.Products.Sum(p => p.Reviews?.Sum(r => r.Rating) ?? 0);
    var avgRating = totalReviews > 0 ? (double)totalRatingSum / totalReviews : 0;
}
@section Styles {
    <style>
        /* ============================================================
           ROOT VARIABLES
           ============================================================ */
        :root {
            --accent: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-dark: #4c1d95;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --accent-glow: 0 8px 32px rgba(109, 40, 217, 0.25);
            --bg: #f6f5fa;
            --surface: #ffffff;
            --surface-hover: #faf9fe;
            --surface-alt: #f6f5fa;
            --text-primary: #1a1625;
            --text-secondary: #6b6478;
            --text-muted: #a5a0b4;
            --border: #edeaf5;
            --border-strong: #d4cee8;
            --border-focus: #d4cee8;
            --success: #10b981;
            --success-bg: #ecfdf5;
            --error: #ef4444;
            --error-bg: #fef2f2;
            --warning: #f59e0b;
            --info: #3b82f6;
            --shadow-xs: 0 1px 3px rgba(30, 27, 46, 0.04);
            --shadow-sm: 0 4px 16px rgba(109, 40, 217, 0.07);
            --shadow-md: 0 12px 40px rgba(109, 40, 217, 0.10);
            --shadow-lg: 0 24px 60px rgba(30, 27, 46, 0.15);
            --shadow-xl: 0 32px 80px rgba(30, 27, 46, 0.20);
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
            --duration: 0.35s;
            --font-display: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        body {
            font-family: var(--font-body);
            background: var(--bg);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        .profile-container {
            max-width: 1010px;
            width: 100%;
            margin: 28px auto;
            padding: 0 24px;
        }

        /* ============================================================
           PROFILE HEADER & STORY INTEGRATION
           ============================================================ */
        .profile-header {
            display: flex;
            align-items: center;
            gap: 44px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 36px 44px;
            position: relative;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            margin-bottom: 28px;
        }

        .profile-header::before {
            content: '';
            position: absolute;
            top: 0; left: 40px; right: 40px;
            height: 3px;
            background: var(--accent);
            border-radius: 0 0 3px 3px;
        }

        /* Avatar Story Wrapper */
        .profile-avatar-container {
            position: relative;
            display: inline-block;
            flex-shrink: 0;
            cursor: pointer;
        }

        .story-ring-wrapper {
            padding: 4px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform var(--duration) var(--ease);
        }

        .story-ring-wrapper.active-story {
            background: var(--accent-gradient);
        }

        .profile-avatar, .profile-avatar-fallback {
            width: 126px;
            height: 126px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--surface) !important;
            box-shadow: var(--shadow-sm);
            margin: 0 !important;
        }

        .profile-avatar-fallback {
            background: var(--accent-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 46px;
            color: var(--accent-light);
        }

        /* Floating Add Story Button */
        .avatar-add-story-btn {
            position: absolute;
            bottom: 6px;
            right: 6px;
            width: 34px;
            height: 34px;
            background: var(--accent);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            border: 3px solid var(--surface);
            box-shadow: var(--shadow-md);
            z-index: 10;
            transition: all 0.2s ease;
        }

        .avatar-add-story-btn:hover {
            background: var(--accent-hover);
            transform: scale(1.1);
        }

        .avatar-status {
            position: absolute;
            bottom: 6px;
            right: 6px;
            width: 18px;
            height: 18px;
            background: var(--success);
            border-radius: 50%;
            border: 3px solid var(--surface);
        }

        /* ----- Details ----- */
        .profile-details { flex: 1; min-width: 0; }
        .profile-username-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 6px; }
        .profile-username { font-family: var(--font-display); font-size: 32px; font-weight: 600; color: var(--text-primary); margin: 0; }
        
        .edit-profile-btn {
            background: transparent;
            border: 1.5px solid var(--border-strong);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            padding: 7px 18px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
            display: inline-flex;
            align-items: center; gap: 6px;
        }
        .edit-profile-btn:hover { background: var(--accent-dark); border-color: var(--accent-dark); color: #fff; }

        .profile-stats-row { display: flex; gap: 32px; margin: 14px 0 18px; flex-wrap: wrap; padding-top: 14px; border-top: 1px solid var(--border); }
        .stat-item { display: flex; align-items: baseline; gap: 6px; font-size: 13.5px; color: var(--text-secondary); }
        .stat-count { font-family: var(--font-display); font-weight: 600; font-size: 19px; color: var(--text-primary); }
        .stat-item .stat-icon { color: var(--accent); font-size: 13px; }

        .stats-message-btn {
            display: inline-flex; align-items: center; gap: 8px;
            background: var(--accent-dark); color: #fff; padding: 10px 22px;
            border-radius: var(--radius-sm); font-size: 13px; font-weight: 600;
            text-decoration: none; margin-bottom: 18px; transition: all var(--duration) var(--ease);
        }
        .stats-message-btn:hover { background: var(--accent-hover); color: #fff; }

        .profile-bio { font-size: 14px; line-height: 1.7; color: var(--text-secondary); max-width: 520px; }
        .bio-label { display: inline-flex; align-items: center; gap: 5px; font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--accent-hover); margin-bottom: 8px; }
        .bio-label::after { content: ''; width: 22px; height: 1px; background: var(--border-focus); }
        .bio-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
        .bio-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--surface-alt); border: 1px solid var(--border); padding: 4px 13px; border-radius: 20px; font-size: 11.5px; font-weight: 600; color: var(--text-secondary); }
        .bio-badge i { color: var(--accent); font-size: 10px; }

        /* ============================================================
           TABS & PRODUCT GRID
           ============================================================ */
        .profile-tabs { display: flex; gap: 28px; margin-bottom: 24px; border-bottom: 1px solid var(--border); }
        .tab-btn { background: transparent; border: none; color: var(--text-muted); display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.6px; padding: 12px 2px; text-transform: uppercase; position: relative; }
        .tab-btn.active { color: var(--text-primary); }
        .tab-btn.active::after { content: ''; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: var(--accent); }

        .instagram-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 4px; }
        .product-grid-item { background: var(--surface); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column; cursor: pointer; border: 1px solid var(--border); transition: all var(--duration) var(--ease); position: relative; }
        .product-grid-item:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
        .image-wrap { position: relative; overflow: hidden; background: var(--surface-alt); aspect-ratio: 1 / 1; }
        .image-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
        .product-grid-item:hover .image-wrap img { transform: scale(1.04); }
        .product-badge { position: absolute; top: 12px; left: 12px; background: var(--accent-dark); color: #fff; font-size: 9.5px; font-weight: 700; padding: 4px 12px; border-radius: 3px; }
        .image-count-badge { position: absolute; top: 12px; right: 12px; background: rgba(23, 24, 29, 0.65); color: #fff; font-size: 10.5px; font-weight: 700; padding: 4px 10px; border-radius: 20px; backdrop-filter: blur(3px); }
        
        .product-quick-actions { position: absolute; inset: 0; background: rgba(23, 24, 29, 0.35); display: flex; align-items: center; justify-content: center; gap: 16px; opacity: 0; transition: opacity var(--duration) var(--ease); }
        .product-grid-item:hover .product-quick-actions { opacity: 1; }
        .product-quick-actions button { background: var(--surface); border: none; border-radius: 50%; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-md); }
        .product-quick-actions button:hover { background: var(--accent); color: #fff; }

        .product-details { padding: 15px 17px 17px; flex: 1; display: flex; flex-direction: column; }
        .product-name { font-size: 15.5px; font-weight: 600; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .product-meta { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 10px; border-top: 1px solid var(--border); }
        .price { font-size: 17px; font-weight: 600; }
        .review-count { font-size: 11.5px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; }

        /* ============================================================
           MODALS & REVIEWS
           ============================================================ */
        .modal { display: none; position: fixed; z-index: 100000; inset: 0; background: rgba(23, 24, 29, 0.55); backdrop-filter: blur(6px); align-items: center; justify-content: center; padding: 20px; }
        .modal.flex { display: flex; }
        .product-modal-content { background: var(--surface); border-radius: var(--radius-lg); width: 100%; max-width: 900px; height: 88vh; max-height: 720px; box-shadow: var(--shadow-xl); display: flex; overflow: hidden; animation: modalContentIn 0.3s var(--ease); position: relative; }
        @@keyframes modalContentIn { from { opacity: 0; transform: translateY(16px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

        .product-modal-media { background: var(--surface-alt); width: 46%; position: relative; }
        .modal-gallery-img { width: 100%; height: 100%; object-fit: contain; padding: 20px; }
        .gallery-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 34px; height: 34px; border-radius: 50%; background: rgba(23, 24, 29, 0.45); color: #fff; border: none; cursor: pointer; z-index: 3; }
        .gallery-nav.prev { left: 12px; } .gallery-nav.next { right: 12px; }

        .product-modal-info { flex: 1; display: flex; flex-direction: column; border-left: 1px dashed var(--border-strong); position: relative; }
        .seam-dot { position: absolute; width: 15px; height: 15px; border-radius: 50%; background: var(--bg); left: -8px; }
        .seam-dot.top { top: -8px; } .seam-dot.bottom { bottom: -8px; }

        .product-modal-header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
        .product-modal-store { display: flex; align-items: center; gap: 12px; }
        .product-modal-store img { width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid var(--border); }
        .close-modal { width: 34px; height: 34px; border-radius: 50%; background: var(--surface-alt); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; }

        .product-modal-body { flex: 1; overflow-y: auto; }
        .product-modal-meta { padding: 20px 24px; border-bottom: 1px solid var(--border); }
        .product-modal-meta h3 { font-size: 20px; font-weight: 600; margin-bottom: 6px; }
        .price-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
        .price-badge { font-size: 11px; font-weight: 600; color: var(--success); background: var(--success-bg); padding: 2px 13px; border-radius: 20px; }
        .description { font-size: 14px; color: var(--text-secondary); line-height: 1.75; white-space: pre-line; }

        .product-modal-reviews { padding: 20px 24px 24px; }
        .review-row { background: var(--surface-alt); border-radius: var(--radius-sm); padding: 14px 16px; margin-bottom: 10px; border: 1px solid transparent; }
        .reviewer-avatar { width: 28px; height: 28px; border-radius: 50%; background: var(--accent-dark); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
        .delete-review-btn { width: 100%; background: var(--error-bg); color: var(--error); border: none; padding: 8px 0; border-radius: var(--radius-sm); cursor: pointer; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 6px; }

        .modal-nav-arrow { position: fixed; top: 50%; transform: translateY(-50%); width: 46px; height: 46px; border-radius: 50%; background: var(--surface); border: 1px solid var(--border); cursor: pointer; box-shadow: var(--shadow-md); display: none; align-items: center; justify-content: center; z-index: 100001; }
        .modal-nav-arrow.prev { left: 20px; } .modal-nav-arrow.next { right: 20px; }
        .modal-nav-arrow.disabled { opacity: 0.25; pointer-events: none; }

        @@media (max-width: 768px) {
            .profile-header { flex-direction: column; text-align: center; padding: 30px 22px; }
            .instagram-grid { grid-template-columns: repeat(2, 1fr); }
            .product-modal-content { flex-direction: column; height: 92vh; }
            .product-modal-media { width: 100%; height: 220px; }
        }
    </style>
}

<link rel="stylesheet" href="~/css/stories.css" />
@{
    ViewData["OwnerStoreLogo"] = Model.Store?.LogoURL;
    ViewData["OwnerStoreName"] = Model.Store?.StoreName;
}

@if (!string.IsNullOrEmpty(Model.StoryUploadError))
{
    <div class="alert alert-danger" style="max-width:980px;margin:12px auto;">@Model.StoryUploadError</div>
}

<partial name="_StoryBarOwner" model="Model.OwnStoriesWithStats" />
<partial name="_StoryViewer" />

<div class="profile-container">
    <!-- ========== PROFILE HEADER ========== -->
    <div class="profile-header">
        <div class="profile-avatar-container">
            @{
                var hasActiveStories = Model.OwnStoriesWithStats != null && Model.OwnStoriesWithStats.Any();
            }
            <!-- Clicking the avatar views stories if they exist, otherwise opens upload -->
            <div class="story-ring-wrapper @(hasActiveStories ? "active-story" : "")" 
                 onclick="@(hasActiveStories ? "RealNestStories.openOwn(0)" : "RealNestStories.openUploadStoryModal()")">
                
                @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
                {
                    <img class="profile-avatar" src="@Model.Store.LogoURL" alt="@Model.Store.StoreName Logo" />
                }
                else
                {
                    <div class="profile-avatar-fallback">
                        <i class="fas fa-store"></i>
                    </div>
                }
            </div>

            <!-- The Plus Button Overlay -->
            <div class="avatar-add-story-btn" onclick="event.stopPropagation(); RealNestStories.openUploadStoryModal()" title="Add Story">
                <i class="fas fa-plus"></i>
            </div>

            @if (!hasActiveStories)
            {
                <div class="avatar-status"></div>
            }
        </div>

        <div class="profile-details">
            <div class="profile-username-row">
                <h2 class="profile-username">@Model.Store?.StoreName</h2>
                <a asp-page="/StoreOwner/StoreProfile" class="edit-profile-btn">
                    <i class="fas fa-pen"></i> Edit Profile
                </a>
            </div>
            <div class="profile-stats-row">
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-box"></i></span>
                    <span class="stat-count">@Model.Products.Count</span> products
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-user-friends"></i></span>
                    <span class="stat-count">@Model.FollowersCount</span> followers
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-star"></i></span>
                    <span class="stat-count">@totalReviews</span> reviews
                </div>
                @if (totalReviews > 0)
                {
                    <div class="stat-item">
                        <span class="stat-icon"><i class="fas fa-medal"></i></span>
                        <span class="stat-count">@avgRating.ToString("0.0")</span> avg rating
                    </div>
                }
            </div>
            <a href="/Chat" class="stats-message-btn">
                <i class="fas fa-comment-dots"></i> Messages
            </a>
            <div class="profile-bio">
                <span class="bio-label">Official Store</span>
                <p>@Model.Store?.Description</p>
                <div class="bio-badges">
                    <span class="bio-badge"><i class="fas fa-check-circle"></i> Verified</span>
                    <span class="bio-badge"><i class="fas fa-clock"></i> Active</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== TABS ========== -->
    <div class="profile-tabs">
        <button class="tab-btn active">
            <i class="fas fa-table-cells"></i> Products
        </button>
    </div>

    <!-- ========== PRODUCT GRID ========== -->
    @if (Model.Products.Any())
    {
        <div class="instagram-grid">
            @foreach (var p in Model.Products)
            {
                var orderedImages = (p.Images?.OrderByDescending(im => im.IsPrimary).ThenBy(im => im.DisplayOrder).ToList()) ?? new();
                var img = orderedImages.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
                var imageCount = orderedImages.Count;
                var reviewCount = p.Reviews?.Count ?? 0;
                <div class="product-grid-item" data-product-id="@p.ProductID" onclick="openProductModal(@p.ProductID)">
                    <div class="image-wrap">
                        <img src="@img" alt="@p.ProductName" loading="lazy" />
                        <span class="product-badge">For Sale</span>
                        @if (imageCount > 1) { <span class="image-count-badge"><i class="fas fa-images"></i> @imageCount</span> }
                        <div class="product-quick-actions">
                            <button onclick="event.stopPropagation(); openProductModal(@p.ProductID)" title="Quick view">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="product-details">
                        <span class="product-name">@p.ProductName</span>
                        <div class="product-meta">
                            <span class="price">$@p.Price</span>
                            <span class="review-count"><i class="fas fa-star"></i> @reviewCount review@(reviewCount != 1 ? "s" : "")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-store"></i></div>
            <h3>Your store is empty</h3>
            <p>Start adding products to your store and they'll appear here.</p>
            <a asp-page="/StoreOwner/AddProduct" class="empty-action-btn">
                <i class="fas fa-plus-circle"></i> Add Your First Product
            </a>
        </div>
    }
</div>

<!-- ========== MODAL NAV ARROWS ========== -->
<button id="navPrev" class="modal-nav-arrow prev" onclick="goToAdjacentProduct(-1)"><i class="fas fa-chevron-left"></i></button>
<button id="navNext" class="modal-nav-arrow next" onclick="goToAdjacentProduct(1)"><i class="fas fa-chevron-right"></i></button>

<!-- ========== PRODUCT MODALS ========== -->
@foreach (var p in Model.Products)
{
    var orderedImages = (p.Images?.OrderByDescending(im => im.IsPrimary).ThenBy(im => im.DisplayOrder).ToList()) ?? new();
    var reviewCount = p.Reviews?.Count ?? 0;
    <div id="modal-@p.ProductID" class="modal" data-product-id="@p.ProductID" onclick="handleOutsideClick(event, @p.ProductID)">
        <div class="product-modal-content" onclick="event.stopPropagation()">
            <div class="product-modal-media" data-current-image="0">
                @if (orderedImages.Any())
                {
                    for (int idx = 0; idx < orderedImages.Count; idx++)
                    {
                        <img class="modal-gallery-img" src="@orderedImages[idx].ImageUrl" style="display:@(idx == 0 ? "block" : "none")" />
                    }
                }
                @if (orderedImages.Count > 1)
                {
                    <button class="gallery-nav prev" onclick="changeModalImage(@p.ProductID, -1)"><i class="fas fa-chevron-left"></i></button>
                    <button class="gallery-nav next" onclick="changeModalImage(@p.ProductID, 1)"><i class="fas fa-chevron-right"></i></button>
                }
            </div>
            <div class="product-modal-info">
                <span class="seam-dot top"></span><span class="seam-dot bottom"></span>
                <div class="product-modal-header">
                    <div class="product-modal-store">
                        <img src="@(Model.Store?.LogoURL ?? "/images/store.png")" />
                        <span class="store-name">@Model.Store?.StoreName</span>
                    </div>
                    <button class="close-modal" onclick="closeProductModal(@p.ProductID)">&times;</button>
                </div>
                <div class="product-modal-body">
                    <div class="product-modal-meta">
                        <h3>@p.ProductName</h3>
                        <div class="price-row"><span class="price">$@p.Price</span><span class="price-badge">In Stock</span></div>
                        <p class="description">@p.Description</p>
                    </div>
                    <div class="product-modal-reviews">
                        @if (p.Reviews != null && p.Reviews.Any())
                        {
                            @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="review-row">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar">@review.Customer?.User?.FullName?.FirstOrDefault()</div>
                                        <strong>@review.Customer?.User?.FullName</strong>
                                    </div>
                                    <p>@review.Comment</p>
                                    <form method="post" asp-page-handler="DeleteReview" asp-route-reviewId="@review.ReviewID">
                                        <button type="submit" class="delete-review-btn"><i class="fa-solid fa-trash-can"></i> Remove</button>
                                    </form>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    const productOrder = [@Html.Raw(string.Join(",", Model.Products.Select(p => p.ProductID)))];
    let currentProductId = null;

    function openProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (!modal) return;
        if (modal.parentElement !== document.body) document.body.appendChild(modal);
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        currentProductId = id;
        updateNavArrows();
    }

    function closeProductModal(id) {
        const modal = document.getElementById('modal-' + id);
        if (!modal) return;
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        currentProductId = null;
        hideNavArrows();
    }

    function handleOutsideClick(event, id) { if (event.target.classList.contains('modal')) closeProductModal(id); }

    function updateNavArrows() {
        const prev = document.getElementById('navPrev');
        const next = document.getElementById('navNext');
        if (currentProductId === null) return hideNavArrows();
        const idx = productOrder.indexOf(currentProductId);
        prev.style.display = next.style.display = 'flex';
        prev.classList.toggle('disabled', idx <= 0);
        next.classList.toggle('disabled', idx >= productOrder.length - 1);
    }

    function hideNavArrows() {
        document.getElementById('navPrev').style.display = 'none';
        document.getElementById('navNext').style.display = 'none';
    }

    function goToAdjacentProduct(direction) {
        const idx = productOrder.indexOf(currentProductId);
        const newId = productOrder[idx + direction];
        if (newId) { closeProductModal(currentProductId); openProductModal(newId); }
    }

    function changeModalImage(productId, direction) {
        const modal = document.getElementById('modal-' + productId);
        const imgs = modal.querySelectorAll('.modal-gallery-img');
        const media = modal.querySelector('.product-modal-media');
        let current = parseInt(media.dataset.currentImage);
        imgs[current].style.display = 'none';
        current = (current + direction + imgs.length) % imgs.length;
        imgs[current].style.display = 'block';
        media.dataset.currentImage = current;
    }

    window.onload = function () {
        hideNavArrows();
        const params = new URLSearchParams(window.location.search);
        const productId = params.get('productId');
        if (productId) openProductModal(Number(productId));
    };
</script>
