@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.HomeModel
@{
    ViewData["Title"] = "Home";
    ViewData["HideTopbar"] = true;
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
    var totalReviews = Model.Products.Sum(p => p.Reviews?.Count ?? 0);
    var totalRatingSum = Model.Products.Sum(p => p.Reviews?.Sum(r => r.Rating) ?? 0);
    var avgRating = totalReviews > 0 ? (double)totalRatingSum / totalReviews : 0;
}
@section Styles {
    <style>
        :root {
            --accent: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-dark: #4f46e5;
            --accent-gradient: linear-gradient( 135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100% );
            --accent-glow: 0 8px 32px rgba(109, 40, 217, 0.20);
            --bg: #f8f7fc;
            --surface: #ffffff;
            --surface-hover: #faf9fe;
            --surface-alt: #f6f5fa;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border: #ece8f6;
            --border-strong: #d4cee8;
            --border-focus: #d4cee8;
            --success: #10b981;
            --error: #dc2626;
            --warning: #f59e0b;
            --shadow-xs: 0 1px 3px rgba(30,27,46,.04);
            --shadow-sm: 0 4px 12px rgba(109,40,217,.06);
            --shadow-md: 0 10px 30px rgba(109,40,217,.10);
            --shadow-lg: 0 20px 50px rgba(30,27,46,.18);
            --shadow-xl: 0 32px 80px rgba(30,27,46,.20);
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --ease: cubic-bezier(0.22,1,0.36,1);
            --duration: .35s;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        .profile-container {
            max-width: 1010px;
            width: 100%;
            margin: 28px auto;
            padding: 0 24px;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 44px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 36px 44px;
            position: relative;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            margin-bottom: 28px;
        }

            .profile-header::before {
                content: '';
                position: absolute;
                top: 0;
                left: 40px;
                right: 40px;
                height: 3px;
                background: var(--accent);
                border-radius: 0 0 3px 3px;
            }

        .profile-avatar-container {
            position: relative;
            display: inline-block;
            flex-shrink: 0;
            cursor: pointer;
        }

        .story-ring-wrapper {
            padding: 4px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform var(--duration) var(--ease);
        }

            .story-ring-wrapper.active-story {
                background: var(--accent-gradient);
            }

        .profile-avatar, .profile-avatar-fallback {
            width: 126px;
            height: 126px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--surface) !important;
            box-shadow: var(--shadow-sm);
            margin: 0 !important;
        }

        .profile-avatar-fallback {
            background: var(--accent-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 46px;
            color: var(--accent-light);
        }

        .avatar-add-story-btn {
            position: absolute;
            bottom: 6px;
            right: 6px;
            width: 34px;
            height: 34px;
            background: var(--accent);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            border: 3px solid var(--surface);
            box-shadow: var(--shadow-md);
            z-index: 10;
            transition: all 0.2s ease;
        }

            .avatar-add-story-btn:hover {
                background: var(--accent-hover);
                transform: scale(1.1);
            }

        .avatar-status {
            position: absolute;
            bottom: 6px;
            right: 6px;
            width: 18px;
            height: 18px;
            background: var(--success);
            border-radius: 50%;
            border: 3px solid var(--surface);
        }

        .logout-btn {
            background: #ef4444;
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 8px 18px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .25s ease;
        }

            .logout-btn:hover {
                background: #dc2626;
                transform: translateY(-2px);
                box-shadow: var(--shadow-sm);
            }

            .logout-btn i {
                font-size: 13px;
            }

        .profile-details {
            flex: 1;
            min-width: 0;
        }

        .profile-username-row {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 6px;
        }

        .profile-username {
            font-family: var(--font-display);
            font-size: 32px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        .edit-profile-btn {
            background: transparent;
            border: 1.5px solid var(--border-strong);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            padding: 7px 18px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .edit-profile-btn:hover {
                background: var(--accent-dark);
                border-color: var(--accent-dark);
                color: #fff;
            }

        .profile-stats-row {
            display: flex;
            gap: 32px;
            margin: 14px 0 18px;
            flex-wrap: wrap;
            padding-top: 14px;
            border-top: 1px solid var(--border);
        }

        .stat-item {
            display: flex;
            align-items: baseline;
            gap: 6px;
            font-size: 13.5px;
            color: var(--text-secondary);
        }

        .stat-count {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 19px;
            color: var(--text-primary);
        }

        .stat-item .stat-icon {
            color: var(--accent);
            font-size: 13px;
        }

        .stats-message-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-dark);
            color: #fff;
            padding: 10px 22px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: 18px;
            transition: all var(--duration) var(--ease);
        }

            .stats-message-btn:hover {
                background: var(--accent-hover);
                color: #fff;
            }

        .profile-bio {
            font-size: 14px;
            line-height: 1.7;
            color: var(--text-secondary);
            max-width: 520px;
        }

        .bio-label {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-hover);
            margin-bottom: 8px;
        }

            .bio-label::after {
                content: '';
                width: 22px;
                height: 1px;
                background: var(--border-focus);
            }

        .bio-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 12px;
        }

        .bio-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--surface-alt);
            border: 1px solid var(--border);
            padding: 4px 13px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--text-secondary);
        }

            .bio-badge i {
                color: var(--accent);
                font-size: 10px;
            }

        .profile-tabs {
            display: flex;
            gap: 28px;
            margin-bottom: 24px;
            border-bottom: 1px solid var(--border);
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.6px;
            padding: 12px 2px;
            text-transform: uppercase;
            position: relative;
        }

            .tab-btn.active {
                color: var(--text-primary);
            }

                .tab-btn.active::after {
                    content: '';
                    position: absolute;
                    left: 0;
                    right: 0;
                    bottom: -1px;
                    height: 2px;
                    background: var(--accent);
                }

        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 22px;
            margin-top: 4px;
        }

        .product-grid-item {
            background: var(--surface);
            border-radius: var(--radius-md);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            border: 1px solid var(--border);
            transition: all var(--duration) var(--ease);
            position: relative;
        }

            .product-grid-item:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
            }

        .image-wrap {
            position: relative;
            overflow: hidden;
            background: var(--surface-alt);
            aspect-ratio: 1 / 1;
        }

            .image-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s var(--ease);
            }

        .product-grid-item:hover .image-wrap img {
            transform: scale(1.04);
        }

        .product-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: var(--accent-dark);
            color: #fff;
            font-size: 9.5px;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 3px;
        }

        .image-count-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(23, 24, 29, 0.65);
            color: #fff;
            font-size: 10.5px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            backdrop-filter: blur(3px);
        }

        .product-quick-actions {
            position: absolute;
            inset: 0;
            background: rgba(23, 24, 29, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            opacity: 0;
            transition: opacity var(--duration) var(--ease);
        }

        .product-grid-item:hover .product-quick-actions {
            opacity: 1;
        }

        .product-quick-actions button {
            background: var(--surface);
            border: none;
            border-radius: 50%;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-md);
        }

            .product-quick-actions button:hover {
                background: var(--accent);
                color: #fff;
            }

        .product-details {
            padding: 15px 17px 17px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .product-name {
            font-size: 15.5px;
            font-weight: 600;
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 10px;
            border-top: 1px solid var(--border);
        }

        .price {
            font-size: 17px;
            font-weight: 600;
        }

        .review-count {
            font-size: 11.5px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ============================================================
                           INSTAGRAM-STYLE FEED — store header on top, image, details below
                           ============================================================ */
        .feed-overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 100000;
            background: #efedf5;
            overflow-y: scroll;
            scroll-snap-type: y mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }

            .feed-overlay.open {
                display: block;
            }

            .feed-overlay.dragging {
                scroll-snap-type: none;
                scroll-behavior: auto;
            }

        .product-feed-item {
            height: 100vh;
            width: 100%;
            scroll-snap-align: start;
            scroll-snap-stop: always;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 20px;
            box-sizing: border-box;
        }

        .product-post-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            width: 100%;
            max-width: 470px;
            height: 100%;
            max-height: 800px;
            box-shadow: var(--shadow-xl);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        /* ---- Post header: shop logo + name, always visible at top ---- */
        .post-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            background: var(--surface);
        }

        .post-header-store {
            display: flex;
            align-items: center;
            gap: 11px;
            min-width: 0;
        }

            .post-header-store img {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                object-fit: cover;
                border: 1.5px solid var(--border);
                flex-shrink: 0;
            }

        .post-header-store-name {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-header-store-sub {
            font-size: 11px;
            color: var(--text-muted);
        }

        .post-close-btn {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--surface-alt);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: var(--text-secondary);
            flex-shrink: 0;
        }

            .post-close-btn:hover {
                background: var(--border);
            }

        /* ---- Image area ---- */
        .post-media {
            background: #000;
            width: 100%;
            aspect-ratio: 1 / 1;
            flex-shrink: 0;
            position: relative;
            cursor: grab;
            overflow: hidden;
        }

            .post-media:active {
                cursor: grabbing;
            }

            .post-media img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                user-select: none;
                -webkit-user-drag: none;
            }

        .gallery-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(23, 24, 29, 0.45);
            color: #fff;
            border: none;
            cursor: pointer;
            z-index: 3;
        }

            .gallery-nav.prev {
                left: 10px;
            }

            .gallery-nav.next {
                right: 10px;
            }

        .gallery-dots {
            position: absolute;
            bottom: 10px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 5px;
        }

            .gallery-dots span {
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: rgba(255,255,255,0.45);
            }

                .gallery-dots span.active {
                    background: #fff;
                }

        /* ---- Details below image ---- */
        .post-body {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            overscroll-behavior: contain;
        }

        .post-meta {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
        }

            .post-meta h3 {
                font-size: 16px;
                font-weight: 700;
                margin: 0 0 6px;
                color: var(--text-primary);
            }

        .post-price-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        .post-price {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .post-stock-badge {
            font-size: 10.5px;
            font-weight: 700;
            color: var(--success);
            background: var(--success-bg);
            padding: 2px 11px;
            border-radius: 20px;
        }

        .post-description {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.65;
            white-space: pre-line;
        }

        .post-reviews {
            padding: 14px 16px 20px;
        }

        .post-reviews-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .review-row {
            background: var(--surface-alt);
            border-radius: var(--radius-sm);
            padding: 11px 13px;
            margin-bottom: 8px;
            border: 1px solid var(--border);
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 5px;
        }

        .reviewer-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--accent-dark);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10.5px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .review-row p {
            font-size: 12.5px;
            color: var(--text-secondary);
            margin: 0 0 8px;
            line-height: 1.5;
        }

        .review-row strong {
            font-size: 12.5px;
            color: var(--text-primary);
        }

        .delete-review-btn {
            width: 100%;
            background: var(--error-bg);
            color: var(--error);
            border: none;
            padding: 6px 0;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 10.5px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        @@media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
                padding: 30px 22px;
            }

            .instagram-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .product-feed-item {
                padding: 0;
            }

            .product-post-card {
                max-width: 100%;
                max-height: 100%;
                border-radius: 0;
                border: none;
            }
        }
    </style>
}

<link rel="stylesheet" href="~/css/stories.css" />
@{
    ViewData["OwnerStoreLogo"] = Model.Store?.LogoURL;
    ViewData["OwnerStoreName"] = Model.Store?.StoreName;
}

@if (!string.IsNullOrEmpty(Model.StoryUploadError))
{
    <div class="alert alert-danger" style="max-width:980px;margin:12px auto;">@Model.StoryUploadError</div>
}

<partial name="_StoryBarOwner" model="Model.OwnStoriesWithStats" />
<partial name="_StoryViewer" />

<div class="profile-container">
    <!-- ========== PROFILE HEADER ========== -->
    <div class="profile-header">
        <div class="profile-avatar-container">
            @{
                var hasActiveStories = Model.OwnStoriesWithStats != null && Model.OwnStoriesWithStats.Any();
            }
            <div class="story-ring-wrapper @(hasActiveStories ? "active-story" : "")"
                 onclick="@(hasActiveStories ? "RealNestStories.openOwn(0)" : "RealNestStories.openUploadStoryModal()")">

                @if (!string.IsNullOrWhiteSpace(Model.Store?.LogoURL))
                {
                    <img class="profile-avatar" src="@Model.Store.LogoURL" alt="@Model.Store.StoreName Logo" />
                }
                else
                {
                    <div class="profile-avatar-fallback">
                        <i class="fas fa-store"></i>
                    </div>
                }
            </div>

            <div class="avatar-add-story-btn" onclick="event.stopPropagation(); RealNestStories.openUploadStoryModal()" title="Add Story">
                <i class="fas fa-plus"></i>
            </div>

            @if (!hasActiveStories)
            {
                <div class="avatar-status"></div>
            }
        </div>

        <div class="profile-details">
            <div class="profile-username-row">
                <h2 class="profile-username">@Model.Store?.StoreName</h2>
                <a asp-page="/StoreOwner/StoreProfile" class="edit-profile-btn">
                    <i class="fas fa-pen"></i> Edit Profile
                </a>

                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="/"
                      method="post"
                      style="display:inline;">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-right-from-bracket"></i>
                        Logout
                    </button>
                </form>
            </div>
            <div class="profile-stats-row">
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-box"></i></span>
                    <span class="stat-count">@Model.Products.Count</span> products
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-user-friends"></i></span>
                    <span class="stat-count">@Model.FollowersCount</span> followers
                </div>
                <div class="stat-item">
                    <span class="stat-icon"><i class="fas fa-star"></i></span>
                    <span class="stat-count">@totalReviews</span> reviews
                </div>
                @if (totalReviews > 0)
                {
                    <div class="stat-item">
                        <span class="stat-icon"><i class="fas fa-medal"></i></span>
                        <span class="stat-count">@avgRating.ToString("0.0")</span> avg rating
                    </div>
                }
            </div>
            <a href="/Chat" class="stats-message-btn">
                <i class="fas fa-comment-dots"></i> Messages
            </a>
            <div class="profile-bio">
                <span class="bio-label">Official Store</span>
                <p>@Model.Store?.Description</p>
                <div class="bio-badges">
                    <span class="bio-badge"><i class="fas fa-check-circle"></i> Verified</span>
                    <span class="bio-badge"><i class="fas fa-clock"></i> Active</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== TABS ========== -->
    <div class="profile-tabs">
        <button class="tab-btn active">
            <i class="fas fa-table-cells"></i> Products
        </button>
    </div>

    <!-- ========== PRODUCT GRID ========== -->
    @if (Model.Products.Any())
    {
        <div class="instagram-grid">
            @foreach (var p in Model.Products)
            {
                var orderedImages = (p.Images?.OrderByDescending(im => im.IsPrimary).ThenBy(im => im.DisplayOrder).ToList()) ?? new();
                var img = orderedImages.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
                var imageCount = orderedImages.Count;
                var reviewCount = p.Reviews?.Count ?? 0;
                <div class="product-grid-item" data-product-id="@p.ProductID" onclick="openProductModal(@p.ProductID)">
                    <div class="image-wrap">
                        <img src="@img" alt="@p.ProductName" loading="lazy" />
                        <span class="product-badge">For Sale</span>
                        @if (imageCount > 1)
                        {
                            <span class="image-count-badge"><i class="fas fa-images"></i> @imageCount</span>
                        }
                        <div class="product-quick-actions">
                            <button onclick="event.stopPropagation(); openProductModal(@p.ProductID)" title="Quick view">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="product-details">
                        <span class="product-name">@p.ProductName</span>
                        <div class="product-meta">
                            <span class="price">$@p.Price</span>
                            <span class="review-count"><i class="fas fa-star"></i> @reviewCount review@(reviewCount != 1 ? "s" : "")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-store"></i></div>
            <h3>Your store is empty</h3>
            <p>Start adding products to your store and they'll appear here.</p>
            <a asp-page="/StoreOwner/AddProduct" class="empty-action-btn">
                <i class="fas fa-plus-circle"></i> Add Your First Product
            </a>
        </div>
    }
</div>

<!-- ========== INSTAGRAM-STYLE FEED OVERLAY ========== -->
<div id="feedOverlay" class="feed-overlay">
    @foreach (var p in Model.Products)
    {
        var orderedImages = (p.Images?.OrderByDescending(im => im.IsPrimary).ThenBy(im => im.DisplayOrder).ToList()) ?? new();
        var reviewCount = p.Reviews?.Count ?? 0;
        var imageCount = orderedImages.Count;
        <section id="feed-@p.ProductID" class="product-feed-item" data-product-id="@p.ProductID">
            <div class="product-post-card">

                <!-- ===== Store header, ALWAYS on top of the post ===== -->
                <div class="post-header">
                    <div class="post-header-store">
                        <img src="@(Model.Store?.LogoURL ?? "/images/store.png")" alt="@Model.Store?.StoreName" />
                        <div>
                            <div class="post-header-store-name">@Model.Store?.StoreName</div>
                            <div class="post-header-store-sub">Official Store</div>
                        </div>
                    </div>
                    <button class="post-close-btn" onclick="closeProductModal()">&times;</button>
                </div>

                <!-- ===== Image ===== -->
                <div class="post-media" data-current-image="0">
                    @if (orderedImages.Any())
                    {
                        for (int idx = 0; idx < orderedImages.Count; idx++)
                        {
                            <img src="@orderedImages[idx].ImageUrl" style="display:@(idx == 0 ? "block" : "none")" draggable="false" />
                        }
                    }
                    @if (imageCount > 1)
                    {
                        <button class="gallery-nav prev" onclick="changeModalImage(@p.ProductID, -1)"><i class="fas fa-chevron-left"></i></button>
                        <button class="gallery-nav next" onclick="changeModalImage(@p.ProductID, 1)"><i class="fas fa-chevron-right"></i></button>
                        <div class="gallery-dots">
                            @for (int d = 0; d < imageCount; d++)
                            {
                                <span class="@(d == 0 ? "active" : "")"></span>
                            }
                        </div>
                    }
                </div>

                <!-- ===== Details below the image ===== -->
                <div class="post-body">
                    <div class="post-meta">
                        <h3>@p.ProductName</h3>
                        <div class="post-price-row">
                            <span class="post-price">$@p.Price</span>
                            <span class="post-stock-badge">In Stock</span>
                        </div>
                        <p class="post-description">@p.Description</p>
                    </div>
                    <div class="post-reviews">
                        @if (p.Reviews != null && p.Reviews.Any())
                        {
                            <div class="post-reviews-title">@reviewCount Review@(reviewCount != 1 ? "s" : "")</div>
                            @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="review-row">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar">@review.Customer?.User?.FullName?.FirstOrDefault()</div>
                                        <strong>@review.Customer?.User?.FullName</strong>
                                    </div>
                                    <p>@review.Comment</p>
                                    <form method="post" asp-page-handler="DeleteReview" asp-route-reviewId="@review.ReviewID">
                                        <button type="submit" class="delete-review-btn"><i class="fa-solid fa-trash-can"></i> Remove</button>
                                    </form>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </section>
    }
</div>

<script>
    const productOrder = [@Html.Raw(string.Join(",", Model.Products.Select(p => p.ProductID)))];
    let currentProductId = null;
    const feedOverlay = document.getElementById('feedOverlay');

    function sectionFor(id) {
        return document.getElementById('feed-' + id);
    }

    function openProductModal(id) {
        if (!feedOverlay) return;
        feedOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        currentProductId = id;

        const sec = sectionFor(id);
        if (sec) {
            feedOverlay.scrollTop = sec.offsetTop;
        }
    }

    function closeProductModal() {
        if (!feedOverlay) return;
        feedOverlay.classList.remove('open');
        document.body.style.overflow = '';
        currentProductId = null;
    }

    // Keep currentProductId in sync as the user swipes/scrolls/drags
    let scrollRAF = null;
    if (feedOverlay) {
        feedOverlay.addEventListener('scroll', function () {
            if (scrollRAF) return;
            scrollRAF = requestAnimationFrame(function () {
                scrollRAF = null;
                const scrollCenter = feedOverlay.scrollTop + feedOverlay.clientHeight / 2;
                let closestId = currentProductId;
                let closestDist = Infinity;
                productOrder.forEach(function (id) {
                    const sec = sectionFor(id);
                    if (!sec) return;
                    const center = sec.offsetTop + sec.offsetHeight / 2;
                    const dist = Math.abs(center - scrollCenter);
                    if (dist < closestDist) { closestDist = dist; closestId = id; }
                });
                if (closestId !== currentProductId) {
                    currentProductId = closestId;
                }
            });
        });
    }

    function changeModalImage(productId, direction) {
        const sec = sectionFor(productId);
        if (!sec) return;
        const imgs = sec.querySelectorAll('.post-media img');
        const dots = sec.querySelectorAll('.gallery-dots span');
        const media = sec.querySelector('.post-media');
        let current = parseInt(media.dataset.currentImage);
        imgs[current].style.display = 'none';
        if (dots[current]) dots[current].classList.remove('active');
        current = (current + direction + imgs.length) % imgs.length;
        imgs[current].style.display = 'block';
        if (dots[current]) dots[current].classList.add('active');
        media.dataset.currentImage = current;
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && currentProductId !== null) closeProductModal();
    });

    window.onload = function () {
        const params = new URLSearchParams(window.location.search);
        const productId = params.get('productId');
        if (productId) openProductModal(Number(productId));
    };
</script>

<script>
    // Smooth mouse click-and-drag to move between posts (touch scrolls natively already).
    (function () {
        let dragging = false;
        let startY = 0;
        let startScrollTop = 0;
        let velocity = 0;
        let lastY = 0;
        let lastTime = 0;

        function onPointerDown(e) {
            if (e.pointerType !== 'mouse') return;
            if (currentProductId === null) return;

            const mediaEl = e.target.closest('.post-media');
            if (!mediaEl) return;
            if (e.target.closest('.gallery-nav')) return;

            dragging = true;
            startY = lastY = e.clientY;
            startScrollTop = feedOverlay.scrollTop;
            lastTime = performance.now();
            velocity = 0;
            feedOverlay.classList.add('dragging');
            mediaEl.setPointerCapture && mediaEl.setPointerCapture(e.pointerId);
        }

        function onPointerMove(e) {
            if (!dragging) return;
            const now = performance.now();
            const dt = Math.max(now - lastTime, 1);
            velocity = (lastY - e.clientY) / dt;
            lastY = e.clientY;
            lastTime = now;

            const delta = e.clientY - startY;
            feedOverlay.scrollTop = startScrollTop - delta;
        }

        function onPointerUp() {
            if (!dragging) return;
            dragging = false;
            feedOverlay.classList.remove('dragging');

            const idx = productOrder.indexOf(currentProductId);
            if (Math.abs(velocity) > 0.5) {
                const dir = velocity > 0 ? 1 : -1;
                const newId = productOrder[idx + dir];
                if (newId != null) {
                    const sec = sectionFor(newId);
                    if (sec) feedOverlay.scrollTo({ top: sec.offsetTop, behavior: 'smooth' });
                    return;
                }
            }
            const sec = sectionFor(currentProductId);
            if (sec) feedOverlay.scrollTo({ top: sec.offsetTop, behavior: 'smooth' });
        }

        document.addEventListener('pointerdown', onPointerDown);
        document.addEventListener('pointermove', onPointerMove);
        document.addEventListener('pointerup', onPointerUp);
        document.addEventListener('pointercancel', onPointerUp);
    })();
</script>
<script src="~/js/stories.js"></script>
