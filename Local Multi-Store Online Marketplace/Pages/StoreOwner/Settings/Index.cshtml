@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";

}

<style>
    :root {
        /* -------- Brand colors (Purple / Indigo) -------- */
        --accent-color: #6d28d9;
        --accent-hover: #5b21b6;
        --accent-light: #f3effe;
        --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
        /* -------- Neutral palette -------- */
        --bg-color: #f8f7fc;
        --card-bg: #ffffff;
        --text-primary: #1e1b2e;
        --text-secondary: #6b6478;
        --text-muted: #9691a4;
        --border-color: #ece8f6;
        /* -------- Semantic -------- */
        --success-color: #10b981;
        --error-color: #dc2626;
        --warning-color: #f59e0b;
        /* -------- Shadows -------- */
        --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
        --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
        --shadow-lg: 0 20px 50px rgba(30, 27, 46, 0.18);
    }

    .settings-page {
        background: var(--bg-color);
        min-height: calc(100vh - 120px);
        padding: 35px 0 60px;
    }

    .settings-wrapper {
        max-width: 1120px;
        margin: auto;
    }

    .settings-hero {
        background: var(--accent-gradient);
        border-radius: 24px;
        color: white;
        padding: 30px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-lg);
        position: relative;
        overflow: hidden;
    }

        .settings-hero::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
            right: -70px;
            top: -80px;
        }

        .settings-hero h2 {
            margin: 0 0 8px;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.4px;
            position: relative;
            z-index: 1;
        }

        .settings-hero p {
            margin: 0;
            opacity: 0.92;
            font-size: 14px;
            position: relative;
            z-index: 1;
        }

    .status-pill {
        display: inline-block;
        margin-top: 14px;
        background: rgba(255,255,255,0.18);
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 700;
        position: relative;
        z-index: 1;
    }

    .settings-grid {
        display: grid;
        grid-template-columns: 1.35fr 0.85fr;
        gap: 24px;
        align-items: start;
    }

    .settings-card {
        background: var(--card-bg);
        border-radius: 22px;
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 22px;
    }

    .card-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border-color);
        background: var(--bg-color);
    }

        .card-header h3 {
            margin: 0 0 5px;
            color: var(--text-primary);
            font-size: 18px;
            font-weight: 800;
        }

        .card-header p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 500;
        }

    .card-body {
        padding: 24px;
    }

    .setting-option {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .switch-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

        .switch-row input {
            margin-top: 4px;
            transform: scale(1.15);
            accent-color: var(--accent-color);
        }

        .switch-row label {
            margin: 0;
            font-weight: 700;
            color: var(--text-primary);
            font-size: 14px;
        }

        .switch-row small {
            display: block;
            color: var(--text-secondary);
            font-size: 12px;
            margin-top: 4px;
            line-height: 1.5;
            font-weight: 400;
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 7px;
        }

    .form-control,
    .form-select {
        width: 100%;
        border: 1.5px solid var(--border-color);
        border-radius: 12px;
        padding: 11px 15px;
        font-weight: 500;
        color: var(--text-primary);
        outline: none;
        background: var(--bg-color);
        transition: all 0.2s ease;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--accent-color);
            background: var(--card-bg);
            box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.10);
        }

    .help-text {
        color: var(--text-muted);
        font-size: 12px;
        margin-top: 6px;
        font-weight: 400;
        line-height: 1.5;
    }

    .save-btn {
        border: none;
        border-radius: 30px;
        background: var(--accent-gradient);
        color: white;
        padding: 14px 26px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 22px rgba(109, 40, 217, 0.25);
        transition: all 0.25s ease;
    }

        .save-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 28px rgba(109, 40, 217, 0.32);
        }

    .profile-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 30px;
        background: var(--card-bg);
        border: 1.5px solid var(--border-color);
        color: var(--text-secondary);
        padding: 13px 20px;
        font-weight: 700;
        margin-left: 10px;
        transition: all 0.25s ease;
    }

        .profile-link:hover {
            color: var(--accent-color);
            background: var(--accent-light);
            border-color: var(--accent-color);
        }

    .side-card {
        background: var(--card-bg);
        border-radius: 22px;
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-sm);
        padding: 22px;
        margin-bottom: 22px;
    }

        .side-card h4 {
            margin: 0 0 14px;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 800;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-color);
        font-size: 13px;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: var(--text-secondary);
        font-weight: 600;
    }

    .info-value {
        color: var(--text-primary);
        font-weight: 700;
        text-align: right;
    }

    .note-box {
        background: var(--accent-light);
        border: 1px solid #e0d4fb;
        color: var(--accent-hover);
        padding: 14px;
        border-radius: 14px;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.55;
        margin-top: 14px;
    }

    .alert {
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 18px;
        font-weight: 600;
        font-size: 14px;
    }

    .alert-success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .text-danger {
        color: var(--error-color);
        font-size: 12px;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    @@media (max-width: 950px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .profile-link {
            margin-left: 0;
            margin-top: 10px;
        }
    }

    @@media (max-width: 600px) {
        .settings-page {
            padding: 20px 12px;
        }

        .settings-hero {
            padding: 24px;
        }
    }
</style>

<div class="settings-page">
    <div class="settings-wrapper">

        <div class="settings-hero">
            <h2>Operational Settings</h2>
            <p>Manage delivery rules, payment rules, and store availability without duplicating the Store Profile page.</p>

            <span class="status-pill">
                Store: @Model.StoreName
            </span>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form method="post">
            <div class="settings-grid">

                <div>

                    <div class="settings-card">
                        <div class="card-header">
                            <h3>Delivery Settings</h3>
                            <p>Control how delivery fees are calculated for your store.</p>
                        </div>

                        <div class="card-body">

                            <div class="setting-option">
                                <div class="switch-row">
                                    <input asp-for="StoreSettings.HasFixedDeliveryFee" />
                                    <div>
                                        <label asp-for="StoreSettings.HasFixedDeliveryFee">
                                            Use Fixed Delivery Fee
                                        </label>
                                        <small>
                                            If enabled, customers pay one fixed delivery fee. If disabled, delivery fee is calculated based on store/customer distance.
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="StoreSettings.FixedDeliveryFee">Fixed Delivery Fee</label>
                                <input asp-for="StoreSettings.FixedDeliveryFee"
                                       class="form-control"
                                       placeholder="Example: 3.00" />
                                <span asp-validation-for="StoreSettings.FixedDeliveryFee" class="text-danger"></span>
                                <div class="help-text">
                                    Required only when fixed delivery fee is enabled.
                                </div>
                            </div>

                            <div class="note-box">
                                Store location coordinates are managed from Store Profile because they are part of the store identity and delivery location.
                            </div>

                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="card-header">
                            <h3>Payment Settings</h3>
                            <p>Control Cash on Delivery availability and limits.</p>
                        </div>

                        <div class="card-body">

                            <div class="setting-option">
                                <div class="switch-row">
                                    <input asp-for="StoreSettings.CODSupported" />
                                    <div>
                                        <label asp-for="StoreSettings.CODSupported">
                                            Cash On Delivery Supported
                                        </label>
                                        <small>
                                            Enable this if your store accepts cash payment when the order is delivered.
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="StoreSettings.CODMaxLimit">COD Max Limit</label>
                                <input asp-for="StoreSettings.CODMaxLimit"
                                       class="form-control"
                                       placeholder="Example: 5000.00" />
                                <span asp-validation-for="StoreSettings.CODMaxLimit" class="text-danger"></span>
                                <div class="help-text">
                                    Customers cannot use COD above this order amount.
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="card-header">
                            <h3>Store Availability</h3>
                            <p>Use this for temporary opening or closure control.</p>
                        </div>

                        <div class="card-body">

                            <div class="form-group">
                                <label asp-for="StoreSettings.AvailabilityStatus">Availability Status</label>
                                <select asp-for="StoreSettings.AvailabilityStatus" class="form-select">
                                    <option value="Open">Open for Orders</option>
                                    <option value="Inactive">Temporarily Closed</option>
                                </select>
                                <span asp-validation-for="StoreSettings.AvailabilityStatus" class="text-danger"></span>
                                <div class="help-text">
                                    Temporary closure prevents new orders without deleting or rejecting the store.
                                </div>
                            </div>

                            <div class="note-box">
                                Admin-controlled statuses such as Pending, Approved, or Rejected are not edited here. This setting only controls operational availability.
                            </div>

                        </div>
                    </div>

                    <button type="submit" class="save-btn">
                        Save Operational Settings
                    </button>

                    <a href="/StoreOwner/StoreProfile" class="profile-link">
                        Edit Store Profile
                    </a>

                </div>

                <aside>

                    <div class="side-card">
                        <h4>Store Snapshot</h4>

                        <div class="info-row">
                            <span class="info-label">Store Name</span>
                            <span class="info-value">@Model.StoreName</span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Store Code</span>
                            <span class="info-value">
                                @(string.IsNullOrWhiteSpace(Model.StoreCode) ? "Not assigned" : Model.StoreCode)
                            </span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Current Status</span>
                            <span class="info-value">@Model.CurrentStatus</span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Location</span>
                            <span class="info-value">@Model.StoreLocationSummary</span>
                        </div>
                    </div>

                    <div class="side-card">
                        <h4>Business Rules</h4>

                        <div class="info-row">
                            <span class="info-label">Commission</span>
                            <span class="info-value">@Model.CommissionRate.ToString("N2")%</span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Rating</span>
                            <span class="info-value">@Model.Rating.ToString("N1") / 5</span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Total Ratings</span>
                            <span class="info-value">@Model.TotalRatings</span>
                        </div>

                        <div class="note-box">
                            Commission and rating are system-controlled values and cannot be edited by the store owner.
                        </div>
                    </div>

                    <div class="side-card">
                        <h4>Verification</h4>

                        <div class="info-row">
                            <span class="info-label">License No.</span>
                            <span class="info-value">
                                @(string.IsNullOrWhiteSpace(Model.BusinessLicenseNumber) ? "Not provided" : Model.BusinessLicenseNumber)
                            </span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">License File</span>
                            <span class="info-value">
                                @(string.IsNullOrWhiteSpace(Model.BusinessLicenseURL) ? "Not uploaded" : "Uploaded")
                            </span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Created At</span>
                            <span class="info-value">@Model.CreatedAt.ToString("yyyy-MM-dd")</span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Approved At</span>
                            <span class="info-value">
                                @(Model.ApprovedAt.HasValue ? Model.ApprovedAt.Value.ToString("yyyy-MM-dd") : "Not approved yet")
                            </span>
                        </div>

                        <div class="note-box">
                            Business verification is controlled by the admin review process.
                        </div>
                    </div>

                </aside>

            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
