@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Promotions.IndexModel
@{
    ViewData["Title"] = "Promotions";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";

}

@section Styles {
    <style>
        :root {
            /* -------- Brand colors (Purple / Indigo) -------- */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            /* -------- Neutral palette -------- */
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            /* -------- Semantic -------- */
            --success-color: #10b981;
            --error-color: #dc2626;
            --warning-color: #f59e0b;
            /* -------- Shadows -------- */
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
        }

        .container h2 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.4px;
        }

        /* -------- Buttons -------- */
        .btn-primary {
            background: var(--accent-gradient);
            border: none;
            color: white;
            font-weight: 700;
            padding: 11px 22px;
            border-radius: 30px;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .btn-primary:hover,
            .btn-primary:focus {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(109, 40, 217, 0.35);
                color: white;
            }

        /* -------- Alerts -------- */
        .alert {
            border-radius: 14px;
            padding: 13px 18px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid transparent;
        }

        .alert-success {
            background: #ecfdf5;
            color: #065f46;
            border-color: #a7f3d0;
        }

        .alert-info {
            background: var(--accent-light);
            color: var(--accent-hover);
            border-color: #e0d4fb;
        }

        /* -------- Table -------- */
        .table {
            background: var(--card-bg);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            font-size: 14px;
            color: var(--text-primary);
        }

        .table-bordered {
            border: 1px solid var(--border-color);
        }

            .table-bordered th,
            .table-bordered td {
                border: 1px solid var(--border-color);
                padding: 12px 14px;
                vertical-align: middle;
            }

        .table thead th {
            background: var(--accent-light);
            color: var(--accent-color);
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            border-bottom: none;
        }

        .table-striped > tbody > tr:nth-of-type(odd) > td {
            background-color: var(--bg-color);
        }

        .table tbody tr:hover td {
            background-color: var(--accent-light);
        }

        .text-muted {
            color: var(--text-muted) !important;
        }

        /* -------- Badges -------- */
        .badge {
            font-weight: 700;
            font-size: 11px;
            padding: 6px 12px;
            border-radius: 999px;
        }

            .badge.bg-success {
                background-color: #ecfdf5 !important;
                color: #065f46;
            }

            .badge.bg-primary {
                background: var(--accent-light) !important;
                color: var(--accent-color);
            }
    </style>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Promotions</h2>
        <a asp-page="/StoreOwner/Promotions/Create" class="btn btn-primary">
            Send New Promotion
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (Model.Promotions == null || !Model.Promotions.Any())
    {
        <div class="alert alert-info">
            No promotions sent yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Message</th>
                        <th>Coupon</th>
                        <th>Recipients</th>
                        <th>Status</th>
                        <th>Sent At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var promotion in Model.Promotions)
                    {
                        <tr>
                            <td>@promotion.Title</td>
                            <td>@promotion.Message</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(promotion.CouponCode))
                                {
                                    <span class="text-muted">No coupon</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@promotion.CouponCode</span>
                                }
                            </td>
                            <td>@promotion.RecipientCount</td>
                            <td>
                                <span class="badge bg-primary">@promotion.Status</span>
                            </td>
                            <td>
                                @(promotion.SentAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
