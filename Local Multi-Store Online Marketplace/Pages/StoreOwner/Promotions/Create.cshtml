@page
@model Local_Multi_Store_Online_Marketplace.Pages.StoreOwner.Promotions.CreateModel
@{
    ViewData["Title"] = "Send Promotion";
}

<div class="container mt-4">
    <h2 class="mb-4">Send Promotion</h2>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="card shadow-sm p-4">
        <div class="mb-3">
            <label asp-for="Promotion.Title" class="form-label">Title</label>
            <input asp-for="Promotion.Title" class="form-control" placeholder="Example: Weekend Offer" />
            <span asp-validation-for="Promotion.Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Promotion.Message" class="form-label">Message</label>
            <textarea asp-for="Promotion.Message" class="form-control" rows="5" placeholder="Write promotion message"></textarea>
            <span asp-validation-for="Promotion.Message" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Promotion.AudienceType" class="form-label">Audience</label>
            <select asp-for="Promotion.AudienceType" class="form-select">
                <option value="AllCustomers">All Customers</option>
            </select>
            <span asp-validation-for="Promotion.AudienceType" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Promotion.CouponCode" class="form-label">Coupon Code Optional</label>
            <input asp-for="Promotion.CouponCode" class="form-control" placeholder="Example: SAVE10" />
            <span asp-validation-for="Promotion.CouponCode" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Send Promotion</button>
            <a asp-page="/StoreOwner/Promotions/Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}