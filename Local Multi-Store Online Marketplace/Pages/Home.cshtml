@page
@model Local_Multi_Store_Online_Marketplace.Pages.HomeModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 30px auto;
        background: white;
        border-radius: 15px;
        padding: 20px;
    }

    .header {
        display: flex;
        gap: 20px;
        align-items: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    .logo {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
    }

    .stats {
        color: gray;
        margin-top: 6px;
    }

    .product {
        margin-top: 15px;
        padding: 12px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

        .product img {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border-radius: 10px;
        }

    .price {
        color: #ff6600;
        font-weight: bold;
    }


    .reviews-section {
        margin-top: 20px;
        border-top: 1px solid #eee;
        padding-top: 15px;
    }

    .review-item {
        background: #fafafa;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 10px;
    }

    .delete-btn {
        background: #dc2626;
        color: white;
        border: none;
        padding: 8px 12px;
        border-radius: 6px;
        cursor: pointer;
    }

        .delete-btn:hover {
            background: #b91c1c;
        }

    .profile-btn {
        display: inline-block;
        margin-top: 8px;
        margin-bottom: 8px;
        padding: 8px 14px;
        background: #2563eb;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-size: 14px;
    }

        .profile-btn:hover {
            background: #1d4ed8;
            color: white;
        }
</style>

<div class="profile-container">

    <!-- STORE HEADER -->
    <div class="header">

        <img class="logo"
             src="@(Model.Store.LogoURL ?? "/images/store.png")" />

        <div>
            <h2>@Model.Store.StoreName</h2>

            <a asp-page="/StoreOwner/StoreProfile"
               class="profile-btn">
                Edit Profile
            </a>

            <div class="stats">
                Followers: @Model.FollowersCount
            </div>

            <p>@Model.Store.Description</p>
        </div>

    </div>

    <!-- PRODUCTS -->
    <div class="products">

        @foreach (var p in Model.Products)
        {
            var img = p.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

            <div class="product" id="product-@p.ProductID">

                <img src="@img" />

                <h3>@p.ProductName</h3>

                <div class="price">
                    $@p.Price
                </div>

                <p>@p.Description</p>

                <div class="reviews-section">

                    <h4>Reviews</h4>

                    @if (p.Reviews != null && p.Reviews.Any())
                    {
                        @foreach (var review in p.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="review-item">

                                <strong>
                                    @review.Customer?.User?.FullName
                                </strong>

                                <span>
                                    ⭐ @review.Rating
                                </span>

                                <p>@review.Comment</p>

                                <form method="post"
                                      asp-page-handler="DeleteReview"
                                      asp-route-reviewId="@review.ReviewID">

                                    <button type="submit"
                                            class="delete-btn">
                                        Delete Review
                                    </button>

                                </form>

                            </div>
                        }
                    }
                    else
                    {
                        <p>No reviews yet.</p>
                    }

                </div>

           

            </div>
        }

    </div>


</div>
</div>

<script>
    window.onload = function () {

        const params = new URLSearchParams(window.location.search);
        const productId = params.get('productId');

        if (productId) {

            const product = document.getElementById('product-' + productId);

            if (product) {

                product.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });

                product.style.border = '4px solid orange';

                setTimeout(() => {
                    product.style.border = '';
                }, 4000);
            }
        }
    };
</script>