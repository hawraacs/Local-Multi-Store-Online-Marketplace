@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminDeliveryModel
@{
    ViewData["Title"] = "Delivery Management";
}

@section Styles {
    <style>
        .delivery-card {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-top: 20px;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 40px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .status-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .status-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-approve,
        .btn-reject {
            border: none;
            padding: 6px 12px;
            border-radius: 8px;
            cursor: pointer;
            margin-right: 5px;
            font-weight: 600;
        }

        .btn-approve {
            background: #10b981;
            color: white;
        }

        .btn-reject {
            background: #ef4444;
            color: white;
        }

        .reject-input {
            padding: 6px;
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-right: 5px;
            width: 150px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th,
        td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: middle;
        }

        th {
            background: #f9fafb;
            color: #374151;
            font-size: 14px;
        }

        .proof-link {
            color: #2563eb;
            text-decoration: none;
            font-weight: 600;
        }

            .proof-link:hover {
                text-decoration: underline;
            }
    </style>
}

<div class="delivery-card">
    <h3>Delivery Staff Requests</h3>

    @if (TempData["Success"] != null)
    {
        <div style="color: #065f46; background: #d1fae5; padding: 10px; border-radius: 8px; margin-bottom: 10px;">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div style="color: #991b1b; background: #fee2e2; padding: 10px; border-radius: 8px; margin-bottom: 10px;">
            @TempData["Error"]
        </div>
    }

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Vehicle</th>
                    <th>Area</th>
                    <th>ID Proof</th>
                    <th>Status</th>
                    <th>Rejection Reason</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Deliveries == null || !Model.Deliveries.Any())
                {
                    <tr>
                        <td colspan="8">No delivery requests found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var d in Model.Deliveries)
                    {
                        var status = d.Status?.Trim().ToLower();

                        var statusClass = status == "approved"
                        ? "status-approved"
                        : status == "rejected"
                        ? "status-rejected"
                        : "status-pending";

                        <tr>
                            <td>@d.FullName</td>
                            <td>@d.PhoneNumber</td>
                            <td>@d.VehicleType</td>
                            <td>@d.Area</td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(d.IDProofURL))
                                {
                                    <a href="@d.IDProofURL" target="_blank" class="proof-link">View</a>
                                }
                                else
                                {
                                    <span>No file</span>
                                }
                            </td>

                            <td>
                                <span class="status-badge @statusClass">
                                    @d.Status
                                </span>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(d.RejectionReason))
                                {
                                    @d.RejectionReason
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @if (status == "pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                        <button type="submit" class="btn-approve">Approve</button>
                                    </form>

                                    <form method="post" asp-page-handler="Reject" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />

                                        <input type="text"
                                               name="reason"
                                               placeholder="Reject reason"
                                               class="reject-input" />

                                        <button type="submit" class="btn-reject">Reject</button>
                                    </form>
                                }
                                else
                                {
                                    <span>No action</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>