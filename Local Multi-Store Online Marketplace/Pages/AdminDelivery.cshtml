@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminDeliveryModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Delivery | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        body {
            font-family: Inter, Arial, sans-serif;
            background: #f1f5f9;
            margin: 0;
        }

        .topbar {
            background: #0f172a;
            color: white;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
        }

            .topbar a {
                color: white;
                margin-left: 12px;
                text-decoration: none;
                font-weight: 600;
            }

        .container {
            max-width: 1200px;
            margin: 30px auto;
        }

        h2 {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            border-collapse: collapse;
        }

        th, td {
            padding: 14px;
            border-bottom: 1px solid #eee;
            text-align: left;
        }

        th {
            background: #111827;
            color: white;
        }

        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }

        .approve {
            background: #22c55e;
            color: white;
        }

        .reject {
            background: #ef4444;
            color: white;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div>realnest</div>
        <div>
            <a href="/Admin1">Dashboard</a>
            <a href="/AdminStores">Stores</a>
            <a href="/AdminDelivery">Delivery</a>
        </div>
    </div>

    <div class="container">

        <h2><i class="fas fa-truck"></i> Delivery Requests</h2>

        @if (TempData["Success"] != null)
        {
            <div class="success-message">
                @TempData["Success"]
            </div>
        }

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Vehicle</th>
                    <th>Number</th>
                    <th>Area</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Deliveries != null && Model.Deliveries.Any())
                {
                    foreach (var d in Model.Deliveries)
                    {
                        <tr>
                            <td>@d.FullName</td>
                            <td>@d.PhoneNumber</td>
                            <td>@d.VehicleType</td>
                            <td>@d.VehicleNumber</td>
                            <td>@d.Area</td>

                            <td>
                                @if (d.Status != null && d.Status.Trim().Equals("Approved", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span style="color:green;font-weight:bold;">Approved</span>
                                }
                                else if (d.Status != null && d.Status.Trim().Equals("Rejected", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span style="color:red;font-weight:bold;">Rejected</span>
                                }
                                else
                                {
                                    <span style="color:#b45309;font-weight:bold;">Pending</span>
                                }
                            </td>

                            <td>
                                @if (d.Status != null && d.Status.Trim().Equals("Pending", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post"
                                          asp-page-handler="Approve"
                                          asp-route-id="@d.DeliveryPersonID"
                                          style="display:inline;">
                                        <button type="submit" class="btn approve">Approve</button>
                                    </form>

                                    <form method="post"
                                          asp-page-handler="Reject"
                                          asp-route-id="@d.DeliveryPersonID"
                                          style="display:inline;">
                                        <button type="submit" class="btn reject">Reject</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:#6b7280;">No action</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">No delivery requests</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</body>
</html>