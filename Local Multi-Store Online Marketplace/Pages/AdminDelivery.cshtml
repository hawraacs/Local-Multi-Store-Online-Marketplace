@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminDeliveryModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Delivery | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
                min-height: 100vh;
            }

            /* Modern Topbar (consistent with all admin pages) */
            .topbar {
                background: rgba(10, 15, 25, 0.92);
                backdrop-filter: blur(12px);
                color: white;
                padding: 16px 40px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 100;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

                .topbar > div:first-child {
                    font-size: 26px;
                    font-weight: 700;
                    letter-spacing: -0.5px;
                    background: linear-gradient(135deg, #FFFFFF 0%, #B0C4DE 100%);
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                }

                .topbar div:last-child {
                    display: flex;
                    gap: 12px;
                }

                .topbar a {
                    color: #eef2ff;
                    text-decoration: none;
                    font-weight: 500;
                    padding: 8px 16px;
                    border-radius: 40px;
                    transition: all 0.2s ease;
                    font-size: 15px;
                }

                    .topbar a:hover {
                        background: rgba(255, 255, 255, 0.15);
                        transform: translateY(-1px);
                    }

            /* Main container */
            .container {
                max-width: 1400px;
                width: 95%;
                margin: 32px auto;
                padding: 0 20px;
            }

            /* Section styling */
            .section {
                background: white;
                border-radius: 32px;
                padding: 28px 32px;
                margin-bottom: 40px;
                box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.08);
                border: 1px solid rgba(0, 0, 0, 0.04);
            }

            .section-header {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 24px;
                flex-wrap: wrap;
                justify-content: space-between;
            }

                .section-header h2 {
                    font-size: 24px;
                    font-weight: 700;
                    color: #0f172a;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

            .badge {
                background: #f1f5f9;
                padding: 6px 14px;
                border-radius: 40px;
                font-size: 14px;
                font-weight: 600;
                color: #1e293b;
            }

            /* Table wrapper for responsive */
            .table-wrapper {
                overflow-x: auto;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                font-size: 14px;
                min-width: 600px;
            }

            th, td {
                padding: 14px 18px;
                text-align: left;
                border-bottom: 1px solid #eef2f8;
            }

            th {
                background: #f8fafc;
                color: #0f172a;
                font-weight: 600;
                font-size: 14px;
                letter-spacing: -0.2px;
            }

            tr:last-child td {
                border-bottom: none;
            }

            tr:hover td {
                background: #fafcff;
            }

            /* Status badges */
            .status-pending {
                background: #fef3c7;
                color: #b45309;
                padding: 4px 12px;
                border-radius: 40px;
                font-size: 12px;
                font-weight: 600;
                display: inline-block;
            }

            .status-active {
                background: #d1fae5;
                color: #065f46;
                padding: 4px 12px;
                border-radius: 40px;
                font-size: 12px;
                font-weight: 600;
                display: inline-block;
            }

            /* Action buttons */
            .action-group {
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
            }

            .btn {
                padding: 6px 16px;
                border: none;
                border-radius: 40px;
                cursor: pointer;
                font-weight: 600;
                font-size: 13px;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

            .btn-approve {
                background: #10b981;
                color: white;
            }

                .btn-approve:hover {
                    background: #059669;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
                }

            .btn-reject {
                background: #ef4444;
                color: white;
            }

                .btn-reject:hover {
                    background: #dc2626;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 8px rgba(239, 68, 68, 0.3);
                }

            .btn:active {
                transform: translateY(1px);
            }

            /* Empty state */
            .empty-state {
                text-align: center;
                padding: 48px 20px;
                color: #64748b;
            }

                .empty-state i {
                    font-size: 48px;
                    color: #cbd5e1;
                    margin-bottom: 12px;
                }

            /* Responsive */
            @@media (max-width: 768px) {
                .topbar {
                    padding: 12px 24px;
                    flex-direction: column;
                    gap: 12px;
                }

                .container {
                    width: 100%;
                    padding: 0 16px;
                }

                .section {
                    padding: 20px;
                }

                th, td {
                    padding: 10px 12px;
                }
            }

            footer {
                text-align: center;
                padding: 28px 20px 32px;
                color: #5b6e8c;
                font-size: 13px;
                border-top: 1px solid rgba(0,0,0,0.05);
                margin-top: 20px;
            }
    </style>
</head>
<body>

    <div class="topbar">
        <div>realnest</div>
        <div>
            <a href="/Admin1"><i class="fas fa-chalkboard-user"></i> Dashboard</a>
            <a href="/AdminStores"><i class="fas fa-store"></i> Stores</a>
            <a href="/AdminDelivery"><i class="fas fa-truck-fast"></i> Delivery</a>
        </div>
    </div>

    <div class="container">

        <!-- Pending Delivery Requests Section -->
        <div class="section">
            <div class="section-header">
                <h2>
                    <i class="fas fa-clock" style="color:#e67e22;"></i>
                    Pending Delivery Requests
                </h2>
                <div class="badge">
                    <i class="fas fa-hourglass-half"></i> Awaiting approval
                </div>
            </div>

            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Vehicle</th>
                            <th>License Number</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingDelivery != null && Model.PendingDelivery.Any())
                        {
                            foreach (var d in Model.PendingDelivery)
                            {
                                <tr>
                                    <td>@d.DeliveryPersonID</td>
                                    <td>@d.VehicleType</td>
                                    <td>@d.DrivingLicenseNumber</td>
                                    <td><span class="status-pending">@d.Status</span></td>
                                    <td>
                                        <div class="action-group">
                                            <form method="post" asp-page-handler="Approve" style="display: inline;">
                                                <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                                <button type="submit" class="btn btn-approve">
                                                    <i class="fas fa-check"></i> Approve
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" style="display: inline;">
                                                <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                                <button type="submit" class="btn btn-reject">
                                                    <i class="fas fa-times"></i> Reject
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <i class="fas fa-inbox"></i>
                                        <p>No pending delivery requests.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Active Delivery Staff Section -->
        <div class="section">
            <div class="section-header">
                <h2>
                    <i class="fas fa-check-circle" style="color:#10b981;"></i>
                    Active Delivery Staff
                </h2>
                <div class="badge">
                    <i class="fas fa-users"></i> Currently active
                </div>
            </div>

            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Vehicle</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ActiveDelivery != null && Model.ActiveDelivery.Any())
                        {
                            foreach (var d in Model.ActiveDelivery)
                            {
                                <tr>
                                    <td>@d.DeliveryPersonID</td>
                                    <td>@d.VehicleType</td>
                                    <td><span class="status-active">@d.Status</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3">
                                    <div class="empty-state">
                                        <i class="fas fa-user-slash"></i>
                                        <p>No active delivery staff.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <footer>
        <span>✨ Realnest Admin — delivery management ✨</span>
    </footer>

</body>
</html>