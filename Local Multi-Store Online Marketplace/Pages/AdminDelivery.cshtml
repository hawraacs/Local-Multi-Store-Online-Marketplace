@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminDeliveryModel
@{
    ViewData["Title"] = "Delivery Management";
}

@section Styles {
    <style>
        .delivery-card { background: white; border-radius: 24px; padding: 24px; margin-top: 20px; }
        .status-badge { padding: 4px 10px; border-radius: 40px; font-size: 12px; }
        .status-approved { background: #d1fae5; color: #065f46; }
        .status-pending { background: #fef3c7; color: #b45309; }
        .btn-approve, .btn-reject { border: none; padding: 6px 12px; border-radius: 8px; cursor: pointer; margin-right: 5px; }
        .btn-approve { background: #10b981; color: white; }
        .btn-reject { background: #ef4444; color: white; }
        .table-responsive { overflow-x: auto; }
    </style>
}

<div class="delivery-card">
    <h3>Delivery Staff Requests</h3>
    <div class="table-responsive">
        <table>
            <thead>
                <tr><th>Name</th><th>Phone</th><th>Vehicle</th><th>Area</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Deliveries)
                {
                    <tr>
                        <td>@d.FullName</td
                        <td>@d.PhoneNumber</td
                        <td>@d.VehicleType</td
                        <td>@d.Area</td
                        <td><span class="status-badge @(d.Status?.ToLower() == "approved" ? "status-approved" : "status-pending")">@d.Status</span></td
                        <td>
                            @if (d.Status?.ToLower() == "pending")
                            {
                                <form method="post" asp-page-handler="Approve" style="display:inline;">
                                    <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                    <button type="submit" class="btn-approve">Approve</button>
                                </form>
                                <form method="post" asp-page-handler="Reject" style="display:inline;">
                                    <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                    <button type="submit" class="btn-reject">Reject</button>
                                </form>
                            }
                            else
                            {
                                <span>No action</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>