@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminDeliveryModel
@{
    ViewData["Title"] = "Delivery Management";
}

@section Styles {
    <style>
        .delivery-card {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-top: 20px;
        }

            .delivery-card h3 {
                margin-bottom: 20px;
                font-weight: 700;
                color: #0f172a;
            }

        .status-badge {
            padding: 4px 10px;
            border-radius: 40px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }

        .status-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .status-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .status-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-inactive {
            background: #e5e7eb;
            color: #374151;
        }

        .btn-approve,
        .btn-reject,
        .btn-deactivate,
        .btn-activate {
            border: none;
            padding: 6px 12px;
            border-radius: 8px;
            cursor: pointer;
            margin-right: 5px;
            font-weight: 600;
            font-size: 13px;
        }

        .btn-approve,
        .btn-activate {
            background: #16a34a;
            color: white;
        }

        .btn-reject,
        .btn-deactivate {
            background: #dc2626;
            color: white;
        }

        .reject-input {
            padding: 6px;
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-right: 5px;
            width: 160px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th,
        td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: middle;
            font-size: 14px;
        }

        th {
            background: #f9fafb;
            color: #374151;
            font-size: 13px;
        }

        .proof-link {
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
        }

            .proof-link:hover {
                text-decoration: underline;
            }

        .success-box {
            color: #065f46;
            background: #d1fae5;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 12px;
            font-weight: 600;
            line-height: 1.6;
        }

        .error-box {
            color: #991b1b;
            background: #fee2e2;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 12px;
            font-weight: 600;
        }

        .info-box {
            color: #334155;
            background: #f1f5f9;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 16px;
            font-size: 13px;
            line-height: 1.5;
        }

        .login-box {
            min-width: 230px;
        }

        .show-login-btn {
            border: none;
            background: #0f172a;
            color: white;
            padding: 6px 10px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 700;
            font-size: 12px;
        }

            .show-login-btn:hover {
                background: #4f46e5;
            }

        .login-details {
            display: none;
            margin-top: 8px;
            padding: 9px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 12px;
            line-height: 1.7;
            color: #334155;
            word-break: break-word;
        }

            .login-details strong {
                color: #0f172a;
            }

        .copy-text {
            font-weight: 700;
            color: #6366f1;
        }
    </style>
}

<div class="delivery-card">
    <h3>Delivery Staff Requests</h3>

    <div class="info-box">
        When you approve a customer delivery request, the system creates a new delivery login.
        The original customer account stays unchanged.
        You can view each approved delivery login from the <strong>Delivery Login</strong> column.
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="success-box">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="error-box">
            @TempData["Error"]
        </div>
    }

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Vehicle</th>
                    <th>Area</th>
                    <th>ID Proof</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th>Delivery Login</th>
                    <th>Rejection Reason</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Deliveries == null || !Model.Deliveries.Any())
                {
                    <tr>
                        <td colspan="10">No delivery requests found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var d in Model.Deliveries)
                    {
                        var status = d.Status?.Trim().ToLower();

                        var statusClass = status == "approved"
                        ? "status-approved"
                        : status == "rejected"
                        ? "status-rejected"
                        : "status-pending";

                        <tr>
                            <td>@d.FullName</td>
                            <td>@d.PhoneNumber</td>
                            <td>@d.VehicleType</td>
                            <td>@d.Area</td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(d.IDProofURL))
                                {
                                    <a href="@d.IDProofURL" target="_blank" class="proof-link">View</a>
                                }
                                else
                                {
                                    <span>No file</span>
                                }
                            </td>

                            <td>
                                <span class="status-badge @statusClass">
                                    @d.Status
                                </span>
                            </td>

                            <td>
                                @if (status == "approved" && d.IsActive)
                                {
                                    <span class="status-badge status-approved">Active</span>
                                }
                                else if (status == "approved" && !d.IsActive)
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td class="login-box">
                                @if (status == "approved")
                                {
                                    var loginBoxId = $"login_{d.DeliveryPersonID}";
                                    var deliveryEmail = d.User?.Email ?? d.User?.UserName ?? "Email not loaded";

                                    <button type="button"
                                            class="show-login-btn"
                                            onclick="toggleLogin('@loginBoxId')">
                                        Show Login
                                    </button>

                                    <div id="@loginBoxId" class="login-details">
                                        <div>
                                            <strong>Email:</strong>
                                            <span class="copy-text">@deliveryEmail</span>
                                        </div>

                                        <div>
                                            <strong>Password:</strong>
                                            <span class="copy-text">Delivery@12345</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(d.RejectionReason))
                                {
                                    @d.RejectionReason
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @if (status == "pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                        <button type="submit" class="btn-approve">Approve</button>
                                    </form>

                                    <form method="post" asp-page-handler="Reject" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />

                                        <input type="text"
                                               name="reason"
                                               placeholder="Reject reason"
                                               class="reject-input" />

                                        <button type="submit" class="btn-reject">Reject</button>
                                    </form>
                                }
                                else if (status == "approved" && d.IsActive)
                                {
                                    <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                        <button type="submit" class="btn-deactivate">Deactivate</button>
                                    </form>
                                }
                                else if (status == "approved" && !d.IsActive)
                                {
                                    <form method="post" asp-page-handler="Activate" style="display:inline;">
                                        <input type="hidden" name="id" value="@d.DeliveryPersonID" />
                                        <button type="submit" class="btn-activate">Activate</button>
                                    </form>
                                }
                                else
                                {
                                    <span>No action</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleLogin(id) {
        const box = document.getElementById(id);

        if (!box) {
            return;
        }

        box.style.display = box.style.display === "block"
            ? "none"
            : "block";
    }
</script>
