        function formatMessageTime(date) {
            const now =
                new Date();

            const today =
                new Date(
                    now.getFullYear(),
                    now.getMonth(),
                    now.getDate());

            const messageDay =
                new Date(
                    date.getFullYear(),
                    date.getMonth(),
                    date.getDate());

            const diffDays =
                Math.floor(
                    (today - messageDay) /
                    86400000);

            const timeText =
                date.toLocaleTimeString(
                    [],
                    {
                        hour: "2-digit",
                        minute: "2-digit"
                    });

            if (diffDays === 0) {
                return "Today " + timeText;
            }

            if (diffDays === 1) {
                return "Yesterday " + timeText;
            }

            return date.toLocaleDateString(
                [],
                {
                    day: "2-digit",
                    month: "short"
                }) +
                " " +
                timeText;
        }

        function updateMessageTimes() {
            const timeElements =
                document.querySelectorAll(
                    ".message-time");

            timeElements.forEach(
                function (element) {
                    const utcValue =
                        element.getAttribute(
                            "data-utc");

                    if (!utcValue) {
                        return;
                    }

                    const date =
                        new Date(utcValue);

                    if (isNaN(date.getTime())) {
                        return;
                    }

                    element.innerText =
                        formatMessageTime(date);
                });
        }

        function resizeMessageInput() {
            if (!messageInput) {
                return;
            }

            messageInput.style.height =
                "40px";

            messageInput.style.height =
                Math.min(
                    messageInput.scrollHeight,
                    98) +
                "px";
        }

        function updateSmartSuggestions() {
            if (!messageInput ||
                suggestionChips.length === 0) {
                return;
            }

            const text =
                messageInput.value
                    .trim()
                    .toLowerCase();

            const words =
                text.split(/\s+/);

            const lastWord =
                words[words.length - 1] || "";

            let results = [];

            if (lastWord.length === 0) {
                results = [
                    "hello",
                    "is this available",
                    "how much"
                ];
            }
            else {
                results =
                    smartSuggestions
                        .filter(item =>
                            item
                                .toLowerCase()
                                .startsWith(lastWord))
                        .slice(0, 3);
            }

            if (results.length === 0 &&
                text.length > 0) {

                results =
                    smartSuggestions
                        .filter(item =>
                            item
                                .toLowerCase()
                                .includes(lastWord))
                        .slice(0, 3);
            }

            if (results.length === 0) {
                results = [
                    "okay",
                    "thanks",
                    "please"
                ];
            }

            suggestionChips.forEach(
                function (chip, index) {
                    const value =
                        results[index] || "";

                    if (value) {
                        chip.innerText =
                            value;

                        chip.setAttribute(
                            "data-suggestion",
                            value);

                        chip.style.visibility =
                            "visible";
                    }
                    else {
                        chip.innerText = "";

                        chip.setAttribute(
                            "data-suggestion",
                            "");

                        chip.style.visibility =
                            "hidden";
                    }
                });
        }

        function insertIntoMessage(text) {
            if (!messageInput || !text) {
                return;
            }

            const start =
                messageInput.selectionStart;

            const end =
                messageInput.selectionEnd;

            const value =
                messageInput.value;

            messageInput.value =
                value.substring(0, start) +
                text +
                value.substring(end);

            const newPosition =
                start + text.length;

            messageInput.focus();

            messageInput.setSelectionRange(
                newPosition,
                newPosition);

            resizeMessageInput();
            updateSmartSuggestions();
        }

        suggestionChips.forEach(
            function (chip) {
                chip.addEventListener(
                    "click",
                    function () {
                        const suggestion =
                            chip.getAttribute(
                                "data-suggestion");

                        if (!suggestion ||
                            !messageInput) {
                            return;
                        }

                        const currentText =
                            messageInput.value;

                        const endsWithSpace =
                            currentText.endsWith(" ");

                        if (currentText.trim().length === 0) {
                            messageInput.value =
                                suggestion + " ";
                        }
                        else {
                            const lastSpaceIndex =
                                currentText.lastIndexOf(" ");

                            if (lastSpaceIndex === -1) {
                                messageInput.value =
                                    suggestion + " ";
                            }
                            else if (endsWithSpace) {
                                messageInput.value =
                                    currentText +
                                    suggestion +
                                    " ";
                            }
                            else {
                                messageInput.value =
                                    currentText.substring(
                                        0,
                                        lastSpaceIndex + 1) +
                                    suggestion +
                                    " ";
                            }
                        }

                        messageInput.focus();
                        resizeMessageInput();
                        updateSmartSuggestions();
                    });
            });

        function backspaceMessage() {
            if (!messageInput) {
                return;
            }

            const start =
                messageInput.selectionStart;

            const end =
                messageInput.selectionEnd;

            const value =
                messageInput.value;

            if (start !== end) {
                messageInput.value =
                    value.substring(0, start) +
                    value.substring(end);

                messageInput.setSelectionRange(
                    start,
                    start);
            }
            else if (start > 0) {
                messageInput.value =
                    value.substring(0, start - 1) +
                    value.substring(start);

                messageInput.setSelectionRange(
                    start - 1,
                    start - 1);
            }

            messageInput.focus();
            resizeMessageInput();
            updateSmartSuggestions();
        }

        function setLetterKeyboard() {
            numbersMode = false;

            letterKeys.forEach(
                function (button, index) {
                    const value =
                        letterValues[index];

                    if (value) {
                        const finalValue =
                            uppercaseMode
                                ? value.toUpperCase()
                                : value;

                        button.setAttribute(
                            "data-key",
                            finalValue);

                        button.innerText =
                            finalValue;

                        button.style.visibility =
                            "visible";
                    }
                });

            if (numbersKey) {
                numbersKey.innerText =
                    "123";
            }
        }

        function setNumberKeyboard() {
            numbersMode = true;

            letterKeys.forEach(
                function (button, index) {
                    const value =
                        numberValues[index];

                    if (value) {
                        button.setAttribute(
                            "data-key",
                            value);

                        button.innerText =
                            value;

                        button.style.visibility =
                            "visible";
                    }
                    else {
                        button.style.visibility =
                            "hidden";
                    }
                });

            if (numbersKey) {
                numbersKey.innerText =
                    "ABC";
            }
        }

        if (keyboardToggleBtn &&
            iosKeyboard) {

            keyboardToggleBtn.addEventListener(
                "click",
                function () {
                    iosKeyboard.classList.toggle(
