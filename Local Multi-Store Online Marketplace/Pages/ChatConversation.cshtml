@page
@model Local_Multi_Store_Online_Marketplace.Pages.ChatConversationModel

@{
    Layout = null;

    var displayName = Model.OtherUser?.FullName
        ?? Model.OtherUser?.UserName
        ?? "User";

    var avatarLetter = !string.IsNullOrWhiteSpace(displayName)
        ? displayName.Substring(0, 1).ToUpper()
        : "U";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Chat</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --bg-color: #fdfbf7; /* Cozy warm white canvas */
            --card-bg: #ffffff;
            --border-color: #f3ece3; /* Soft warm borders */
            --text-primary: #1c1917; /* Slate dark brown/black */
            --text-secondary: #78716c; /* Elegant muted stone gray */
            /* White & Orange Sunset Palette */
            --accent-color: #ff6b35; /* Radiant bright orange */
            --accent-hover: #f05a22; /* Rich dark orange */
            --accent-light: #fff1eb; /* Pastel orange tint */
            --accent-gradient: linear-gradient(135deg, #ff9f43 0%, #ff6b35 50%, #f05a22 100%); /* Orange-to-coral punch */

            --online-color: #10b981; /* Active green */
            --offline-color: #78716c; /* Offline grey */
            --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --shadow-sm: 0 4px 12px rgba(255, 107, 53, 0.04);
            --shadow-md: 0 10px 30px rgba(255, 107, 53, 0.08);
            --shadow-lg: 0 20px 40px rgba(255, 107, 53, 0.12);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            background: linear-gradient(
                135deg,
                #e8eef8 0%,
                #f7fafc 45%,
                #e8f1ff 100%);
        }

        .page-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
        }

        .wrapper {
            width: 100%;
            max-width: 900px;
            height: calc(100vh - 36px);
            display: flex;
            flex-direction: column;
            background: rgba(255, 255, 255, 0.95);
            border: 1px solid var(--border-color);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
            backdrop-filter: blur(18px);
        }

        /* HEADER TOPBAR */
        .topbar {
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            background: rgba(255, 255, 255, 0.9);
            z-index: 10;
        }

        .user {
            display: flex;
            gap: 12px;
            align-items: center;
            min-width: 0;
        }

        .avatar {
            width: 46px;
            height: 46px;
            border-radius: 16px;
            background: var(--accent-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 18px;
            box-shadow: 0 4px 14px rgba(255, 107, 53, 0.25);
            border: 1.5px solid rgba(255, 255, 255, 0.8);
        }

        .user-meta {
            min-width: 0;
        }

        .user-name {
            font-weight: 800;
            color: var(--text-primary);
            max-width: 320px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 16px;
        }

        .online {
            color: var(--online-color);
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .offline {
            color: var(--offline-color);
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .delete {
            background: #fff5f5;
            border: 1px solid #ffd1cc;
            color: var(--error-color);
            padding: 10px 18px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            font-size: 13px;
            transition: all 0.2s ease;
        }

        .delete:hover {
            background: #e11d48;
            color: white;
        }

        /* MESSAGES STREAM */
        .messages {
            flex: 1;
            padding: 18px;
            overflow: auto;
            background:
                radial-gradient(
                    circle at top left,
                    rgba(37,99,235,.08),
                    transparent 35%),
                radial-gradient(
                    circle at bottom right,
                    rgba(14,165,233,.08),
                    transparent 35%),
                #f8fafc;
        }

        .msg {
            display: flex;
            width: 100%;
        }

        .me {
            justify-content: flex-end;
        }

        .other {
            justify-content: flex-start;
        }

        .bubble {
            max-width: 70%;
            padding: 12px 16px;
            border-radius: 20px;
            font-size: 14px;
            line-height: 1.5;
            word-break: break-word;
            box-shadow: var(--shadow-sm);
        }

        .me .bubble {
            background: var(--accent-gradient);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .other .bubble {
            background: white;
            color: var(--text-primary);
            border: 1px solid var(--border-color);
            border-bottom-left-radius: 4px;
        }

        .time {
            font-size: 10px;
            opacity: 0.8;
            margin-top: 6px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 4px;
        }

        .other .time {
            justify-content: flex-start;
        }

        .seen-status {
            font-weight: 800;
            font-size: 10px;
        }

        .me .seen-status.sent {
            color: rgba(255, 255, 255, 0.7);
        }

        .me .seen-status.seen {
            color: rgba(255, 255, 255, 0.95);
        }

        .delete-message-btn {
            background: none;
            border: none;
            color: #ffcbd1;
            font-size: 10px;
            margin-top: 6px;
            cursor: pointer;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: color 0.2s ease;
            display: block;
            margin-left: auto;
        }

        .other .delete-message-btn {
            color: var(--error-color);
            margin-left: 0;
            margin-right: auto;
        }

        .me .delete-message-btn:hover {
            color: #ffffff;
        }

        /* PRODUCT CARD INSIDE CHAT */
        .product-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            width: 260px;
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            box-shadow: var(--shadow-sm);
        }

            .product-card img {
                width: 100%;
                height: 160px;
                object-fit: cover;
            }

        .product-body {
            padding: 12px;
        }

        .product-title {
            font-weight: 800;
            margin-bottom: 4px;
            font-size: 14px;
        }

        .product-price {
            color: var(--accent-color);
            font-weight: 800;
            font-size: 15px;
        }

        .product-desc {
            font-size: 12px;
            color: var(--text-secondary);
            margin-top: 6px;
            line-height: 1.4;
        }

        .product-link {
            display: inline-block;
            margin-top: 10px;
            color: var(--accent-color);
            font-weight: 800;
            font-size: 13px;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .product-link:hover {
                color: var(--accent-hover);
            }

        .chat-image {
            max-width: 260px;
            border-radius: 12px;
            display: block;
            box-shadow: var(--shadow-sm);
        }

        .file-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            color: var(--accent-color);
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            font-weight: 800;
            text-decoration: none;
            transition: all 0.2s ease;
            font-size: 13px;
        }

            .file-link:hover {
                border-color: var(--accent-color);
                background: var(--accent-light);
            }

        audio {
            max-width: 260px;
            width: 100%;
            border-radius: 50px;
        }

        /* COMPOSER FIELD */
        .composer-area {
            border-top: 1px solid var(--border-color);
            background: #ffffff;
        }

        .attach-preview {
            display: none;
            padding: 10px 18px;
            border-bottom: 1px solid var(--border-color);
            background: var(--accent-light);
            color: var(--accent-color);
            font-size: 13px;
            font-weight: 800;
        }

        .preview-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .preview-text {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .preview-remove {
            background: var(--error-color);
            color: white;
            border: none;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: opacity 0.2s ease;
        }

            .preview-remove:hover {
                opacity: 0.9;
            }

        /* VOICE COMPONENT */
        .voice-panel {
            display: none;
            padding: 12px 18px;
            border-bottom: 1px solid var(--border-color);
            background: #fff5f5;
        }

        .voice-recording-row {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--error-color);
            font-weight: 800;
            font-size: 13px;
        }

        .record-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--error-color);
            animation: pulse 1s infinite;
        }

        @@keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.35;
            }

            100% {
                opacity: 1;
            }
        }

        .voice-ready-row {
            display: none;
            align-items: center;
            gap: 12px;
        }

        .voice-ready-row audio {
            flex: 1;
            width: 100%;
        }

        /* IOS VIRTUAL KEYBOARD PANEL */
        .ios-keyboard {
            display: none;
            padding: 12px 14px 16px;
            background: #ebe6db;
            border-bottom: 1px solid var(--border-color);
        }

        .ios-keyboard.show {
            display: block;
        }

        .suggestions {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 12px;
            padding: 0 4px;
            overflow-x: auto;
            scrollbar-width: none;
        }

            .suggestions::-webkit-scrollbar {
                display: none;
            }

        .suggestion-chip {
            min-width: 90px;
            max-width: 180px;
            height: 32px;
            padding: 0 16px;
            border: 1px solid var(--border-color);
            border-radius: 50px;
            background: #ffffff;
            color: var(--text-primary);
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            transition: all 0.2s ease;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .suggestion-chip:hover {
            background: white;
            transform: translateY(-1px);
        }

        .suggestion-chip:active {
            transform: translateY(0);
            background: #e0ecff;
        }

        .key-row {
            display: flex;
            justify-content: center;
            gap: 6px;
            margin-bottom: 8px;
        }

        .middle-row {
            padding: 0 20px;
        }

        .key-btn {
            min-width: 32px;
            flex-grow: 1;
            height: 42px;
            border: none;
            border-radius: 8px;
            background: #ffffff;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 2px 0 #cfc7ba;
            transition: background 0.1s ease, transform 0.1s ease;
        }

        .key-btn:active {
            background: #e5e7eb;
            transform: translateY(1px);
            box-shadow: none;
        }

        .special-key {
            min-width: 54px;
            background: #c5bdae;
            font-size: 13px;
            color: #44403c;
        }

        .space-key {
            flex-grow: 8;
            max-width: 300px;
            font-size: 13px;
        }

        .emoji-key {
            min-width: 44px;
            background: #c5bdae;
            font-size: 16px;
        }

        .bottom-row {
            padding: 0 4px;
        }

        .keyboard-toggle-active {
            background: var(--accent-color) !important;
            color: white !important;
        }

        /* EMOJI COMPONENT */
        .emoji-panel {
            display: none;
            grid-template-columns: repeat(8, 1fr);
            gap: 8px;
            padding: 12px 6px 4px;
            max-height: 180px;
            overflow-y: auto;
            border-top: 1px solid var(--border-color);
            margin-top: 10px;
        }

        .emoji-panel.show {
            display: grid;
        }

        .emoji-btn {
            height: 38px;
            border: none;
            border-radius: 8px;
            background: #ffffff;
            font-size: 20px;
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            transition: transform 0.1s ease;
        }

        .emoji-btn:active {
            background: #e5e7eb;
            transform: translateY(1px);
        }

        /* COMPOSER FORM */
        .composer {
            display: flex;
            padding: 14px 18px;
            gap: 10px;
            align-items: flex-end;
            background: #ffffff;
        }

        .message-input {
            flex: 1;
            min-height: 42px;
            max-height: 98px;
            padding: 11px 18px;
            border-radius: 24px;
            border: 1px solid var(--border-color);
            outline: none;
            resize: none;
            font-size: 14px;
            background: var(--bg-color);
            transition: all 0.25s ease;
            font-family: var(--font-family);
        }

        .message-input:focus {
            background: white;
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(147,197,253,.25);
        }

        .send,
        .icon-btn {
            background: var(--accent-color);
            border: none;
            color: white;
            height: 42px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: 800;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .send {
            padding: 0 20px;
            border-radius: 24px;
            box-shadow: 0 4px 10px rgba(255, 107, 53, 0.2);
            font-size: 14px;
        }

        .send:hover,
        .icon-btn:hover {
            background: #1d4ed8;
        }

        .icon-btn {
            width: 42px;
            padding: 0;
            font-size: 16px;
            box-shadow: var(--shadow-sm);
            background: #f5f2eb;
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        .recording-btn {
            background: #ef4444 !important;
        }

        .product-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            width: 270px;
            border: 1px solid #e2e8f0;
            color: #111827;
        }

        .product-card img {
            width: 100%;
            height: 175px;
            object-fit: cover;
        }

        .product-body {
            padding: 11px;
        }

        .product-title {
            font-weight: 900;
            margin-bottom: 5px;
        }

        .product-price {
            color: #ff6600;
            font-weight: 900;
        }

        .product-desc {
            font-size: 13px;
            color: #64748b;
            margin-top: 5px;
        }

        .product-link {
            display: inline-block;
            margin-top: 8px;
            color: #2563eb;
            font-weight: 900;
        }

        .chat-image {
            max-width: 270px;
            border-radius: 14px;
            display: block;
        }

        .file-link {
            display: inline-block;
            background: white;
            color: #2563eb;
            padding: 11px;
            border-radius: 12px;
            border: 1px solid #dbe3ef;
            font-weight: 900;
            text-decoration: none;
        }

        audio {
            max-width: 270px;
            width: 100%;
        }

        /* =====================================================
           CHAT TOAST NOTIFICATIONS
           ===================================================== */

        .chat-toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 999999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .chat-toast {
            width: min(390px, calc(100vw - 40px));
            padding: 15px 16px;
            border-radius: 15px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            color: #ffffff;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.28);
            opacity: 0;
            transform: translateX(45px);
            transition:
                opacity 0.28s ease,
                transform 0.28s ease;
            pointer-events: auto;
        }

        .chat-toast.show {
            opacity: 1;
            transform: translateX(0);
        }

        .chat-toast-error {
            background: linear-gradient(135deg, #b91c1c, #dc2626);
        }

        .chat-toast-warning {
            background: linear-gradient(135deg, #b45309, #d97706);
        }

        .chat-toast-info {
            background: linear-gradient(135deg, #1d4ed8, #2563eb);
        }

        .chat-toast-icon {
            width: 34px;
            height: 34px;
            flex: 0 0 34px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            font-weight: 900;
        }

        .chat-toast-content {
            flex: 1;
            min-width: 0;
        }

        .chat-toast-title {
            display: block;
            margin-bottom: 3px;
            font-size: 14px;
            font-weight: 900;
        }

        .chat-toast-message {
            display: block;
            font-size: 13px;
            font-weight: 600;
            line-height: 1.5;
        }

        .chat-toast-close {
            border: none;
            background: transparent;
            color: #ffffff;
            padding: 0;
            font-size: 23px;
            line-height: 1;
            cursor: pointer;
        }

        @@media (max-width: 680px) {
            .page-shell {
                padding: 0;
            }

            .wrapper {
                height: 100vh;
                border-radius: 0;
                max-width: none;
            }

            .bubble {
                max-width: 84%;
            }

            .send {
                padding: 0 16px;
            }

            .icon-btn {
                width: 38px;
                height: 38px;
            }

            .key-btn {
                min-width: 25px;
                height: 38px;
                font-size: 14px;
            }

            .special-key {
                min-width: 42px;
            }

            .emoji-panel {
                grid-template-columns: repeat(7, 1fr);
            }

            .chat-toast-container {
                top: 12px;
                right: 12px;
                left: 12px;
            }

            .chat-toast {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <div id="chatToastContainer"
         class="chat-toast-container"
         aria-live="polite"
         aria-atomic="true">
    </div>

    <div class="page-shell">

        <div class="wrapper">

            <!-- CONVERSATION HEADER -->
            <div class="topbar">

                <div class="user">

                    <div class="avatar">
                        @avatarLetter
                    </div>

                    <div class="user-meta">

                        <div class="user-name">
                            @displayName
                        </div>

                        <div class="@(Model.IsOnlineUser ? "online" : "offline")">
                            <i class="fa-solid fa-circle" style="font-size: 7px;"></i>
                            @(Model.IsOnlineUser ? "Online" : "Offline")
                        </div>

                    </div>

                </div>

                <form method="post"
                      asp-page-handler="DeleteChat">

                    <input type="hidden"
                           name="userId"
                           value="@Model.ReceiverId" />

                    <button type="submit"
                            class="delete"
                            onclick="return confirm('Delete this conversation?')">
                        Delete
                    </button>

                </form>

            </div>

            <div class="messages"
                 id="messagesBox">

                @foreach (var msg in Model.Messages)
                {
                    <div class="msg @(msg.SenderID == Model.CurrentUserId ? "me" : "other")">

                        <div class="bubble">

                            @if (msg.Product != null)
                            {
                                var image =
                                    msg.Product.Images?
                                        .FirstOrDefault()?
                                        .ImageUrl
                                    ?? "/images/no-image.png";

                                <div class="product-card">

                                    <img src="@image"
                                         alt="@msg.Product.ProductName"
                                         onerror="this.onerror=null;this.src='/images/no-image.png';" />

                                    <div class="product-body">

                                        <div class="product-title">
                                            @msg.Product.ProductName
                                        </div>

                                        <div class="product-price">
                                            $@msg.Product.Price.ToString("N2")
                                        </div>

                                        <div class="product-desc">
                                            @msg.Product.Description
                                        </div>

                                        @if (User.IsInRole("StoreOwner"))
                                        {
                                            <a href="/Home?productId=@msg.ProductID"
                                               class="product-link">
                                                View Product
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="/CustomerProductDetails?id=@msg.ProductID"
                                               class="product-link">
                                                View Product
                                            </a>
                                        }

                                    </div>

                                </div>
                            }
                            else
                            {
                                @if (!string.IsNullOrWhiteSpace(msg.ImageUrl))
                                {
                                    var lowerUrl =
                                        msg.ImageUrl.ToLower();

                                    if (msg.MessageText == "[VOICE]")
                                    {
                                        <audio controls
                                               src="@msg.ImageUrl">
                                        </audio>
                                    }
                                    else if (
                                        msg.MessageText == "[IMAGE]" ||
                                        lowerUrl.EndsWith(".jpg") ||
                                        lowerUrl.EndsWith(".jpeg") ||
                                        lowerUrl.EndsWith(".png") ||
                                        lowerUrl.EndsWith(".gif") ||
                                        lowerUrl.EndsWith(".webp"))
                                    {
                                        <img class="chat-image"
                                             src="@msg.ImageUrl"
                                             alt="Chat attachment"
                                             onerror="this.onerror=null;this.src='/images/no-image.png';" />

                                        @if (!string.IsNullOrWhiteSpace(msg.MessageText) &&
                                             msg.MessageText != "[IMAGE]")
                                        {
                                            <div style="margin-top:6px;">
                                                @msg.MessageText
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        var fileName =
                                            msg.MessageText
