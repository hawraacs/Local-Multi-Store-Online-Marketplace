@page
@model Local_Multi_Store_Online_Marketplace.Pages.ChatConversationModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Chat</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Inter;
        }

        body {
            background: #eef2f7;
        }

        .wrapper {
            max-width: 800px;
            margin: auto;
            height: 100vh;
            display: flex;
            flex-direction: column;
            background: white;
        }

        .topbar {
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            background: white;
        }

        .user {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #111827;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .online {
            color: green;
            font-size: 12px;
        }

        .offline {
            color: gray;
            font-size: 12px;
        }

        .delete {
            background: #ef4444;
            border: none;
            color: white;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
        }

        .messages {
            flex: 1;
            padding: 15px;
            overflow: auto;
        }

        .msg {
            margin-bottom: 10px;
            display: flex;
        }

        .me {
            justify-content: flex-end;
        }

        .other {
            justify-content: flex-start;
        }

        .bubble {
            max-width: 70%;
            padding: 10px 14px;
            border-radius: 16px;
            font-size: 14px;
        }

        .me .bubble {
            background: #2563eb;
            color: white;
        }

        .other .bubble {
            background: #e5e7eb;
        }

        .time {
            font-size: 10px;
            opacity: .6;
            margin-top: 5px;
        }

        .composer {
            display: flex;
            padding: 10px;
            border-top: 1px solid #eee;
            gap: 10px;
        }

        input {
            flex: 1;
            padding: 10px;
            border-radius: 20px;
            border: 1px solid #ddd;
            outline: none;
        }

        button.send {
            background: #2563eb;
            border: none;
            color: white;
            padding: 0 20px;
            border-radius: 20px;
        }
    </style>
</head>

<body>

    <div class="wrapper">

        <!-- TOP BAR -->
        <div class="topbar">

            <div class="user">
                <div class="avatar">
                    @(Model.OtherUser?.FullName?.Substring(0, 1).ToUpper())
                </div>

                <div>
                    <div style="font-weight:600;">
                        @Model.OtherUser?.FullName
                    </div>

                    <div class="@(Model.IsOnlineUser ? "online" : "offline")">
                        @(Model.IsOnlineUser ? "● Online" : "Offline")
                    </div>
                </div>
            </div>

            <form method="post" asp-page-handler="DeleteChat">
                <input type="hidden" name="userId" value="@Model.ReceiverId" />
                <button class="delete">Delete</button>
            </form>

        </div>

        <!-- MESSAGES -->
        <div class="messages">

            @foreach (var msg in Model.Messages)
            {
                <div class="msg @(msg.SenderID == Model.CurrentUserId ? "me" : "other")">

                    <div class="bubble">
                        @if (msg.Product != null)
                        {
                            var image =
                            msg.Product.Images?.FirstOrDefault()?.ImageUrl
                            ?? "/images/no-image.png";

                            <div style="
        background:white;
        border-radius:12px;
        overflow:hidden;
        width:260px;
        border:1px solid #ddd;">

                                <img src="@image"
                                     style="
                width:100%;
                height:170px;
                object-fit:cover;" />

                                <div style="padding:10px;">

                                    <div style="
                font-weight:bold;
                margin-bottom:5px;">
                                        @msg.Product.ProductName
                                    </div>

                                    <div style="
                color:#ff6600;
                font-weight:bold;">
                                        $@msg.Product.Price
                                    </div>

                                    <div style="
                font-size:13px;
                color:#666;
                margin-top:5px;">
                                        @msg.Product.Description
                                    </div>
                                    @if (User.IsInRole("StoreOwner"))
                                    {
                                        <a href="/Home?productId=@msg.ProductID"
                                           style="display:inline-block;margin-top:8px;color:#2563eb;font-weight:bold;">
                                            View Product
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Customer1?productId=@msg.ProductID"
                                           style="display:inline-block;margin-top:8px;color:#2563eb;font-weight:bold;">
                                            View Product
                                        </a>
                                    }
}
                                </div>
                            </div>
                        }
                        else
                        {
                            @msg.MessageText
                        }

                        <div class="time">
                            @msg.SentAt.ToString("HH:mm")
                        </div>

                        @if (msg.SenderID == Model.CurrentUserId)
                        {
                            <form method="post"
                                  asp-page-handler="DeleteMessage">
                                <input type="hidden" name="messageId" value="@msg.MessageID" />
                                <input type="hidden" name="userId" value="@Model.ReceiverId" />
                                <button style="background:none;border:none;color:red;font-size:10px;">
                                    delete
                                </button>
                            </form>
                        }

                    </div>

                </div>
            }

        </div>

        <!-- INPUT -->
        <form method="post"
              asp-page-handler="Send"
              class="composer">

            <input type="hidden" name="receiverId" value="@Model.ReceiverId" />

            <input type="text"
                   name="MessageText"
                   placeholder="Message..." />

            <button class="send">Send</button>

        </form>

    </div>

</body>
</html>