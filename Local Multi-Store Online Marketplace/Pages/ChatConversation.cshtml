                    keyboardToggleBtn.classList.toggle(
                        "keyboard-toggle-active");

                    if (messageInput) {
                        messageInput.focus();
                    }
                });
        }

        keyButtons.forEach(
            function (button) {
                button.addEventListener(
                    "click",
                    function () {
                        const key =
                            button.getAttribute(
                                "data-key");

                        insertIntoMessage(key);
                    });
            });

        if (backspaceKey) {
            backspaceKey.addEventListener(
                "click",
                backspaceMessage);
        }

        if (spaceKey) {
            spaceKey.addEventListener(
                "click",
                function () {
                    insertIntoMessage(" ");
                });
        }

        if (returnKey) {
            returnKey.addEventListener(
                "click",
                function () {
                    insertIntoMessage("\n");
                });
        }

        if (shiftKey) {
            shiftKey.addEventListener(
                "click",
                function () {
                    uppercaseMode =
                        !uppercaseMode;

                    shiftKey.classList.toggle(
                        "keyboard-toggle-active");

                    if (!numbersMode) {
                        setLetterKeyboard();
                    }
                });
        }

        if (numbersKey) {
            numbersKey.addEventListener(
                "click",
                function () {
                    if (numbersMode) {
                        setLetterKeyboard();
                    }
                    else {
                        setNumberKeyboard();
                    }

                    if (emojiPanel) {
                        emojiPanel.classList.remove(
                            "show");
                    }
                });
        }

        if (emojiKey &&
            emojiPanel) {

            emojiKey.addEventListener(
                "click",
                function () {
                    emojiPanel.classList.toggle(
                        "show");

                    if (messageInput) {
                        messageInput.focus();
                    }
                });
        }

        emojiButtons.forEach(
            function (button) {
                button.addEventListener(
                    "click",
                    function () {
                        const emoji =
                            button.getAttribute(
                                "data-emoji");

                        if (emoji) {
                            insertIntoMessage(
                                emoji);
                        }
                    });
            });

        function showAttachPreview(text) {
            if (attachPreview &&
                previewText) {

                attachPreview.style.display =
                    "block";

                previewText.innerText =
                    text;
            }
        }

        function hideAttachPreview() {
            if (attachPreview &&
                previewText) {

                attachPreview.style.display =
                    "none";

                previewText.innerText =
                    "";
            }
        }

        function clearAttachment() {
            if (attachmentFile) {
                attachmentFile.value =
                    "";
            }

            hideAttachPreview();

            if (voicePanel) {
                voicePanel.style.display =
                    "none";
            }

            if (voiceRecordingRow) {
                voiceRecordingRow.style.display =
                    "none";
            }

            if (voiceReadyRow) {
                voiceReadyRow.style.display =
                    "none";
            }

            if (voiceAudio) {
                voiceAudio.removeAttribute(
                    "src");

                voiceAudio.load();
            }
        }

        if (attachmentFile) {
            attachmentFile.addEventListener(
                "change",
                function () {
                    if (this.files &&
                        this.files.length > 0) {

                        if (voicePanel) {
                            voicePanel.style.display =
                                "none";
                        }

                        showAttachPreview(
                            "Attached: " +
                            this.files[0].name);
                    }
                });
        }

        if (clearAttachmentBtn) {
            clearAttachmentBtn.addEventListener(
                "click",
                clearAttachment);
        }

        if (removeVoiceBtn) {
            removeVoiceBtn.addEventListener(
                "click",
                clearAttachment);
        }

        function formatTime(totalSeconds) {
            const minutes =
                Math.floor(
                    totalSeconds / 60)
                    .toString()
                    .padStart(2, "0");

            const sec =
                (totalSeconds % 60)
                    .toString()
                    .padStart(2, "0");

            return minutes +
                ":" +
                sec;
        }

        function startTimer() {
            seconds = 0;

            if (recordTimer) {
                recordTimer.innerText =
                    "00:00";
            }

            timerInterval =
                setInterval(
                    function () {
                        seconds++;

                        if (recordTimer) {
                            recordTimer.innerText =
                                formatTime(seconds);
                        }
                    },
                    1000);
        }

        function stopTimer() {
            clearInterval(
                timerInterval);
        }

        function stopMicrophone() {
            if (currentStream) {
                currentStream
                    .getTracks()
                    .forEach(
                        track =>
                            track.stop());

                currentStream =
                    null;
            }
        }

        function setRecordButtonNormal() {
            if (recordBtn) {
                recordBtn.innerText =
                    "🎤";

                recordBtn.classList.remove(
                    "recording-btn");

                recordBtn.style.background =
                    "#2563eb";
            }
        }

        function setRecordButtonRecording() {
            if (recordBtn) {
                recordBtn.innerText =
                    "⏹";

                recordBtn.classList.add(
                    "recording-btn");

                recordBtn.style.background =
                    "#ef4444";
            }
        }

        if (recordBtn) {
            recordBtn.addEventListener(
                "click",
                async function () {
                    if (!isRecording) {
                        try {
                            clearAttachment();

                            cancelVoice =
                                false;

                            currentStream =
                                await navigator
                                    .mediaDevices
                                    .getUserMedia({
                                        audio: true
                                    });

                            mediaRecorder =
                                new MediaRecorder(
                                    currentStream);

                            audioChunks = [];

                            mediaRecorder.ondataavailable =
                                function (event) {
                                    if (event.data &&
                                        event.data.size > 0) {

                                        audioChunks.push(
                                            event.data);
                                    }
                                };

                            mediaRecorder.onstop =
                                function () {
                                    stopTimer();
                                    stopMicrophone();
                                    setRecordButtonNormal();

                                    isRecording =
                                        false;

                                    if (cancelVoice) {
                                        clearAttachment();
                                        return;
                                    }

                                    if (!audioChunks ||
                                        audioChunks.length === 0) {

                                        clearAttachment();
                                        return;
                                    }

                                    const audioBlob =
                                        new Blob(
                                            audioChunks,
                                            {
                                                type:
                                                    "audio/webm"
                                            });

                                    const audioFile =
                                        new File(
                                            [audioBlob],
                                            "voice-message.webm",
                                            {
                                                type:
                                                    "audio/webm"
                                            });

                                    const dataTransfer =
                                        new DataTransfer();

                                    dataTransfer.items.add(
                                        audioFile);

                                    if (attachmentFile) {
                                        attachmentFile.files =
                                            dataTransfer.files;
                                    }

                                    const audioUrl =
                                        URL.createObjectURL(
                                            audioBlob);

                                    if (voiceAudio) {
                                        voiceAudio.src =
                                            audioUrl;

                                        voiceAudio.load();
                                    }

                                    if (voicePanel) {
                                        voicePanel.style.display =
                                            "block";
                                    }

                                    if (voiceRecordingRow) {
                                        voiceRecordingRow.style.display =
                                            "none";
                                    }

                                    if (voiceReadyRow) {
                                        voiceReadyRow.style.display =
                                            "flex";
                                    }

                                    showAttachPreview(
                                        "Voice ready: " +
                                        formatTime(seconds) +
                                        " — press Send.");
                                };

                            mediaRecorder.start();

                            isRecording =
                                true;

                            if (voicePanel) {
                                voicePanel.style.display =
                                    "block";
                            }

                            if (voiceRecordingRow) {
                                voiceRecordingRow.style.display =
                                    "flex";
                            }

                            if (voiceReadyRow) {
                                voiceReadyRow.style.display =
                                    "none";
                            }

                            setRecordButtonRecording();
                            startTimer();
                        }
                        catch (error) {
                            console.error(
                                "Microphone access failed:",
                                error);

                            showChatToast(
                                "Please allow microphone access in your browser settings, then try again.",
                                "error",
                                "Microphone permission required");
                        }
                    }
                    else {
                        cancelVoice =
                            false;

                        if (mediaRecorder &&
                            mediaRecorder.state !==
                                "inactive") {

                            mediaRecorder.stop();
                        }
                    }
                });
        }

        if (cancelVoiceBtn) {
            cancelVoiceBtn.addEventListener(
                "click",
                function () {
                    cancelVoice =
                        true;

                    if (mediaRecorder &&
                        mediaRecorder.state !==
                            "inactive") {

                        mediaRecorder.stop();
                    }
                    else {
                        clearAttachment();
                        stopTimer();
                        stopMicrophone();
                        setRecordButtonNormal();

                        isRecording =
                            false;
                    }
                });
        }

        if (chatForm) {
            chatForm.addEventListener(
                "submit",
                function (event) {
                    if (isRecording) {
                        event.preventDefault();

                        showChatToast(
                            "Stop the voice recording first, then press Send.",
                            "warning",
                            "Recording is still active");

                        return;
                    }

                    const hasText =
                        messageInput &&
                        messageInput.value &&
                        messageInput.value
                            .trim()
                            .length > 0;

                    const hasFile =
                        attachmentFile &&
                        attachmentFile.files &&
                        attachmentFile.files.length > 0;

                    if (!hasText &&
                        !hasFile) {

                        event.preventDefault();
                        return;
                    }
                });
        }

        updateMessageTimes();
        updateSmartSuggestions();
    </script>

</body>

</html>

