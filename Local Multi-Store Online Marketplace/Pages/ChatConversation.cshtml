    <script>
        function showChatToast(
            message,
            type = "error",
            title = "Unable to continue") {

            const container =
                document.getElementById(
                    "chatToastContainer");

            if (!container || !message) {
                return;
            }

            const existingToast =
                container.querySelector(
                    ".chat-toast");

            if (existingToast) {
                existingToast.remove();
            }

            const toast =
                document.createElement("div");

            const safeType =
                type === "warning" ||
                type === "info"
                    ? type
                    : "error";

            toast.className =
                `chat-toast chat-toast-${safeType}`;

            toast.setAttribute(
                "role",
                safeType === "error"
                    ? "alert"
                    : "status");

            const icon =
                document.createElement("span");

            icon.className =
                "chat-toast-icon";

            icon.textContent =
                safeType === "warning"
                    ? "!"
                    : safeType === "info"
                        ? "i"
                        : "×";

            const content =
                document.createElement("div");

            content.className =
                "chat-toast-content";

            const titleElement =
                document.createElement("span");

            titleElement.className =
                "chat-toast-title";

            titleElement.textContent =
                title;

            const messageElement =
                document.createElement("span");

            messageElement.className =
                "chat-toast-message";

            messageElement.textContent =
                message;

            const closeButton =
                document.createElement("button");

            closeButton.type =
                "button";

            closeButton.className =
                "chat-toast-close";

            closeButton.setAttribute(
                "aria-label",
                "Close notification");

            closeButton.innerHTML =
                "&times;";

            content.appendChild(
                titleElement);

            content.appendChild(
                messageElement);

            toast.appendChild(icon);
            toast.appendChild(content);
            toast.appendChild(closeButton);

            container.appendChild(toast);

            window.requestAnimationFrame(
                function () {
                    toast.classList.add(
                        "show");
                });

            const closeTimer =
                window.setTimeout(
                    removeToast,
                    5000);

            function removeToast() {
                if (!toast.isConnected) {
                    return;
                }

                window.clearTimeout(
                    closeTimer);

                toast.classList.remove(
                    "show");

                window.setTimeout(
                    function () {
                        toast.remove();
                    },
                    280);
            }

            closeButton.addEventListener(
                "click",
                removeToast);
        }

        const messagesBox =
