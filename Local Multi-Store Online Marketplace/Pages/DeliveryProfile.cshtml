@page "/DeliveryProfile"
@model Local_Multi_Store_Online_Marketplace.Pages.DeliveryProfileModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Delivery Profile</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --primary-light: #dbeafe;
            --secondary: #38bdf8;
            --bg: #f8fafc;
            --bg-2: #eef2f7;
            --surface: #ffffff;
            --ink-900: #0f172a;
            --ink-600: #64748b;
            --ink-400: #94a3b8;
            --border: #e2e8f0;
            --success: #22c55e;
            --success-bg: #dcfce7;
            --warning: #f59e0b;
            --warning-bg: #fef3c7;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --shadow-sm: 0 2px 8px rgba(15, 23, 42, 0.05);
            --shadow-md: 0 10px 30px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 20px 50px rgba(15, 23, 42, 0.16);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: 'Inter', Arial, sans-serif;
            color: var(--ink-900);
        }

        .page {
            min-height: 100vh;
            padding: 28px 20px 60px;
        }

        .container {
            max-width: 1180px;
            margin: auto;
        }

        .error {
            background: var(--danger-bg);
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-weight: 700;
            font-size: 13.5px;
        }

        .success {
            background: var(--success-bg);
            color: #166534;
            border: 1px solid #86efac;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-weight: 700;
            line-height: 1.5;
            font-size: 13.5px;
        }

        /* ================= DRIVER PROFILE CARD ================= */
        .driver-card {
            background: var(--surface);
            border-radius: 26px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 20px;
        }

        .driver-card-header {
            background: linear-gradient(135deg, var(--primary), #1e40af);
            padding: 30px 28px 60px;
            position: relative;
            color: white;
        }

            .driver-card-header::before {
                content: "";
                position: absolute;
                top: -50px;
                right: -50px;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(56, 189, 248, 0.18);
            }

        .driver-header-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            position: relative;
            z-index: 1;
        }

        .driver-brand {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-pill {
            padding: 7px 14px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .status-pill.online {
                background: rgba(34, 197, 94, 0.18);
                color: #ffffff;
            }

            .status-pill.offline {
                background: rgba(239, 68, 68, 0.18);
                color: #ffffff;
            }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

            .status-dot.online {
                background: #4ade80;
                box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.3);
            }

            .status-dot.offline {
                background: #f87171;
            }

        .driver-identity-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-top: 22px;
            position: relative;
            z-index: 1;
        }

        .driver-avatar {
            width: 76px;
            height: 76px;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.15);
            border: 2px solid rgba(255, 255, 255, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: 700;
            font-family: 'Sora', sans-serif;
            flex-shrink: 0;
        }

        .driver-identity-text h1 {
            margin: 0;
            font-size: 22px;
            font-family: 'Sora', sans-serif;
            font-weight: 700;
        }

        .driver-identity-text p {
            margin: 6px 0 0;
            color: #dbeafe;
            font-size: 13px;
            font-weight: 600;
        }

        /* Stats row floats over the header bottom edge */
        .driver-stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin: -40px 24px 24px;
            position: relative;
            z-index: 2;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 16px;
            box-shadow: var(--shadow-md);
            text-align: center;
        }

            .stat-card .stat-icon {
                font-size: 18px;
                margin-bottom: 8px;
            }

            .stat-card span {
                display: block;
                color: var(--ink-400);
                font-size: 11px;
                font-weight: 600;
                margin-bottom: 4px;
            }

            .stat-card strong {
                font-size: 20px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
            }

        /* ================= GRID LAYOUT ================= */
        .grid {
            display: grid;
            grid-template-columns: 1.1fr .9fr;
            gap: 20px;
        }

        .card {
            background: var(--surface);
            border-radius: 20px;
            padding: 22px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            margin-bottom: 20px;
        }

            .card h2 {
                margin: 0 0 16px;
                font-size: 16.5px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 8px;
            }

        /* ================= INFO ROWS (vehicle / location / rating) ================= */
        .info-list {
            display: grid;
            gap: 10px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            gap: 14px;
            padding: 13px 14px;
            background: var(--bg);
            border-radius: 13px;
            border: 1px solid #eef2f7;
            transition: background .15s ease;
        }

            .info-row:hover {
                background: var(--bg-2);
            }

            .info-row label {
                color: var(--ink-400);
                font-weight: 600;
                font-size: 12.5px;
            }

            .info-row span.value {
                color: var(--ink-900);
                font-weight: 700;
                text-align: right;
                font-family: 'JetBrains Mono', monospace;
                font-size: 13px;
            }

        .badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
        }

        .badge-approved {
            background: var(--success-bg);
            color: #166534;
        }

        .badge-off {
            background: var(--danger-bg);
            color: #991b1b;
        }

        .badge-busy {
            background: var(--warning-bg);
            color: #92400e;
        }

        .id-link {
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
        }

            .id-link:hover {
                text-decoration: underline;
            }

        /* ================= ACTIVE DELIVERIES ================= */
        .assignment {
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
            background: var(--bg);
            margin-bottom: 12px;
            transition: all .2s ease;
        }

            .assignment:hover {
                box-shadow: var(--shadow-sm);
            }

            .assignment h3 {
                margin: 0 0 10px;
                font-size: 15px;
                font-family: 'Sora', sans-serif;
            }

            .assignment p {
                margin: 6px 0;
                color: var(--ink-600);
                font-weight: 500;
                font-size: 13.5px;
            }

        .empty {
            text-align: center;
            padding: 30px;
            color: var(--ink-400);
            font-weight: 600;
        }

        .btn {
            border: none;
            border-radius: 12px;
            padding: 11px 16px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-size: 13.5px;
            transition: all .18s ease;
        }

        .btn-orange {
            background: var(--primary);
            color: white;
        }

            .btn-orange:hover {
                background: var(--primary-hover);
                transform: translateY(-1px);
            }

        /* ================= FORM (edit profile) ================= */
        .validation-summary-errors {
            background: var(--danger-bg);
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-weight: 600;
            line-height: 1.5;
            font-size: 13.5px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 20px;
            }

        .validation-summary-valid {
            display: none;
        }

        .field-validation-error {
            color: #b91c1c;
            font-size: 12px;
            font-weight: 600;
            line-height: 1.4;
        }

        .field-validation-valid {
            display: none;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

            .form-group.full {
                grid-column: 1 / -1;
            }

            .form-group label {
                font-weight: 700;
                color: var(--ink-600);
                font-size: 12.5px;
            }

        input,
        select {
            width: 100%;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid #d1d5db;
            outline: none;
            font-size: 14px;
            background: white;
            font-family: 'Inter', sans-serif;
            transition: all .15s ease;
        }

            input:focus,
            select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px var(--primary-light);
            }

        .readonly-input {
            background: #f3f4f6;
            color: var(--ink-600);
            cursor: not-allowed;
        }

        .hint {
            color: var(--ink-400);
            font-size: 12px;
            line-height: 1.4;
        }

        .save-btn {
            margin-top: 16px;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 13px;
            background: var(--primary);
            color: white;
            font-size: 14.5px;
            font-weight: 700;
            cursor: pointer;
            transition: all .18s ease;
        }

            .save-btn:hover {
                background: var(--primary-hover);
                box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            }

        .phone-divider {
            margin: 24px 0;
            border: none;
            border-top: 1px solid var(--border);
        }

        .phone-section-title {
            font-size: 16px !important;
            margin-bottom: 8px !important;
            font-family: 'Sora', sans-serif;
        }

        .phone-description {
            margin: 0 0 16px;
            color: var(--ink-400);
            font-size: 13px;
            line-height: 1.5;
        }

        .otp-form {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px dashed #d1d5db;
        }

        @@media (max-width: 900px) {
            .grid {
                grid-template-columns: 1fr;
            }

            .driver-stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .page {
                padding: 16px;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .driver-card-header {
                padding: 24px 20px 56px;
            }

            .driver-stats-row {
                margin: -36px 14px 20px;
            }
        }
    </style>
</head>

<body>

    <partial name="_DeliveryNav" />

    <div class="page">
        <div class="container">

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="error">
                    @Model.ErrorMessage
                </div>
            }
            else
            {
                @if (TempData["Success"] != null)
                {
                    <div class="success">
                        @TempData["Success"]
                    </div>
                }

                <div asp-validation-summary="All"></div>

                <!-- ================= DRIVER PROFILE CARD ================= -->
                <div class="driver-card">

                    <div class="driver-card-header">

                        <div class="driver-header-top">
                            <div class="driver-brand">
                                🚚 Delivery Partner
                            </div>

                            @if (Model.Profile.IsActive &&
                           Model.Profile.Status == "Approved")
                            {
                                <span class="status-pill online">
                                    <span class="status-dot online"></span>
                                    Approved &amp; Active
                                </span>
                            }
                            else
                            {
                                <span class="status-pill offline">
                                    <span class="status-dot offline"></span>
                                    @Model.Profile.Status
                                </span>
                            }
                        </div>

                        <div class="driver-identity-row">

                            <div class="driver-avatar">
                                @(string.IsNullOrWhiteSpace(Model.Profile.FullName)
                                    ? "D"
                                    : Model.Profile.FullName
                                    .Substring(0, 1)
                                    .ToUpper())
                            </div>

                            <div class="driver-identity-text">
                                <h1>@Model.Profile.FullName</h1>
                                <p>@Model.Profile.Area &bull; @Model.Profile.PhoneNumber</p>
                            </div>

                        </div>

                    </div>

                    <div class="driver-stats-row">

                        <div class="stat-card">
                            <div class="stat-icon">📦</div>
                            <span>Total</span>
                            <strong>@Model.Profile.TotalAssignments</strong>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">📅</div>
                            <span>Today</span>
                            <strong>@Model.Profile.TodayAssignments</strong>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">✅</div>
                            <span>Completed</span>
                            <strong>@Model.Profile.CompletedDeliveries</strong>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">🚚</div>
                            <span>Active</span>
                            <strong>@Model.Profile.ActiveDeliveries</strong>
                        </div>

                    </div>

                </div>

                <div class="grid">

                    <div>

                        <!-- ================= VEHICLE INFORMATION ================= -->
                        <div class="card">
                            <h2>🚗 Vehicle Information</h2>

                            <div class="info-list">

                                <div class="info-row">
                                    <label>Vehicle Type</label>
                                    <span class="value">@Model.Profile.VehicleType</span>
                                </div>

                                <div class="info-row">
                                    <label>Vehicle Number</label>
                                    <span class="value">@Model.Profile.VehicleNumber</span>
                                </div>

                                <div class="info-row">
                                    <label>License Number</label>
                                    <span class="value">@Model.Profile.DrivingLicenseNumber</span>
                                </div>

                                <div class="info-row">
                                    <label>ID Proof</label>
                                    <span class="value">
                                        @if (!string.IsNullOrWhiteSpace(
                                       Model.Profile.IDProofURL))
                                        {
                                            <a class="id-link"
                                               href="@Model.Profile.IDProofURL"
                                               target="_blank"
                                               rel="noopener noreferrer">
                                                View File
                                            </a>
                                        }
                                        else
                                        {
                                            @("Not uploaded")
                                        }
                                    </span>
                                </div>

                            </div>
                        </div>

                        <!-- ================= LOCATION INFORMATION ================= -->
                        <div class="card">
                            <h2>📍 Location Information</h2>

                            <div class="info-list">

                                <div class="info-row">
                                    <label>Working Area</label>
                                    <span class="value">@Model.Profile.Area</span>
                                </div>

                                <div class="info-row">
                                    <label>Last Location</label>
                                    <span class="value">
                                        @if (Model.Profile.CurrentLatitude.HasValue &&
                                       Model.Profile.CurrentLongitude.HasValue)
                                        {
                                            @($"{Model.Profile.CurrentLatitude.Value:0.000000}, {Model.Profile.CurrentLongitude.Value:0.000000}")
                                        }
                                        else
                                        {
                                            @("Not available")
                                        }
                                    </span>
                                </div>

                                <div class="info-row">
                                    <label>Location Updated</label>
                                    <span class="value">
                                        @Model.FormatLocalTime(
                                                 Model.Profile.LastLocationUpdate)
                                    </span>
                                </div>

                                <div class="info-row">
                                    <label>Approved At</label>
                                    <span class="value">
                                        @Model.FormatLocalTime(
                                                 Model.Profile.ApprovedAt)
                                    </span>
                                </div>

                            </div>
                        </div>

                        <!-- ================= RATINGS ================= -->
                        <div class="card">
                            <h2>⭐ Ratings</h2>

                            <div class="info-list">
                                <div class="info-row">
                                    <label>Customer Rating</label>
                                    <span class="value">
                                        ⭐ @Model.Profile.Rating.ToString("0.0") / 5.0
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- ================= ACTIVE DELIVERIES ================= -->
                        <div class="card">
                            <h2>📦 Active Deliveries</h2>

                            @if (Model.ActiveAssignments == null ||
                           !Model.ActiveAssignments.Any())
                            {
                                <div class="empty">
                                    No active deliveries right now.
                                </div>
                            }
                            else
                            {
                                @foreach (var item in
                               Model.ActiveAssignments)
                                {
                                    <div class="assignment">

                                        <h3>
                                            Order @item.OrderNumber
                                        </h3>

                                        <p>
                                            <strong>
                                                Assignment:
                                            </strong>

                                            <span class="badge badge-busy">
                                                @item.AssignmentStatus
                                            </span>
                                        </p>

                                        <p>
                                            <strong>
                                                Order Status:
                                            </strong>

                                            @item.OrderStatus
                                        </p>

                                        <p>
                                            <strong>
                                                Address:
                                            </strong>

                                            @item.CustomerAddress
                                        </p>

                                        <p>
                                            <strong>
                                                Total:
                                            </strong>

                                            $@item.TotalAmount.ToString("N2")
                                        </p>

                                        <p>
                                            <strong>
                                                Payment:
                                            </strong>

                                            @item.PaymentMethod
                                            -
                                            @item.PaymentStatus
                                        </p>

                                        <p>
                                            <strong>
                                                Assigned:
                                            </strong>

                                            @Model.FormatLocalTime(
                                                     item.AssignedAt)
                                        </p>

                                        <a href="/DeliveryDashboard"
                                           class="btn btn-orange">
                                            Manage Delivery
                                        </a>

                                    </div>
                                }
                            }
                        </div>

                    </div>

                    <div>

                        <!-- ================= EDIT PROFILE FORM ================= -->
                        <div class="card">
                            <h2>✏️ Edit Delivery Profile</h2>

                            @* ==========================================
                               FORM 1: UPDATE NORMAL PROFILE INFORMATION
                               ========================================== *@

                            <form method="post"
                                  asp-page-handler="Update">

                                <div class="form-grid">

                                    <div class="form-group full">

                                        <label asp-for="Input.FullName">
                                            Full Name
                                        </label>

                                        <input asp-for="Input.FullName"
                                               maxlength="100"
                                               placeholder="Enter full name" />

                                        <span asp-validation-for="Input.FullName"
                                              class="field-validation-error">
                                        </span>

                                    </div>

                                    <div class="form-group full">
                                        <label asp-for="Input.PhoneNumber">
                                            Current Phone Number
                                        </label>

                                        @if (Model.CanEditPhoneNumber)
                                        {
                                            <input asp-for="Input.PhoneNumber"
                                                   type="tel"
                                                   inputmode="tel"
                                                   autocomplete="tel"
                                                   maxlength="20"
                                                   placeholder="+96176123456" />

                                            <span asp-validation-for="Input.PhoneNumber"
                                                  class="field-validation-error">
                                            </span>

                                            <span class="hint">
                                                Current phone verified.
                                                You can edit this number
                                                and click Save Changes
                                                within 10 minutes.
                                            </span>
                                        }
                                        else
                                        {
                                            <input asp-for="Input.PhoneNumber"
                                                   class="readonly-input"
                                                   readonly
                                                   aria-readonly="true" />

                                            <span class="hint">
                                                Verify your current phone
                                                below before editing this
                                                number.
                                            </span>
                                        }
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="Input.VehicleType">
                                            Vehicle Type
                                        </label>

                                        <select asp-for="Input.VehicleType"
                                                id="profileVehicleType"
                                                onchange="updateProfileVehicleFields()">

                                            <option value="">
                                                Select vehicle type
                                            </option>

                                            <option value="Motorcycle">
                                                Motorcycle
                                            </option>

                                            <option value="Car">
                                                Car
                                            </option>

                                            <option value="Van">
                                                Van
                                            </option>

                                            <option value="Bicycle">
                                                Bicycle
                                            </option>
                                        </select>

                                        <span asp-validation-for="Input.VehicleType"
                                              class="field-validation-error">
                                        </span>
                                    </div>

                                    <div class="form-group"
                                         id="profileVehicleNumberGroup">

                                        <label asp-for="Input.VehicleNumber">
                                            Vehicle Number
                                        </label>

                                        <input asp-for="Input.VehicleNumber"
                                               id="profileVehicleNumber"
                                               maxlength="20"
                                               placeholder="Example: B 123456" />

                                        <span asp-validation-for="Input.VehicleNumber"
                                              class="field-validation-error">
                                        </span>
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="Input.Area">
                                            Working Area
                                        </label>

                                        <select asp-for="Input.Area">

                                            <option value="">
                                                Select your area
                                            </option>

                                            <option value="Beirut">
                                                Beirut
                                            </option>

                                            <option value="Mount Lebanon">
                                                Mount Lebanon
                                            </option>

                                            <option value="Tripoli">
                                                Tripoli
                                            </option>

                                            <option value="Saida">
                                                Saida
                                            </option>

                                            <option value="Tyre">
                                                Tyre
                                            </option>

                                            <option value="Zahle">
                                                Zahle
                                            </option>

                                            <option value="Bekaa">
                                                Bekaa
                                            </option>

                                            <option value="Jounieh">
                                                Jounieh
                                            </option>

                                            <option value="Byblos">
                                                Byblos
                                            </option>

                                            <option value="Nabatieh">
                                                Nabatieh
                                            </option>

                                        </select>

                                        <span asp-validation-for="Input.Area"
                                              class="field-validation-error">
                                        </span>
                                    </div>

                                    <div class="form-group"
                                         id="profileLicenseGroup">

                                        <label asp-for="Input.DrivingLicenseNumber">
                                            Driving License Number
                                        </label>

                                        <input asp-for="Input.DrivingLicenseNumber"
                                               id="profileLicenseNumber"
                                               maxlength="25"
                                               placeholder="Enter license number" />

                                        <span asp-validation-for="Input.DrivingLicenseNumber"
                                              class="field-validation-error">
                                        </span>
                                    </div>

                                </div>

                                <button type="submit"
                                        class="save-btn">
                                    Save Changes
                                </button>

                            </form>

                            <hr class="phone-divider" />

                            @if (!Model.CanEditPhoneNumber)
                            {
                                <h2 class="phone-section-title">
                                    Verify Current Phone
                                </h2>

                                <p class="phone-description">
                                    For security, a verification code will be
                                    sent by SMS to your current phone number:
                                    <strong>@Model.Profile.PhoneNumber</strong>.
                                </p>

                                @if (!string.IsNullOrWhiteSpace(
                               Model.PhoneMessage))
                                {
                                    <div class="success">
                                        @Model.PhoneMessage
                                    </div>
                                }

                                <form method="post"
                                      asp-page-handler="SendPhoneOtp">

                                    <button type="submit"
                                            class="save-btn">
                                        Send OTP to Current Phone
                                    </button>

                                </form>

                                @if (Model.ShowPhoneOtpForm)
                                {
                                    <form method="post"
                                          asp-page-handler="VerifyPhoneOtp"
                                          class="otp-form">

                                        <div class="form-group full">
                                            <label asp-for="PhoneOtpCode">
                                                OTP Code
                                            </label>

                                            <input asp-for="PhoneOtpCode"
                                                   type="text"
                                                   inputmode="numeric"
                                                   autocomplete="one-time-code"
                                                   maxlength="10"
                                                   placeholder="Enter verification code" />

                                            <span asp-validation-for="PhoneOtpCode"
                                                  class="field-validation-error">
                                            </span>

                                            <span class="hint">
                                                Enter the code sent to
                                                @Model.Profile.PhoneNumber
                                            </span>
                                        </div>

                                        <button type="submit"
                                                class="save-btn">
                                            Verify Current Phone
                                        </button>

                                    </form>
                                }
                            }
                            else
                            {
                                <h2 class="phone-section-title">
                                    Phone Editing Enabled
                                </h2>

                                <div class="success">
                                    Your current phone was verified.
                                    Edit the Current Phone Number field above,
                                    then click Save Changes. Editing remains
                                    available for 10 minutes.
                                </div>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>
    </div>

    <script>
        function updateProfileVehicleFields() {
            const vehicleType =
                document.getElementById(
                    "profileVehicleType");

            const vehicleNumberGroup =
                document.getElementById(
                    "profileVehicleNumberGroup");

            const licenseGroup =
                document.getElementById(
                    "profileLicenseGroup");

            const vehicleNumber =
                document.getElementById(
                    "profileVehicleNumber");

            const licenseNumber =
                document.getElementById(
                    "profileLicenseNumber");

            if (!vehicleType ||
                !vehicleNumberGroup ||
                !licenseGroup ||
                !vehicleNumber ||
                !licenseNumber) {
                return;
            }

            const isMotorVehicle =
                vehicleType.value === "Motorcycle" ||
                vehicleType.value === "Car" ||
                vehicleType.value === "Van";

            const isBicycle =
                vehicleType.value === "Bicycle";

            vehicleNumber.required =
                isMotorVehicle;

            licenseNumber.required =
                isMotorVehicle;

            if (isBicycle) {
                vehicleNumberGroup.style.display =
                    "none";

                licenseGroup.style.display =
                    "none";

                vehicleNumber.value =
                    "";

                licenseNumber.value =
                    "";
            }
            else {
                vehicleNumberGroup.style.display =
                    "flex";

                licenseGroup.style.display =
                    "flex";
            }
        }

        document.addEventListener(
            "DOMContentLoaded",
            updateProfileVehicleFields);
    </script>

</body>
</html>
