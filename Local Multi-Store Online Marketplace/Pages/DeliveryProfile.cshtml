@page "/DeliveryProfile"
@model Local_Multi_Store_Online_Marketplace.Pages.DeliveryProfileModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Delivery Profile</title>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .page {
            min-height: 100vh;
            padding: 35px;
        }

        .container {
            max-width: 1150px;
            margin: auto;
        }

        .top-card {
            background: linear-gradient(135deg, #111827, #1e3a5f);
            color: white;
            border-radius: 22px;
            padding: 26px;
            box-shadow: 0 16px 35px rgba(15,23,42,.18);
            margin-bottom: 22px;
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: center;
            flex-wrap: wrap;
        }

        .identity {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .avatar {
            width: 68px;
            height: 68px;
            border-radius: 22px;
            background: white;
            color: #1e3a5f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 900;
        }

        .identity h1 {
            margin: 0;
            font-size: 26px;
        }

        .identity p {
            margin: 6px 0 0;
            color: #dbeafe;
            font-weight: 700;
        }

        .top-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            border: none;
            border-radius: 12px;
            padding: 11px 15px;
            font-weight: 900;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .btn-light {
            background: white;
            color: #111827;
        }

        .btn-orange {
            background: #ff6b35;
            color: white;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.1fr .9fr;
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 18px;
            padding: 22px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15,23,42,.08);
            margin-bottom: 20px;
        }

            .card h2 {
                margin: 0 0 16px;
                font-size: 20px;
            }

        .stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 8px 20px rgba(15,23,42,.07);
        }

            .stat-card span {
                color: #6b7280;
                font-size: 12px;
                font-weight: 800;
            }

            .stat-card strong {
                display: block;
                margin-top: 8px;
                font-size: 26px;
                color: #111827;
            }

        .info-list {
            display: grid;
            gap: 12px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            gap: 14px;
            padding: 12px;
            background: #f9fafb;
            border-radius: 12px;
            border: 1px solid #eef2f7;
        }

            .info-row label {
                color: #6b7280;
                font-weight: 800;
                font-size: 13px;
            }

            .info-row span {
                color: #111827;
                font-weight: 900;
                text-align: right;
            }

        .badge {
            display: inline-block;
            padding: 6px 11px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
        }

        .badge-approved {
            background: #dcfce7;
            color: #166534;
        }

        .badge-busy {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-off {
            background: #fee2e2;
            color: #991b1b;
        }

        .success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
            padding: 13px;
            border-radius: 13px;
            margin-bottom: 18px;
            font-weight: 900;
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 13px;
            border-radius: 13px;
            margin-bottom: 18px;
            font-weight: 900;
        }

        .validation-summary-errors {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 13px;
            border-radius: 13px;
            margin-bottom: 18px;
            font-weight: 800;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

            .form-group.full {
                grid-column: 1 / -1;
            }

            .form-group label {
                font-weight: 900;
                color: #374151;
                font-size: 13px;
            }

        input,
        select {
            padding: 12px 13px;
            border-radius: 12px;
            border: 1px solid #d1d5db;
            outline: none;
            font-size: 14px;
        }

            input:focus,
            select:focus {
                border-color: #1e3a5f;
                box-shadow: 0 0 0 3px rgba(30,58,95,.12);
            }

        .save-btn {
            margin-top: 16px;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 13px;
            background: #111827;
            color: white;
            font-size: 15px;
            font-weight: 900;
            cursor: pointer;
        }

            .save-btn:hover {
                background: #ff6b35;
            }

        .assignment {
            border: 1px solid #e5e7eb;
            border-radius: 15px;
            padding: 15px;
            background: #f9fafb;
            margin-bottom: 12px;
        }

            .assignment h3 {
                margin: 0 0 10px;
                font-size: 16px;
            }

            .assignment p {
                margin: 6px 0;
                color: #374151;
                font-weight: 700;
                font-size: 14px;
            }

        .empty {
            text-align: center;
            padding: 25px;
            color: #6b7280;
            font-weight: 800;
        }

        .id-link {
            color: #2563eb;
            font-weight: 900;
            text-decoration: none;
        }

            .id-link:hover {
                text-decoration: underline;
            }

        @@media (max-width: 900px) {
            .grid {
                grid-template-columns: 1fr;
            }

            .stats {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 600px) {
            .page {
                padding: 18px;
            }

            .form-grid,
            .stats {
                grid-template-columns: 1fr;
            }

            .top-card {
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>
    <partial name="_DeliveryNav" />
    <div class="page">
        <div class="container">

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
            else
            {
                <div class="top-card">
                    <div class="identity">
                        <div class="avatar">
                            @(string.IsNullOrWhiteSpace(Model.Profile.FullName)
                                ? "D"
                                : Model.Profile.FullName.Substring(0, 1).ToUpper())
                        </div>

                        <div>
                            <h1>@Model.Profile.FullName</h1>
                            <p>
                                Delivery Partner • @Model.Profile.Area
                            </p>
                        </div>
                    </div>

                    <div class="top-actions">
                        <a href="/DeliveryDashboard" class="btn btn-light">
                            ← Dashboard
                        </a>

                        <a href="/DeliveryDashboard" class="btn btn-orange">
                            My Deliveries
                        </a>
                    </div>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="success">@TempData["Success"]</div>
                }

                <div asp-validation-summary="All"></div>

                <div class="stats">
                    <div class="stat-card">
                        <span>Total Assignments</span>
                        <strong>@Model.Profile.TotalAssignments</strong>
                    </div>

                    <div class="stat-card">
                        <span>Today</span>
                        <strong>@Model.Profile.TodayAssignments</strong>
                    </div>

                    <div class="stat-card">
                        <span>Completed</span>
                        <strong>@Model.Profile.CompletedDeliveries</strong>
                    </div>

                    <div class="stat-card">
                        <span>Active</span>
                        <strong>@Model.Profile.ActiveDeliveries</strong>
                    </div>
                </div>

                <div class="grid">
                    <div>
                        <div class="card">
                            <h2>Profile Information</h2>

                            <div class="info-list">
                                <div class="info-row">
                                    <label>Status</label>
                                    <span>
                                        @if (Model.Profile.IsActive && Model.Profile.Status == "Approved")
                                        {
                                            <span class="badge badge-approved">Approved & Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-off">@Model.Profile.Status</span>
                                        }
                                    </span>
                                </div>

                                <div class="info-row">
                                    <label>Phone</label>
                                    <span>@Model.Profile.PhoneNumber</span>
                                </div>

                                <div class="info-row">
                                    <label>Vehicle</label>
                                    <span>@Model.Profile.VehicleType</span>
                                </div>

                                <div class="info-row">
                                    <label>Vehicle Number</label>
                                    <span>@Model.Profile.VehicleNumber</span>
                                </div>

                                <div class="info-row">
                                    <label>License Number</label>
                                    <span>@Model.Profile.DrivingLicenseNumber</span>
                                </div>

                                <div class="info-row">
                                    <label>Rating</label>
                                    <span>⭐ @Model.Profile.Rating.ToString("0.0")</span>
                                </div>

                                <div class="info-row">
                                    <label>Approved At</label>
                                    <span>@Model.FormatLocalTime(Model.Profile.ApprovedAt)</span>
                                </div>

                                <div class="info-row">
                                    <label>Last Location</label>
                                    <span>
                                        @if (Model.Profile.CurrentLatitude.HasValue &&
                                       Model.Profile.CurrentLongitude.HasValue)
                                        {
                                            @($"{Model.Profile.CurrentLatitude.Value:0.000000}, {Model.Profile.CurrentLongitude.Value:0.000000}")
                                        }
                                        else
                                        {
                                            @("Not available")
                                        }
                                    </span>
                                </div>

                                <div class="info-row">
                                    <label>Location Updated</label>
                                    <span>@Model.FormatLocalTime(Model.Profile.LastLocationUpdate)</span>
                                </div>

                                <div class="info-row">
                                    <label>ID Proof</label>
                                    <span>
                                        @if (!string.IsNullOrWhiteSpace(Model.Profile.IDProofURL))
                                        {
                                            <a class="id-link" href="@Model.Profile.IDProofURL" target="_blank">
                                                View File
                                            </a>
                                        }
                                        else
                                        {
                                            @("Not uploaded")
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <h2>Active Deliveries</h2>

                            @if (Model.ActiveAssignments == null || !Model.ActiveAssignments.Any())
                            {
                                <div class="empty">
                                    No active deliveries right now.
                                </div>
                            }
                            else
                            {
                                @foreach (var item in Model.ActiveAssignments)
                                {
                                    <div class="assignment">
                                        <h3>Order @item.OrderNumber</h3>

                                        <p>
                                            <strong>Assignment:</strong>
                                            <span class="badge badge-busy">@item.AssignmentStatus</span>
                                        </p>

                                        <p>
                                            <strong>Order Status:</strong>
                                            @item.OrderStatus
                                        </p>

                                        <p>
                                            <strong>Address:</strong>
                                            @item.CustomerAddress
                                        </p>

                                        <p>
                                            <strong>Total:</strong>
                                            $@item.TotalAmount.ToString("N2")
                                        </p>

                                        <p>
                                            <strong>Payment:</strong>
                                            @item.PaymentMethod - @item.PaymentStatus
                                        </p>

                                        <p>
                                            <strong>Assigned:</strong>
                                            @Model.FormatLocalTime(item.AssignedAt)
                                        </p>

                                        <a href="/DeliveryDashboard" class="btn btn-orange">
                                            Manage Delivery
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div>
                        <div class="card">
                            <h2>Edit Delivery Profile</h2>

                            <form method="post" asp-page-handler="Update">
                                <div class="form-grid">
                                    <div class="form-group full">
                                        <label>Full Name</label>
                                        <input asp-for="Input.FullName" />
                                    </div>

                                    <div class="form-group full">
                                        <label>Phone Number</label>
                                        <input asp-for="Input.PhoneNumber" />
                                    </div>

                                    <div class="form-group">
                                        <label>Vehicle Type</label>
                                        <select asp-for="Input.VehicleType">
                                            <option value="">Select vehicle type</option>
                                            <option value="Motorcycle">Motorcycle</option>
                                            <option value="Car">Car</option>
                                            <option value="Van">Van</option>
                                            <option value="Bicycle">Bicycle</option>
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <label>Vehicle Number</label>
                                        <input asp-for="Input.VehicleNumber" />
                                    </div>

                                    <div class="form-group">
                                        <label>Working Area</label>
                                        <select asp-for="Input.Area">
                                            <option value="">Select your area</option>
                                            <option value="Beirut">Beirut</option>
                                            <option value="Mount Lebanon">Mount Lebanon</option>
                                            <option value="Tripoli">Tripoli</option>
                                            <option value="Saida">Saida</option>
                                            <option value="Tyre">Tyre</option>
                                            <option value="Zahle">Zahle</option>
                                            <option value="Bekaa">Bekaa</option>
                                            <option value="Jounieh">Jounieh</option>
                                            <option value="Byblos">Byblos</option>
                                            <option value="Nabatieh">Nabatieh</option>
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <label>Driving License Number</label>
                                        <input asp-for="Input.DrivingLicenseNumber" />
                                    </div>
                                </div>

                                <button type="submit" class="save-btn">
                                    Save Changes
                                </button>
                            </form>
                        </div>

                        <div class="card">
                            <h2>Profile Notes</h2>

                            <div class="info-list">
                                <div class="info-row">
                                    <label>GPS Tracking</label>
                                    <span>Updated from dashboard</span>
                                </div>

                                <div class="info-row">
                                    <label>Order Actions</label>
                                    <span>Use Delivery Dashboard</span>
                                </div>

                                <div class="info-row">
                                    <label>Approval</label>
                                    <span>Managed by Admin</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</body>
</html>