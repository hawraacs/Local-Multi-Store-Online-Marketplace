@page
@model Local_Multi_Store_Online_Marketplace.Pages.Customer1Model
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Customer Feed | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(145deg, #f6f9fc 0%, #edf2f7 100%);
        }

        .topbar {
            background: rgba(10,15,25,0.92);
            backdrop-filter: blur(12px);
            color: white;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
        }

        .menu a {
            color: #eef2ff;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 40px;
        }

            .menu a:hover {
                background: rgba(255,255,255,0.15);
            }

        .feed {
            max-width: 720px;
            margin: 40px auto;
        }

        .post {
            background: white;
            border-radius: 28px;
            margin-bottom: 32px;
            overflow: hidden;
            box-shadow: 0 12px 28px rgba(0,0,0,0.08);
        }

            .post img {
                width: 100%;
                height: 220px;
                object-fit: cover;
            }

        .post-body {
            padding: 22px;
        }

        .post-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .store {
            font-weight: 600;
            color: #FF6B35;
        }

        .product-name {
            font-size: 22px;
            font-weight: 700;
            margin-top: 10px;
        }

        .product-price {
            font-size: 24px;
            font-weight: 800;
            color: #e67e22;
        }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .btn-like,
        .btn-cart {
            padding: 10px 18px;
            border-radius: 50px;
            border: 1px solid #ddd;
            cursor: pointer;
            background: white;
        }

        .btn-cart {
            background: #0a0f19;
            color: white;
        }

        .empty-message {
            text-align: center;
            margin-top: 80px;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div>realnest</div>

        <div class="menu">
            <a href="/Customer1">Explore</a>
            <a href="/CustomerFeed">Feed</a>
            <a href="/CustomerProducts">Shop</a>
            <a href="/CustomerCart">Cart</a>
            <a href="/CustomerPromotions">Promotions</a>
            <a href="/CustomerOrders">Orders</a>
            <a href="/Chat">Chat</a>
            <a href="/CustomerProfile">Profile</a>
        </div>
    </div>

    <div class="feed">

        @if (TempData["Success"] != null)
        {
            <div>@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div>@TempData["Error"]</div>
        }

        @if (Model.Products.Any())
        {
            foreach (var product in Model.Products)
            {
                var isFollowing = Model.FollowingStoreIds.Contains(product.StoreID);

                string imageUrl = "/images/no-image.png";
                if (product.Images != null && product.Images.Any())
                {
                    var primary = product.Images.FirstOrDefault(i => i.IsPrimary);
                    imageUrl = (primary ?? product.Images.First()).ImageUrl;
                }

                <div class="post">

                    <div class="post-body">

                        <!-- HEADER -->
                        <div class="post-header">

                            <div class="store">
                                🏪 @(product.Store?.StoreName ?? "Unknown Store")
                            </div>

                            @if (isFollowing)
                            {
                                <form method="post" asp-page-handler="UnfollowStore" asp-route-storeId="@product.StoreID">
                                    <button type="submit" class="btn-like" style="background:#fee2e2;color:#991b1b;">
                                        Unfollow
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="FollowStore" asp-route-storeId="@product.StoreID">
                                    <button type="submit" class="btn-like" style="background:#dcfce7;color:#166534;">
                                        Follow
                                    </button>
                                </form>
                            }

                        </div>

                        <!-- IMAGE -->
                        <img src="@imageUrl" />

                        <!-- PRODUCT -->
                        <div class="product-name">@product.ProductName</div>

                        <div class="product-price">
                            $@product.Price.ToString("N2")
                        </div>

                        <div class="product-description">
                            @product.Description
                        </div>

                        <!-- ACTIONS (WITH CORRECT ROUTING) -->
                        <div class="actions">

                            <form method="post"
                                  asp-page-handler="AddWishlist"
                                  asp-route-productId="@product.ProductID">
                                <button type="submit" class="btn-like">❤️ Like</button>
                            </form>

                            <form method="post"
                                  asp-page-handler="AddToCart"
                                  asp-route-productId="@product.ProductID">
                                <button type="submit" class="btn-cart">🛒 Add To Cart</button>
                            </form>

                            <a class="btn-like"
                               href="/CreateProductReview?storeId=@product.StoreID">
                                ⭐ Review
                            </a>

                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-message">
                No products yet — check back soon!
            </div>
        }

    </div>

</body>
</html>