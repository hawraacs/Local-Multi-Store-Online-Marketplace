@page
@model Local_Multi_Store_Online_Marketplace.Pages.Customer1Model
@{
    Layout = null;
    var hasActiveExploreFilters = Model.CategoryId.HasValue || Model.StoreId.HasValue
        || !string.IsNullOrEmpty(Model.Area) || Model.MinPrice.HasValue || Model.MaxPrice.HasValue;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>Explore | realnest</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <link rel="stylesheet"
          href="~/css/customer-explore.css"
          asp-append-version="true" />
    <link rel="stylesheet"
          href="~/css/customer-explore-polish.css"
          asp-append-version="true" />

    <style>
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-steel: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #faf9fc;
            --text-primary: #1e1b2e;
        }

        .brand-mark {
            color: #ffffff !important;
            background: var(--accent-gradient) !important;
        }

        .category-chip.active {
            background: var(--accent-gradient) !important;
            color: #ffffff !important;
            border-color: transparent !important;
        }

        .tile-price {
            background: var(--accent-gradient) !important;
            color: #ffffff !important;
        }

        .tile-badge {
            background: rgba(109, 40, 217, 0.85) !important;
            color: #ffffff !important;
        }

        /* NEW — boosted/sponsored tile badge, overrides the default purple tile-badge */
        .sponsored-badge {
            background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%) !important;
            color: #ffffff !important;
        }

        .follow-button,
        .primary-product-button,
        .comment-submit-button {
            background: var(--accent-gradient) !important;
            color: #ffffff !important;
            border-color: transparent !important;
        }

        .modal-action-button:hover,
        .secondary-product-button:hover,
        .write-review-link {
            background: var(--accent-gradient) !important;
            -webkit-background-clip: text !important;
            background-clip: text !important;
            -webkit-text-fill-color: transparent !important;
            color: var(--accent-color) !important;
        }

        .product-review-stars,
        .intro-stat .stat-icon {
            color: var(--accent-color) !important;
        }

        .loader-spinner {
            border-top-color: var(--accent-color) !important;
        }

        .mobile-bottom-nav a.active {
            color: var(--accent-color) !important;
        }

        .mobile-bottom-nav {
            display: flex !important;
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 200;
            background: #ffffff;
            border-top: 1px solid #ece8f6;
            justify-content: space-between;
            gap: 2px;
            padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
            overflow-x: auto;
        }

            .mobile-bottom-nav a {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2px;
                font-size: 10.5px;
                color: #6b6478;
                text-decoration: none;
                padding: 4px 6px;
                flex-shrink: 0;
                position: relative;
            }

                .mobile-bottom-nav a i {
                    font-size: 17px;
                }

        .category-chip:hover {
            border-color: var(--accent-color) !important;
            color: var(--accent-color) !important;
        }

        .tile-store-fallback {
            background: var(--accent-gradient) !important;
            color: #ffffff !important;
        }

        .modal-store-avatar {
            background: var(--accent-gradient) !important;
        }

        .media-nav {
            color: var(--accent-color) !important;
        }

            .media-nav:hover {
                background: var(--accent-light) !important;
            }

        .grid-legend i,
        .modal-caption a,
        .modal-store-link:hover strong,
        .comments-list a {
            color: var(--accent-color) !important;
        }

        .modal-action-button.active,
        .modal-action-button.liked,
        .modal-action-button[aria-pressed="true"] {
            color: var(--accent-color) !important;
        }

        .comment-submit-button i {
            color: #ffffff !important;
        }

        ::selection {
            background: var(--accent-light);
            color: var(--accent-color);
        }

        a {
            color: var(--accent-color);
        }

        html,
        body {
            background: var(--bg-color, #faf9fc) !important;
        }

        .explore-page {
            background: var(--bg-color, #faf9fc) !important;
            position: relative;
            overflow-x: hidden;
            padding-bottom: 82px;
        }

        .explore-intro {
            position: relative;
            overflow: hidden;
            isolation: isolate;
            border-radius: 20px;
            padding: 36px 32px;
            min-height: 300px;
            background: #2a2140;
        }

        .intro-slide {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 1.4s ease;
            z-index: 0;
        }

            .intro-slide.active {
                opacity: 1;
            }

        .explore-intro::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(20, 14, 40, 0.72) 0%, rgba(35, 22, 70, 0.62) 100%);
            z-index: 1;
            pointer-events: none;
        }

        .explore-intro > div:first-child,
        .explore-intro h1,
        .explore-intro p {
            position: relative;
            z-index: 2;
            background: transparent !important;
            color: #ffffff !important;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.45);
        }

        .explore-intro .eyebrow {
            position: relative;
            z-index: 2;
            color: #ffffff !important;
            background: rgba(255, 255, 255, 0.24) !important;
        }

        .explore-intro p {
            opacity: 1;
        }

        .explore-intro h1 span {
            position: relative;
            z-index: 2;
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            -webkit-text-fill-color: unset !important;
            color: #d8cef0 !important;
        }

        .intro-stat {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.14) !important;
            border: 1px solid rgba(255, 255, 255, 0.25) !important;
            backdrop-filter: blur(6px);
        }

            .intro-stat strong,
            .intro-stat span {
                color: #ffffff !important;
            }

            .intro-stat .stat-icon {
                color: #d8cef0 !important;
            }

        @@keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            .explore-intro, .category-chip, .explore-tile, .intro-stat, .intro-slide {
                animation: none !important;
                transition: none !important;
            }
        }

        .explore-intro > div,
        .intro-stat {
            animation: fadeSlideUp 0.55s ease both;
        }

        .intro-stat {
            animation-delay: 0.1s;
        }

        .category-chip {
            animation: fadeSlideUp 0.4s ease both;
        }

            .category-chip:nth-child(1) {
                animation-delay: 0.02s;
            }

            .category-chip:nth-child(2) {
                animation-delay: 0.06s;
            }

            .category-chip:nth-child(3) {
                animation-delay: 0.10s;
            }

            .category-chip:nth-child(4) {
                animation-delay: 0.14s;
            }

            .category-chip:nth-child(5) {
                animation-delay: 0.18s;
            }

            .category-chip:nth-child(6) {
                animation-delay: 0.22s;
            }

        .explore-tile {
            animation: fadeSlideUp 0.45s ease both;
            transition: transform 0.25s ease, box-shadow 0.25s ease !important;
        }

            .explore-tile:hover {
                transform: translateY(-5px);
                box-shadow: 0 14px 28px rgba(109, 40, 217, 0.18) !important;
            }

        .intro-stat .stat-icon {
            animation: pulseGlow 3.4s ease-in-out infinite;
        }

        @@keyframes pulseGlow {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }

            50% {
                transform: scale(1.05);
                opacity: 0.88;
            }
        }

        .mobile-bottom-nav {
            box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
        }

            .mobile-bottom-nav a {
                border-radius: 12px;
                transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
            }

                .mobile-bottom-nav a:hover {
                    background: var(--accent-light);
                    color: var(--accent-color);
                }

                .mobile-bottom-nav a.active {
                    background: var(--accent-light) !important;
                    font-weight: 700;
                    transform: translateY(-2px);
                }

                .mobile-bottom-nav a i {
                    transition: transform 0.2s ease;
                }

                .mobile-bottom-nav a.active i {
                    transform: scale(1.12);
                }

        /* Cart badge (used by _CartCountBadge partial inside _CustomerBottomNav) */
        .unread-nav-badge {
            position: absolute;
            top: 2px;
            right: 18px;
            background: var(--accent-gradient);
            color: #fff;
            font-size: 10px;
            font-weight: 800;
            min-width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            box-shadow: 0 3px 8px rgba(109, 40, 217, 0.3);
        }

        /* Chat unread dot (used inside _CustomerBottomNav) */
        .chat-icon-wrap {
            position: relative;
            display: inline-flex;
        }

            .chat-icon-wrap .chat-nav-dot {
                position: absolute;
                top: -2px;
                right: -4px;
                width: 9px;
                height: 9px;
                background: #ed4956;
                border: 2px solid #fff;
                border-radius: 50%;
                box-sizing: content-box;
            }

        /* =====================================================
           DISCOVERY BAR (search toolbar + collapsible filters)
           ===================================================== */
        .discovery-bar {
            margin: 22px 0 16px;
        }

        .discovery-search {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 14px;
            height: 52px;
            background: #ffffff;
            border: 1px solid #e7e2f2;
            border-radius: 16px;
            box-shadow: 0 10px 28px rgba(67, 46, 110, 0.07);
        }

            .discovery-search > i.fa-magnifying-glass {
                color: #9992ab;
            }

            .discovery-search input[type="text"] {
                flex: 1;
                height: 100%;
                border: none;
                outline: none;
                font-size: 14px;
                color: var(--text-primary);
                background: transparent;
            }

        .discovery-toggle {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            height: 36px;
            padding: 0 14px;
            border: 1px solid #ded8eb;
            border-radius: 10px;
            background: #fff;
            color: #5f5870;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            flex-shrink: 0;
        }

            .discovery-toggle[aria-expanded="true"] {
                border-color: var(--accent-color);
                color: var(--accent-color);
            }

            .discovery-toggle i {
                font-size: 11px;
                transition: transform 0.2s ease;
            }

            .discovery-toggle[aria-expanded="true"] i {
                transform: rotate(180deg);
            }

        .discovery-submit {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border: none;
            border-radius: 10px;
            background: var(--accent-gradient);
            color: #fff;
            cursor: pointer;
            flex-shrink: 0;
        }

        .discovery-filters {
            margin-top: 12px;
            padding: 18px;
            border: 1px solid #e7e2f2;
            border-radius: 16px;
            background: #ffffff;
            box-shadow: 0 10px 28px rgba(67, 46, 110, 0.07);
            max-height: 500px;
            overflow: hidden;
            transition: max-height 0.25s ease, opacity 0.25s ease, margin-top 0.25s ease, padding 0.25s ease;
        }

            .discovery-filters.is-collapsed {
                max-height: 0;
                opacity: 0;
                margin-top: 0;
                padding-top: 0;
                padding-bottom: 0;
                border-width: 0;
                box-shadow: none;
            }

        /* Store search autocomplete dropdown */
        .store-search-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid #e7e2f2;
            border-radius: 14px;
            box-shadow: 0 16px 32px rgba(67, 46, 110, 0.14);
            z-index: 50;
            max-height: 320px;
            overflow-y: auto;
            padding: 6px;
        }

            .store-search-dropdown.hidden {
                display: none;
            }

        .store-search-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 10px;
            cursor: pointer;
            text-decoration: none;
            color: var(--text-primary);
        }

            .store-search-item:hover {
                background: var(--accent-light);
            }

            .store-search-item img,
            .store-search-item .store-search-fallback {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                object-fit: cover;
                flex-shrink: 0;
            }

            .store-search-item .store-search-fallback {
                display: flex;
                align-items: center;
                justify-content: center;
                background: var(--accent-gradient);
                color: #fff;
                font-weight: 800;
                font-size: 13px;
            }

            .store-search-item strong {
                display: block;
                font-size: 13.5px;
            }

            .store-search-item small {
                color: #8d859c;
                font-size: 11.5px;
            }

        .store-search-empty {
            padding: 12px;
            text-align: center;
            color: #8d859c;
            font-size: 12.5px;
        }

        .market-filter-grid {
            display: grid;
            grid-template-columns: minmax(220px, 2fr) repeat(3, minmax(150px, 1fr)) repeat(2, minmax(120px, .75fr));
            gap: 12px;
        }

        .market-filter-field label {
            display: block;
            margin-bottom: 6px;
            color: #5f5870;
            font-size: 11px;
            font-weight: 800;
        }

        .market-filter-field input,
        .market-filter-field select {
            width: 100%;
            min-height: 44px;
            padding: 0 12px;
            border: 1px solid #ded8eb;
            border-radius: 12px;
            background: #fff;
            color: #1e1b2e;
            outline: none;
        }

            .market-filter-field input:focus,
            .market-filter-field select:focus {
                border-color: var(--accent-color);
                box-shadow: 0 0 0 3px rgba(109, 40, 217, .10);
            }

        .market-filter-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 14px;
        }

        .market-filter-button,
        .market-filter-clear {
            min-height: 42px;
            padding: 0 18px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .market-filter-button {
            border: none;
            color: #fff;
            background: var(--accent-gradient);
        }

        .market-filter-clear {
            border: 1px solid #ded8eb;
            color: #5f5870;
            background: #fff;
        }

        @@media (max-width: 1100px) {
            .market-filter-grid

        {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        }

        @@media (max-width: 700px) {
            .market-filter-grid

        {
            grid-template-columns: 1fr 1fr;
        }

        .market-filter-field:first-child {
            grid-column: 1 / -1;
        }

        .market-filter-actions {
            justify-content: stretch;
        }

        .market-filter-button, .market-filter-clear {
            flex: 1;
        }

        }
    </style>
</head>

<body>
    <form id="antiForgeryForm" method="post" class="hidden-antiforgery-form">
        @Html.AntiForgeryToken()
    </form>

    <main id="exploreApp"
          class="explore-page"
          data-category="@(Model.SelectedCategory ?? string.Empty)"
          data-search-term="@(Model.SearchTerm ?? string.Empty)"
          data-category-id="@(Model.CategoryId?.ToString() ?? string.Empty)"
          data-store-id="@(Model.StoreId?.ToString() ?? string.Empty)"
          data-area="@(Model.Area ?? string.Empty)"
          data-min-price="@(Model.MinPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)"
          data-max-price="@(Model.MaxPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)"
          data-current-page="1"
          data-has-more="@Model.HasMoreItems.ToString().ToLowerInvariant()">

        <section class="explore-intro">

            <div class="intro-slide active" style="background-image: url('https://commons.wikimedia.org/wiki/Special:FilePath/Fashion_model_looking_at_the_camera.jpg');"></div>
            <div class="intro-slide" style="background-image: url('https://commons.wikimedia.org/wiki/Special:FilePath/Smartphone_in_Hand_(Unsplash).jpg');"></div>
            <div class="intro-slide" style="background-image: url('https://commons.wikimedia.org/wiki/Special:FilePath/Fondue_dish.jpg');"></div>

            <div>
                <span class="eyebrow">Discover local stores</span>

                <h1>
                    Shop local,
                    <span>discover more.</span>
                </h1>

                <p>
                    Every active product appears here automatically, together with any existing image, carousel or reel content.
                    Open any item for details, reviews, wishlist, cart and familiar recommendations.
                </p>
            </div>

            <div class="intro-stat">
                <span class="stat-icon">
                    <i class="fa-solid fa-infinity"></i>
                </span>

                <div>
                    <strong>Infinite Explore</strong>
                    <span>New items load automatically while you scroll.</span>
                </div>
            </div>
        </section>

        <!-- =========================================================
             DISCOVERY BAR — search toolbar (products + store name
             autocomplete) with collapsible advanced filters
             ========================================================= -->
        <section class="discovery-bar">
            <form method="get" asp-page="/Customer1" id="exploreDiscoveryForm">
                <input type="hidden" name="category" value="@Model.SelectedCategory" />

                <div class="discovery-search">
                    <i class="fa-solid fa-magnifying-glass"></i>

                    <input type="text"
                           id="exploreStoreSearchInput"
                           name="SearchTerm"
                           value="@Model.SearchTerm"
                           placeholder="Search products or stores by name"
                           autocomplete="off" />

                    <div id="exploreStoreSearchResults" class="store-search-dropdown hidden"></div>

                    <button type="button" class="discovery-toggle" id="exploreFiltersToggle"
                            aria-expanded="@(hasActiveExploreFilters ? "true" : "false")"
                            aria-controls="exploreAdvancedFilters">
                        Filters <i class="fa-solid fa-chevron-down"></i>
                    </button>

                    <button type="submit" class="discovery-submit" aria-label="Search">
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>

                <div class="discovery-filters market-filter-panel @(hasActiveExploreFilters ? "" : "is-collapsed")" id="exploreAdvancedFilters">

                    <div class="market-filter-grid">
                        <div class="market-filter-field">
                            <label for="exploreCategory">Category</label>
                            <select id="exploreCategory" name="CategoryId">
                                <option value="">All categories</option>
                                @foreach (var filterCategory in Model.FilterCategories)
                                {
                                    <option value="@filterCategory.CategoryID"
                                            selected="@(Model.CategoryId == filterCategory.CategoryID ? "selected" : null)">
                                        @filterCategory.CategoryName
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="market-filter-field">
                            <label for="exploreStore">Store</label>
                            <select id="exploreStore" name="StoreId">
                                <option value="">All stores</option>
                                @foreach (var filterStore in Model.FilterStores)
                                {
                                    <option value="@filterStore.StoreID"
                                            selected="@(Model.StoreId == filterStore.StoreID ? "selected" : null)">
                                        @filterStore.StoreName
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="market-filter-field">
                            <label for="exploreArea">Area</label>
                            <select id="exploreArea" name="Area">
                                <option value="">All areas</option>
                                @foreach (var filterArea in Model.FilterAreas)
                                {
                                    <option value="@filterArea" selected="@(Model.Area == filterArea ? "selected" : null)">@filterArea</option>
                                }
                            </select>
                        </div>

                        <div class="market-filter-field">
                            <label for="exploreMinPrice">Min price</label>
                            <input id="exploreMinPrice" type="number" min="0" step="0.01"
                                   name="MinPrice" value="@Model.MinPrice" placeholder="$0" />
                        </div>

                        <div class="market-filter-field">
                            <label for="exploreMaxPrice">Max price</label>
                            <input id="exploreMaxPrice" type="number" min="0" step="0.01"
                                   name="MaxPrice" value="@Model.MaxPrice" placeholder="Any" />
                        </div>
                    </div>

                    <div class="market-filter-actions">
                        <a asp-page="/Customer1" class="market-filter-clear">
                            <i class="fa-solid fa-rotate-left"></i> Clear
                        </a>
                        <button type="submit" class="market-filter-button">
                            <i class="fa-solid fa-magnifying-glass"></i> Search / Filter
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <section class="category-section"
                 aria-label="Product categories">

            <a asp-page="/Customer1"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-storeId="@Model.StoreId"
               asp-route-area="@Model.Area"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               class="category-chip @(string.IsNullOrWhiteSpace(Model.SelectedCategory) ? "active" : string.Empty)">
                All
            </a>

            @foreach (var category in Model.NavbarCategories)
            {
                var isActive = string.Equals(
                Model.SelectedCategory,
                category,
                StringComparison.OrdinalIgnoreCase);

                <a asp-page="/Customer1"
                   asp-route-category="@category"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-storeId="@Model.StoreId"
                   asp-route-area="@Model.Area"
                   asp-route-minPrice="@Model.MinPrice"
                   asp-route-maxPrice="@Model.MaxPrice"
                   class="category-chip @(isActive ? "active" : string.Empty)">
                    @category
                </a>
            }
        </section>

        @if (TempData["Success"] is string successMessage &&
        !string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="server-message success">
                <i class="fa-solid fa-circle-check"></i>
                @successMessage
            </div>
        }

        @if (TempData["Error"] is string errorMessage &&
        !string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="server-message error">
                <i class="fa-solid fa-circle-exclamation"></i>
                @errorMessage
            </div>
        }

        <section class="grid-heading">
            <div>
                <h2>
                    @(string.IsNullOrWhiteSpace(Model.SelectedCategory)
                        ? "Explore"
                        : Model.SelectedCategory)
                </h2>

                <p>
                    Click any item for a SHEIN-style quick view and familiar recommendations.
                </p>
            </div>

            <div class="grid-legend">
                <span>
                    <i class="fa-solid fa-play"></i>
                    Reel
                </span>

                <span>
                    <i class="fa-regular fa-images"></i>
                    Carousel
                </span>

                <span>
                    <i class="fa-solid fa-bag-shopping"></i>
                    Product
                </span>
            </div>
        </section>

        <section id="exploreGrid"
                 class="explore-grid"
                 aria-live="polite">

            @foreach (var item in Model.InitialItems)
            {
                var isPost = string.Equals(
                item.GridItemType,
                "Post",
                StringComparison.OrdinalIgnoreCase);

                var isVideo = string.Equals(
                item.MediaType,
                "Video",
                StringComparison.OrdinalIgnoreCase);

                var isReel = string.Equals(
                item.PostType,
                "Reel",
                StringComparison.OrdinalIgnoreCase);

                var isCarousel = string.Equals(
                item.PostType,
                "Carousel",
                StringComparison.OrdinalIgnoreCase);

                <button type="button"
                        class="explore-tile"
                        data-grid-item
                        data-item-type="@item.GridItemType"
                        data-post-id="@item.ExplorePostID"
                        data-product-id="@item.ProductID"
                        aria-label="@(isPost
                            ? $"Open post from {item.StoreName}"
                            : $"Open product {item.ProductName}")">

                    <span class="tile-media">
                        @if (isVideo &&
                       string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                        {
                            <video muted
                                   loop
                                   playsinline
                                   preload="metadata"
                                   data-reel-preview>
                                <source src="@item.MediaUrl" />
                            </video>
                        }
                        else
                        {
                            <img src="@(isVideo
                                    ? item.ThumbnailUrl
                                    : item.MediaUrl)"
                                 alt="@(item.ProductName ?? item.StoreName)"
                                 loading="lazy"
                                 onerror="this.onerror=null;this.src='/images/product-placeholder.svg';" />
                        }
                    </span>

                    <span class="tile-gradient"></span>

                    <span class="tile-top">
                        @if (item.IsBoosted)
                        {
                            <span class="tile-badge sponsored-badge">
                                <i class="fa-solid fa-bolt"></i>
                                Sponsored
                            </span>
                        }
                        else if (isReel)
                        {
                            <span class="tile-badge">
                                <i class="fa-solid fa-play"></i>
                                Reel
                            </span>
                        }
                        else if (isCarousel)
                        {
                            <span class="tile-badge">
                                <i class="fa-regular fa-images"></i>
                                @item.MediaCount
                            </span>
                        }
                        else if (!isPost)
                        {
                            <span class="tile-badge">
                                <i class="fa-solid fa-bag-shopping"></i>
                                Product
                            </span>
                        }

                        @if (item.ProductPrice.HasValue)
                        {
                            <span class="tile-price">
                                $@item.ProductPrice.Value.ToString("N2")
                            </span>
                        }
                    </span>

                    <span class="tile-bottom">
                        <span class="tile-store">
                            @if (!string.IsNullOrWhiteSpace(item.StoreLogoUrl))
                            {
                                <img src="@item.StoreLogoUrl"
                                     alt="@item.StoreName"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />

                                <span class="tile-store-fallback">
                                    @(string.IsNullOrWhiteSpace(item.StoreName)
                                        ? "S"
                                        : item.StoreName.Substring(0, 1).ToUpper())
                                </span>
                            }
                            else
                            {
                                <span class="tile-store-fallback visible">
                                    @(string.IsNullOrWhiteSpace(item.StoreName)
                                        ? "S"
                                        : item.StoreName.Substring(0, 1).ToUpper())
                                </span>
                            }

                            <span>@item.StoreName</span>
                        </span>

                        @if (!string.IsNullOrWhiteSpace(item.ProductName))
                        {
                            <strong>@item.ProductName</strong>
                        }
                    </span>
                </button>
            }
        </section>

        <div id="emptyExploreState"
             class="empty-explore @(Model.InitialItems.Any() ? "hidden" : string.Empty)">

            <span>
                <i class="fa-regular fa-compass"></i>
            </span>

            <h3>No Explore items found</h3>

            <p>
                Try another category or return later when stores publish new content.
            </p>
        </div>

        <div id="infiniteLoader"
             class="infinite-loader @(Model.HasMoreItems ? string.Empty : "hidden")">

            <span class="loader-spinner"></span>
            <span>Loading more discoveries...</span>
        </div>

        <div id="infiniteSentinel"
             class="infinite-sentinel"
             aria-hidden="true"></div>

        <div id="endOfFeed"
             class="end-of-feed @(!Model.HasMoreItems && Model.InitialItems.Any() ? string.Empty : "hidden")">

            <i class="fa-solid fa-circle-check"></i>
            You reached the end for now.
        </div>
    </main>

    <partial name="_CustomerBottomNav" />

    <div id="exploreModal"
         class="explore-modal"
         aria-hidden="true"
         role="dialog"
         aria-modal="true"
         aria-labelledby="modalStoreName">

        <div class="explore-modal-backdrop"
             data-close-explore-modal></div>

        <div class="explore-modal-card">
            <button type="button"
                    class="modal-close"
                    aria-label="Close details"
                    data-close-explore-modal>
                <i class="fa-solid fa-xmark"></i>
            </button>

            <section class="modal-media-pane">
                <div id="modalLoading"
                     class="modal-loading">

                    <span class="loader-spinner large"></span>
                    <span>Opening item...</span>
                </div>

                <div id="modalMediaStage"
                     class="modal-media-stage hidden">

                    <div id="modalMediaContent"
                         class="modal-media-content"></div>

                    <button id="mediaPreviousButton"
                            type="button"
                            class="media-nav previous hidden"
                            aria-label="Previous media">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>

                    <button id="mediaNextButton"
                            type="button"
                            class="media-nav next hidden"
                            aria-label="Next media">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>

                    <div id="mediaCounter"
                         class="media-counter hidden"></div>
                </div>
            </section>

            <aside id="modalInformation"
                   class="modal-information hidden">

                <div class="modal-scroll-area">
                    <header class="modal-store-header">
                        <a id="modalStoreLink"
                           href="#"
                           class="modal-store-link">

                            <span id="modalStoreAvatar"
                                  class="modal-store-avatar"></span>

                            <span>
                                <strong id="modalStoreName"></strong>
                                <small id="modalPostDate"></small>
                            </span>
                        </a>

                        <button id="modalFollowButton"
                                type="button"
                                class="follow-button">
                            Follow
                        </button>
                    </header>

                    <section class="modal-caption-section">
                        <p id="modalCaption"
                           class="modal-caption"></p>

                        <div id="modalStats" class="modal-stats">
                            <span>
                                <i class="fa-regular fa-eye"></i>
                                <strong id="modalViewCount">0</strong>
                            </span>

                            <span>
                                <i class="fa-regular fa-heart"></i>
                                <strong id="modalLikeCount">0</strong>
                            </span>

                            <span>
                                <i class="fa-regular fa-comment"></i>
                                <strong id="modalCommentCount">0</strong>
                            </span>
                        </div>
                    </section>

                    <section id="modalPrimaryActions" class="modal-primary-actions">
                        <button id="modalLikeButton"
                                type="button"
                                class="modal-action-button">
                            <i class="fa-regular fa-heart"></i>
                            <span>Like</span>
                        </button>

                        <button id="focusCommentButton"
                                type="button"
                                class="modal-action-button">
                            <i class="fa-regular fa-comment"></i>
                            <span>Comment</span>
                        </button>

                        <button id="modalShareButton"
                                type="button"
                                class="modal-action-button">
                            <i class="fa-regular fa-paper-plane"></i>
                            <span>Share</span>
                        </button>
                    </section>

                    <section id="linkedProductSection"
                             class="linked-product-section hidden">

                        <div id="linkedProductLabel" class="section-label">
                            Product details
                        </div>

                        <article class="linked-product-card">
                            <a id="linkedProductLink"
                               href="#"
                               class="linked-product-main">

                                <img id="linkedProductImage"
                                     src="/images/product-placeholder.svg"
                                     alt="Linked product" />

                                <span>
                                    <small id="linkedProductCategory"></small>
                                    <strong id="linkedProductName"></strong>
                                    <span id="linkedProductDescription"></span>
                                </span>

                                <b id="linkedProductPrice"></b>
                            </a>

                            <div class="linked-product-actions">
                                <button id="wishlistProductButton"
                                        type="button"
                                        class="secondary-product-button">

                                    <i class="fa-regular fa-heart"></i>
                                    Save
                                </button>

                                <button id="cartProductButton"
                                        type="button"
                                        class="primary-product-button">

                                    <i class="fa-solid fa-bag-shopping"></i>
                                    Add to cart
                                </button>
                            </div>

                            <div id="outOfStockMessage"
                                 class="out-of-stock-message hidden">
                                This product is out of stock.
                            </div>
                        </article>
                    </section>

                    <section id="commentsSection" class="comments-section">
                        <div class="section-heading">
                            <div>
                                <span class="section-label">Conversation</span>
                                <h3>Comments</h3>
                            </div>
                        </div>

                        <form id="commentForm"
                              class="comment-form">

                            <textarea id="commentTextInput"
                                      name="commentText"
                                      maxlength="1000"
                                      rows="2"
                                      placeholder="Write a comment..."
                                      required></textarea>

                            <button type="submit"
                                    class="comment-submit-button"
                                    aria-label="Post comment">
                                <i class="fa-solid fa-arrow-up"></i>
                            </button>
                        </form>

                        <div id="modalComments"
                             class="comments-list"></div>

                        <div id="emptyComments"
                             class="empty-comments hidden">
                            Be the first to comment.
                        </div>
                    </section>

                    <section id="productReviewsSection"
                             class="product-reviews-section hidden">

                        <div class="product-review-header">
                            <div>
                                <span class="section-label">Customer feedback</span>
                                <h3>Ratings & reviews</h3>
                            </div>

                            <a id="writeProductReviewLink"
                               href="#"
                               class="write-review-link">
                                <i class="fa-solid fa-star"></i>
                                Write a review
                            </a>
                        </div>

                        <div class="product-review-summary">
                            <strong id="productReviewRating">0.0</strong>

                            <span>
                                <span id="productReviewStars"
                                      class="product-review-stars"></span>
                                <small id="productReviewCount">0 reviews</small>
                            </span>
                        </div>

                        <div id="modalProductReviews"
                             class="product-reviews-list"></div>

                        <div id="emptyProductReviews"
                             class="empty-related hidden">
                            No product reviews yet.
                        </div>
                    </section>

                    <section class="related-section">
                        <div class="section-heading">
                            <div>
                                <span class="section-label">Keep exploring</span>
                                <h3>Familiar products and content</h3>
                            </div>
                        </div>

                        <div id="relatedItemsGrid"
                             class="related-items-grid"></div>

                        <div id="emptyRelatedItems"
                             class="empty-related hidden">
                            No related items yet.
                        </div>
                    </section>
                </div>
            </aside>
        </div>
    </div>

    <div id="toastContainer"
         class="toast-container"
         aria-live="polite"
         aria-atomic="true"></div>

    <script src="~/js/customer-explore.js"
            asp-append-version="true"></script>
    <script src="~/js/customer-explore-fixes.js"
            asp-append-version="true"></script>

    <script>
        (function () {
            var slides = document.querySelectorAll('.explore-intro .intro-slide');
            if (slides.length === 0) return;

            var current = 0;
            setInterval(function () {
                slides[current].classList.remove('active');
                current = (current + 1) % slides.length;
                slides[current].classList.add('active');
            }, 4000);
        })();
    </script>

    <script>
        // =====================================================
        // DISCOVERY BAR: collapsible filters + store autocomplete
        // (kept inline since this page does not use a separate JS
        // file for the search toolbar)
        // =====================================================
        (function () {
            var toggleBtn = document.getElementById('exploreFiltersToggle');
            var filtersPanel = document.getElementById('exploreAdvancedFilters');

            if (toggleBtn && filtersPanel) {
                toggleBtn.addEventListener('click', function () {
                    var isCollapsed = filtersPanel.classList.toggle('is-collapsed');
                    toggleBtn.setAttribute('aria-expanded', (!isCollapsed).toString());
                });
            }

            var searchInput = document.getElementById('exploreStoreSearchInput');
            var resultsBox = document.getElementById('exploreStoreSearchResults');

            if (!searchInput || !resultsBox) return;

            var debounceTimer = null;

            function escapeHtml(value) {
                var div = document.createElement('div');
                div.textContent = value || '';
                return div.innerHTML;
            }

            function renderStores(stores) {
                if (!stores.length) {
                    resultsBox.innerHTML = '<div class="store-search-empty">No matching stores</div>';
                    resultsBox.classList.remove('hidden');
                    return;
                }

                resultsBox.innerHTML = stores.map(function (store) {
                    var safeName = escapeHtml(store.storeName);
                    var safeArea = escapeHtml(store.area);

                    var avatar = store.logoUrl
                        ? '<img src="' + escapeHtml(store.logoUrl) + '" alt="' + safeName + '" onerror="this.onerror=null;this.style.display=\'none\';">'
                        : '<span class="store-search-fallback">' + (safeName ? safeName.charAt(0).toUpperCase() : 'S') + '</span>';

                    return '<a class="store-search-item" href="/StoreCustomerProfile?id=' + store.storeId + '">' +
                        avatar +
                        '<span><strong>' + safeName + '</strong>' +
                        (safeArea ? '<small>' + safeArea + '</small>' : '') +
                        '</span></a>';
                }).join('');

                resultsBox.classList.remove('hidden');
            }

            searchInput.addEventListener('input', function () {
                var term = searchInput.value.trim();

                clearTimeout(debounceTimer);

                if (term.length === 0) {
                    resultsBox.classList.add('hidden');
                    resultsBox.innerHTML = '';
                    return;
                }

                debounceTimer = setTimeout(function () {
                    fetch('/Customer1?handler=SearchStores&term=' + encodeURIComponent(term))
                        .then(function (res) { return res.json(); })
                        .then(function (data) {
                            if (data && data.success) {
                                renderStores(data.stores || []);
                            }
                        })
                        .catch(function () {
                            resultsBox.classList.add('hidden');
                        });
                }, 250);
            });

            document.addEventListener('click', function (event) {
                if (!resultsBox.contains(event.target) && event.target !== searchInput) {
                    resultsBox.classList.add('hidden');
                }
            });

            searchInput.addEventListener('focus', function () {
                if (searchInput.value.trim().length > 0 && resultsBox.innerHTML) {
                    resultsBox.classList.remove('hidden');
                }
            });
        })();
    </script>
</body>
</html>
