@page
@model Local_Multi_Store_Online_Marketplace.Pages.Customer1Model
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Customer Feed</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f7fb;
        }

        .topbar {
            background: #111827;
            color: white;
            padding: 14px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
        }

        .menu a {
            color: white;
            margin: 0 10px;
            text-decoration: none;
            font-size: 14px;
        }

        .feed {
            max-width: 720px;
            margin: 30px auto;
        }

        .post {
            background: white;
            border-radius: 18px;
            margin-bottom: 25px;
            overflow: hidden;
            box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        }

        .post-body {
            padding: 18px;
        }

        .post-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .store a {
            font-weight: 700;
            color: #ff6b35;
            text-decoration: none;
        }

        .product-name {
            font-size: 20px;
            font-weight: 700;
            margin-top: 10px;
        }

        .product-price {
            font-size: 18px;
            font-weight: 800;
            color: #e67e22;
            margin-top: 5px;
        }

        .post img {
            width: 100%;
            height: 240px;
            object-fit: cover;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .btn-like, .btn-cart {
            padding: 8px 14px;
            border-radius: 20px;
            border: 1px solid #ddd;
            background: white;
            cursor: pointer;
            font-size: 13px;
        }

        .btn-cart {
            background: #111827;
            color: white;
        }

        .empty-message {
            text-align: center;
            margin-top: 80px;
            color: gray;
        }

        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.4);
            z-index: 99999;
        }

        .modal-content {
            width: 300px;
            background: white;
            margin: 120px auto;
            padding: 20px;
            border-radius: 12px;
        }

        .modal-btn {
            display: block;
            text-decoration: none;
            color: black;
            background: #f5f5f5;
            padding: 12px;
            margin-top: 10px;
            border-radius: 8px;
        }

        .close-btn {
            margin-top: 15px;
            width: 100%;
            padding: 10px;
        }
    </style>
</head>

<body>

    <!-- TOP BAR -->
    <div class="topbar">
        <div><b>realnest</b></div>

        <div class="menu">
            <a href="/Customer1">Explore</a>
            <a href="/CustomerFeed">Feed</a>
            <a href="/CustomerProducts">Shop</a>
            <a href="/CustomerCart">Cart</a>
            <a href="/CustomerOrders">Orders</a>
            <a href="/Chat">Chat</a>
            <a href="/CustomerProfile">Profile</a>
        </div>
    </div>

    <!-- FEED -->
    <div class="feed">

        @if (TempData["Success"] != null)
        {
            <div style="color:green">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div style="color:red">@TempData["Error"]</div>
        }

        @if (Model.Products.Any())
        {
            foreach (var product in Model.Products)
            {
                var isFollowing = Model.FollowingStoreIds.Contains(product.StoreID);

                string imageUrl = "/images/no-image.png";
                if (product.Images != null && product.Images.Any())
                {
                    var primary = product.Images.FirstOrDefault(i => i.IsPrimary);
                    imageUrl = (primary ?? product.Images.First()).ImageUrl;
                }

                <div class="post" id="product-@product.ProductID">

                    <div class="post-body">

                        <!-- HEADER -->
                        <div class="post-header">

                            <!-- CLICKABLE STORE NAME -->
                            <div class="store">
                                <a href="/StoreCustomerProfile?id=@product.StoreID">
                                    🏪 @product.Store?.StoreName
                                </a>
                            </div>

                            @if (isFollowing)
                            {
                                <form method="post" asp-page-handler="UnfollowStore" asp-route-storeId="@product.StoreID">
                                    <button class="btn-like" style="background:#fee2e2;color:#991b1b;">
                                        Unfollow
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="FollowStore" asp-route-storeId="@product.StoreID">
                                    <button class="btn-like" style="background:#dcfce7;color:#166534;">
                                        Follow
                                    </button>
                                </form>
                            }

                        </div>

                        <!-- IMAGE -->
                        <img src="@imageUrl" />

                        <!-- PRODUCT INFO -->
                        <div class="product-name">@product.ProductName</div>

                        <div class="product-price">
                            $@product.Price.ToString("N2")
                        </div>

                        <div>@product.Description</div>

                        <!-- ACTIONS -->
                        <div class="actions">

                            <form method="post"
                                  asp-page-handler="AddWishlist"
                                  asp-route-productId="@product.ProductID">
                                <button class="btn-like">❤️ Like</button>
                            </form>

                            <form method="post"
                                  asp-page-handler="AddToCart"
                                  asp-route-productId="@product.ProductID">
                                <button class="btn-cart">🛒 Add</button>
                            </form>

                            <!-- SHARE BUTTON -->
                            <button type="button"
                                    class="btn-like"
                                    onclick="openShare('@product.Store.OwnerUserID',
                           '@product.ProductID',
                           '@product.ProductName',
                           '@product.Price')">
                                🔄 Share
                            </button>

                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-message">
                No products yet — follow stores to see content.
            </div>
        }

    </div>

    <div id="shareModal" class="modal">

        <div class="modal-content">

            <h3>Share Product</h3>

            <a id="chatLink" class="modal-btn">
                💬 Open Store Chat
            </a>

            <a id="whatsappLink"
               class="modal-btn"
               target="_blank">
                📱 WhatsApp
            </a>

            <button type="button"
                    class="close-btn"
                    onclick="closeShare()">
                Close
            </button>

        </div>

    </div>

    <script>
        function openShare(ownerId, productId, name, price) {

            document.getElementById("shareModal").style.display = "block";

            document.getElementById("chatLink").href =
                "/Customer1?handler=ShareToStore" +
                "&productId=" + productId +
                "&storeOwnerId=" + ownerId;

            document.getElementById("whatsappLink").href =
                "https://wa.me/?text=" +
                encodeURIComponent(name + " - $" + price);
        }

        function closeShare() {
            document.getElementById("shareModal").style.display = "none";
        }
    </script>
    <script>
        window.onload = function () {

            const params = new URLSearchParams(window.location.search);
            const productId = params.get('productId');

            if (productId) {

                const post = document.getElementById('product-' + productId);

                if (post) {

                    post.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });

                    post.style.border = '4px solid orange';

                    setTimeout(() => {
                        post.style.border = '';
                    }, 4000);
                }
            }
        };
    </script>

</body>
</html>