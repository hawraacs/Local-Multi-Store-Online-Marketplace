@page
@model Local_Multi_Store_Online_Marketplace.Pages.Customer1Model
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Customer Feed | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(145deg, #f6f9fc 0%, #edf2f7 100%);
            margin: 0;
            min-height: 100vh;
        }

        .topbar {
            background: rgba(10, 15, 25, 0.92);
            backdrop-filter: blur(12px);
            color: white;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

            .topbar > div:first-child {
                font-size: 26px;
                font-weight: 700;
                letter-spacing: -0.5px;
                background: linear-gradient(135deg, #FFFFFF 0%, #B0C4DE 100%);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

        .menu {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

            .menu a {
                color: #eef2ff;
                margin: 0 6px;
                text-decoration: none;
                font-weight: 500;
                padding: 8px 16px;
                border-radius: 40px;
                transition: all 0.2s ease;
                font-size: 15px;
                letter-spacing: -0.2px;
            }

                .menu a:hover {
                    background: rgba(255, 255, 255, 0.15);
                    color: white;
                    transform: translateY(-1px);
                }

        .feed {
            max-width: 720px;
            width: 90%;
            margin: 40px auto;
            padding: 0 16px;
        }

        .message {
            padding: 14px 18px;
            border-radius: 12px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 20px;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .post {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(0px);
            border-radius: 28px;
            margin-bottom: 32px;
            overflow: hidden;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08), 0 2px 4px rgba(0, 0, 0, 0.02);
            transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

            .post:hover {
                transform: translateY(-6px);
                box-shadow: 0 24px 40px rgba(0, 0, 0, 0.12);
            }

            .post img {
                width: 100%;
                height: 340px;
                object-fit: cover;
                background: #e2e8f0;
                transition: transform 0.4s ease;
            }

            .post:hover img {
                transform: scale(1.02);
            }

        .post-body {
            padding: 22px 24px 26px;
        }

        .store {
            font-weight: 600;
            font-size: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #FF6B35;
            margin-bottom: 8px;
            display: inline-block;
            background: rgba(255, 107, 53, 0.08);
            padding: 4px 12px;
            border-radius: 40px;
        }

        .product-name {
            font-size: 24px;
            font-weight: 700;
            margin: 12px 0 6px;
            letter-spacing: -0.3px;
            color: #0a1927;
            line-height: 1.3;
        }

        .product-price {
            color: #e67e22;
            font-weight: 800;
            font-size: 26px;
            margin: 10px 0;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .product-price::before {
                content: "💰";
                font-size: 22px;
                filter: drop-shadow(0 1px 1px rgba(0,0,0,0.1));
            }

        .product-description {
            color: #2c3e44;
            margin: 16px 0 20px;
            line-height: 1.55;
            font-size: 15px;
            border-left: 3px solid #ff6b3540;
            padding-left: 16px;
        }

        .actions {
            display: flex;
            gap: 16px;
            margin-top: 6px;
        }

        .btn-like,
        .btn-cart {
            padding: 10px 22px;
            border-radius: 60px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid #e2e8f0;
            background: white;
            transition: all 0.2s;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-like {
            background: white;
            color: #475569;
        }

            .btn-like:hover {
                background: #fff0f0;
                border-color: #ffb3b3;
                color: #e53e3e;
                transform: scale(0.97);
            }

        .btn-cart {
            background: linear-gradient(95deg, #0a0f19 0%, #1f2a3a 100%);
            color: white;
            border: none;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
        }

            .btn-cart:hover {
                background: linear-gradient(95deg, #1f2a3a 0%, #2d3e52 100%);
                transform: translateY(-2px);
                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
            }

            .btn-cart:active {
                transform: translateY(1px);
            }

        .empty-message {
            text-align: center;
            margin-top: 80px;
            padding: 48px 24px;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(8px);
            border-radius: 48px;
            color: #1e293b;
            font-size: 18px;
            font-weight: 500;
            border: 1px dashed #cbd5e1;
        }

            .empty-message::before {
                content: "🛍️";
                display: block;
                font-size: 64px;
                margin-bottom: 20px;
                opacity: 0.7;
            }

        @@media (max-width: 640px) {
            .topbar {
                padding: 12px 20px;
                flex-direction: column;
                gap: 12px;
            }

            .menu a {
                padding: 6px 12px;
                font-size: 13px;
            }

            .feed {
                width: 100%;
                margin: 24px auto;
            }

            .post img {
                height: 260px;
            }

            .product-name {
                font-size: 20px;
            }

            .product-price {
                font-size: 22px;
            }

            .post-body {
                padding: 18px;
            }
        }

        @@keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .post {
            animation: fadeSlideUp 0.5s ease forwards;
        }

        footer {
            text-align: center;
            padding: 32px 20px 40px;
            color: #5b6e8c;
            font-size: 13px;
            border-top: 1px solid rgba(0,0,0,0.05);
            margin-top: 20px;
        }
    </style>
</head>
<body>

    <div class="topbar">
        <div>realnest</div>

        <div class="menu">
            <a href="/Customer1"><i class="fas fa-home"></i> Feed</a>
            <a href="/CustomerProducts"><i class="fas fa-store"></i> Shop</a>
            <a href="/CustomerCart"><i class="fas fa-shopping-cart"></i> Cart</a>
            <a href="/CustomerOrders"><i class="fas fa-truck"></i> Orders</a>
            <a href="/CustomerProfile"><i class="fas fa-user-circle"></i> Profile</a>
        </div>
    </div>

    <div class="feed">

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="message error-message">
                @TempData["Error"]
            </div>
        }

        @if (Model.Products.Any())
        {
            foreach (var product in Model.Products)
            {
                string imageUrl = "/images/no-image.png";

                if (product.Images != null && product.Images.Any())
                {
                    var primary = product.Images.FirstOrDefault(i => i.IsPrimary);
                    imageUrl = (primary ?? product.Images.First()).ImageUrl;
                }

                <div class="post">
                    <img src="@imageUrl"
                         alt="@product.ProductName"
                         loading="lazy"
                         onerror="this.onerror=null;this.src='/images/no-image.png';" />

                    <div class="post-body">

                        <div class="store">
                            🏪 @(product.Store?.StoreName ?? "Unknown Store")
                        </div>

                        <div class="product-name">
                            @product.ProductName
                        </div>

                        <div class="product-price">
                            $@product.Price.ToString("N2")
                        </div>

                        <div class="product-description">
                            @(product.Description?.Length > 120
                                ? product.Description.Substring(0, 120) + "..."
                                : product.Description)
                        </div>

                        <div class="actions">

                            <form method="post"
                                  asp-page-handler="AddWishlist"
                                  asp-route-productId="@product.ProductID">

                                <button type="submit"
                                        class="btn-like"
                                        aria-label="Add product to wishlist">
                                    <i class="far fa-heart"></i>
                                    Like
                                </button>

                            </form>

                            <form method="post"
                                  asp-page-handler="AddToCart"
                                  asp-route-productId="@product.ProductID">

                                <button type="submit" class="btn-cart">
                                    <i class="fas fa-cart-plus"></i>
                                    Add to Cart
                                </button>

                            </form>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-message">
                No products yet — check back soon for amazing items!
            </div>
        }

    </div>

    <footer>
        <span>✨ Realnest — discover local treasures ✨</span>
    </footer>

</body>
</html>