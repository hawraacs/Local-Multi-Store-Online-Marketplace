@page
@model Local_Multi_Store_Online_Marketplace.Pages.Customer1Model
@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Customer Feed</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>

        body {
            font-family: Poppins;
            background: #f4f4f7;
            margin: 0;
        }

        /* TOP NAV */
        .topbar {
            background: #111;
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .menu a {
            color: white;
            margin: 0 10px;
            text-decoration: none;
        }

        /* FEED */
        .feed {
            width: 600px;
            margin: auto;
            padding: 20px;
        }

        .post {
            background: white;
            border-radius: 12px;
            margin-bottom: 20px;
            overflow: hidden;
        }

            .post img {
                width: 100%;
                height: 300px;
                object-fit: cover;
            }

        .post-body {
            padding: 15px;
        }

        .store {
            font-weight: 600;
        }

        .actions {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
        }

    </style>
</head>

<body>

    <div class="topbar">
        <div>Realnest</div>

        <div class="menu">
            <a href="/Customer1">Dashboard</a>
            <a href="/CustomerProducts">Shop</a>
            <a href="/CustomerCart">Cart</a>
            <a href="/CustomerOrders">Orders</a>
            <a href="/CustomerProfile">Profile</a>
        </div>
    </div>

    <div class="feed">

        <!-- POST -->
        <div class="post">
            <img src="/images/p1.jpg" />
            <div class="post-body">
                <div class="store">Nike Store</div>
                <p>New summer collection 🔥</p>

                <div class="actions">
                    <span>❤️ Like</span>
                    <span>🛒 Add</span>
                </div>
            </div>
        </div>

        <!-- POST -->
        <div class="post">
            <img src="/images/p2.jpg" />
            <div class="post-body">
                <div class="store">Adidas Store</div>
                <p>50% discount today</p>

                <div class="actions">
                    <span>❤️ Like</span>
                    <span>🛒 Add</span>
                </div>
            </div>
        </div>

    </div>

</body>

</html>