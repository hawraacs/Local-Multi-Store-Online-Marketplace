@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProfileModel

@{
    Layout = null;

    var deliveryLoginError =
        TempData["DeliveryLoginError"]?.ToString();

    var storeOwnerLoginError =
        TempData["StoreOwnerLoginError"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>My Profile | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            :root {
                --bg-color: #faf9fc;
                --card-bg: #ffffff;
                --border-color: #ece8f6;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                --accent-color: #6d28d9;
                --accent-hover: #5b21b6;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --success-color: #10b981;
                --error-color: #dc2626;
                --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                --font-display: 'Playfair Display', Georgia, serif;
                --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.05);
                --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.08);
                --shadow-lg: 0 20px 44px rgba(30, 27, 46, 0.16);
                --radius-lg: 20px;
                --radius-md: 14px;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: var(--font-family);
                background: var(--bg-color);
                color: var(--text-primary);
                min-height: 100vh;
                padding-bottom: 100px;
            }

            .mobile-bottom-nav {
                display: flex !important;
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: 200;
                background: #ffffff;
                border-top: 1px solid #ece8f6;
                justify-content: space-between;
                gap: 2px;
                padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
                overflow-x: auto;
                box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
            }

                .mobile-bottom-nav a {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 2px;
                    font-size: 10.5px;
                    color: #6b6478;
                    text-decoration: none;
                    padding: 4px 6px;
                    flex-shrink: 0;
                    position: relative;
                    border-radius: 12px;
                    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
                }

                    .mobile-bottom-nav a i {
                        font-size: 17px;
                        transition: transform 0.2s ease;
                    }

                    .mobile-bottom-nav a:hover {
                        background: var(--accent-light);
                        color: var(--accent-color);
                    }

                    .mobile-bottom-nav a.active {
                        color: var(--accent-color) !important;
                        background: var(--accent-light) !important;
                        font-weight: 700;
                        transform: translateY(-2px);
                    }

                        .mobile-bottom-nav a.active i {
                            transform: scale(1.12);
                        }

            .unread-nav-badge {
                position: absolute;
                top: 2px;
                right: 18px;
                background: var(--accent-gradient);
                color: #fff;
                font-size: 10px;
                font-weight: 800;
                min-width: 16px;
                height: 16px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                box-shadow: 0 3px 8px rgba(109, 40, 217, 0.3);
            }

            .chat-icon-wrap {
                position: relative;
                display: inline-flex;
            }

                .chat-icon-wrap .chat-nav-dot {
                    position: absolute;
                    top: -2px;
                    right: -4px;
                    width: 9px;
                    height: 9px;
                    background: #ed4956;
                    border: 2px solid #fff;
                    border-radius: 50%;
                    box-sizing: content-box;
                }

            .profile-container {
                max-width: 900px;
                width: 100%;
                margin: 28px auto;
                padding: 0 20px;
            }

            .main-content {
                width: 100%;
                min-width: 0;
            }

            .profile-header-card {
                position: relative;
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-md);
                padding: 0 24px 20px;
                margin-bottom: 22px;
                overflow: hidden;
            }

            .profile-cover {
                height: 74px;
                margin: 0 -24px 0;
                background: var(--accent-gradient);
                background-size: 200% 200%;
                animation: coverDrift 10s ease infinite;
                position: relative;
            }

                .profile-cover::after {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background-image: radial-gradient(circle at 15% 30%, rgba(255,255,255,0.16) 0, transparent 45%), radial-gradient(circle at 85% 70%, rgba(255,255,255,0.12) 0, transparent 40%);
                }

            @@keyframes coverDrift {
                0%, 100% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }
            }

            .header-menu-btn {
                position: absolute;
                top: 16px;
                right: 16px;
                width: 38px;
                height: 38px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.22);
                backdrop-filter: blur(6px);
                border: 1px solid rgba(255, 255, 255, 0.4);
                color: #ffffff;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
                cursor: pointer;
                transition: background-color 0.15s ease, transform 0.15s ease;
                z-index: 2;
            }

                .header-menu-btn:hover {
                    background: rgba(255, 255, 255, 0.34);
                    transform: translateY(-1px);
                }

            .ig-top-row {
                display: flex;
                align-items: flex-end;
                gap: 16px;
                margin-top: -34px;
                position: relative;
                z-index: 1;
            }

            .ig-avatar {
                width: 76px;
                height: 76px;
                flex-shrink: 0;
                border-radius: 50%;
                background: var(--accent-gradient);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 32px;
                color: #ffffff;
                border: 4px solid #ffffff;
                box-shadow: var(--shadow-md);
                transition: transform 0.2s ease;
            }

                .ig-avatar:hover {
                    transform: scale(1.04) rotate(-2deg);
                }

            .ig-identity {
                padding-bottom: 6px;
            }

            .ig-identity {
                flex-grow: 1;
                min-width: 0;
            }

            .ig-name {
                font-family: var(--font-display);
                font-size: 19px;
                font-weight: 700;
                color: var(--text-primary);
                display: flex;
                align-items: center;
                gap: 6px;
                line-height: 1.3;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .ig-joined {
                font-size: 12px;
                color: var(--text-secondary);
                margin-top: 3px;
            }

            .ig-stats-row {
                display: flex;
                margin-top: 18px;
                padding-top: 16px;
                border-top: 1px solid var(--border-color);
            }

            .ig-stat {
                flex: 1;
                text-align: center;
                cursor: default;
                border-radius: 10px;
                padding: 4px 2px;
                transition: background-color 0.15s ease;
            }

                .ig-stat.clickable {
                    cursor: pointer;
                }

                    .ig-stat.clickable:hover {
                        background: var(--accent-light);
                    }

            .ig-stat-count {
                display: block;
                font-size: 17px;
                font-weight: 800;
                color: var(--text-primary);
            }

            .ig-stat-label {
                display: block;
                font-size: 11px;
                color: var(--text-secondary);
                margin-top: 2px;
                text-transform: uppercase;
                letter-spacing: 0.3px;
            }

            .ig-badges {
                display: flex;
                flex-wrap: wrap;
                gap: 6px;
                margin-top: 16px;
            }

            .sidebar-badge {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                background: var(--accent-light);
                padding: 4px 9px;
                border-radius: 10px;
                font-size: 11px;
                font-weight: 700;
                color: var(--accent-color);
            }

            .loyalty-badge {
                background: #fffbeb;
                color: #d97706;
                border: 1px solid #fef3c7;
            }

            .restricted-badge {
                background: #fee2e2;
                color: #b91c1c;
            }

            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(30, 27, 46, 0.5);
                z-index: 9998;
                opacity: 0;
                transition: opacity 0.25s ease;
            }

                .sidebar-overlay.open {
                    display: block;
                    opacity: 1;
                }

            .profile-sidebar {
                position: fixed;
                top: 0;
                right: -300px;
                width: 280px;
                max-width: 85vw;
                height: 100%;
                background: var(--card-bg);
                border-left: 1px solid var(--border-color);
                box-shadow: var(--shadow-lg);
                z-index: 9999;
                overflow-y: auto;
                transition: right 0.3s ease;
                display: flex;
                flex-direction: column;
            }

                .profile-sidebar.open {
                    right: 0;
                }

            .sidebar-drawer-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 18px 16px;
                border-bottom: 1px solid var(--border-color);
            }

                .sidebar-drawer-head span {
                    font-family: var(--font-display);
                    font-weight: 700;
                    font-size: 15px;
                }

            .sidebar-close-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 30px;
                height: 30px;
                border-radius: 50%;
                background: var(--bg-color);
                border: 1px solid var(--border-color);
                color: var(--text-secondary);
                font-size: 15px;
                cursor: pointer;
            }

            .sidebar-nav {
                padding: 10px 12px;
            }

            .sidebar-nav-label,
            .sidebar-section-label {
                font-size: 10.5px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                color: var(--text-secondary);
                padding: 12px 12px 6px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 12px;
                width: 100%;
                padding: 11px 12px;
                font-size: 14px;
                font-weight: 600;
                font-family: var(--font-family);
                color: var(--text-primary);
                text-decoration: none;
                background: transparent;
                border: none;
                border-radius: 10px;
                cursor: pointer;
                text-align: left;
                transition: background-color 0.15s ease, color 0.15s ease;
            }

                .sidebar-link i {
                    width: 18px;
                    text-align: center;
                    color: var(--accent-color);
                    font-size: 15px;
                }

                .sidebar-link:hover {
                    background: var(--accent-light);
                }

                .sidebar-link.active {
                    background: var(--accent-color);
                    color: #ffffff;
                    font-weight: 800;
                    box-shadow: 0 6px 14px rgba(109, 40, 217, 0.25);
                }

                    .sidebar-link.active i {
                        color: #ffffff;
                    }

                .sidebar-link.logout {
                    color: var(--error-color);
                }

                    .sidebar-link.logout i {
                        color: var(--error-color);
                    }

                    .sidebar-link.logout:hover {
                        background: #fef2f2;
                    }

            .sidebar-divider {
                height: 1px;
                background: var(--border-color);
                margin: 8px 12px;
            }

            .logout-form {
                margin: 0;
            }

            .content-topbar {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 16px;
                margin-bottom: 22px;
            }

            .page-heading h1 {
                font-family: var(--font-display);
                font-size: 26px;
                font-weight: 700;
                color: var(--text-primary);
            }

            .page-heading p {
                font-size: 13.5px;
                color: var(--text-secondary);
                margin-top: 4px;
            }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 10px;
                flex-shrink: 0;
            }

            .mobile-menu-btn {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                color: var(--text-primary);
                font-weight: 700;
                font-size: 13px;
                padding: 9px 14px;
                border-radius: 50px;
                cursor: pointer;
                box-shadow: var(--shadow-sm);
            }

                .mobile-menu-btn i.fa-bars {
                    color: var(--accent-color);
                }

            .tab-content {
                display: none;
                animation: fadeUp 0.35s ease forwards;
            }

                .tab-content.active {
                    display: block;
                }

            .settings-grid {
                display: flex;
                flex-direction: column;
                gap: 18px;
            }

            .settings-card {
                position: relative;
                background: var(--card-bg);
                padding: 24px 26px 24px 30px;
                border-radius: var(--radius-lg);
                border: 1px solid var(--border-color);
                box-shadow: var(--shadow-sm);
                transition: box-shadow 0.2s ease, transform 0.2s ease;
                --card-accent: var(--accent-color);
                --card-accent-light: var(--accent-light);
            }

                .settings-card::before {
                    content: "";
                    position: absolute;
                    left: 0;
                    top: 18px;
                    bottom: 18px;
                    width: 4px;
                    border-radius: 4px;
                    background: var(--card-accent);
                }

                .settings-card:hover {
                    box-shadow: var(--shadow-md);
                    transform: translateY(-2px);
                }

                .settings-card.accent-store {
                    --card-accent: #2563eb;
                    --card-accent-light: #eaf1ff;
                }

                .settings-card.accent-delivery {
                    --card-accent: #d97706;
                    --card-accent-light: #fff6e8;
                }

                .settings-card h3 {
                    font-size: 16.5px;
                    font-weight: 800;
                    margin-bottom: 14px;
                    color: var(--text-primary);
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    border-bottom: 1px solid var(--border-color);
                    padding-bottom: 12px;
                }

                    .settings-card h3 i {
                        width: 36px;
                        height: 36px;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        background: var(--card-accent-light);
                        border-radius: 10px;
                        color: var(--card-accent);
                        font-size: 15px;
                    }

                .settings-card p {
                    color: var(--text-secondary);
                    font-size: 13.5px;
                    line-height: 1.55;
                    margin-bottom: 18px;
                }

            .settings-btn {
                display: inline-flex;
                align-items: center;
                gap: 9px;
                background: var(--accent-gradient);
                color: white;
                padding: 10px 18px;
                text-decoration: none;
                border-radius: 50px;
                font-weight: 700;
                font-size: 13px;
                transition: all 0.2s ease;
                border: none;
                cursor: pointer;
                margin-right: 10px;
                margin-bottom: 8px;
                box-shadow: 0 4px 10px rgba(109, 40, 217, 0.18);
            }

                .settings-btn:hover {
                    opacity: 0.94;
                }

                .settings-btn.subtle {
                    background: var(--card-bg);
                    color: var(--accent-color);
                    border: 1px solid var(--border-color);
                    box-shadow: none;
                }

                    .settings-btn.subtle:hover {
                        background: var(--accent-light);
                    }

            .message {
                padding: 14px 18px;
                border-radius: 12px;
                font-weight: 700;
                margin-bottom: 20px;
            }

            .success-message {
                background: #ecfdf5;
                color: var(--success-color);
                border: 1px solid #d1fae5;
            }

            .error-message {
                background: #fef2f2;
                color: var(--error-color);
                border: 1px solid #fee2e2;
            }

            .warning-message {
                background: #fff5f5;
                color: var(--error-color);
                border: 1px solid #ffd1cc;
                padding: 12px;
                border-radius: 10px;
                font-size: 13.5px;
                margin-bottom: 16px;
            }

            .info-message {
                background: var(--accent-light);
                color: var(--accent-color);
                border: 1px solid var(--border-color);
                padding: 12px;
                border-radius: 10px;
                font-size: 13.5px;
                margin-bottom: 16px;
            }

            .delivery-login-card {
                display: none;
                margin-top: 16px;
                background: var(--bg-color);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-md);
                padding: 18px;
            }

                .delivery-login-card.open {
                    display: block;
                }

            .delivery-login-form {
                display: grid;
                gap: 12px;
                margin-top: 12px;
            }

            .delivery-login-btn {
                border: none;
                background: var(--accent-gradient);
                color: white;
                padding: 11px;
                border-radius: 50px;
                font-weight: 700;
                cursor: pointer;
                transition: opacity 0.15s;
                box-shadow: 0 4px 10px rgba(109, 40, 217, 0.25);
            }

                .delivery-login-btn:hover {
                    opacity: 0.95;
                }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

                .form-group label {
                    font-size: 12.5px;
                    font-weight: 700;
                    color: var(--text-secondary);
                }

                .form-group input,
                .form-group select,
                .form-group textarea {
                    padding: 10px 12px;
                    border: 1px solid var(--border-color);
                    border-radius: 8px;
                    outline: none;
                    font-size: 14px;
                    color: var(--text-primary);
                    width: 100%;
                    background: var(--card-bg);
                    font-family: var(--font-family);
                    transition: all 0.2s ease;
                }

                    .form-group input:focus,
                    .form-group select:focus,
                    .form-group textarea:focus {
                        border-color: var(--accent-color);
                    }

            .instagram-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 22px;
            }

            .product-grid-item {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-lg);
                overflow: hidden;
                display: flex;
                flex-direction: column;
                box-shadow: var(--shadow-sm);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .product-grid-item:hover {
                    transform: translateY(-4px);
                    box-shadow: var(--shadow-md);
                }

                .product-grid-item img {
                    width: 100%;
                    height: 170px;
                    object-fit: cover;
                    border-bottom: 1px solid var(--border-color);
                }

            .product-details {
                padding: 16px;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

                .product-details h4 {
                    font-size: 14.5px;
                    font-weight: 700;
                    color: var(--text-primary);
                    margin-bottom: 6px;
                    height: 38px;
                    overflow: hidden;
                }

                .product-details .price {
                    font-size: 15.5px;
                    font-weight: 800;
                    color: var(--accent-color);
                    margin-bottom: 12px;
                }

            .view-btn {
                background-color: var(--accent-light);
                color: var(--accent-color);
                border: 1px solid var(--border-color);
                text-align: center;
                text-decoration: none;
                border-radius: 50px;
                padding: 8px;
                font-size: 13px;
                font-weight: 700;
                transition: all 0.15s ease;
                margin-top: auto;
            }

                .view-btn:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: #ffffff;
                }

            .empty-state {
                text-align: center;
                padding: 54px 20px;
                color: var(--text-secondary);
            }

            .empty-icon {
                font-size: 46px;
                margin-bottom: 14px;
                color: var(--border-color);
            }

            .empty-state h3 {
                font-size: 18px;
                font-weight: 800;
                color: var(--text-primary);
                margin-bottom: 8px;
            }

            .empty-state p {
                font-size: 13.5px;
                max-width: 350px;
                margin: 0 auto;
                line-height: 1.5;
            }

            .activity-section {
                margin-bottom: 30px;
            }

                .activity-section:last-child {
                    margin-bottom: 0;
                }

            .activity-section-title {
                font-family: var(--font-display);
                font-size: 16.5px;
                font-weight: 700;
                color: var(--text-primary);
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 14px;
                padding-bottom: 10px;
                border-bottom: 1px solid var(--border-color);
            }

                .activity-section-title i {
                    color: var(--accent-color);
                    font-size: 14px;
                }

            .reviews-container {
                display: flex;
                flex-direction: column;
                gap: 14px;
            }

            .review-row {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-md);
                padding: 18px 20px;
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                gap: 16px;
                box-shadow: var(--shadow-sm);
            }

            .review-main {
                flex-grow: 1;
            }

                .review-main h4 {
                    font-size: 15px;
                    font-weight: 700;
                    color: var(--text-primary);
                    margin-bottom: 6px;
                }

                .review-main p {
                    font-size: 13.5px;
                    color: var(--text-secondary);
                    line-height: 1.5;
                    font-style: italic;
                }

            .review-meta {
                text-align: right;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 6px;
                min-width: 110px;
            }

            .stars-row {
                display: flex;
                gap: 2px;
            }

            .modal {
                display: none;
                position: fixed;
                z-index: 20000;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(30, 27, 46, 0.6);
                backdrop-filter: blur(5px);
            }

            .modal-content {
                background-color: var(--card-bg);
                margin: 10% auto;
                padding: 30px;
                border-radius: var(--radius-lg);
                width: 90%;
                max-width: 440px;
                box-shadow: var(--shadow-lg);
                border: 1px solid var(--border-color);
                position: relative;
                animation: zoomIn 0.3s ease;
            }

            .close-modal {
                position: absolute;
                right: 20px;
                top: 15px;
                font-size: 24px;
                font-weight: bold;
                color: var(--text-secondary);
                cursor: pointer;
            }

                .close-modal:hover {
                    color: var(--text-primary);
                }

            .modal h3 {
                margin-bottom: 20px;
                font-size: 19px;
                color: var(--text-primary);
                font-weight: 800;
            }

            .modal-form {
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

            .save-btn {
                background: var(--accent-gradient);
                color: white;
                border: none;
                padding: 12px;
                border-radius: 50px;
                font-weight: 700;
                cursor: pointer;
                transition: opacity 0.15s ease;
                box-shadow: 0 4px 12px rgba(109, 40, 217, 0.25);
            }

                .save-btn:hover {
                    opacity: 0.95;
                }

            .following-list-item {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 8px 16px;
                transition: background-color 0.1s ease;
            }

                .following-list-item:hover {
                    background-color: var(--bg-color);
                }

            .following-store-info {
                display: flex;
                align-items: center;
                gap: 12px;
                cursor: pointer;
                text-decoration: none;
                color: inherit;
                flex-grow: 1;
                min-width: 0;
            }

            .following-store-logo {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                object-fit: cover;
                border: 1px solid var(--border-color);
                flex-shrink: 0;
            }

            .following-store-names {
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .following-store-name {
                font-size: 14px;
                font-weight: 700;
                color: var(--text-primary);
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .following-store-desc {
                font-size: 12px;
                color: var(--text-secondary);
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .following-action-btn {
                background-color: var(--accent-light);
                border: 1px solid var(--border-color);
                color: var(--accent-color);
                font-weight: 700;
                font-size: 12px;
                padding: 5px 16px;
                border-radius: 50px;
                text-decoration: none;
                cursor: pointer;
                transition: all 0.15s;
                flex-shrink: 0;
            }

                .following-action-btn:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: #ffffff;
                }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes zoomIn {
                from {
                    transform: scale(0.95);
                    opacity: 0;
                }

                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            @@media (max-width: 992px) {
                .instagram-grid {
                    grid-template-columns: repeat(1, 1fr);
                    gap: 16px;
                }
            }

            @@media (max-width: 480px) {
                .ig-name {
                    font-size: 17px;
                }

                .ig-avatar {
                    width: 58px;
                    height: 58px;
                    font-size: 26px;
                }
            }

            footer {
                text-align: center;
                padding: 40px 20px;
                color: var(--text-secondary);
                font-size: 12px;
                border-top: 1px solid var(--border-color);
                margin-top: 40px;
            }
    </style>
</head>

<body>

    <partial name="_CustomerBottomNav" />

    <div class="profile-container">

        <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>

        <div class="profile-header-card">
            <div class="profile-cover"></div>

            <button type="button" class="header-menu-btn" onclick="openSidebar()" aria-label="Open menu">
                <i class="fas fa-bars"></i>
            </button>

            <div class="ig-top-row">
                <div class="ig-avatar">
                    <i class="fas fa-user-astronaut"></i>
                </div>
                <div class="ig-identity">
                    <div class="ig-name">
                        @Model.CustomerFullName
                        @if (Model.IsVerified)
                        {
                            <span title="Verified Customer">
                                <i class="fas fa-check-circle" style="color: #6d28d9; font-size: 14px;"></i>
                            </span>
                        }
                    </div>
                    <div class="ig-joined">Customer since @Model.CreatedAt.ToString("MMM yyyy")</div>
                </div>
            </div>

            <div class="ig-stats-row">
                <div class="ig-stat">
                    <span class="ig-stat-count">@Model.OrdersCount</span>
                    <span class="ig-stat-label">Orders</span>
                </div>
                <div class="ig-stat clickable" onclick="openFollowingModal()">
                    <span class="ig-stat-count">@Model.FollowedStoresList.Count</span>
                    <span class="ig-stat-label">Following</span>
                </div>
                <div class="ig-stat">
                    <span class="ig-stat-count">@Model.ReviewsList.Count</span>
                    <span class="ig-stat-label">Reviews</span>
                </div>
                <div class="ig-stat">
                    <span class="ig-stat-count">@Model.WishlistCount</span>
                    <span class="ig-stat-label">Wishlist</span>
                </div>
            </div>

            <div class="ig-badges">
                <span class="sidebar-badge loyalty-badge">
                    <i class="fas fa-star"></i> @Model.LoyaltyPoints pts
                </span>
                <span class="sidebar-badge">
                    <i class="fas fa-venus-mars"></i> @Model.Gender
                </span>
                @if (Model.CODBlocked)
                {
                    <span class="sidebar-badge restricted-badge">
                        <i class="fas fa-ban"></i> COD Restricted
                    </span>
                }
            </div>
        </div>

        <aside id="sidebar" class="profile-sidebar">

            <div class="sidebar-drawer-head">
                <span>Menu</span>
                <button type="button" class="sidebar-close-btn" onclick="closeSidebar()" aria-label="Close menu">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>

            <nav class="sidebar-nav">
                <div class="sidebar-nav-label">Dashboard</div>

                <button id="link-settings-tab" class="sidebar-link active" data-tab="settings-tab" onclick="selectTab('settings-tab')">
                    <i class="fas fa-sliders-h"></i> Management
                </button>
                <button id="link-activity-tab" class="sidebar-link" data-tab="activity-tab" onclick="selectTab('activity-tab')">
                    <i class="fas fa-clock-rotate-left"></i> Your Activity
                </button>
                <button id="link-wishlist-tab" class="sidebar-link" data-tab="wishlist-tab" onclick="selectTab('wishlist-tab')">
                    <i class="far fa-bookmark"></i> Wishlist
                </button>

                <div class="sidebar-divider"></div>
                <div class="sidebar-nav-label">Account</div>

                <button type="button" class="sidebar-link" onclick="openEditModal(); closeSidebar();">
                    <i class="fas fa-user-pen"></i> Edit Profile
                </button>

                <div class="sidebar-divider"></div>
                <div class="sidebar-nav-label">Support</div>

                <a href="/HelpCenter" class="sidebar-link">
                    <i class="fas fa-circle-question"></i> Help Center
                </a>
                <a href="/CustomerComplaint" class="sidebar-link">
                    <i class="fas fa-flag"></i> File a Complaint
                </a>

                <div class="sidebar-divider"></div>

                <form method="post" asp-page="/Identity/Account/Logout" asp-route-returnUrl="/" class="logout-form">
                    <button type="submit" class="sidebar-link logout">
                        <i class="fas fa-right-from-bracket"></i> Logout
                    </button>
                </form>
            </nav>
        </aside>

        <main class="main-content">

            <div class="content-topbar">
                <div class="page-heading">
                    <h1 id="pageTitle">Management</h1>
                    <p id="pageSubtitle">Manage your account security, store access, and delivery access.</p>
                </div>
                <div class="topbar-actions">
                    <partial name="_MessageBell" />
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="message success-message">
                    @TempData["Success"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="message error-message">
                    Please check your information and try again.
                </div>
            }

            <div id="settings-tab" class="tab-content active">

                <div class="settings-grid">

                    <div class="settings-card">
                        <h3><i class="fas fa-sliders-h"></i> Account Settings</h3>
                        <p>Manage your physical addresses or update your login credentials. Use "Edit Profile" in the menu to change your name or phone number.</p>

                        <a class="settings-btn" href="/Identity/Account/Manage/ChangePassword">
                            <i class="fas fa-key"></i> Change Password
                        </a>
                        <a class="settings-btn subtle" href="/CustomerAddresses">
                            <i class="fas fa-location-dot"></i> My Addresses
                        </a>
                        <a class="settings-btn subtle" href="/CustomerComplaint">
                            <i class="fas fa-flag"></i> File a Complaint
                        </a>
                    </div>

                    <div class="settings-card accent-store">
                        <h3><i class="fas fa-store"></i> Store Owner Access</h3>

                        @if (!string.IsNullOrWhiteSpace(Model.StoreAccessMessage))
                        {
                            if (Model.HasPendingStoreRequest)
                            {
                                <div class="warning-message">
                                    <i class="fas fa-clock"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasApprovedStoreOwnerAccount)
                            {
                                <div class="info-message">
                                    <i class="fas fa-info-circle"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasRejectedStoreRequest)
                            {
                                <div class="error-message"
                                     style="padding:10px; border-radius:10px; font-size:13.5px; margin-bottom:12px;">
                                    <i class="fas fa-times-circle"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasStoreRequest)
                            {
                                <div class="warning-message">
                                    <i class="fas fa-triangle-exclamation"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else
                            {
                                <p>@Model.StoreAccessMessage</p>
                            }
                        }

                        @if (Model.HasApprovedStoreOwnerAccount)
                        {
                            <button type="button"
                                    id="showStoreOwnerLoginButton"
                                    class="settings-btn"
                                    onclick="toggleStoreOwnerLogin()">
                                <i class="fas fa-sign-in-alt"></i>
                                Login as Store Owner
                            </button>

                            <div id="storeOwnerLoginBox"
                                 class="delivery-login-card @(string.IsNullOrWhiteSpace(storeOwnerLoginError) ? "" : "open")">

                                <h4 style="font-weight:700; margin-bottom:6px; font-size:14px;">
                                    Store Owner Log In
                                </h4>

                                <p style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;">
                                    This Store Owner account is linked securely to your customer account.
                                    Enter the Store Owner password provided by the administrator.
                                </p>

                                @if (!string.IsNullOrWhiteSpace(storeOwnerLoginError))
                                {
                                    <div class="error-message"
                                         style="padding:10px; border-radius:10px; font-size:13px; margin-bottom:12px;">
                                        @storeOwnerLoginError
                                    </div>
                                }

                                <form method="post"
                                      asp-page-handler="StoreOwnerLogin"
                                      class="delivery-login-form"
                                      autocomplete="off">

                                    <div class="form-group">
                                        <label for="StoreOwnerAccountEmail">
                                            Your Store Owner Email
                                        </label>

                                        <input id="StoreOwnerAccountEmail"
                                               type="email"
                                               value="@Model.StoreOwnerAccountEmail"
                                               readonly
                                               aria-readonly="true"
                                               tabindex="-1" />
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="StoreOwnerPassword">
                                            Store Owner Password
                                        </label>

                                        <input asp-for="StoreOwnerPassword"
                                               type="password"
                                               placeholder="Enter Store Owner password"
                                               autocomplete="current-password"
                                               required />
                                    </div>

                                    <button type="submit"
                                            class="delivery-login-btn">
                                        Open Store Owner Dashboard
                                    </button>
                                </form>
                            </div>
                        }
                        else if (Model.HasPendingStoreRequest)
                        {
                            <button type="button"
                                    class="settings-btn"
                                    style="opacity:0.6; cursor:not-allowed;"
                                    disabled>
                                <i class="fas fa-clock"></i>
                                Waiting for Admin Approval
                            </button>
                        }
                        else if (Model.HasRejectedStoreRequest)
                        {
                            <a href="/StoreRequest"
                               class="settings-btn">
                                <i class="fas fa-rotate-right"></i>
                                Update and Resubmit Store Request
                            </a>
                        }
                        else if (!Model.HasStoreRequest)
                        {
                            <a href="/StoreRequest"
                               class="settings-btn">
                                <i class="fas fa-chalkboard-user"></i>
                                Request Store Owner Account
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    class="settings-btn"
                                    style="opacity:0.6; cursor:not-allowed;"
                                    disabled>
                                <i class="fas fa-ban"></i>
                                Store Owner Access Unavailable
                            </button>
                        }
                    </div>

                    <div class="settings-card accent-delivery">
                        <h3><i class="fas fa-motorcycle"></i> Delivery Staff Access</h3>

                        @if (!string.IsNullOrWhiteSpace(Model.DeliveryAccessMessage))
                        {
                            if (Model.HasPendingDeliveryRequest)
                            {
                                <div class="warning-message"><i class="fas fa-clock"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else if (Model.HasApprovedDeliveryAccount)
                            {
                                <div class="info-message"><i class="fas fa-info-circle"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else if (Model.HasRejectedDeliveryRequest)
                            {
                                <div class="error-message" style="padding:10px; border-radius:10px; font-size:13.5px; margin-bottom:12px;"><i class="fas fa-times-circle"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else
                            {
                                <p>@Model.DeliveryAccessMessage</p>
                            }
                        }

                        @if (Model.HasApprovedDeliveryAccount)
                        {
                            <button type="button" id="showDeliveryLoginButton" class="settings-btn" onclick="toggleDeliveryLogin()">
                                <i class="fas fa-sign-in-alt"></i> Login as Delivery Staff
                            </button>

                            <div id="deliveryLoginBox" class="delivery-login-card @(string.IsNullOrWhiteSpace(deliveryLoginError) ? "" : "open")">
                                <h4 style="font-weight:700; margin-bottom:6px; font-size:14px;">Delivery Log In</h4>
                                <p style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;">
                                    This delivery account is linked securely to your customer account. Enter only the delivery password provided by the administrator.
                                </p>

                                @if (!string.IsNullOrWhiteSpace(deliveryLoginError))
                                {
                                    <div class="error-message" style="padding:10px; border-radius:10px; font-size:13px; margin-bottom:12px;">
                                        @deliveryLoginError
                                    </div>
                                }

                                <form method="post" asp-page-handler="DeliveryLogin" class="delivery-login-form" autocomplete="off">
                                    <div class="form-group">
                                        <label for="DeliveryAccountEmail">Your Delivery Email</label>
                                        <input id="DeliveryAccountEmail"
                                               type="email"
                                               value="@Model.DeliveryAccountEmail"
                                               readonly
                                               aria-readonly="true"
                                               tabindex="-1" />
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="DeliveryPassword">Delivery Password</label>
                                        <input asp-for="DeliveryPassword"
                                               type="password"
                                               placeholder="Enter delivery password"
                                               autocomplete="current-password"
                                               required />
                                    </div>

                                    <button type="submit" class="delivery-login-btn">
                                        Open Delivery Dashboard
                                    </button>
                                </form>
                            </div>
                        }
                        else if (Model.HasPendingDeliveryRequest)
                        {
                            <button type="button" class="settings-btn" style="opacity:0.6; cursor:not-allowed;" disabled>
                                <i class="fas fa-clock"></i> Waiting for Admin Approval
                            </button>
                        }
                        else
                        {
                            <a href="/DeliveryRequest" class="settings-btn">
                                <i class="fas fa-id-card"></i> Request Delivery Account
                            </a>
                        }
                    </div>

                </div>
            </div>

            <div id="activity-tab" class="tab-content">

                <div class="activity-section">
                    <h3 class="activity-section-title"><i class="far fa-star"></i> Your Reviews</h3>

                    @if (Model.ReviewsList.Any())
                    {
                        <div class="reviews-container">
                            @foreach (var r in Model.ReviewsList)
                            {
                                var productName = CustomerProfileModel.GetSafeString(r.Product, new[] { "ProductName", "Name" }, "Product");
                                var rating = CustomerProfileModel.GetSafeInt(r, new[] { "Rating", "Stars", "Score" }, 5);
                                var comment = CustomerProfileModel.GetSafeString(r, new[] { "Comment", "Text", "ReviewText", "Description" }, "No feedback left.");

                                <div class="review-row">
                                    <div class="review-main">
                                        <h4>@productName</h4>
                                        <p>"@comment"</p>
                                    </div>
                                    <div class="review-meta">
                                        <div class="stars-row">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= rating)
                                                {
                                                    <i class="fas fa-star" style="color: #FFC107;"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star" style="color: #dbdbdb;"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="padding: 40px 20px;">
                            <div class="empty-icon" style="font-size: 40px;"><i class="far fa-star"></i></div>
                            <h3 style="font-size: 16px;">No Reviews Found</h3>
                            <p style="font-size: 13px;">You have not published any reviews for purchased products yet.</p>
                        </div>
                    }
                </div>

                <div class="activity-section">
                    <h3 class="activity-section-title"><i class="fas fa-ban"></i> Blocked Shops</h3>

                    <div class="empty-state" style="padding: 40px 20px;">
                        <div class="empty-icon" style="font-size: 40px;"><i class="fas fa-store-slash"></i></div>
                        <h3 style="font-size: 16px;">No Blocked Shops</h3>
                        <p style="font-size: 13px;">Shops you block will stop appearing in your feed, search, and recommendations.</p>
                    </div>
                </div>

                <div class="activity-section">
                    <h3 class="activity-section-title"><i class="fas fa-globe"></i> Language Preference</h3>

                    <div class="settings-card" style="box-shadow: none; padding: 22px; margin-bottom: 0;">
                        <div class="form-group" style="max-width: 280px; margin-bottom: 16px;">
                            <label for="languageSelect">App Language</label>
                            <select id="languageSelect">
                                <option value="en">English</option>
                                <option value="ar">العربية (Arabic)</option>
                                <option value="fr">Français</option>
                            </select>
                        </div>
                        <button type="button" class="settings-btn" onclick="saveLanguagePreference()">
                            <i class="fas fa-check"></i> Save Language
                        </button>
                    </div>
                </div>

            </div>

            <div id="wishlist-tab" class="tab-content">
                @if (Model.WishlistList.Any())
                {
                    <div class="instagram-grid">
                        @foreach (var wish in Model.WishlistList)
                        {
                            var productName = CustomerProfileModel.GetSafeString(wish.Product, new[] { "ProductName", "Name", "Title" }, "Marketplace Product");
                            var productPrice = CustomerProfileModel.GetSafeDecimal(wish.Product, new[] { "Price" }, 0.00m);
                            var productImage = CustomerProfileModel.GetPrimaryProductImageUrl(wish.Product)
                                ?? "https://cdn-icons-png.flaticon.com/512/1170/1170576.png";
                            var productId = CustomerProfileModel.GetSafeInt(wish.Product, new[] { "ProductID", "Id" }, 0);
                            <div class="product-grid-item">
                                <img src="@productImage"
                                     alt="@productName"
                                     onerror="this.src='https://cdn-icons-png.flaticon.com/512/1170/1170576.png'" />

                                <div class="product-details">
                                    <h4>@productName</h4>

                                    <span class="price">$@productPrice.ToString("F2")</span>

                                    <a href="/ProductDetails?id=@productId" class="view-btn">
                                        View Details
                                    </a>

                                    <form method="post" asp-page-handler="ToggleWishlist">
                                        <input type="hidden" name="productId" value="@productId" />

                                        <button type="submit" class="wishlist-btn">
                                            <i class="fas fa-heart"></i> Remove from Wishlist
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="far fa-bookmark"></i></div>
                        <h3>Wishlist is Empty</h3>
                        <p>Save items you like to monitor price changes and purchase them easily.</p>
                    </div>
                }
            </div>

        </main>
    </div>

    <div id="editProfileModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeEditModal()">&times;</span>
            <h3>Edit Profile Details</h3>
            <form method="post" class="modal-form">
                <div class="form-group">
                    <label for="CustomerFullName">Full Name</label>
                    <input type="text" id="CustomerFullName" name="CustomerFullName" value="@Model.CustomerFullName" required />
                </div>
                <div class="form-group">
                    <label for="CustomerPhone">Phone Number</label>
                    <input type="text" id="CustomerPhone" name="CustomerPhone" value="@Model.CustomerPhone" required />
                </div>
                <button type="submit" class="save-btn">Save Changes</button>
            </form>
        </div>
    </div>

    <div id="followingModal" class="modal">
        <div class="modal-content" style="max-width: 400px; padding: 0; overflow: hidden; border-radius: 12px;">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--border-color);">
                <div style="width: 24px;"></div>
                <h3 style="margin: 0; font-size: 16px; font-weight: 800; text-align: center;">Following</h3>
                <span class="close-modal" onclick="closeFollowingModal()" style="font-size: 20px; font-weight: bold; color: #aaa; cursor: pointer; line-height: 1;">&times;</span>
            </div>
            <div style="max-height: 350px; overflow-y: auto; padding: 8px 0;">
                @if (Model.FollowedStoresList.Any())
                {
                    @foreach (var follow in Model.FollowedStoresList)
                    {
                        var storeName = CustomerProfileModel.GetSafeString(follow.Store, new[] { "StoreName", "Name", "Title" }, "Local Store");
                        var storeDesc = CustomerProfileModel.GetSafeString(follow.Store, new[] { "Description", "Bio", "About" }, "Favorite marketplace shop.");
                        var storeLogo = CustomerProfileModel.GetSafeString(follow.Store, new[] { "LogoUrl", "Logo", "ImageUrl", "LogoPath" }, "https://cdn-icons-png.flaticon.com/512/869/869636.png");
                        var storeId = CustomerProfileModel.GetSafeInt(follow.Store, new[] { "StoreID", "Id" }, 0);

                        <div class="following-list-item">
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-store-info">
                                <img src="@storeLogo" alt="@storeName" class="following-store-logo" onerror="this.src='https://cdn-icons-png.flaticon.com/512/869/869636.png'" />
                                <div class="following-store-names">
                                    <span class="following-store-name">@storeName</span>
                                    <span class="following-store-desc">@storeDesc</span>
                                </div>
                            </a>
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-action-btn">Visit</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary); font-size: 14px;">
                        You are not following any shops yet.
                    </div>
                }
            </div>
        </div>
    </div>

    <footer>
        <span>✨ Realnest — your local marketplace companion ✨</span>
    </footer>

    <script>
            const TAB_META = {
                "settings-tab": {
                    title: "Management",
                    subtitle: "Manage your account security, store access, and delivery access."
                },
                "activity-tab": {
                    title: "Your Activity",
                    subtitle: "Reviews you've left, blocked shops, and language preferences."
                },
                "wishlist-tab": {
                    title: "Wishlist",
                    subtitle: "Products you've saved to track and revisit."
                }
            };

            function openEditModal() {
                document.getElementById("editProfileModal").style.display = "block";
            }

            function closeEditModal() {
                document.getElementById("editProfileModal").style.display = "none";
            }

            function openFollowingModal() {
                document.getElementById("followingModal").style.display = "block";
            }

            function closeFollowingModal() {
                document.getElementById("followingModal").style.display = "none";
            }

            function saveLanguagePreference() {
                const select = document.getElementById("languageSelect");
                const label = select.options[select.selectedIndex].text;
                alert("Language set to " + label + " (placeholder — connect this to your backend to persist it).");
            }

            window.onclick = function(event) {
                const modalsToCheck = [
                    "editProfileModal",
                    "followingModal"
                ];

                modalsToCheck.forEach(function(id) {
                    const modal = document.getElementById(id);
                    if (event.target === modal) {
                        modal.style.display = "none";
                    }
                });
            }

            function openSidebar() {
                document.getElementById("sidebar").classList.add("open");
                document.getElementById("sidebarOverlay").classList.add("open");
                document.body.style.overflow = "hidden";
            }

            function closeSidebar() {
                document.getElementById("sidebar").classList.remove("open");
                document.getElementById("sidebarOverlay").classList.remove("open");
                document.body.style.overflow = "";
            }

            function switchTab(tabId) {
                document.querySelectorAll(".tab-content").forEach(tab => {
                    tab.classList.remove("active");
                });
                document.querySelectorAll(".sidebar-link[data-tab]").forEach(link => {
                    link.classList.remove("active");
                });

                document.getElementById(tabId).classList.add("active");

                const activeLink = document.getElementById("link-" + tabId);
                if (activeLink) {
                    activeLink.classList.add("active");
                }

                const meta = TAB_META[tabId];
                if (meta) {
                    document.getElementById("pageTitle").textContent = meta.title;
                    document.getElementById("pageSubtitle").textContent = meta.subtitle;
                }
            }

            function selectTab(tabId) {
                switchTab(tabId);
                closeSidebar();
            }

            function toggleDeliveryLogin() {
                const loginBox = document.getElementById("deliveryLoginBox");

                if (!loginBox) {
                    return;
                }

                loginBox.classList.toggle("open");

                if (loginBox.classList.contains("open")) {
                    clearDeliveryPassword();

                    window.setTimeout(function() {
                        const passwordInput =
                            document.getElementById("DeliveryPassword");

                        if (passwordInput) {
                            passwordInput.focus();
                        }
                    }, 50);
                }
            }

            function clearDeliveryPassword() {
                const passwordInput =
                    document.getElementById("DeliveryPassword");

                if (passwordInput) {
                    passwordInput.value = "";
                }
            }

            function toggleStoreOwnerLogin() {
                const loginBox =
                    document.getElementById("storeOwnerLoginBox");

                if (!loginBox) {
                    return;
                }

                loginBox.classList.toggle("open");

                if (loginBox.classList.contains("open")) {
                    clearStoreOwnerPassword();

                    window.setTimeout(function() {
                        const passwordInput =
                            document.getElementById("StoreOwnerPassword");

                        if (passwordInput) {
                            passwordInput.focus();
                        }
                    }, 50);
                }
            }

            function clearStoreOwnerPassword() {
                const passwordInput =
                    document.getElementById("StoreOwnerPassword");

                if (passwordInput) {
                    passwordInput.value = "";
                }
            }

            document.addEventListener("DOMContentLoaded", function() {
                clearDeliveryPassword();
                clearStoreOwnerPassword();
            });

            window.addEventListener("pageshow", function() {
                clearDeliveryPassword();
                clearStoreOwnerPassword();
            });
    </script>

</body>
</html>
