@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProfileModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Customer Profile</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>

        body {
            font-family: Poppins;
            background: #f4f4f7;
            margin: 0;
        }

        .topbar {
            background: #111;
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
        }

        .container {
            width: 1000px;
            margin: 30px auto;
        }

        .profile-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .profile-image {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: #ddd;
        }

        .stats {
            display: flex;
            gap: 30px;
            margin-top: 15px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
        }

        .btn {
            display: inline-block;
            background: #111;
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 8px;
            margin-top: 10px;
        }

    </style>

</head>

<body>

    <div class="topbar">

        <div>Realnest</div>

        <div>
            <a href="/Customer1" style="color:white;">Dashboard</a>
            |
            <a href="/CustomerProducts" style="color:white;">Shop</a>
            |
            <a href="/CustomerCart" style="color:white;">Cart</a>
            |
            <a href="/CustomerOrders" style="color:white;">Orders</a>
        </div>

    </div>

    <div class="container">

        <div class="profile-card">

            <div class="profile-image"></div>

            <div>

                <h2>Customer Name</h2>

                <p>customer@email.com</p>

                <div class="stats">

                    <div>
                        <strong>12</strong><br />
                        Orders
                    </div>

                    <div>
                        <strong>5</strong><br />
                        Stores Followed
                    </div>

                    <div>
                        <strong>8</strong><br />
                        Reviews
                    </div>

                </div>

            </div>

        </div>

        <div class="card">

            <h3>Account Settings</h3>

            <a class="btn" href="/ChangeProfile">
                Edit Profile
            </a>

            <a class="btn" href="/ChangePassword">
                Change Password
            </a>

        </div>

        <div class="card">

            <h3>Become a Store Owner</h3>

            <p>
                Submit a request and wait for admin approval.
            </p>

            <a class="btn" href="/StoreRequest">
                Request Store Owner Account
            </a>

        </div>

        <div class="card">

            <h3>Become Delivery Staff</h3>

            <p>
                Submit your vehicle and license information.
            </p>

            <a class="btn" href="/DeliveryRequest">
                Request Delivery Account
            </a>

        </div>

    </div>

</body>
</html>