@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProfileModel
@{
    ViewData["Title"] = "Customer Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Profile</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: Poppins;
            background: #f4f4f7;
            margin: 0;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            padding: 20px;
            background: #111;
            color: white;
        }

        .container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            padding: 30px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 12px;
        }

        .full {
            grid-column: span 2;
        }

        label {
            display: block;
            margin-top: 10px;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }

        button {
            width: 100%;
            margin-top: 15px;
            padding: 12px;
            border: none;
            background: #111;
            color: white;
            border-radius: 8px;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div>Customer Profile</div>
        <div>Realnest</div>
    </div>

    <div class="container">

        <!-- ================= PROFILE ================= -->
        <div class="card">
            <h3>My Profile</h3>

            <form method="post">

                <label>Full Name</label>
                <input asp-for="CustomerFullName" />

                <label>Email</label>
                <input asp-for="CustomerEmail" />

                <label>Phone</label>
                <input asp-for="CustomerPhone" />

                <button type="submit">Update Profile</button>
            </form>
        </div>

        <!-- ================= STORE REQUEST ================= -->
        <div class="card">
            <h3>Become Store Owner</h3>

            <form method="post" asp-page-handler="StoreRequest">

                <label>Store Name</label>
                <input asp-for="Store.StoreName" />

                <label>Phone</label>
                <input asp-for="Store.PhoneNumber" />

                <label>Email</label>
                <input asp-for="Store.Email" />

                <label>Address</label>
                <input asp-for="Store.AddressLine1" />

                <label>Business License</label>
                <input asp-for="Store.BusinessLicenseNumber" />

                <button type="submit">Send Request</button>
            </form>
        </div>

        <!-- ================= DELIVERY REQUEST ================= -->
        <div class="card full">
            <h3>Become Delivery Staff</h3>

            <form method="post" asp-page-handler="DeliveryRequest">

                <label>Vehicle Type</label>
                <input asp-for="Delivery.VehicleType" />

                <label>Vehicle Number</label>
                <input asp-for="Delivery.VehicleNumber" />

                <label>Driving License</label>
                <input asp-for="Delivery.DrivingLicenseNumber" />

                <button type="submit">Send Request</button>
            </form>
        </div>

    </div>

</body>
</html>