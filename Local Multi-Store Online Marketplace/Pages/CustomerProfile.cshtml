@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProfileModel

@{
    Layout = null;

    var deliveryLoginError =
        TempData["DeliveryLoginError"]?.ToString();

    var storeOwnerLoginError =
        TempData["StoreOwnerLoginError"]?.ToString();

    var shouldOpenManagementTab =
        !string.IsNullOrWhiteSpace(deliveryLoginError) ||
        !string.IsNullOrWhiteSpace(storeOwnerLoginError);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>My Profile | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #fafafa;
            color: #262626;
            min-height: 100vh;
        }

        /* Topbar Reset & Instagram Modernization */
        .topbar {
            background: #ffffff;
            border-bottom: 1px solid #dbdbdb;
            padding: 12px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .topbar > div:first-child {
                font-size: 24px;
                font-weight: 700;
                letter-spacing: -0.5px;
                color: #262626;
                font-style: italic;
            }

            .topbar > div:last-child {
                display: flex;
                gap: 20px;
                flex-wrap: wrap;
            }

            .topbar a {
                color: #262626;
                text-decoration: none;
                font-weight: 500;
                padding: 8px 12px;
                border-radius: 4px;
                transition: all 0.2s ease;
                font-size: 14px;
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .topbar a:hover {
                    color: #FF6B35;
                    background: #fafafa;
                }

        /* Instagram Layout Grid */
        .profile-container {
            max-width: 935px;
            width: 100%;
            margin: 30px auto;
            padding: 0 20px;
        }

        /* Header Section */
        .profile-header {
            display: flex;
            align-items: center;
            gap: 60px;
            padding-bottom: 44px;
            border-bottom: 1px solid #dbdbdb;
            margin-bottom: 20px;
        }

        .profile-avatar-container {
            flex-shrink: 0;
        }

        .profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f5f7fa 0%, #cbd5e1 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 70px;
            color: #475569;
            border: 2px solid #dbdbdb;
        }

        .profile-details {
            flex-grow: 1;
        }

        .profile-username-row {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .profile-username {
            font-size: 28px;
            font-weight: 300;
            color: #262626;
            display: flex;
            align-items: center;
        }

        .edit-profile-btn {
            background-color: transparent;
            border: 1px solid #dbdbdb;
            border-radius: 4px;
            color: #262626;
            padding: 5px 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.15s ease;
        }

            .edit-profile-btn:hover {
                background-color: #fafafa;
                border-color: #a8a8a8;
            }

        .profile-stats-row {
            display: flex;
            gap: 40px;
            margin-bottom: 20px;
        }

        .stat-item {
            font-size: 16px;
            color: #262626;
            transition: opacity 0.15s ease;
        }

        .stat-item-clickable:hover {
            opacity: 0.7;
        }

        .stat-count {
            font-weight: 600;
        }

        .profile-bio {
            font-size: 14px;
            line-height: 1.5;
            color: #262626;
        }

            .profile-bio h1 {
                font-size: 16px;
                font-weight: 600;
                margin-bottom: 4px;
            }

        .bio-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
        }

        .bio-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #f1f5f9;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            color: #475569;
        }

        .loyalty-badge {
            background: #fef3c7;
            color: #d97706;
        }

        /* Instagram Navigation Tabs */
        .profile-tabs {
            display: flex;
            justify-content: center;
            border-top: 1px solid #dbdbdb;
            gap: 60px;
            margin-bottom: 20px;
        }

        .tab-btn {
            background: transparent;
            border: none;
            border-top: 1px solid transparent;
            color: #8e8e8e;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            padding: 16px 0;
            text-transform: uppercase;
            margin-top: -1px;
            transition: color 0.15s ease;
        }

            .tab-btn:hover {
                color: #262626;
            }

            .tab-btn.active {
                color: #262626;
                border-top: 1px solid #262626;
            }

        /* Tab Content Styling */
        .tab-content {
            display: none;
            animation: fadeUp 0.4s ease forwards;
        }

            .tab-content.active {
                display: block;
            }

        /* Grid layouts (Instagram 3-columns) */
        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            margin-top: 20px;
        }

        /* Card Layouts */
        .store-grid-item {
            background: #ffffff;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            padding: 24px;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .store-grid-item:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            }

            .store-grid-item img {
                width: 85px;
                height: 85px;
                border-radius: 50%;
                object-fit: cover;
                margin-bottom: 12px;
                border: 1px solid #efefef;
            }

            .store-grid-item h4 {
                font-size: 16px;
                font-weight: 600;
                color: #262626;
                margin-bottom: 6px;
            }

            .store-grid-item p {
                font-size: 13px;
                color: #8e8e8e;
                margin-bottom: 16px;
                line-height: 1.4;
                height: 36px;
                overflow: hidden;
                text-overflow: ellipsis;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
            }

        .visit-btn {
            background-color: #0095f6;
            color: #fff;
            border: none;
            border-radius: 4px;
            padding: 6px 16px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            width: 100%;
            text-align: center;
            transition: background-color 0.15s ease;
        }

            .visit-btn:hover {
                background-color: #0077c5;
            }

        /* Product Cards */
        .product-grid-item {
            background: #ffffff;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .product-grid-item:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            }

            .product-grid-item img {
                width: 100%;
                height: 200px;
                object-fit: cover;
                border-bottom: 1px solid #efefef;
            }

        .product-details {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

            .product-details h4 {
                font-size: 15px;
                font-weight: 600;
                color: #262626;
                margin-bottom: 6px;
                height: 40px;
                overflow: hidden;
            }

            .product-details .price {
                font-size: 16px;
                font-weight: 700;
                color: #FF6B35;
                margin-bottom: 12px;
            }

        .view-btn {
            background-color: #262626;
            color: #fff;
            text-align: center;
            text-decoration: none;
            border-radius: 4px;
            padding: 8px;
            font-size: 13px;
            font-weight: 600;
            transition: background-color 0.15s ease;
            margin-top: auto;
        }

            .view-btn:hover {
                background-color: #FF6B35;
            }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #8e8e8e;
        }

        .empty-icon {
            font-size: 50px;
            margin-bottom: 16px;
            color: #dbdbdb;
        }

        .empty-state h3 {
            font-size: 20px;
            font-weight: 600;
            color: #262626;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
            max-width: 350px;
            margin: 0 auto 20px;
            line-height: 1.5;
        }

        /* Reviews Tab Layout */
        .reviews-container {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-top: 20px;
        }

        .review-row {
            background: #ffffff;
            border: 1px solid #dbdbdb;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
        }

        .review-main {
            flex-grow: 1;
        }

            .review-main h4 {
                font-size: 16px;
                font-weight: 600;
                color: #262626;
                margin-bottom: 6px;
            }

            .review-main p {
                font-size: 14px;
                color: #4b5563;
                line-height: 1.5;
                font-style: italic;
            }

        .review-meta {
            text-align: right;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 6px;
            min-width: 120px;
        }

        .stars-row {
            display: flex;
            gap: 2px;
        }

        .review-date {
            font-size: 12px;
            color: #8e8e8e;
        }

        /* Settings Card & Inner Buttons */
        .settings-card {
            background: white;
            padding: 28px 32px;
            border-radius: 12px;
            margin-bottom: 24px;
            border: 1px solid #dbdbdb;
        }

            .settings-card h3 {
                font-size: 18px;
                font-weight: 600;
                margin-bottom: 16px;
                color: #262626;
                display: flex;
                align-items: center;
                gap: 10px;
                border-bottom: 1px solid #f1f5f9;
                padding-bottom: 12px;
            }

            .settings-card p {
                color: #475569;
                font-size: 14px;
                line-height: 1.5;
                margin-bottom: 20px;
            }

        .settings-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #262626;
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            margin-right: 12px;
            margin-bottom: 8px;
        }

            .settings-btn:hover {
                background: #FF6B35;
            }

        /* Alert Banners */
        .message {
            padding: 14px 18px;
            border-radius: 8px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .warning-message {
            background: #fff7ed;
            color: #9a3412;
            border: 1px solid #fed7aa;
            padding: 12px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .info-message {
            background: #eff6ff;
            color: #1e3a8a;
            border: 1px solid #bfdbfe;
            padding: 12px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 16px;
        }

        /* Modals (Standard Instagram style overlay) */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
        }

        .modal-content {
            background-color: #ffffff;
            margin: 10% auto;
            padding: 30px;
            border-radius: 12px;
            width: 90%;
            max-width: 450px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            position: relative;
            animation: zoomIn 0.3s ease;
        }

        .close-modal {
            position: absolute;
            right: 20px;
            top: 15px;
            font-size: 24px;
            font-weight: bold;
            color: #aaa;
            cursor: pointer;
        }

            .close-modal:hover {
                color: #333;
            }

        .modal h3 {
            margin-bottom: 20px;
            font-size: 20px;
            color: #262626;
            font-weight: 600;
        }

        .modal-form {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

            .form-group label {
                font-size: 13px;
                font-weight: 600;
                color: #4b5563;
            }

            .form-group input {
                padding: 10px 12px;
                border: 1px solid #dbdbdb;
                border-radius: 6px;
                outline: none;
                font-size: 14px;
                color: #262626;
                width: 100%;
            }

                .form-group input:focus {
                    border-color: #a8a8a8;
                }

        .save-btn {
            background-color: #0095f6;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.15s ease;
        }

            .save-btn:hover {
                background-color: #0077c5;
            }

        /* Following Modal Custom Styles */
        .following-list-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 16px;
            transition: background-color 0.1s ease;
        }

            .following-list-item:hover {
                background-color: #fafafa;
            }

        .following-store-info {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            flex-grow: 1;
            min-width: 0;
        }

        .following-store-logo {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #dbdbdb;
            flex-shrink: 0;
        }

        .following-store-names {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .following-store-name {
            font-size: 14px;
            font-weight: 600;
            color: #262626;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .following-store-desc {
            font-size: 12px;
            color: #8e8e8e;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .following-action-btn {
            background-color: transparent;
            border: 1px solid #dbdbdb;
            color: #262626;
            font-weight: 600;
            font-size: 12px;
            padding: 5px 12px;
            border-radius: 4px;
            text-decoration: none;
            cursor: pointer;
            transition: background-color 0.15s, border-color 0.15s;
            flex-shrink: 0;
        }

            .following-action-btn:hover {
                background-color: #fafafa;
                border-color: #a8a8a8;
            }

        /* Delivery Login Box */
        .delivery-login-card {
            display: none;
            margin-top: 18px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 18px;
        }

            .delivery-login-card.open {
                display: block;
            }

        .delivery-login-form {
            display: grid;
            gap: 12px;
            margin-top: 12px;
        }

        .delivery-login-btn {
            border: none;
            background: #0095f6;
            color: white;
            padding: 11px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.15s;
        }

            .delivery-login-btn:hover {
                background-color: #0077c5;
            }

        /* Animations & Media Queries */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes zoomIn {
            from {
                transform: scale(0.95);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        @@media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
                gap: 24px;
                padding-bottom: 24px;
            }

            .profile-stats-row {
                justify-content: center;
            }

            .instagram-grid {
                grid-template-columns: repeat(1, 1fr);
                gap: 16px;
            }

            .profile-tabs {
                gap: 20px;
            }
        }

        footer {
            text-align: center;
            padding: 40px 20px;
            color: #8e8e8e;
            font-size: 12px;
            border-top: 1px solid #dbdbdb;
            margin-top: 40px;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div>realnest</div>

        <div>
            <a href="/Customer1">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a href="/CustomerProducts">
                <i class="fas fa-store"></i> Shop
            </a>
            <a href="/CustomerCart">
                <i class="fas fa-shopping-cart"></i> Cart
            </a>
            <a href="/CustomerOrders">
                <i class="fas fa-truck"></i> Orders
            </a>
            <a href="/CustomerProfile">
                <i class="fas fa-user-circle"></i> Profile
            </a>
        </div>
    </div>

    <div class="profile-container">

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">
                @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="message error-message">
                Please check your information and try again.
            </div>
        }

        <!-- Instagram Profile Header -->
        <div class="profile-header">
            <div class="profile-avatar-container">
                <div class="profile-avatar">
                    <i class="fas fa-user-astronaut"></i>
                </div>
            </div>

            <div class="profile-details">
                <div class="profile-username-row">
                    <h2 class="profile-username">
                        @Model.CustomerFullName
                        @if (Model.IsVerified)
                        {
                            <span title="Verified Customer">
                                <i class="fas fa-check-circle" style="color: #0095f6; font-size: 18px; margin-left: 8px;"></i>
                            </span>
                        }
                    </h2>
                    <button class="edit-profile-btn" onclick="openEditModal()">Edit Profile</button>
                    <button class="edit-profile-btn" onclick="switchTab('settings-tab')" style="border: none; padding: 5px;"><i class="fas fa-cog"></i></button>
                </div>

                <div class="profile-stats-row">
                    <div class="stat-item">
                        <span class="stat-count">@Model.OrdersCount</span> orders
                    </div>
                    <!-- Clicking Following opens the Following List Modal popup, styled like Instagram -->
                    <div class="stat-item stat-item-clickable" onclick="openFollowingModal()" style="cursor: pointer;">
                        <span class="stat-count">@Model.FollowedStoresList.Count</span> following
                    </div>
                    <div class="stat-item">
                        <span class="stat-count">@Model.WishlistCount</span> wishlisted
                    </div>
                </div>

                <div class="profile-bio">
                    <h1>@Model.CustomerFullName</h1>
                    <p class="bio-text"><i class="fas fa-envelope" style="color:#8e8e8e; margin-right:4px;"></i> @Model.CustomerEmail</p>
                    <p class="bio-text"><i class="fas fa-phone" style="color:#8e8e8e; margin-right:4px;"></i> @Model.CustomerPhone</p>

                    <div class="bio-badges">
                        <span class="bio-badge loyalty-badge">
                            <i class="fas fa-star"></i> @Model.LoyaltyPoints Loyalty Pts
                        </span>
                        <span class="bio-badge">
                            <i class="fas fa-venus-mars"></i> @Model.Gender
                        </span>
                        <span class="bio-badge">
                            <i class="fas fa-calendar-alt"></i> Joined @Model.CreatedAt.ToString("MMM yyyy")
                        </span>
                        @if (Model.CODBlocked)
                        {
                            <span class="bio-badge" style="background:#fee2e2; color:#b91c1c;">
                                <i class="fas fa-ban"></i> COD Restricted
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Instagram Tabs Navigation -->
        <div class="profile-tabs">
            <button id="btn-shops-tab" class="tab-btn active" onclick="switchTab('shops-tab')">
                <i class="fas fa-store"></i> Shops
            </button>
            <button id="btn-wishlist-tab" class="tab-btn" onclick="switchTab('wishlist-tab')">
                <i class="far fa-bookmark"></i> Wishlist
            </button>
            <button id="btn-reviews-tab" class="tab-btn" onclick="switchTab('reviews-tab')">
                <i class="far fa-star"></i> Reviews
            </button>
            <button id="btn-settings-tab" class="tab-btn" onclick="switchTab('settings-tab')">
                <i class="fas fa-cog"></i> Management
            </button>
        </div>

        <!-- TAB CONTENT: SHOPS -->
        <div id="shops-tab" class="tab-content active">
            @if (Model.FollowedStoresList.Any())
            {
                <div class="instagram-grid">
                    @foreach (var follow in Model.FollowedStoresList)
                    {
                        var storeName = CustomerProfileModel.GetSafeString(follow.Store, new[] { "StoreName", "Name", "Title" }, "Local Store");
                        var storeDesc = CustomerProfileModel.GetSafeString(follow.Store, new[] { "Description", "Bio", "About" }, "Favorite marketplace shop.");
                        var storeLogo = CustomerProfileModel.GetSafeString(follow.Store, new[] { "LogoUrl", "Logo", "ImageUrl", "LogoPath" }, "https://cdn-icons-png.flaticon.com/512/869/869636.png");
                        var storeId = CustomerProfileModel.GetSafeInt(follow.Store, new[] { "StoreID", "Id" }, 0);

                        <div class="store-grid-item">
                            <img src="@storeLogo" alt="@storeName" onerror="this.src='https://cdn-icons-png.flaticon.com/512/869/869636.png'" />
                            <h4>@storeName</h4>
                            <p>@storeDesc</p>
                            <a href="/StoreCustomerProfile?id=@storeId" class="visit-btn">Visit Store</a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-store-slash"></i></div>
                    <h3>No Followed Shops Yet</h3>
                    <p>When you follow retail stores, they will show up here as quick shortcuts.</p>
                </div>
            }
        </div>

        <!-- TAB CONTENT: WISHLIST -->
        <div id="wishlist-tab" class="tab-content">
            @if (Model.WishlistList.Any())
            {
                <div class="instagram-grid">
                    @foreach (var wish in Model.WishlistList)
                    {
                        var productName = CustomerProfileModel.GetSafeString(wish.Product, new[] { "ProductName", "Name", "Title" }, "Marketplace Product");
                        var productPrice = CustomerProfileModel.GetSafeDecimal(wish.Product, new[] { "Price" }, 0.00m);
                        var productImage = CustomerProfileModel.GetSafeString(wish.Product, new[] { "ProductImageUrl", "ImageUrl", "ImagePath", "Image" }, "https://cdn-icons-png.flaticon.com/512/1170/1170576.png");
                        var productId = CustomerProfileModel.GetSafeInt(wish.Product, new[] { "ProductID", "Id" }, 0);

                        <div class="product-grid-item">
                            <img src="@productImage" alt="@productName" onerror="this.src='https://cdn-icons-png.flaticon.com/512/1170/1170576.png'" />
                            <div class="product-details">
                                <h4>@productName</h4>
                                <span class="price">$@productPrice.ToString("F2")</span>
                                <a href="/ProductDetails?id=@productId" class="view-btn">View Details</a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="far fa-bookmark"></i></div>
                    <h3>Wishlist is Empty</h3>
                    <p>Save items you like to monitor price changes and purchase them easily.</p>
                </div>
            }
        </div>

        <!-- TAB CONTENT: REVIEWS -->
        <div id="reviews-tab" class="tab-content">
            @if (Model.ReviewsList.Any())
            {
                <div class="reviews-container">
                    @foreach (var r in Model.ReviewsList)
                    {
                        var productName = CustomerProfileModel.GetSafeString(r.Product, new[] { "ProductName", "Name" }, "Product");
                        var rating = CustomerProfileModel.GetSafeInt(r, new[] { "Rating", "Stars", "Score" }, 5);
                        var comment = CustomerProfileModel.GetSafeString(r, new[] { "Comment", "Text", "ReviewText", "Description" }, "No feedback left.");

                        <div class="review-row">
                            <div class="review-main">
                                <h4>@productName</h4>
                                <p>"@comment"</p>
                            </div>
                            <div class="review-meta">
                                <div class="stars-row">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= rating)
                                        {
                                            <i class="fas fa-star" style="color: #FFC107;"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star" style="color: #dbdbdb;"></i>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="far fa-star"></i></div>
                    <h3>No Reviews Found</h3>
                    <p>You have not published any reviews for purchased products yet.</p>
                </div>
            }
        </div>

        <!-- TAB CONTENT: ACCOUNT MANAGEMENT & SETTINGS -->
        <div id="settings-tab" class="tab-content">

            <div class="settings-card">
                <h3>
                    <i class="fas fa-sliders-h" style="color:#FF6B35;"></i>
                    Account Settings
                </h3>
                <p>Modify basic information, manage physical addresses, or update login credentials.</p>

                <button class="settings-btn" onclick="openEditModal()">
                    <i class="fas fa-user-edit"></i> Edit Profile
                </button>
                <a class="settings-btn" href="/Identity/Account/Manage/ChangePassword">
                    <i class="fas fa-key"></i> Change Password
                </a>
                <a class="settings-btn" href="/CustomerAddresses">
                    <i class="fas fa-location-dot"></i> My Addresses
                </a>
            </div>

            <div class="settings-card">
                <h3>
                    <i class="fas fa-store" style="color:#FF6B35;"></i>
                    Store Owner Access
                </h3>

                @if (!string.IsNullOrWhiteSpace(Model.StoreAccessMessage))
                {
                    if (Model.HasPendingStoreRequest)
                    {
                        <div class="warning-message">
                            <i class="fas fa-clock"></i>
                            @Model.StoreAccessMessage
                        </div>
                    }
                    else if (Model.HasApprovedStoreOwnerAccount)
                    {
                        <div class="info-message">
                            <i class="fas fa-info-circle"></i>
                            @Model.StoreAccessMessage
                        </div>
                    }
                    else if (Model.HasRejectedStoreRequest)
                    {
                        <div class="error-message"
                             style="padding:10px; border-radius:8px; font-size:14px; margin-bottom:12px;">
                            <i class="fas fa-times-circle"></i>
                            @Model.StoreAccessMessage
                        </div>
                    }
                    else if (Model.HasStoreRequest)
                    {
                        <div class="warning-message">
                            <i class="fas fa-triangle-exclamation"></i>
                            @Model.StoreAccessMessage
                        </div>
                    }
                    else
                    {
                        <p>@Model.StoreAccessMessage</p>
                    }
                }

                @if (Model.HasApprovedStoreOwnerAccount)
                {
                    <button type="button"
                            id="showStoreOwnerLoginButton"
                            class="settings-btn"
                            onclick="toggleStoreOwnerLogin()">
                        <i class="fas fa-sign-in-alt"></i>
                        Login as Store Owner
                    </button>

                    <div id="storeOwnerLoginBox"
                         class="delivery-login-card @(string.IsNullOrWhiteSpace(storeOwnerLoginError) ? "" : "open")">

                        <h4 style="font-weight:600; margin-bottom:6px;">
                            Store Owner Log In
                        </h4>

                        <p style="font-size:13px; color:#64748b; margin-bottom:12px;">
                            This Store Owner account is linked securely to your customer account.
                            Enter the Store Owner password provided by the administrator.
                        </p>

                        @if (!string.IsNullOrWhiteSpace(storeOwnerLoginError))
                        {
                            <div class="error-message"
                                 style="padding:10px; border-radius:8px; font-size:13px; margin-bottom:12px;">
                                @storeOwnerLoginError
                            </div>
                        }

                        <form method="post"
                              asp-page-handler="StoreOwnerLogin"
                              class="delivery-login-form"
                              autocomplete="off">

                            <div class="form-group">
                                <label for="StoreOwnerAccountEmail">
                                    Your Store Owner Email
                                </label>

                                <input id="StoreOwnerAccountEmail"
                                       type="email"
                                       value="@Model.StoreOwnerAccountEmail"
                                       readonly
                                       aria-readonly="true"
                                       tabindex="-1" />
                            </div>

                            <div class="form-group">
                                <label asp-for="StoreOwnerPassword">
                                    Store Owner Password
                                </label>

                                <input asp-for="StoreOwnerPassword"
                                       type="password"
                                       placeholder="Enter Store Owner password"
                                       autocomplete="current-password"
                                       required />
                            </div>

                            <button type="submit"
                                    class="delivery-login-btn">
                                Open Store Owner Dashboard
                            </button>
                        </form>
                    </div>
                }
                else if (Model.HasPendingStoreRequest)
                {
                    <button type="button"
                            class="settings-btn"
                            style="opacity:0.6; cursor:not-allowed;"
                            disabled>
                        <i class="fas fa-clock"></i>
                        Waiting for Admin Approval
                    </button>
                }
                else if (Model.HasRejectedStoreRequest)
                {
                    <a href="/StoreRequest"
                       class="settings-btn">
                        <i class="fas fa-rotate-right"></i>
                        Update and Resubmit Store Request
                    </a>
                }
                else if (!Model.HasStoreRequest)
                {
                    <a href="/StoreRequest"
                       class="settings-btn">
                        <i class="fas fa-chalkboard-user"></i>
                        Request Store Owner Account
                    </a>
                }
                else
                {
                    <button type="button"
                            class="settings-btn"
                            style="opacity:0.6; cursor:not-allowed;"
                            disabled>
                        <i class="fas fa-ban"></i>
                        Store Owner Access Unavailable
                    </button>
                }
            </div>

            <div class="settings-card">
                <h3>
                    <i class="fas fa-motorcycle" style="color:#FF6B35;"></i>
                    Delivery Staff Access
                </h3>

                @if (!string.IsNullOrWhiteSpace(Model.DeliveryAccessMessage))
                {
                    if (Model.HasPendingDeliveryRequest)
                    {
                        <div class="warning-message"><i class="fas fa-clock"></i> @Model.DeliveryAccessMessage</div>
                    }
                    else if (Model.HasApprovedDeliveryAccount)
                    {
                        <div class="info-message"><i class="fas fa-info-circle"></i> @Model.DeliveryAccessMessage</div>
                    }
                    else if (Model.HasRejectedDeliveryRequest)
                    {
                        <div class="error-message" style="padding:10px; border-radius:8px; font-size:14px; margin-bottom:12px;"><i class="fas fa-times-circle"></i> @Model.DeliveryAccessMessage</div>
                    }
                    else
                    {
                        <p>@Model.DeliveryAccessMessage</p>
                    }
                }

                @if (Model.HasApprovedDeliveryAccount)
                {
                    <button type="button" id="showDeliveryLoginButton" class="settings-btn" onclick="toggleDeliveryLogin()">
                        <i class="fas fa-sign-in-alt"></i> Login as Delivery Staff
                    </button>

                    <div id="deliveryLoginBox" class="delivery-login-card @(string.IsNullOrWhiteSpace(deliveryLoginError) ? "" : "open")">
                        <h4 style="font-weight:600; margin-bottom:6px;">Delivery Log In</h4>
                        <p style="font-size:13px; color:#64748b; margin-bottom:12px;">
                            This delivery account is linked securely to your customer account. Enter only the delivery password provided by the administrator.
                        </p>

                        @if (!string.IsNullOrWhiteSpace(deliveryLoginError))
                        {
                            <div class="error-message" style="padding:10px; border-radius:8px; font-size:13px; margin-bottom:12px;">
                                @deliveryLoginError
                            </div>
                        }

                        <form method="post" asp-page-handler="DeliveryLogin" class="delivery-login-form" autocomplete="off">
                            <div class="form-group">
                                <label for="DeliveryAccountEmail">Your Delivery Email</label>
                                <input id="DeliveryAccountEmail"
                                       type="email"
                                       value="@Model.DeliveryAccountEmail"
                                       readonly
                                       aria-readonly="true"
                                       tabindex="-1" />
                            </div>

                            <div class="form-group">
                                <label asp-for="DeliveryPassword">Delivery Password</label>
                                <input asp-for="DeliveryPassword"
                                       type="password"
                                       placeholder="Enter delivery password"
                                       autocomplete="current-password"
                                       required />
                            </div>

                            <button type="submit" class="delivery-login-btn">
                                Open Delivery Dashboard
                            </button>
                        </form>
                    </div>
                }
                else if (Model.HasPendingDeliveryRequest)
                {
                    <button type="button" class="settings-btn" style="opacity:0.6; cursor:not-allowed;" disabled>
                        <i class="fas fa-clock"></i> Waiting for Admin Approval
                    </button>
                }
                else
                {
                    <a href="/DeliveryRequest" class="settings-btn">
                        <i class="fas fa-id-card"></i> Request Delivery Account
                    </a>
                }
            </div>

        </div>

    </div>

    <!-- Edit Profile Modal -->
    <div id="editProfileModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeEditModal()">&times;</span>
            <h3>Edit Profile Details</h3>
            <form method="post" class="modal-form">
                <div class="form-group">
                    <label for="CustomerFullName">Full Name</label>
                    <input type="text" id="CustomerFullName" name="CustomerFullName" value="@Model.CustomerFullName" required />
                </div>
                <div class="form-group">
                    <label for="CustomerPhone">Phone Number</label>
                    <input type="text" id="CustomerPhone" name="CustomerPhone" value="@Model.CustomerPhone" required />
                </div>
                <button type="submit" class="save-btn">Save Changes</button>
            </form>
        </div>
    </div>

    <!-- Following List Modal Popup -->
    <div id="followingModal" class="modal">
        <div class="modal-content" style="max-width: 400px; padding: 0; overflow: hidden; border-radius: 12px;">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid #dbdbdb;">
                <div style="width: 24px;"></div>
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; text-align: center;">Following</h3>
                <span class="close-modal" onclick="closeFollowingModal()" style="font-size: 20px; font-weight: bold; color: #aaa; cursor: pointer; line-height: 1;">&times;</span>
            </div>
            <div style="max-height: 350px; overflow-y: auto; padding: 8px 0;">
                @if (Model.FollowedStoresList.Any())
                {
                    @foreach (var follow in Model.FollowedStoresList)
                    {
                        var storeName = CustomerProfileModel.GetSafeString(follow.Store, new[] { "StoreName", "Name", "Title" }, "Local Store");
                        var storeDesc = CustomerProfileModel.GetSafeString(follow.Store, new[] { "Description", "Bio", "About" }, "Favorite marketplace shop.");
                        var storeLogo = CustomerProfileModel.GetSafeString(follow.Store, new[] { "LogoUrl", "Logo", "ImageUrl", "LogoPath" }, "https://cdn-icons-png.flaticon.com/512/869/869636.png");
                        var storeId = CustomerProfileModel.GetSafeInt(follow.Store, new[] { "StoreID", "Id" }, 0);

                        <div class="following-list-item">
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-store-info">
                                <img src="@storeLogo" alt="@storeName" class="following-store-logo" onerror="this.src='https://cdn-icons-png.flaticon.com/512/869/869636.png'" />
                                <div class="following-store-names">
                                    <span class="following-store-name">@storeName</span>
                                    <span class="following-store-desc">@storeDesc</span>
                                </div>
                            </a>
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-action-btn">Visit</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; padding: 40px 20px; color: #8e8e8e; font-size: 14px;">
                        You are not following any shops yet.
                    </div>
                }
            </div>
        </div>
    </div>

    <footer>
        <span>✨ Realnest — your local marketplace companion ✨</span>
    </footer>

    <script>
        // Modal Handlers (Profile Edit)
        function openEditModal() {
            document.getElementById("editProfileModal").style.display = "block";
        }

        function closeEditModal() {
            document.getElementById("editProfileModal").style.display = "none";
        }

        // Modal Handlers (Following List)
        function openFollowingModal() {
            document.getElementById("followingModal").style.display = "block";
        }

        function closeFollowingModal() {
            document.getElementById("followingModal").style.display = "none";
        }

        // Close modals on external overlay click
        window.onclick = function(event) {
            const editModal = document.getElementById("editProfileModal");
            const followingModal = document.getElementById("followingModal");

            if (event.target === editModal) {
                editModal.style.display = "none";
            }
            if (event.target === followingModal) {
                followingModal.style.display = "none";
            }
        }

        // Instagram-style Tab Switcher
        function switchTab(tabId) {
            // Hide all tabs
            document.querySelectorAll(".tab-content").forEach(tab => {
                tab.classList.remove("active");
            });
            document.querySelectorAll(".tab-btn").forEach(btn => {
                btn.classList.remove("active");
            });

            // Show selected tab
            document.getElementById(tabId).classList.add("active");
            document.getElementById("btn-" + tabId).classList.add("active");
        }

        // Delivery form login expander
        function toggleDeliveryLogin() {
            const loginBox = document.getElementById("deliveryLoginBox");

            if (!loginBox) {
                return;
            }

            loginBox.classList.toggle("open");

            if (loginBox.classList.contains("open")) {
                clearDeliveryPassword();

                window.setTimeout(function () {
                    const passwordInput =
                        document.getElementById("DeliveryPassword");

                    if (passwordInput) {
                        passwordInput.focus();
                    }
                }, 50);
            }
        }

        function clearDeliveryPassword() {
            const passwordInput =
                document.getElementById("DeliveryPassword");

            if (passwordInput) {
                passwordInput.value = "";
            }
        }

        // Store Owner form login expander
        function toggleStoreOwnerLogin() {
            const loginBox =
                document.getElementById("storeOwnerLoginBox");

            if (!loginBox) {
                return;
            }

            loginBox.classList.toggle("open");

            if (loginBox.classList.contains("open")) {
                clearStoreOwnerPassword();

                window.setTimeout(function () {
                    const passwordInput =
                        document.getElementById("StoreOwnerPassword");

                    if (passwordInput) {
                        passwordInput.focus();
                    }
                }, 50);
            }
        }

        function clearStoreOwnerPassword() {
            const passwordInput =
                document.getElementById("StoreOwnerPassword");

            if (passwordInput) {
                passwordInput.value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            clearDeliveryPassword();
            clearStoreOwnerPassword();

            const shouldOpenManagementTab =
        @shouldOpenManagementTab.ToString().ToLowerInvariant();

            if (shouldOpenManagementTab) {
                switchTab("settings-tab");
            }
        });

        window.addEventListener("pageshow", function () {
            clearDeliveryPassword();
            clearStoreOwnerPassword();
        });
    </script>

</body>
</html>