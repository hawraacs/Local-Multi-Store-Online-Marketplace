@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProfileModel

@{
    Layout = null;

    var deliveryLoginError =
        TempData["DeliveryLoginError"]?.ToString();

    var storeOwnerLoginError =
        TempData["StoreOwnerLoginError"]?.ToString();

    var shouldOpenManagementTab =
        !string.IsNullOrWhiteSpace(deliveryLoginError) ||
        !string.IsNullOrWhiteSpace(storeOwnerLoginError);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>My Profile | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            :root {
                --bg-color: #faf9fc;
                --card-bg: #ffffff;
                --border-color: #ece8f6;
                --text-primary: #1e1b2e;
                --text-secondary: #6b6478;
                --accent-color: #6d28d9;
                --accent-hover: #5b21b6;
                --accent-light: #f3effe;
                --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
                --like-color: #ef4444;
                --success-color: #10b981;
                --error-color: #dc2626;
                --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.04);
                --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.08);
                --shadow-lg: 0 20px 40px rgba(109, 40, 217, 0.12);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: var(--font-family);
                background: var(--bg-color);
                color: var(--text-primary);
                min-height: 100vh;
                padding-bottom: 100px;
            }

            .mobile-bottom-nav {
                display: flex !important;
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: 200;
                background: #ffffff;
                border-top: 1px solid #ece8f6;
                justify-content: space-between;
                gap: 2px;
                padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
                overflow-x: auto;
                box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
            }

                .mobile-bottom-nav a {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 2px;
                    font-size: 10.5px;
                    color: #6b6478;
                    text-decoration: none;
                    padding: 4px 6px;
                    flex-shrink: 0;
                    position: relative;
                    border-radius: 12px;
                    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
                }

                    .mobile-bottom-nav a i {
                        font-size: 17px;
                        transition: transform 0.2s ease;
                    }

                    .mobile-bottom-nav a:hover {
                        background: var(--accent-light);
                        color: var(--accent-color);
                    }

                    .mobile-bottom-nav a.active {
                        color: var(--accent-color) !important;
                        background: var(--accent-light) !important;
                        font-weight: 700;
                        transform: translateY(-2px);
                    }

                        .mobile-bottom-nav a.active i {
                            transform: scale(1.12);
                        }

            .unread-nav-badge {
                position: absolute;
                top: 2px;
                right: 18px;
                background: var(--accent-gradient);
                color: #fff;
                font-size: 10px;
                font-weight: 800;
                min-width: 16px;
                height: 16px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                box-shadow: 0 3px 8px rgba(109, 40, 217, 0.3);
            }

            .chat-icon-wrap {
                position: relative;
                display: inline-flex;
            }

                .chat-icon-wrap .chat-nav-dot {
                    position: absolute;
                    top: -2px;
                    right: -4px;
                    width: 9px;
                    height: 9px;
                    background: #ed4956;
                    border: 2px solid #fff;
                    border-radius: 50%;
                    box-sizing: content-box;
                }

            .profile-container {
                max-width: 1180px;
                width: 100%;
                margin: 30px auto;
                padding: 0 20px;
            }

            .profile-header {
                display: flex;
                align-items: center;
                gap: 60px;
                padding-bottom: 44px;
                border-bottom: 1px solid var(--border-color);
                margin-bottom: 28px;
            }

            .profile-avatar-container {
                flex-shrink: 0;
            }

            .profile-avatar {
                width: 150px;
                height: 150px;
                border-radius: 50%;
                background: var(--accent-gradient);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 70px;
                color: #ffffff;
                border: 2px solid #ffffff;
                box-shadow: var(--shadow-md);
            }

            .profile-details {
                flex-grow: 1;
            }

            .profile-username-row {
                display: flex;
                align-items: center;
                gap: 20px;
                flex-wrap: wrap;
                margin-bottom: 20px;
            }

            .profile-username {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 28px;
                font-weight: 800;
                color: var(--text-primary);
                display: flex;
                align-items: center;
            }

            .profile-stats-row {
                display: flex;
                gap: 40px;
                margin-bottom: 20px;
            }

            .stat-item {
                font-size: 16px;
                color: var(--text-primary);
                transition: opacity 0.15s ease;
            }

            .stat-item-clickable:hover {
                color: var(--accent-color);
            }

            .stat-count {
                font-weight: 700;
            }

            .profile-bio {
                font-size: 14px;
                line-height: 1.5;
                color: var(--text-secondary);
            }

            .bio-badges {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin-top: 12px;
            }

            .bio-badge {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                background: var(--accent-light);
                padding: 4px 10px;
                border-radius: 12px;
                font-size: 12px;
                font-weight: 700;
                color: var(--accent-color);
            }

            .loyalty-badge {
                background: #fffbeb;
                color: #d97706;
                border: 1px solid #fef3c7;
            }

            .menu-trigger-btn {
                width: 38px;
                height: 38px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
                background-color: var(--accent-light);
                border: 1px solid var(--border-color);
                border-radius: 50px;
                color: var(--accent-color);
                cursor: pointer;
                flex-shrink: 0;
                transition: all 0.2s ease;
            }

                .menu-trigger-btn:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: #ffffff;
                }

            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(30, 27, 46, 0.5);
                z-index: 9998;
                opacity: 0;
                transition: opacity 0.25s ease;
            }

                .sidebar-overlay.open {
                    display: block;
                    opacity: 1;
                }

            .sidebar {
                position: fixed;
                top: 0;
                right: -300px;
                width: 280px;
                max-width: 82vw;
                height: 100%;
                background: var(--card-bg);
                box-shadow: var(--shadow-lg);
                z-index: 9999;
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                transition: right 0.3s ease;
            }

                .sidebar.open {
                    right: 0;
                }

            .sidebar-panel-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 16px 20px;
                border-bottom: 1px solid var(--border-color);
                flex-shrink: 0;
            }

                .sidebar-panel-header h3 {
                    font-size: 16px;
                    font-weight: 800;
                    color: var(--text-primary);
                }

            .sidebar-divider {
                height: 1px;
                background: var(--border-color);
                margin: 6px 0;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 14px;
                width: 100%;
                padding: 14px 20px;
                font-size: 14.5px;
                font-weight: 600;
                font-family: var(--font-family);
                color: var(--text-primary);
                text-decoration: none;
                background: transparent;
                border: none;
                cursor: pointer;
                text-align: left;
                transition: background-color 0.15s ease, color 0.15s ease;
            }

                .sidebar-link i {
                    width: 18px;
                    text-align: center;
                    color: var(--accent-color);
                    font-size: 16px;
                }

                .sidebar-link:hover {
                    background: var(--accent-light);
                }

                .sidebar-link.active {
                    background: var(--accent-light);
                    color: var(--accent-color);
                    font-weight: 800;
                }

                    .sidebar-link.active i {
                        color: var(--accent-color);
                    }

                .sidebar-link.logout {
                    color: var(--error-color);
                }

                    .sidebar-link.logout i {
                        color: var(--error-color);
                    }

                    .sidebar-link.logout:hover {
                        background: #fef2f2;
                    }

            .logout-form {
                margin: 0;
            }

            .content-area {
                width: 100%;
            }

            .profile-user-bio {
                cursor: pointer;
                border-radius: 10px;
                padding: 6px 0;
                margin-bottom: 4px;
                transition: opacity 0.15s ease;
            }

                .profile-user-bio:hover {
                    opacity: 0.75;
                }

                .profile-user-bio p {
                    font-size: 14px;
                    line-height: 1.5;
                    color: var(--text-primary);
                }

                .profile-user-bio .bio-placeholder {
                    color: var(--text-secondary);
                    font-style: italic;
                }

                    .profile-user-bio .bio-placeholder i {
                        margin-right: 6px;
                        color: var(--accent-color);
                    }

            .tab-content {
                display: none;
                animation: fadeUp 0.4s ease forwards;
            }

                .tab-content.active {
                    display: block;
                }

            .instagram-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
            }

            .product-grid-item {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                box-shadow: var(--shadow-sm);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .product-grid-item:hover {
                    transform: translateY(-4px);
                    box-shadow: var(--shadow-md);
                }

                .product-grid-item img {
                    width: 100%;
                    height: 180px;
                    object-fit: cover;
                    border-bottom: 1px solid var(--border-color);
                }

            .product-details {
                padding: 16px;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

                .product-details h4 {
                    font-size: 15px;
                    font-weight: 700;
                    color: var(--text-primary);
                    margin-bottom: 6px;
                    height: 40px;
                    overflow: hidden;
                }

                .product-details .price {
                    font-size: 16px;
                    font-weight: 800;
                    color: var(--accent-color);
                    margin-bottom: 12px;
                }

            .view-btn {
                background-color: var(--accent-light);
                color: var(--accent-color);
                border: 1px solid var(--border-color);
                text-align: center;
                text-decoration: none;
                border-radius: 50px;
                padding: 8px;
                font-size: 13px;
                font-weight: 700;
                transition: all 0.15s ease;
                margin-top: auto;
            }

                .view-btn:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: #ffffff;
                }

            .empty-state {
                text-align: center;
                padding: 60px 20px;
                color: var(--text-secondary);
            }

            .empty-icon {
                font-size: 50px;
                margin-bottom: 16px;
                color: var(--border-color);
            }

            .empty-state h3 {
                font-size: 20px;
                font-weight: 800;
                color: var(--text-primary);
                margin-bottom: 8px;
            }

            .empty-state p {
                font-size: 14px;
                max-width: 350px;
                margin: 0 auto 20px;
                line-height: 1.5;
            }

            .activity-section {
                margin-bottom: 32px;
            }

                .activity-section:last-child {
                    margin-bottom: 0;
                }

            .activity-section-title {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 17px;
                font-weight: 800;
                color: var(--text-primary);
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 14px;
                padding-bottom: 10px;
                border-bottom: 1px solid var(--border-color);
            }

                .activity-section-title i {
                    color: var(--accent-color);
                    font-size: 15px;
                }

            .reviews-container {
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

            .review-row {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                padding: 20px;
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                gap: 16px;
                box-shadow: var(--shadow-sm);
            }

            .review-main {
                flex-grow: 1;
            }

                .review-main h4 {
                    font-size: 16px;
                    font-weight: 700;
                    color: var(--text-primary);
                    margin-bottom: 6px;
                }

                .review-main p {
                    font-size: 14px;
                    color: var(--text-secondary);
                    line-height: 1.5;
                    font-style: italic;
                }

            .review-meta {
                text-align: right;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 6px;
                min-width: 120px;
            }

            .stars-row {
                display: flex;
                gap: 2px;
            }

            .settings-card {
                background: var(--card-bg);
                padding: 28px 32px;
                border-radius: 20px;
                margin-bottom: 24px;
                border: 1px solid var(--border-color);
                box-shadow: var(--shadow-sm);
            }

                .settings-card h3 {
                    font-size: 18px;
                    font-weight: 800;
                    margin-bottom: 16px;
                    color: var(--text-primary);
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    border-bottom: 1px solid var(--border-color);
                    padding-bottom: 12px;
                }

                .settings-card p {
                    color: var(--text-secondary);
                    font-size: 14px;
                    line-height: 1.5;
                    margin-bottom: 20px;
                }

            .settings-btn {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                background: var(--accent-gradient);
                color: white;
                padding: 10px 20px;
                text-decoration: none;
                border-radius: 50px;
                font-weight: 700;
                font-size: 13px;
                transition: all 0.2s ease;
                border: none;
                cursor: pointer;
                margin-right: 12px;
                margin-bottom: 8px;
                box-shadow: 0 4px 10px rgba(109, 40, 217, 0.15);
            }

                .settings-btn:hover {
                    opacity: 0.95;
                }

            .message {
                padding: 14px 18px;
                border-radius: 8px;
                font-weight: 700;
                margin-bottom: 20px;
            }

            .success-message {
                background: #ecfdf5;
                color: var(--success-color);
                border: 1px solid #d1fae5;
            }

            .error-message {
                background: #fef2f2;
                color: var(--error-color);
                border: 1px solid #fee2e2;
            }

            .warning-message {
                background: #fff5f5;
                color: var(--error-color);
                border: 1px solid #ffd1cc;
                padding: 12px;
                border-radius: 8px;
                font-size: 14px;
                margin-bottom: 16px;
            }

            .info-message {
                background: var(--accent-light);
                color: var(--accent-color);
                border: 1px solid var(--border-color);
                padding: 12px;
                border-radius: 8px;
                font-size: 14px;
                margin-bottom: 16px;
            }

            .modal {
                display: none;
                position: fixed;
                z-index: 20000;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(30, 27, 46, 0.6);
                backdrop-filter: blur(5px);
            }

            .modal-content {
                background-color: var(--card-bg);
                margin: 10% auto;
                padding: 30px;
                border-radius: 20px;
                width: 90%;
                max-width: 450px;
                box-shadow: var(--shadow-lg);
                border: 1px solid var(--border-color);
                position: relative;
                animation: zoomIn 0.3s ease;
            }

            .close-modal {
                position: absolute;
                right: 20px;
                top: 15px;
                font-size: 24px;
                font-weight: bold;
                color: var(--text-secondary);
                cursor: pointer;
            }

                .close-modal:hover {
                    color: var(--text-primary);
                }

            .modal h3 {
                margin-bottom: 20px;
                font-size: 20px;
                color: var(--text-primary);
                font-weight: 800;
            }

            .modal-form {
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

                .form-group label {
                    font-size: 13px;
                    font-weight: 700;
                    color: var(--text-secondary);
                }

                .form-group input,
                .form-group select,
                .form-group textarea {
                    padding: 10px 12px;
                    border: 1px solid var(--border-color);
                    border-radius: 8px;
                    outline: none;
                    font-size: 14px;
                    color: var(--text-primary);
                    width: 100%;
                    background: var(--bg-color);
                    font-family: var(--font-family);
                    transition: all 0.2s ease;
                }

                .form-group textarea {
                    resize: vertical;
                    min-height: 90px;
                }

                    .form-group input:focus,
                    .form-group select:focus,
                    .form-group textarea:focus {
                        border-color: var(--accent-color);
                        background: #ffffff;
                    }

            .save-btn {
                background: var(--accent-gradient);
                color: white;
                border: none;
                padding: 12px;
                border-radius: 50px;
                font-weight: 700;
                cursor: pointer;
                transition: opacity 0.15s ease;
                box-shadow: 0 4px 12px rgba(109, 40, 217, 0.25);
            }

                .save-btn:hover {
                    opacity: 0.95;
                }

            .following-list-item {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 8px 16px;
                transition: background-color 0.1s ease;
            }

                .following-list-item:hover {
                    background-color: var(--bg-color);
                }

            .following-store-info {
                display: flex;
                align-items: center;
                gap: 12px;
                cursor: pointer;
                text-decoration: none;
                color: inherit;
                flex-grow: 1;
                min-width: 0;
            }

            .following-store-logo {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                object-fit: cover;
                border: 1px solid var(--border-color);
                flex-shrink: 0;
            }

            .following-store-names {
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .following-store-name {
                font-size: 14px;
                font-weight: 700;
                color: var(--text-primary);
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .following-store-desc {
                font-size: 12px;
                color: var(--text-secondary);
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .following-action-btn {
                background-color: var(--accent-light);
                border: 1px solid var(--border-color);
                color: var(--accent-color);
                font-weight: 700;
                font-size: 12px;
                padding: 5px 16px;
                border-radius: 50px;
                text-decoration: none;
                cursor: pointer;
                transition: all 0.15s;
                flex-shrink: 0;
            }

                .following-action-btn:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: #ffffff;
                }

            .delivery-login-card {
                display: none;
                margin-top: 18px;
                background: var(--bg-color);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                padding: 18px;
            }

                .delivery-login-card.open {
                    display: block;
                }

            .delivery-login-form {
                display: grid;
                gap: 12px;
                margin-top: 12px;
            }

            .delivery-login-btn {
                border: none;
                background: var(--accent-gradient);
                color: white;
                padding: 11px;
                border-radius: 50px;
                font-weight: 700;
                cursor: pointer;
                transition: opacity 0.15s;
                box-shadow: 0 4px 10px rgba(109, 40, 217, 0.25);
            }

                .delivery-login-btn:hover {
                    opacity: 0.95;
                }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(12px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes zoomIn {
                from {
                    transform: scale(0.95);
                    opacity: 0;
                }

                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            @@media (max-width: 768px) {
                .profile-header {
                    flex-direction: column;
                    text-align: center;
                    gap: 24px;
                    padding-bottom: 24px;
                }

                .profile-stats-row {
                    justify-content: center;
                }

                .instagram-grid {
                    grid-template-columns: repeat(1, 1fr);
                    gap: 16px;
                }
            }

            footer {
                text-align: center;
                padding: 40px 20px;
                color: var(--text-secondary);
                font-size: 12px;
                border-top: 1px solid var(--border-color);
                margin-top: 40px;
            }
    </style>
</head>

<body>

    <partial name="_CustomerBottomNav" />

    <div class="profile-container" style="position: relative;">

        <div style="position: absolute; top: 0; right: 20px; z-index: 10;">
            <partial name="_MessageBell" />
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">
                @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="message error-message">
                Please check your information and try again.
            </div>
        }

        <div class="profile-header">
            <div class="profile-avatar-container">
                <div class="profile-avatar">
                    <i class="fas fa-user-astronaut"></i>
                </div>
            </div>

            <div class="profile-details">
                <div class="profile-username-row">
                    <h2 class="profile-username">
                        @Model.CustomerFullName
                        @if (Model.IsVerified)
                        {
                            <span title="Verified Customer">
                                <i class="fas fa-check-circle" style="color: #6d28d9; font-size: 18px; margin-left: 8px;"></i>
                            </span>
                        }
                    </h2>
                    <button class="menu-trigger-btn" onclick="openSidebar()" title="Menu">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>

                <div class="profile-user-bio" onclick="openEditBioModal()" title="Click to edit your bio">
                    @if (!string.IsNullOrWhiteSpace(Model.CustomerBio))
                    {
                        <p>@Model.CustomerBio</p>
                    }
                    else
                    {
                        <p class="bio-placeholder"><i class="fas fa-pen"></i>Add a bio</p>
                    }
                </div>

                <div class="profile-stats-row">
                    <div class="stat-item">
                        <span class="stat-count">@Model.OrdersCount</span> orders
                    </div>
                    <div class="stat-item stat-item-clickable" onclick="openFollowingModal()" style="cursor: pointer;">
                        <span class="stat-count">@Model.FollowedStoresList.Count</span> following
                    </div>
                    <div class="stat-item">
                        <span class="stat-count">@Model.WishlistCount</span> wishlisted
                    </div>
                </div>

                <div class="profile-bio">
                    <p class="bio-text"><i class="fas fa-envelope" style="color:#6b6478; margin-right:4px;"></i> @Model.CustomerEmail</p>
                    <p class="bio-text"><i class="fas fa-phone" style="color:#6b6478; margin-right:4px;"></i> @Model.CustomerPhone</p>

                    <div class="bio-badges">
                        <span class="bio-badge loyalty-badge">
                            <i class="fas fa-star"></i> @Model.LoyaltyPoints Loyalty Pts
                        </span>
                        <span class="bio-badge">
                            <i class="fas fa-venus-mars"></i> @Model.Gender
                        </span>
                        <span class="bio-badge">
                            <i class="fas fa-calendar-alt"></i> Joined @Model.CreatedAt.ToString("MMM yyyy")
                        </span>
                        @if (Model.CODBlocked)
                        {
                            <span class="bio-badge" style="background:#fee2e2; color:#b91c1c;">
                                <i class="fas fa-ban"></i> COD Restricted
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>

        <aside id="sidebar" class="sidebar">
            <div class="sidebar-panel-header">
                <h3>Menu</h3>
                <span class="close-modal" onclick="closeSidebar()" style="position: static; font-size: 20px; color: #aaa; cursor: pointer;">&times;</span>
            </div>

            <button id="link-wishlist-tab" class="sidebar-link active" data-tab="wishlist-tab" onclick="selectTab('wishlist-tab')">
                <i class="far fa-bookmark"></i> Wishlist
            </button>
            <button id="link-activity-tab" class="sidebar-link" data-tab="activity-tab" onclick="selectTab('activity-tab')">
                <i class="fas fa-clock-rotate-left"></i> Your Activity
            </button>
            <button id="link-settings-tab" class="sidebar-link" data-tab="settings-tab" onclick="selectTab('settings-tab')">
                <i class="fas fa-cog"></i> Management
            </button>

            <div class="sidebar-divider"></div>

            <button type="button" class="sidebar-link" onclick="closeSidebar(); openEditModal();">
                <i class="fas fa-user-pen"></i> Edit Profile
            </button>
            <button type="button" class="sidebar-link" onclick="closeSidebar(); openEditBioModal();">
                <i class="fas fa-pen"></i> Edit Bio
            </button>
            <a href="/HelpCenter" class="sidebar-link">
                <i class="fas fa-circle-question"></i> Help Center
            </a>
            <a href="/CustomerComplaint" class="sidebar-link">
                <i class="fas fa-flag"></i> File a Complaint
            </a>

            <div class="sidebar-divider"></div>

            <form method="post" asp-page="/Identity/Account/Logout" asp-route-returnUrl="/" class="logout-form">
                <button type="submit" class="sidebar-link logout">
                    <i class="fas fa-right-from-bracket"></i> Logout
                </button>
            </form>
        </aside>

        <div class="page-layout">
            <main class="content-area">

                <div id="wishlist-tab" class="tab-content active">
                    @if (Model.WishlistList.Any())
                    {
                        <div class="instagram-grid">
                            @foreach (var wish in Model.WishlistList)
                            {
                                var productName = CustomerProfileModel.GetSafeString(wish.Product, new[] { "ProductName", "Name", "Title" }, "Marketplace Product");
                                var productPrice = CustomerProfileModel.GetSafeDecimal(wish.Product, new[] { "Price" }, 0.00m);
                                var productImage = CustomerProfileModel.GetSafeString(wish.Product, new[] { "ProductImageUrl", "ImageUrl", "ImagePath", "Image" }, "https://cdn-icons-png.flaticon.com/512/1170/1170576.png");
                                var productId = CustomerProfileModel.GetSafeInt(wish.Product, new[] { "ProductID", "Id" }, 0);

                                <div class="product-grid-item">
                                    <img src="@productImage" alt="@productName" onerror="this.src='https://cdn-icons-png.flaticon.com/512/1170/1170576.png'" />
                                    <div class="product-details">
                                        <h4>@productName</h4>
                                        <span class="price">$@productPrice.ToString("F2")</span>
                                        <a href="/ProductDetails?id=@productId" class="view-btn">View Details</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon"><i class="far fa-bookmark"></i></div>
                            <h3>Wishlist is Empty</h3>
                            <p>Save items you like to monitor price changes and purchase them easily.</p>
                        </div>
                    }
                </div>

                <div id="activity-tab" class="tab-content">

                    <div class="activity-section">
                        <h3 class="activity-section-title"><i class="far fa-star"></i> Your Reviews</h3>

                        @if (Model.ReviewsList.Any())
                        {
                            <div class="reviews-container">
                                @foreach (var r in Model.ReviewsList)
                                {
                                    var productName = CustomerProfileModel.GetSafeString(r.Product, new[] { "ProductName", "Name" }, "Product");
                                    var rating = CustomerProfileModel.GetSafeInt(r, new[] { "Rating", "Stars", "Score" }, 5);
                                    var comment = CustomerProfileModel.GetSafeString(r, new[] { "Comment", "Text", "ReviewText", "Description" }, "No feedback left.");

                                    <div class="review-row">
                                        <div class="review-main">
                                            <h4>@productName</h4>
                                            <p>"@comment"</p>
                                        </div>
                                        <div class="review-meta">
                                            <div class="stars-row">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= rating)
                                                    {
                                                        <i class="fas fa-star" style="color: #FFC107;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="far fa-star" style="color: #dbdbdb;"></i>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state" style="padding: 40px 20px;">
                                <div class="empty-icon" style="font-size: 40px;"><i class="far fa-star"></i></div>
                                <h3 style="font-size: 17px;">No Reviews Found</h3>
                                <p style="font-size: 13px;">You have not published any reviews for purchased products yet.</p>
                            </div>
                        }
                    </div>

                    <div class="activity-section">
                        <h3 class="activity-section-title"><i class="fas fa-ban"></i> Blocked Shops</h3>

                        <div class="empty-state" style="padding: 40px 20px;">
                            <div class="empty-icon" style="font-size: 40px;"><i class="fas fa-store-slash"></i></div>
                            <h3 style="font-size: 17px;">No Blocked Shops</h3>
                            <p style="font-size: 13px;">Shops you block will stop appearing in your feed, search, and recommendations.</p>
                        </div>
                    </div>

                    <div class="activity-section">
                        <h3 class="activity-section-title"><i class="fas fa-globe"></i> Language Preference</h3>

                        <div class="settings-card" style="box-shadow: none; padding: 22px; margin-bottom: 0;">
                            <div class="form-group" style="max-width: 280px; margin-bottom: 16px;">
                                <label for="languageSelect">App Language</label>
                                <select id="languageSelect">
                                    <option value="en">English</option>
                                    <option value="ar">العربية (Arabic)</option>
                                    <option value="fr">Français</option>
                                </select>
                            </div>
                            <button type="button" class="settings-btn" onclick="saveLanguagePreference()">
                                <i class="fas fa-check"></i> Save Language
                            </button>
                        </div>
                    </div>

                </div>

                <div id="settings-tab" class="tab-content">

                    <div class="settings-card">
                        <h3>
                            <i class="fas fa-sliders-h" style="color: var(--accent-color);"></i>
                            Account Settings
                        </h3>
                        <p>Manage your physical addresses or update your login credentials. Use "Edit Profile" in the sidebar to change your name or phone number.</p>

                        <a class="settings-btn" href="/Identity/Account/Manage/ChangePassword">
                            <i class="fas fa-key"></i> Change Password
                        </a>
                        <a class="settings-btn" href="/CustomerAddresses">
                            <i class="fas fa-location-dot"></i> My Addresses
                        </a>
                        <a class="settings-btn" href="/CustomerComplaint">
                            <i class="fas fa-flag"></i> File a Complaint
                        </a>
                    </div>

                    <div class="settings-card">
                        <h3>
                            <i class="fas fa-store" style="color: var(--accent-color);"></i>
                            Store Owner Access
                        </h3>

                        @if (!string.IsNullOrWhiteSpace(Model.StoreAccessMessage))
                        {
                            if (Model.HasPendingStoreRequest)
                            {
                                <div class="warning-message">
                                    <i class="fas fa-clock"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasApprovedStoreOwnerAccount)
                            {
                                <div class="info-message">
                                    <i class="fas fa-info-circle"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasRejectedStoreRequest)
                            {
                                <div class="error-message"
                                     style="padding:10px; border-radius:8px; font-size:14px; margin-bottom:12px;">
                                    <i class="fas fa-times-circle"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else if (Model.HasStoreRequest)
                            {
                                <div class="warning-message">
                                    <i class="fas fa-triangle-exclamation"></i>
                                    @Model.StoreAccessMessage
                                </div>
                            }
                            else
                            {
                                <p>@Model.StoreAccessMessage</p>
                            }
                        }

                        @if (Model.HasApprovedStoreOwnerAccount)
                        {
                            <button type="button"
                                    id="showStoreOwnerLoginButton"
                                    class="settings-btn"
                                    onclick="toggleStoreOwnerLogin()">
                                <i class="fas fa-sign-in-alt"></i>
                                Login as Store Owner
                            </button>

                            <div id="storeOwnerLoginBox"
                                 class="delivery-login-card @(string.IsNullOrWhiteSpace(storeOwnerLoginError) ? "" : "open")">

                                <h4 style="font-weight:600; margin-bottom:6px;">
                                    Store Owner Log In
                                </h4>

                                <p style="font-size:13px; color:#64748b; margin-bottom:12px;">
                                    This Store Owner account is linked securely to your customer account.
                                    Enter the Store Owner password provided by the administrator.
                                </p>

                                @if (!string.IsNullOrWhiteSpace(storeOwnerLoginError))
                                {
                                    <div class="error-message"
                                         style="padding:10px; border-radius:8px; font-size:13px; margin-bottom:12px;">
                                        @storeOwnerLoginError
                                    </div>
                                }

                                <form method="post"
                                      asp-page-handler="StoreOwnerLogin"
                                      class="delivery-login-form"
                                      autocomplete="off">

                                    <div class="form-group">
                                        <label for="StoreOwnerAccountEmail">
                                            Your Store Owner Email
                                        </label>

                                        <input id="StoreOwnerAccountEmail"
                                               type="email"
                                               value="@Model.StoreOwnerAccountEmail"
                                               readonly
                                               aria-readonly="true"
                                               tabindex="-1" />
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="StoreOwnerPassword">
                                            Store Owner Password
                                        </label>

                                        <input asp-for="StoreOwnerPassword"
                                               type="password"
                                               placeholder="Enter Store Owner password"
                                               autocomplete="current-password"
                                               required />
                                    </div>

                                    <button type="submit"
                                            class="delivery-login-btn">
                                        Open Store Owner Dashboard
                                    </button>
                                </form>
                            </div>
                        }
                        else if (Model.HasPendingStoreRequest)
                        {
                            <button type="button"
                                    class="settings-btn"
                                    style="opacity:0.6; cursor:not-allowed;"
                                    disabled>
                                <i class="fas fa-clock"></i>
                                Waiting for Admin Approval
                            </button>
                        }
                        else if (Model.HasRejectedStoreRequest)
                        {
                            <a href="/StoreRequest"
                               class="settings-btn">
                                <i class="fas fa-rotate-right"></i>
                                Update and Resubmit Store Request
                            </a>
                        }
                        else if (!Model.HasStoreRequest)
                        {
                            <a href="/StoreRequest"
                               class="settings-btn">
                                <i class="fas fa-chalkboard-user"></i>
                                Request Store Owner Account
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    class="settings-btn"
                                    style="opacity:0.6; cursor:not-allowed;"
                                    disabled>
                                <i class="fas fa-ban"></i>
                                Store Owner Access Unavailable
                            </button>
                        }
                    </div>

                    <div class="settings-card">
                        <h3>
                            <i class="fas fa-motorcycle" style="color: var(--accent-color);"></i>
                            Delivery Staff Access
                        </h3>

                        @if (!string.IsNullOrWhiteSpace(Model.DeliveryAccessMessage))
                        {
                            if (Model.HasPendingDeliveryRequest)
                            {
                                <div class="warning-message"><i class="fas fa-clock"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else if (Model.HasApprovedDeliveryAccount)
                            {
                                <div class="info-message"><i class="fas fa-info-circle"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else if (Model.HasRejectedDeliveryRequest)
                            {
                                <div class="error-message" style="padding:10px; border-radius:8px; font-size:14px; margin-bottom:12px;"><i class="fas fa-times-circle"></i> @Model.DeliveryAccessMessage</div>
                            }
                            else
                            {
                                <p>@Model.DeliveryAccessMessage</p>
                            }
                        }

                        @if (Model.HasApprovedDeliveryAccount)
                        {
                            <button type="button" id="showDeliveryLoginButton" class="settings-btn" onclick="toggleDeliveryLogin()">
                                <i class="fas fa-sign-in-alt"></i> Login as Delivery Staff
                            </button>

                            <div id="deliveryLoginBox" class="delivery-login-card @(string.IsNullOrWhiteSpace(deliveryLoginError) ? "" : "open")">
                                <h4 style="font-weight:600; margin-bottom:6px;">Delivery Log In</h4>
                                <p style="font-size:13px; color:#64748b; margin-bottom:12px;">
                                    This delivery account is linked securely to your customer account. Enter only the delivery password provided by the administrator.
                                </p>

                                @if (!string.IsNullOrWhiteSpace(deliveryLoginError))
                                {
                                    <div class="error-message" style="padding:10px; border-radius:8px; font-size:13px; margin-bottom:12px;">
                                        @deliveryLoginError
                                    </div>
                                }

                                <form method="post" asp-page-handler="DeliveryLogin" class="delivery-login-form" autocomplete="off">
                                    <div class="form-group">
                                        <label for="DeliveryAccountEmail">Your Delivery Email</label>
                                        <input id="DeliveryAccountEmail"
                                               type="email"
                                               value="@Model.DeliveryAccountEmail"
                                               readonly
                                               aria-readonly="true"
                                               tabindex="-1" />
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="DeliveryPassword">Delivery Password</label>
                                        <input asp-for="DeliveryPassword"
                                               type="password"
                                               placeholder="Enter delivery password"
                                               autocomplete="current-password"
                                               required />
                                    </div>

                                    <button type="submit" class="delivery-login-btn">
                                        Open Delivery Dashboard
                                    </button>
                                </form>
                            </div>
                        }
                        else if (Model.HasPendingDeliveryRequest)
                        {
                            <button type="button" class="settings-btn" style="opacity:0.6; cursor:not-allowed;" disabled>
                                <i class="fas fa-clock"></i> Waiting for Admin Approval
                            </button>
                        }
                        else
                        {
                            <a href="/DeliveryRequest" class="settings-btn">
                                <i class="fas fa-id-card"></i> Request Delivery Account
                            </a>
                        }
                    </div>

                </div>

            </main>
        </div>

    </div>

    <div id="editProfileModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeEditModal()">&times;</span>
            <h3>Edit Profile Details</h3>
            <form method="post" class="modal-form">
                <div class="form-group">
                    <label for="CustomerFullName">Full Name</label>
                    <input type="text" id="CustomerFullName" name="CustomerFullName" value="@Model.CustomerFullName" required />
                </div>
                <div class="form-group">
                    <label for="CustomerPhone">Phone Number</label>
                    <input type="text" id="CustomerPhone" name="CustomerPhone" value="@Model.CustomerPhone" required />
                </div>
                <button type="submit" class="save-btn">Save Changes</button>
            </form>
        </div>
    </div>

    <div id="editBioModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeEditBioModal()">&times;</span>
            <h3>Edit Your Bio</h3>
            <form method="post" class="modal-form" asp-page-handler="EditBio">
                <div class="form-group">
                    <label for="CustomerBio">Bio</label>
                    <textarea id="CustomerBio" name="CustomerBio" placeholder="Tell other shoppers a little about yourself...">@Model.CustomerBio</textarea>
                </div>
                <button type="submit" class="save-btn">Save Bio</button>
            </form>
        </div>
    </div>

    <div id="followingModal" class="modal">
        <div class="modal-content" style="max-width: 400px; padding: 0; overflow: hidden; border-radius: 12px;">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--border-color);">
                <div style="width: 24px;"></div>
                <h3 style="margin: 0; font-size: 16px; font-weight: 800; text-align: center;">Following</h3>
                <span class="close-modal" onclick="closeFollowingModal()" style="font-size: 20px; font-weight: bold; color: #aaa; cursor: pointer; line-height: 1;">&times;</span>
            </div>
            <div style="max-height: 350px; overflow-y: auto; padding: 8px 0;">
                @if (Model.FollowedStoresList.Any())
                {
                    @foreach (var follow in Model.FollowedStoresList)
                    {
                        var storeName = CustomerProfileModel.GetSafeString(follow.Store, new[] { "StoreName", "Name", "Title" }, "Local Store");
                        var storeDesc = CustomerProfileModel.GetSafeString(follow.Store, new[] { "Description", "Bio", "About" }, "Favorite marketplace shop.");
                        var storeLogo = CustomerProfileModel.GetSafeString(follow.Store, new[] { "LogoUrl", "Logo", "ImageUrl", "LogoPath" }, "https://cdn-icons-png.flaticon.com/512/869/869636.png");
                        var storeId = CustomerProfileModel.GetSafeInt(follow.Store, new[] { "StoreID", "Id" }, 0);

                        <div class="following-list-item">
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-store-info">
                                <img src="@storeLogo" alt="@storeName" class="following-store-logo" onerror="this.src='https://cdn-icons-png.flaticon.com/512/869/869636.png'" />
                                <div class="following-store-names">
                                    <span class="following-store-name">@storeName</span>
                                    <span class="following-store-desc">@storeDesc</span>
                                </div>
                            </a>
                            <a href="/StoreCustomerProfile?id=@storeId" class="following-action-btn">Visit</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary); font-size: 14px;">
                        You are not following any shops yet.
                    </div>
                }
            </div>
        </div>
    </div>

    <footer>
        <span>✨ Realnest — your local marketplace companion ✨</span>
    </footer>

    <script>
            function openEditModal() {
                document.getElementById("editProfileModal").style.display = "block";
            }

            function closeEditModal() {
                document.getElementById("editProfileModal").style.display = "none";
            }

            function openEditBioModal() {
                document.getElementById("editBioModal").style.display = "block";
            }

            function closeEditBioModal() {
                document.getElementById("editBioModal").style.display = "none";
            }

            function openFollowingModal() {
                document.getElementById("followingModal").style.display = "block";
            }

            function closeFollowingModal() {
                document.getElementById("followingModal").style.display = "none";
            }

            function saveLanguagePreference() {
                const select = document.getElementById("languageSelect");
                const label = select.options[select.selectedIndex].text;
                alert("Language set to " + label + " (placeholder — connect this to your backend to persist it).");
            }

            window.onclick = function(event) {
                const modalsToCheck = [
                    "editProfileModal",
                    "editBioModal",
                    "followingModal"
                ];

                modalsToCheck.forEach(function (id) {
                    const modal = document.getElementById(id);
                    if (event.target === modal) {
                        modal.style.display = "none";
                    }
                });
            }

            function openSidebar() {
                document.getElementById("sidebar").classList.add("open");
                document.getElementById("sidebarOverlay").classList.add("open");
                document.body.style.overflow = "hidden";
            }

            function closeSidebar() {
                document.getElementById("sidebar").classList.remove("open");
                document.getElementById("sidebarOverlay").classList.remove("open");
                document.body.style.overflow = "";
            }

            function switchTab(tabId) {
                document.querySelectorAll(".tab-content").forEach(tab => {
                    tab.classList.remove("active");
                });
                document.querySelectorAll(".sidebar-link[data-tab]").forEach(link => {
                    link.classList.remove("active");
                });

                document.getElementById(tabId).classList.add("active");

                const activeLink = document.getElementById("link-" + tabId);
                if (activeLink) {
                    activeLink.classList.add("active");
                }
            }

            function selectTab(tabId) {
                switchTab(tabId);
                closeSidebar();
            }

            function toggleDeliveryLogin() {
                const loginBox = document.getElementById("deliveryLoginBox");

                if (!loginBox) {
                    return;
                }

                loginBox.classList.toggle("open");

                if (loginBox.classList.contains("open")) {
                    clearDeliveryPassword();

                    window.setTimeout(function () {
                        const passwordInput =
                            document.getElementById("DeliveryPassword");

                        if (passwordInput) {
                            passwordInput.focus();
                        }
                    }, 50);
                }
            }

            function clearDeliveryPassword() {
                const passwordInput =
                    document.getElementById("DeliveryPassword");

                if (passwordInput) {
                    passwordInput.value = "";
                }
            }

            function toggleStoreOwnerLogin() {
                const loginBox =
                    document.getElementById("storeOwnerLoginBox");

                if (!loginBox) {
                    return;
                }

                loginBox.classList.toggle("open");

                if (loginBox.classList.contains("open")) {
                    clearStoreOwnerPassword();

                    window.setTimeout(function () {
                        const passwordInput =
                            document.getElementById("StoreOwnerPassword");

                        if (passwordInput) {
                            passwordInput.focus();
                        }
                    }, 50);
                }
            }

            function clearStoreOwnerPassword() {
                const passwordInput =
                    document.getElementById("StoreOwnerPassword");

                if (passwordInput) {
                    passwordInput.value = "";
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                clearDeliveryPassword();
                clearStoreOwnerPassword();

                const shouldOpenManagementTab =
            @shouldOpenManagementTab.ToString().ToLowerInvariant();

                if (shouldOpenManagementTab) {
                    switchTab("settings-tab");
                }
            });

            window.addEventListener("pageshow", function () {
                clearDeliveryPassword();
                clearStoreOwnerPassword();
            });
    </script>

</body>
</html>