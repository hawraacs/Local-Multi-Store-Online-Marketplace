@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminStoresModel
@{
    ViewData["Title"] = "Store Management";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ============================================================
                           ADMIN THEME — matches Admin Dashboard (light / indigo+sky)
                           ============================================================ */
        :root {
            /* ── Backgrounds ── */
            --bg-color: #F8FAFC;
            --bg-soft: #F1F5F9;
            --card-bg: #FFFFFF;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --surface-hover: #F1F5F9;
            /* ── Text ── */
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            --text: #0F172A;
            /* ── Borders ── */
            --border-color: #E2E8F0;
            --border: #E2E8F0;
            /* ── Accent (Indigo + Sky) ── */
            --accent-color: #6366F1;
            --accent-hover: #4F46E5;
            --accent-light: #EEF2FF;
            --accent-gradient: linear-gradient(135deg, #6366F1 0%, #0EA5E9 100%);
            --brand: #6366F1;
            --brand-dark: #4338CA;
            --brand-light: #A5B4FC;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --brand-soft-hover: rgba(99, 102, 241, 0.15);
            /* ── Semantic States ── */
            --success: #16A34A;
            --success-bg: #DCFCE7;
            --success-txt: #15803D;
            --warning: #D97706;
            --warning-bg: #FEF3C7;
            --warning-txt: #B45309;
            --danger: #DC2626;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --info: #6366F1;
            --info-bg: #EEF2FF;
            --info-txt: #4338CA;
            /* ── Shadows ── */
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 3px rgba(15, 23, 42, 0.06);
            --shadow-md: 0 4px 12px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 12px 32px rgba(15, 23, 42, 0.10);
            --shadow-hover: 0 16px 40px rgba(15, 23, 42, 0.14);
            /* ── Radius / Font / Transition ── */
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 1.5rem;
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            --navy: #0F172A;
            --navy-light: #1E293B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-color);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .page-wrap {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 1.5rem 3rem;
        }

        /* ── Header ── */
        .page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.75rem;
        }

            .page-header h1 {
                font-size: 1.9rem;
                font-weight: 900;
                letter-spacing: -0.03em;
                background: var(--accent-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin-bottom: 0.25rem;
            }

            .page-header p {
                color: var(--text-secondary);
                font-size: 0.9rem;
            }

        .header-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #FFFFFF;
            color: var(--text-primary);
            border-radius: 999px;
            padding: 8px 18px 8px 14px;
            font-size: 12.5px;
            font-weight: 600;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            white-space: nowrap;
        }

            .header-badge .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--brand);
                flex-shrink: 0;
                animation: pulse-dot 2s ease-in-out infinite;
            }

        @@keyframes pulse-dot {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.4;
                transform: scale(0.85);
            }
        }

        /* ── Alerts ── */
        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-sm);
            margin-bottom: 1.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            border-left: 4px solid transparent;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background-color: var(--success-bg);
            border-left-color: var(--success);
            color: var(--success-txt);
        }

            .alert-success::before {
                content: "✓";
                font-weight: bold;
                background: var(--success);
                color: white;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                flex-shrink: 0;
            }

        .alert-danger {
            background-color: var(--danger-bg);
            border-left-color: var(--danger);
            color: var(--danger-txt);
        }

            .alert-danger::before {
                content: "!";
                font-weight: bold;
                background: var(--danger);
                color: white;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                flex-shrink: 0;
            }

        /* ── Summary stat chips ── */
        .stats-strip {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
            margin-bottom: 1.75rem;
        }

        @@media (max-width: 900px) {
            .stats-strip {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 560px) {
            .stats-strip {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .mini-stat {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 16px 14px;
            box-shadow: var(--shadow-sm);
            transition: transform var(--transition), box-shadow var(--transition);
            cursor: pointer;
        }

            .mini-stat:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md);
            }

            .mini-stat .mini-icon {
                width: 32px;
                height: 32px;
                border-radius: 9px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                margin-bottom: 10px;
            }

            .mini-stat.total .mini-icon {
                background: var(--brand-soft);
                color: var(--brand);
            }

            .mini-stat.pending .mini-icon {
                background: var(--warning-bg);
                color: var(--warning-txt);
            }

            .mini-stat.active .mini-icon {
                background: var(--success-bg);
                color: var(--success-txt);
            }

            .mini-stat.suspended .mini-icon {
                background: var(--danger-bg);
                color: var(--danger-txt);
            }

            .mini-stat.expired .mini-icon {
                background: #F1F5F9;
                color: var(--text-muted);
            }

            .mini-stat .mini-value {
                font-size: 24px;
                font-weight: 900;
                letter-spacing: -0.02em;
                color: var(--text-primary);
                margin-bottom: 2px;
            }

            .mini-stat .mini-label {
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: var(--text-muted);
            }

        /* ── Main Card ── */
        .stores-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 1.75rem 1.75rem 1.25rem;
            box-shadow: var(--shadow-sm);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .stores-card:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

        /* ── Tabs ── */
        .tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            background: var(--surface-2);
            padding: 5px;
            border-radius: 999px;
            border: 1px solid var(--border);
            margin-bottom: 1.5rem;
            width: fit-content;
            max-width: 100%;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 8px 18px;
            font-weight: 700;
            font-size: 0.83rem;
            cursor: pointer;
            color: var(--text-secondary);
            border-radius: 999px;
            transition: all var(--transition);
            font-family: var(--font);
            letter-spacing: 0.01em;
            white-space: nowrap;
        }

            .tab-btn:hover {
                color: var(--brand);
            }

            .tab-btn.active {
                color: #fff;
                background: var(--accent-gradient);
                box-shadow: 0 4px 12px rgba(99, 102, 241, 0.30);
            }

            .tab-btn:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 2px;
            }

        /* ── Table ── */
        .table-responsive {
            overflow-x: auto;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--surface);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        thead th {
            text-align: left;
            padding: 0.9rem 1rem;
            background: var(--surface-2);
            font-weight: 700;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            border-bottom: 1.5px solid var(--border);
            white-space: nowrap;
        }

            thead th:first-child {
                border-radius: var(--radius-sm) 0 0 0;
            }

            thead th:last-child {
                border-radius: 0 var(--radius-sm) 0 0;
            }

        tbody td {
            padding: 0.9rem 1rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            color: var(--text-secondary);
            transition: background var(--transition);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover td {
            background: var(--surface-hover);
        }

        /* ── Store / owner identity cells ── */
        .store-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .store-avatar {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: var(--brand-soft);
            color: var(--brand);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            flex-shrink: 0;
        }

        .store-cell strong {
            display: block;
            color: var(--text-primary);
            font-weight: 700;
            font-size: 0.88rem;
        }

        .store-city {
            font-size: 11px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .owner-cell strong {
            color: var(--text-primary);
            font-weight: 600;
            display: block;
            font-size: 0.85rem;
        }

        .owner-email {
            font-size: 11.5px;
            color: var(--text-muted);
        }

        /* ── Status Badges ── */
        .status-badge {
            padding: 0.3rem 0.85rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }

            .status-badge::before {
                content: "";
                width: 5px;
                height: 5px;
                border-radius: 50%;
                flex-shrink: 0;
            }

        .status-pending {
            background: var(--warning-bg);
            color: var(--warning-txt);
        }

            .status-pending::before {
                background: var(--warning);
            }

        .status-approved {
            background: var(--success-bg);
            color: var(--success-txt);
        }

            .status-approved::before {
                background: var(--success);
            }

        .status-inactive {
            background: var(--bg-soft);
            color: var(--text-muted);
        }

            .status-inactive::before {
                background: var(--text-muted);
            }

        .status-expired {
            background: var(--danger-bg);
            color: var(--danger-txt);
        }

            .status-expired::before {
                background: var(--danger);
            }

        .status-suspended {
            background: #FEF2F2;
            color: #991B1B;
        }

            .status-suspended::before {
                background: #DC2626;
            }

        /* ── Expiry cell ── */
        .expiry-cell {
            font-size: 0.82rem;
            white-space: nowrap;
        }

        .expiry-date {
            font-weight: 600;
            color: var(--text-primary);
        }

        .expiry-sub {
            color: var(--text-muted);
            font-size: 0.72rem;
            display: block;
            margin-top: 2px;
        }

            .expiry-sub.expired-txt {
                color: var(--danger);
                font-weight: 700;
            }

        .expiry-never {
            color: var(--text-muted);
            font-style: italic;
        }

        /* ── Actions Cell ── */
        .actions-cell {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            align-items: center;
            min-width: 240px;
        }

        .btn-approve, .btn-reject, .btn-deactivate, .btn-activate {
            border: none;
            padding: 0.4rem 0.85rem;
            border-radius: 999px;
            cursor: pointer;
            font-size: 0.72rem;
            font-weight: 700;
            transition: all var(--transition);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            letter-spacing: 0.01em;
            font-family: var(--font);
        }

        .btn-approve {
            background: var(--success-bg);
            color: var(--success-txt);
        }

            .btn-approve:hover {
                background: var(--success);
                color: #fff;
                transform: translateY(-1px);
                box-shadow: var(--shadow-sm);
            }

        .btn-reject {
            background: var(--danger-bg);
            color: var(--danger-txt);
        }

            .btn-reject:hover {
                background: var(--danger);
                color: #fff;
                transform: translateY(-1px);
            }

        .btn-deactivate {
            background: var(--warning-bg);
            color: var(--warning-txt);
        }

            .btn-deactivate:hover {
                background: var(--warning);
                color: #fff;
                transform: translateY(-1px);
            }

        .btn-activate {
            background: var(--brand-soft);
            color: var(--brand-dark);
        }

            .btn-activate:hover {
                background: var(--brand);
                color: #fff;
                transform: translateY(-1px);
                box-shadow: var(--shadow-sm);
            }

        button:focus-visible {
            outline: 2px solid var(--brand);
            outline-offset: 2px;
        }

        /* ── Empty state ── */
        .empty-row td {
            padding: 3.5rem 1rem !important;
        }

        .empty-state-inline {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
        }

            .empty-state-inline i {
                font-size: 30px;
                color: var(--border);
            }

            .empty-state-inline strong {
                font-size: 0.95rem;
                color: var(--text-secondary);
                font-weight: 700;
            }

            .empty-state-inline span {
                font-size: 0.82rem;
            }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .page-wrap {
                padding: 0 1rem 2rem;
                margin: 1rem auto;
            }

            .stores-card {
                padding: 1.1rem;
            }

            .tab-btn {
                padding: 6px 14px;
                font-size: 0.78rem;
            }

            thead th, tbody td {
                padding: 0.65rem 0.65rem;
            }

            .actions-cell {
                gap: 0.3rem;
                min-width: 0;
            }

            .btn-approve, .btn-reject, .btn-deactivate, .btn-activate {
                padding: 0.3rem 0.6rem;
                font-size: 0.65rem;
            }
        }

        @@media (max-width: 480px) {
            .tabs {
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                max-width: 100%;
            }

            .tab-btn {
                flex: 0 0 auto;
            }
        }
    </style>
}

@{
    var totalStores = Model.Stores?.Count ?? 0;
    var activeCount = Model.Stores?.Count(s => (s.Status ?? "").Equals("Approved", StringComparison.OrdinalIgnoreCase)) ?? 0;
    var suspendedCount = Model.Stores?.Count(s => (s.Status ?? "").Equals("Suspended", StringComparison.OrdinalIgnoreCase)) ?? 0;
    var expiredCount = Model.Stores?.Count(s => (s.SubscriptionStatus ?? "").Equals("Expired", StringComparison.OrdinalIgnoreCase)) ?? 0;
}

<div class="page-wrap">

    <div class="page-header">
        <div>
            <h1><i class="fas fa-store" style="-webkit-text-fill-color: var(--brand); margin-right:8px;"></i>Store Management</h1>
            <p>Manage store approvals, subscriptions, and account status</p>
        </div>
        <div class="header-badge">
            <span class="dot"></span>
            @totalStores total stores
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- ── Quick summary chips (click to filter, same as tabs) ── -->
    <div class="stats-strip">
        <div class="mini-stat total" onclick="document.querySelector('.tab-btn[data-tab=all]').click()">
            <div class="mini-icon"><i class="fas fa-store"></i></div>
            <div class="mini-value">@totalStores</div>
            <div class="mini-label">All Stores</div>
        </div>
        <div class="mini-stat pending" onclick="document.querySelector('.tab-btn[data-tab=pending]').click()">
            <div class="mini-icon"><i class="fas fa-hourglass-half"></i></div>
            <div class="mini-value">@Model.PendingCount</div>
            <div class="mini-label">Pending</div>
        </div>
        <div class="mini-stat active" onclick="document.querySelector('.tab-btn[data-tab=active]').click()">
            <div class="mini-icon"><i class="fas fa-check-circle"></i></div>
            <div class="mini-value">@activeCount</div>
            <div class="mini-label">Active</div>
        </div>
        <div class="mini-stat suspended" onclick="document.querySelector('.tab-btn[data-tab=suspended]').click()">
            <div class="mini-icon"><i class="fas fa-ban"></i></div>
            <div class="mini-value">@suspendedCount</div>
            <div class="mini-label">Suspended</div>
        </div>
        <div class="mini-stat expired" onclick="document.querySelector('.tab-btn[data-tab=expired]').click()">
            <div class="mini-icon"><i class="fas fa-calendar-times"></i></div>
            <div class="mini-value">@expiredCount</div>
            <div class="mini-label">Expired</div>
        </div>
    </div>

    <div class="stores-card">

        <div class="tabs">
            <button class="tab-btn active" data-tab="all">All Stores</button>
            <button class="tab-btn" data-tab="pending">Pending (@Model.PendingCount)</button>
            <button class="tab-btn" data-tab="active">Active</button>
            <button class="tab-btn" data-tab="inactive">Inactive</button>
            <button class="tab-btn" data-tab="suspended">Suspended</button>
            <button class="tab-btn" data-tab="expired">Expired</button>
        </div>

        <div class="table-responsive">
            <table id="storesTable">
                <thead>
                    <tr>
                        <th>Store</th>
                        <th>Owner</th>
                        <th>Status</th>
                        <th>Subscription</th>
                        <th>Expiry</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Stores != null && Model.Stores.Any())
                    {
                        foreach (var store in Model.Stores)
                        {
                            if (store == null) continue;

                            var status = store.Status ?? "Pending";
                            var statusKey = status.ToLower();

                            var subStatus = store.SubscriptionStatus ?? "Active";
                            var subStatusKey = subStatus.ToLower();

                            int daysLeft = 0;
                            bool hasExpiry = store.SubscriptionExpiryDate.HasValue;
                            if (hasExpiry)
                            {
                                daysLeft = (store.SubscriptionExpiryDate.Value.Date - DateTime.UtcNow.Date).Days;
                            }

                            var storeInitial = string.IsNullOrWhiteSpace(store.StoreName) ? "S" : store.StoreName.Substring(0, 1).ToUpper();

                            <tr data-status="@statusKey" data-substatus="@subStatusKey">
                                <td>
                                    <div class="store-cell">
                                        <span class="store-avatar">@storeInitial</span>
                                        <div>
                                            <strong>@store.StoreName</strong>
                                            <span class="store-city"><i class="fas fa-location-dot"></i> @store.City</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="owner-cell">
                                    <strong>@store.Owner?.FullName</strong>
                                    <span class="owner-email">@store.OwnerEmail</span>
                                </td>
                                <td>
                                    <span class="status-badge
                                        @(statusKey == "approved" ? "status-approved" :
                                              statusKey == "pending" ? "status-pending" :
                                              "status-inactive")">
                                        @status
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge
                                        @(subStatusKey == "active" ? "status-approved" :
                                              subStatusKey == "expired" ? "status-expired" :
                                              "status-inactive")">
                                        @subStatus
                                    </span>
                                </td>
                                <td class="expiry-cell">
                                    @if (hasExpiry)
                                    {
                                        if (daysLeft < 0)
                                        {
                                            <span class="expiry-date">@store.SubscriptionExpiryDate.Value.ToString("dd MMM yyyy")</span>
                                            <span class="expiry-sub expired-txt">Expired</span>
                                        }
                                        else
                                        {
                                            <span class="expiry-date">@store.SubscriptionExpiryDate.Value.ToString("dd MMM yyyy")</span>
                                            <span class="expiry-sub">@daysLeft days left</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="expiry-never">Never</span>
                                    }
                                </td>
                                <td class="actions-cell">
                                    @if (statusKey == "pending")
                                    {
                                        <form method="post" asp-page-handler="Approve" style="display:inline;">
                                            <input type="hidden" name="id" value="@store.StoreID" />
                                            <button class="btn-approve" title="Approve store"><i class="fas fa-check"></i> Approve</button>
                                        </form>
                                        <form method="post" asp-page-handler="Reject" style="display:inline;">
                                            <input type="hidden" name="id" value="@store.StoreID" />
                                            <button class="btn-reject" title="Reject store"><i class="fas fa-xmark"></i> Reject</button>
                                        </form>
                                    }
                                    else if (statusKey == "approved")
                                    {
                                        <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                            <input type="hidden" name="id" value="@store.StoreID" />
                                            <button class="btn-deactivate" title="Deactivate store"><i class="fas fa-ban"></i> Deactivate</button>
                                        </form>
                                    }
                                    else if (statusKey == "inactive")
                                    {
                                        <form method="post" asp-page-handler="Activate" style="display:inline;">
                                            <input type="hidden" name="id" value="@store.StoreID" />
                                            <button class="btn-activate" title="Activate store"><i class="fas fa-play"></i> Activate</button>
                                        </form>
                                    }

                                    <form method="post" asp-page-handler="Extend" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-activate" title="Extend subscription by 30 days"><i class="fas fa-calendar-plus"></i> +30d</button>
                                    </form>
                                    <form method="post" asp-page-handler="Suspend" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-deactivate" title="Suspend subscription"><i class="fas fa-pause"></i> Suspend</button>
                                    </form>
                                    <form method="post" asp-page-handler="ActivateSubscription" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-approve" title="Activate subscription"><i class="fas fa-rotate"></i> Activate Sub</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="empty-row">
                            <td colspan="6">
                                <div class="empty-state-inline">
                                    <i class="fas fa-inbox"></i>
                                    <strong>No stores found</strong>
                                    <span>Stores will appear here once they register.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const tabs = document.querySelectorAll('.tab-btn');
    const rows = document.querySelectorAll('#storesTable tbody tr');

    function filterTable(tabId) {
        rows.forEach(row => {
            // Skip the empty state row (colspan)
            if (row.classList.contains('empty-row')) {
                return;
            }
            const status = row.dataset.status;      // from store.Status (lowercase)
            const subStatus = row.dataset.substatus; // store.SubscriptionStatus (lowercase)
            let shouldShow = false;

            switch(tabId) {
                case 'all': shouldShow = true; break;
                case 'pending': shouldShow = (status === 'pending'); break;
                case 'active': shouldShow = (status === 'approved'); break;
                case 'inactive': shouldShow = (status !== 'pending' && status !== 'approved'); break;
                case 'suspended': shouldShow = (status === 'suspended'); break;
                case 'expired': shouldShow = (subStatus === 'expired'); break;
                default: shouldShow = true;
            }
            row.style.display = shouldShow ? '' : 'none';
        });
    }

    // Handle tab clicks
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterTable(btn.dataset.tab);
        });
    });

    // ── Auto‑select tab from URL parameter ──
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
        const targetTab = document.querySelector(`.tab-btn[data-tab="${tabParam}"]`);
        if (targetTab) {
            targetTab.click();
        }
    }
</script>