@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminStoresModel
@{
    ViewData["Title"] = "Store Management";
}

@section Styles {
    <style>
        .stores-card {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-top: 20px;
        }

        .tabs {
            display: flex;
            gap: 8px;
            border-bottom: 1px solid #e2e8f0;
            margin-bottom: 24px;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 10px 20px;
            font-weight: 600;
            cursor: pointer;
            color: #64748b;
        }

            .tab-btn.active {
                color: #FF6B35;
                border-bottom: 2px solid #FF6B35;
            }

        .status-badge {
            padding: 4px 10px;
            border-radius: 40px;
            font-size: 12px;
        }

        .status-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .status-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .status-inactive {
            background: #e2e8f0;
            color: #334155;
        }

        .btn-approve, .btn-reject, .btn-deactivate, .btn-activate {
            border: none;
            padding: 6px 12px;
            border-radius: 8px;
            cursor: pointer;
            margin-right: 5px;
        }

        .btn-approve {
            background: #10b981;
            color: white;
        }

        .btn-reject {
            background: #ef4444;
            color: white;
        }

        .btn-deactivate {
            background: #f59e0b;
            color: white;
        }

        .btn-activate {
            background: #2563eb;
            color: white;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }
    </style>
}

<div class="stores-card">
    <h3>Store Management</h3>

    <div class="tabs">
        <button class="tab-btn active" data-tab="all">All Stores</button>
        <button class="tab-btn" data-tab="pending">Pending (@Model.PendingCount)</button>
        <button class="tab-btn" data-tab="active">Active</button>
        <button class="tab-btn" data-tab="inactive">Inactive</button>
    </div>

    <div class="table-responsive">
        <table id="storesTable">
            <thead>
                <tr>
                    <th>Store Name</th>
                    <th>Owner</th>
                    <th>Email</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Stores != null && Model.Stores.Any())
                {
                    foreach (var store in Model.Stores)
                    {
                        if (store == null) continue;

                        string storeName = store.StoreName ?? "N/A";
                        string ownerName = store.Owner?.FullName ?? "Unknown";
                        string email = store.Email ?? "";
                        string city = store.City ?? "";
                        string status = store.Status ?? "Pending";
                        string statusKey = status.ToLower();

                        <tr data-status="@statusKey">
                            <td>@storeName</td>
                            <td>@ownerName</td>
                            <td>@email</td>
                            <td>@city</td>
                            <td>
                                <span class="status-badge
                                    @(statusKey == "approved" ? "status-approved" :
                                        (statusKey == "pending" ? "status-pending" : "status-inactive"))">
                                    @status
                                </span>
                            </td>
                            <td>
                                @if (statusKey == "pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button type="submit" class="btn-approve"><i class="fas fa-check"></i> Approve</button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button type="submit" class="btn-reject"><i class="fas fa-times"></i> Reject</button>
                                    </form>
                                }
                                else if (statusKey == "approved")
                                {
                                    <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button type="submit" class="btn-deactivate">Deactivate</button>
                                    </form>
                                }
                                else if (statusKey == "inactive")
                                {
                                    <form method="post" asp-page-handler="Activate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button type="submit" class="btn-activate">Activate</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding:40px;">No stores found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    const tabs = document.querySelectorAll('.tab-btn'); 
    const storeRows = document.querySelectorAll('#storesTable tbody tr');
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const tab = btn.dataset.tab;
            storeRows.forEach(row => {
                const status = row.dataset.status;
                if (tab === 'all') row.style.display = '';
                else if (tab === 'pending' && status === 'pending') row.style.display = '';
                else if (tab === 'active' && status === 'approved') row.style.display = '';
                else if (tab === 'inactive' && status === 'inactive') row.style.display = '';
                else row.style.display = 'none';
            });
        });
    });
</script>