@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminStoresModel
@{
    ViewData["Title"] = "Store Management";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ============================================================
                   ADMIN THEME — matches Admin Dashboard (light / indigo+sky)
                   ============================================================ */
        :root {
            /* ── Backgrounds ── */
            --bg-color: #F8FAFC;
            --bg-soft: #F1F5F9;
            --card-bg: #FFFFFF;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --surface-hover: #F1F5F9;
            /* ── Text ── */
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            --text: #0F172A;
            /* ── Borders ── */
            --border-color: #E2E8F0;
            --border: #E2E8F0;
            /* ── Accent (Indigo + Sky) ── */
            --accent-color: #6366F1;
            --accent-hover: #4F46E5;
            --accent-light: #EEF2FF;
            --accent-gradient: linear-gradient(135deg, #6366F1 0%, #0EA5E9 100%);
            --brand: #6366F1;
            --brand-dark: #4338CA;
            --brand-light: #A5B4FC;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --brand-soft-hover: rgba(99, 102, 241, 0.15);
            /* ── Semantic States ── */
            --success: #16A34A;
            --success-bg: #DCFCE7;
            --success-txt: #15803D;
            --warning: #D97706;
            --warning-bg: #FEF3C7;
            --warning-txt: #B45309;
            --danger: #DC2626;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --info: #6366F1;
            --info-bg: #EEF2FF;
            --info-txt: #4338CA;
            /* ── Shadows ── */
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 3px rgba(15, 23, 42, 0.06);
            --shadow-md: 0 4px 12px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 12px 32px rgba(15, 23, 42, 0.10);
            --shadow-hover: 0 16px 40px rgba(15, 23, 42, 0.14);
            /* ── Radius / Font / Transition ── */
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 1.5rem;
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            --navy: #0F172A;
            --navy-light: #1E293B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-color);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Alerts ── */
        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-sm);
            margin-bottom: 1.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            border-left: 4px solid transparent;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background-color: var(--success-bg);
            border-left-color: var(--success);
            color: var(--success-txt);
        }

            .alert-success::before {
                content: "✓";
                font-weight: bold;
                background: var(--success);
                color: white;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                flex-shrink: 0;
            }

        .alert-danger {
            background-color: var(--danger-bg);
            border-left-color: var(--danger);
            color: var(--danger-txt);
        }

            .alert-danger::before {
                content: "!";
                font-weight: bold;
                background: var(--danger);
                color: white;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                flex-shrink: 0;
            }

        /* ── Main Card ── */
        .stores-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 2rem 2rem 1.5rem;
            margin: 2rem auto;
            max-width: 1400px;
            box-shadow: var(--shadow-sm);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .stores-card:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

            .stores-card h3 {
                font-size: 1.75rem;
                font-weight: 800;
                letter-spacing: -0.03em;
                background: var(--accent-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin-bottom: 0.25rem;
                display: inline-block;
            }

            .stores-card > p {
                color: var(--text-secondary);
                margin-top: 0.25rem;
                font-size: 0.9rem;
            }

        /* ── Tabs ── */
        .tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 0.25rem;
            border-bottom: 2px solid var(--border);
            margin: 1.5rem 0 1.75rem 0;
            padding-bottom: 0;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 0.65rem 1.25rem;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            color: var(--text-secondary);
            border-radius: var(--radius-sm) var(--radius-sm) 0 0;
            transition: all var(--transition);
            position: relative;
            font-family: var(--font);
            letter-spacing: 0.01em;
        }

            .tab-btn:hover {
                color: var(--brand);
                background: var(--brand-soft);
            }

            .tab-btn.active {
                color: var(--brand);
                background: transparent;
            }

                .tab-btn.active::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 3px;
                    background: var(--accent-gradient);
                    border-radius: 3px 3px 0 0;
                }

            .tab-btn:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 2px;
            }

        /* ── Table ── */
        .table-responsive {
            overflow-x: auto;
            border-radius: var(--radius);
            margin-top: 0.5rem;
            border: 1px solid var(--border);
            background: var(--surface);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        thead th {
            text-align: left;
            padding: 0.9rem 1rem;
            background: var(--surface-2);
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            border-bottom: 1.5px solid var(--border);
            white-space: nowrap;
        }

        tbody td {
            padding: 0.9rem 1rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            color: var(--text-secondary);
            transition: background var(--transition);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover td {
            background: var(--surface-hover);
        }

        /* ── Status Badges ── */
        .status-badge {
            padding: 0.25rem 0.8rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            white-space: nowrap;
            letter-spacing: 0.01em;
            border: 1px solid transparent;
        }

        .status-pending {
            background: var(--warning-bg);
            color: var(--warning-txt);
            border-color: #FCD34D;
        }

        .status-approved {
            background: var(--success-bg);
            color: var(--success-txt);
            border-color: #86EFAC;
        }

        .status-inactive {
            background: var(--bg-soft);
            color: var(--text-muted);
            border-color: var(--border);
        }

        .status-expired {
            background: var(--danger-bg);
            color: var(--danger-txt);
            border-color: #FCA5A5;
        }

        .status-suspended {
            background: #FEF2F2;
            color: #991B1B;
            border-color: #FCA5A5;
        }

        .status-pending::before {
            content: "⏳";
            font-size: 0.7rem;
        }

        .status-approved::before {
            content: "✓";
            font-weight: bold;
        }

        .status-inactive::before {
            content: "⛔";
            font-size: 0.7rem;
        }

        .status-expired::before {
            content: "⌛";
            font-size: 0.7rem;
        }

        .status-suspended::before {
            content: "🚫";
            font-size: 0.7rem;
        }

        /* ── Actions Cell ── */
        .actions-cell {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            align-items: center;
        }

        .btn-approve,
        .btn-reject,
        .btn-deactivate,
        .btn-activate {
            border: none;
            padding: 0.35rem 0.85rem;
            border-radius: 999px;
            cursor: pointer;
            font-size: 0.72rem;
            font-weight: 600;
            transition: all var(--transition);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            letter-spacing: 0.01em;
            box-shadow: var(--shadow-sm);
            font-family: var(--font);
        }

        .btn-approve {
            background: var(--success);
            color: white;
        }

            .btn-approve:hover {
                background: #0E9F6E;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .btn-reject {
            background: var(--danger);
            color: white;
        }

            .btn-reject:hover {
                background: #B91C1C;
                transform: translateY(-1px);
            }

        .btn-deactivate {
            background: var(--warning);
            color: white;
        }

            .btn-deactivate:hover {
                background: #B45309;
                transform: translateY(-1px);
            }

        .btn-activate {
            background: var(--brand);
            color: white;
        }

            .btn-activate:hover {
                background: var(--brand-dark);
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        /* ── Subscription expiry column ── */
        td:nth-child(7) {
            font-size: 0.8rem;
            white-space: nowrap;
        }

            td:nth-child(7) small {
                color: var(--text-muted);
                font-size: 0.7rem;
                display: block;
                margin-top: 0.15rem;
            }

        /* ── Empty state ── */
        tbody tr td[colspan] {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
            font-style: italic;
            font-size: 0.95rem;
        }

            tbody tr td[colspan]::before {
                content: "📭 ";
                font-style: normal;
            }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .stores-card {
                padding: 1.25rem;
                margin: 1rem;
            }

            .tab-btn {
                padding: 0.45rem 0.9rem;
                font-size: 0.8rem;
            }

            thead th,
            tbody td {
                padding: 0.65rem 0.65rem;
            }

            .actions-cell {
                gap: 0.3rem;
            }

            .btn-approve,
            .btn-reject,
            .btn-deactivate,
            .btn-activate {
                padding: 0.25rem 0.6rem;
                font-size: 0.65rem;
            }

            td:nth-child(7) {
                font-size: 0.7rem;
            }

                td:nth-child(7) small {
                    font-size: 0.6rem;
                }
        }

        @@media (max-width: 480px) {
            .tabs {
                gap: 0;
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

            .tab-btn {
                flex: 0 0 auto;
                padding: 0.4rem 0.75rem;
                font-size: 0.75rem;
            }
        }

        button:focus-visible {
            outline: 2px solid var(--brand);
            outline-offset: 2px;
        }
    </style>
}
<div class="stores-card">
    <h3>🏪 Store Management</h3>
    <p style="color: var(--gray-600); margin-top: 0.25rem; font-size: 0.9rem;">Manage store approvals, subscriptions, and account status</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="tabs">
        <button class="tab-btn active" data-tab="all">📋 All Stores</button>
        <button class="tab-btn" data-tab="pending">⏳ Pending (@Model.PendingCount)</button>
        <button class="tab-btn" data-tab="active">✅ Active</button>
        <button class="tab-btn" data-tab="inactive">❌ Inactive</button>
        <button class="tab-btn" data-tab="suspended">🚫 Suspended</button>
        <button class="tab-btn" data-tab="expired">⌛ Expired</button>
    </div>
    <div class="table-responsive">
        <table id="storesTable">
            <thead>
                <tr>
                    <th>Store Name</th>
                    <th>Owner</th>
                    <th>Email</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Subscription</th>
                    <th>Expiry Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Stores != null && Model.Stores.Any())
                {
                    foreach (var store in Model.Stores)
                    {
                        if (store == null) continue;

                        var status = store.Status ?? "Pending";
                        var statusKey = status.ToLower();

                        var subStatus = store.SubscriptionStatus ?? "Active";
                        var subStatusKey = subStatus.ToLower();

                        int daysLeft = 0;
                        bool hasExpiry = store.SubscriptionExpiryDate.HasValue;
                        if (hasExpiry)
                        {
                            daysLeft = (store.SubscriptionExpiryDate.Value.Date - DateTime.UtcNow.Date).Days;
                        }

                        <tr data-status="@statusKey" data-substatus="@subStatusKey">
                            <td>@store.StoreName</td>
                            <td>@store.Owner?.FullName</td>
                            <td>@store.OwnerEmail</td>
                            <td>@store.City</td>
                            <td>
                                <span class="status-badge
                                    @(statusKey == "approved" ? "status-approved" :
                                        statusKey == "pending" ? "status-pending" :
                                        "status-inactive")">
                                    @status
                                </span>
                            </td>
                            <td>
                                <span class="status-badge
                                    @(subStatusKey == "active" ? "status-approved" :
                                        subStatusKey == "expired" ? "status-expired" :
                                        "status-inactive")">
                                    @subStatus
                                </span>
                            </td>
                            <td>
                                @if (hasExpiry)
                                {
                                    if (daysLeft < 0)
                                    {
                                        <span style="color: #dc2626; font-weight: 500;">Expired</span>
                                        <br />
                                        <small>@store.SubscriptionExpiryDate.Value.ToString("yyyy-MM-dd")</small>
                                    }
                                    else
                                    {
                                        <span>@store.SubscriptionExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                                        <br />
                                        <small>@daysLeft days left</small>
                                    }
                                }
                                else
                                {
                                    <span style="color: var(--gray-600);">Never</span>
                                }
                            </td>
                            <td class="actions-cell">
                                @if (statusKey == "pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-approve" title="Approve store">✓ Approve</button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-reject" title="Reject store">✗ Reject</button>
                                    </form>
                                }
                                else if (statusKey == "approved")
                                {
                                    <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-deactivate" title="Deactivate store">⛔ Deactivate</button>
                                    </form>
                                }
                                else if (statusKey == "inactive")
                                {
                                    <form method="post" asp-page-handler="Activate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-activate" title="Activate store">▶ Activate</button>
                                    </form>
                                }

                                <form method="post" asp-page-handler="Extend" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-activate" title="Extend subscription by 30 days">📅 Extend (+30d)</button>
                                </form>
                                <form method="post" asp-page-handler="Suspend" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-deactivate" title="Suspend subscription">⏸ Suspend</button>
                                </form>
                                <form method="post" asp-page-handler="ActivateSubscription" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-approve" title="Activate subscription">🔄 Activate Sub</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align: center; padding: 3rem;">📭 No stores found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    const tabs = document.querySelectorAll('.tab-btn');
    const rows = document.querySelectorAll('#storesTable tbody tr');

    function filterTable(tabId) {
        rows.forEach(row => {
            // Skip the empty state row (colspan)
            if (row.cells.length === 1 && row.cells[0].colSpan) {
                row.style.display = '';
                return;
            }
            const status = row.dataset.status;      // from store.Status (lowercase)
            const subStatus = row.dataset.substatus; // store.SubscriptionStatus (lowercase)
            let shouldShow = false;

            switch(tabId) {
                case 'all': shouldShow = true; break;
                case 'pending': shouldShow = (status === 'pending'); break;
                case 'active': shouldShow = (status === 'approved'); break;
                case 'inactive': shouldShow = (status !== 'pending' && status !== 'approved'); break;
                case 'suspended': shouldShow = (status === 'suspended'); break;
                case 'expired': shouldShow = (subStatus === 'expired'); break;
                default: shouldShow = true;
            }
            row.style.display = shouldShow ? '' : 'none';
        });
    }

    // Handle tab clicks
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterTable(btn.dataset.tab);
        });
    });

    // ── Auto‑select tab from URL parameter ──
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
        const targetTab = document.querySelector(`.tab-btn[data-tab="${tabParam}"]`);
        if (targetTab) {
            targetTab.click();
        }
    }
</script>