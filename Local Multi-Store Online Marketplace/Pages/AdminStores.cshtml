@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminStoresModel
@{
    ViewData["Title"] = "Store Management";
}

@section Styles {
    <style>
        /* Modern CSS Reset & Variables */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #3B82F6;
            --primary-dark: #2563EB;
            --primary-light: #EFF6FF;
            --success: #10b981;
            --success-light: #d1fae5;
            --danger: #ef4444;
            --danger-light: #fee2e2;
            --warning: #f59e0b;
            --warning-light: #fef3c7;
            --info: #3b82f6;
            --info-light: #dbeafe;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --radius-sm: 0.375rem;
            --radius-md: 0.5rem;
            --radius-lg: 0.75rem;
            --radius-xl: 1rem;
            --radius-2xl: 1.5rem;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #eef2f6 100%);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            color: var(--gray-800);
        }

        @@import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap');

        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            margin-bottom: 1.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            border-left: 4px solid transparent;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background-color: #ecfdf5;
            border-left-color: var(--success);
            color: #065f46;
        }

        .alert-danger {
            background-color: #fef2f2;
            border-left-color: var(--danger);
            color: #991b1b;
        }

        .alert-success::before {
            content: "✓";
            font-weight: bold;
            background: var(--success);
            color: white;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .alert-danger::before {
            content: "!";
            font-weight: bold;
            background: var(--danger);
            color: white;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .stores-card {
            background: white;
            border-radius: var(--radius-2xl);
            padding: 1.75rem;
            margin: 2rem auto;
            max-width: 1400px;
            box-shadow: var(--shadow-lg);
            transition: box-shadow 0.3s ease;
        }

            .stores-card:hover {
                box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.15);
            }

            .stores-card h3 {
                font-size: 1.75rem;
                font-weight: 700;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                background-clip: text;
                -webkit-background-clip: text;
                color: transparent;
                margin-bottom: 0.25rem;
                display: inline-block;
            }

        .tabs {
            display: flex;
            gap: 0.5rem;
            border-bottom: 2px solid var(--gray-200);
            margin: 1.5rem 0 1.75rem 0;
            padding-bottom: 0;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            color: var(--gray-600);
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            transition: all 0.2s ease;
            position: relative;
        }

            .tab-btn:hover {
                color: var(--primary);
                background-color: var(--primary-light);
            }

            .tab-btn.active {
                color: var(--primary);
                background-color: white;
            }

                .tab-btn.active::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 3px;
                    background: var(--primary);
                    border-radius: 3px 3px 0 0;
                }

        .table-responsive {
            overflow-x: auto;
            border-radius: var(--radius-lg);
            margin-top: 0.5rem;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 0.875rem;
        }

        th {
            text-align: left;
            padding: 1rem 1rem;
            background-color: var(--gray-50);
            font-weight: 600;
            color: var(--gray-700);
            border-bottom: 1px solid var(--gray-200);
            white-space: nowrap;
        }

        td {
            padding: 1rem 1rem;
            border-bottom: 1px solid var(--gray-100);
            vertical-align: middle;
            transition: background-color 0.2s ease;
        }

        tbody tr:hover {
            background-color: var(--gray-50);
        }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }

        .status-pending {
            background: var(--warning-light);
            color: #b45309;
        }

        .status-approved {
            background: var(--success-light);
            color: #065f46;
        }

        .status-inactive {
            background: var(--gray-200);
            color: var(--gray-700);
        }

        .status-expired {
            background: var(--danger-light);
            color: #991b1b;
        }

        .status-pending::before {
            content: "⏳";
            font-size: 0.7rem;
        }

        .status-approved::before {
            content: "✓";
            font-weight: bold;
        }

        .status-inactive::before {
            content: "⛔";
            font-size: 0.7rem;
        }

        .actions-cell {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
        }

        .btn-approve, .btn-reject, .btn-deactivate, .btn-activate {
            border: none;
            padding: 0.4rem 0.9rem;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 600;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            letter-spacing: 0.01em;
            box-shadow: var(--shadow-sm);
        }

        .btn-approve {
            background: var(--success);
            color: white;
        }

            .btn-approve:hover {
                background: #0e9f6e;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .btn-reject {
            background: var(--danger);
            color: white;
        }

            .btn-reject:hover {
                background: #dc2626;
                transform: translateY(-1px);
            }

        .btn-deactivate {
            background: var(--warning);
            color: white;
        }

            .btn-deactivate:hover {
                background: #d97706;
                transform: translateY(-1px);
            }

        .btn-activate {
            background: var(--primary);
            color: white;
        }

            .btn-activate:hover {
                background: var(--primary-dark);
                transform: translateY(-1px);
            }

        form .btn-activate {
            background: #8b5cf6;
        }

            form .btn-activate:hover {
                background: #7c3aed;
            }

        form .btn-deactivate {
            background: #f97316;
        }

        td:nth-child(7) {
            font-size: 0.8rem;
            white-space: nowrap;
        }

            td:nth-child(7) small {
                color: var(--gray-600);
                font-size: 0.7rem;
                display: block;
                margin-top: 0.2rem;
            }

        @@media (max-width: 768px) {
            .stores-card {
                padding: 1.25rem;
                margin: 1rem;
            }

            .tab-btn {
                padding: 0.5rem 1rem;
                font-size: 0.85rem;
            }

            th, td {
                padding: 0.75rem 0.75rem;
            }

            .actions-cell {
                gap: 0.35rem;
            }

            .btn-approve, .btn-reject, .btn-deactivate, .btn-activate {
                padding: 0.3rem 0.7rem;
                font-size: 0.7rem;
            }
        }

        button:focus-visible {
            outline: 2px solid var(--primary);
            outline-offset: 2px;
        }

        tbody tr td[colspan] {
            text-align: center;
            padding: 3rem;
            color: var(--gray-600);
            font-style: italic;
        }
    </style>
}

<div class="stores-card">
    <h3>🏪 Store Management</h3>
    <p style="color: var(--gray-600); margin-top: 0.25rem; font-size: 0.9rem;">Manage store approvals, subscriptions, and account status</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="tabs">
        <button class="tab-btn active" data-tab="all">📋 All Stores</button>
        <button class="tab-btn" data-tab="pending">⏳ Pending (@Model.PendingCount)</button>
        <button class="tab-btn" data-tab="active">✅ Active</button>
        <button class="tab-btn" data-tab="inactive">❌ Inactive</button>
        <button class="tab-btn" data-tab="suspended">🚫 Suspended</button>
        <button class="tab-btn" data-tab="expired">⌛ Expired</button>
    </div>
    <div class="table-responsive">
        <table id="storesTable">
            <thead>
                <tr>
                    <th>Store Name</th>
                    <th>Owner</th>
                    <th>Email</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Subscription</th>
                    <th>Expiry Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Stores != null && Model.Stores.Any())
                {
                    foreach (var store in Model.Stores)
                    {
                        if (store == null) continue;

                        var status = store.Status ?? "Pending";
                        var statusKey = status.ToLower();

                        var subStatus = store.SubscriptionStatus ?? "Active";
                        var subStatusKey = subStatus.ToLower();

                        int daysLeft = 0;
                        bool hasExpiry = store.SubscriptionExpiryDate.HasValue;
                        if (hasExpiry)
                        {
                            daysLeft = (store.SubscriptionExpiryDate.Value.Date - DateTime.UtcNow.Date).Days;
                        }

                        <tr data-status="@statusKey" data-substatus="@subStatusKey">
                            <td>@store.StoreName</td>
                            <td>@store.Owner?.FullName</td>
                            <td>@store.OwnerEmail</td>
                            <td>@store.City</td>
                            <td>
                                <span class="status-badge
                                    @(statusKey == "approved" ? "status-approved" :
                                        statusKey == "pending" ? "status-pending" :
                                        "status-inactive")">
                                    @status
                                </span>
                            </td>
                            <td>
                                <span class="status-badge
                                    @(subStatusKey == "active" ? "status-approved" :
                                        subStatusKey == "expired" ? "status-expired" :
                                        "status-inactive")">
                                    @subStatus
                                </span>
                            </td>
                            <td>
                                @if (hasExpiry)
                                {
                                    if (daysLeft < 0)
                                    {
                                        <span style="color: #dc2626; font-weight: 500;">Expired</span>
                                        <br />
                                        <small>@store.SubscriptionExpiryDate.Value.ToString("yyyy-MM-dd")</small>
                                    }
                                    else
                                    {
                                        <span>@store.SubscriptionExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                                        <br />
                                        <small>@daysLeft days left</small>
                                    }
                                }
                                else
                                {
                                    <span style="color: var(--gray-600);">Never</span>
                                }
                            </td>
                            <td class="actions-cell">
                                @if (statusKey == "pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-approve" title="Approve store">✓ Approve</button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-reject" title="Reject store">✗ Reject</button>
                                    </form>
                                }
                                else if (statusKey == "approved")
                                {
                                    <form method="post" asp-page-handler="Deactivate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-deactivate" title="Deactivate store">⛔ Deactivate</button>
                                    </form>
                                }
                                else if (statusKey == "inactive")
                                {
                                    <form method="post" asp-page-handler="Activate" style="display:inline;">
                                        <input type="hidden" name="id" value="@store.StoreID" />
                                        <button class="btn-activate" title="Activate store">▶ Activate</button>
                                    </form>
                                }

                                <form method="post" asp-page-handler="Extend" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-activate" title="Extend subscription by 30 days">📅 Extend (+30d)</button>
                                </form>
                                <form method="post" asp-page-handler="Suspend" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-deactivate" title="Suspend subscription">⏸ Suspend</button>
                                </form>
                                <form method="post" asp-page-handler="ActivateSubscription" style="display:inline;">
                                    <input type="hidden" name="id" value="@store.StoreID" />
                                    <button class="btn-approve" title="Activate subscription">🔄 Activate Sub</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align: center; padding: 3rem;">📭 No stores found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    const tabs = document.querySelectorAll('.tab-btn');
    const rows = document.querySelectorAll('#storesTable tbody tr');

    function filterTable(tabId) {
        rows.forEach(row => {
            // Skip the empty state row (colspan)
            if (row.cells.length === 1 && row.cells[0].colSpan) {
                row.style.display = '';
                return;
            }
            const status = row.dataset.status;      // from store.Status (lowercase)
            const subStatus = row.dataset.substatus; // store.SubscriptionStatus (lowercase)
            let shouldShow = false;

            switch(tabId) {
                case 'all': shouldShow = true; break;
                case 'pending': shouldShow = (status === 'pending'); break;
                case 'active': shouldShow = (status === 'approved'); break;
                case 'inactive': shouldShow = (status !== 'pending' && status !== 'approved'); break;
                case 'suspended': shouldShow = (status === 'suspended'); break;
                case 'expired': shouldShow = (subStatus === 'expired'); break;
                default: shouldShow = true;
            }
            row.style.display = shouldShow ? '' : 'none';
        });
    }

    // Handle tab clicks
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterTable(btn.dataset.tab);
        });
    });

    // ── Auto‑select tab from URL parameter ──
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
        const targetTab = document.querySelector(`.tab-btn[data-tab="${tabParam}"]`);
        if (targetTab) {
            targetTab.click();
        }
    }
</script>