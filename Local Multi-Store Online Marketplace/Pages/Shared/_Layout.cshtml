@using Microsoft.AspNetCore.Identity
@using Multi_Store.Core.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Multi Store</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">

    @await RenderSectionAsync("Styles", required: false)

    <style>
            :root {
                --admin-bg: #F8FAFC;
                --admin-sidebar-bg: linear-gradient(170deg, #4F46E5 0%, #3730A3 100%);
                --admin-sidebar-bg-hover: rgba(255, 255, 255, 0.10);
                --admin-sidebar-active: rgba(255, 255, 255, 0.16);
                --admin-accent: #6366F1;
                --admin-accent-soft: rgba(99, 102, 241, 0.12);
                --admin-accent-hover: #4F46E5;
                --admin-border: #E2E8F0;
                --admin-text: #0F172A;
                --admin-text-muted: #64748B;
                --sidebar-w: 264px;
                --sidebar-w-collapsed: 80px;
                --topbar-h: 68px;
                --radius: 12px;
                --shadow-topbar: 0 1px 3px rgba(15, 23, 42, 0.04), 0 1px 2px rgba(15, 23, 42, 0.06);
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                background: var(--admin-bg);
            }

            /* =========================
                                   ROLE NAV (non-admin roles)
                                   ========================= */
            .role-nav {
                background: #1E293B;
                padding: 8px 0;
                box-shadow: 0 2px 8px rgba(0,0,0,.1);
                position: sticky;
                top: 0;
                z-index: 99;
            }

                .role-nav .nav-links {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                    align-items: center;
                }

                .role-nav a {
                    color: #E2E8F0;
                    text-decoration: none;
                    padding: 8px 16px;
                    border-radius: 40px;
                    font-size: 14px;
                    font-weight: 500;
                    transition: all .2s;
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                }

                    .role-nav a:hover {
                        background: rgba(255,255,255,.1);
                        color: white;
                        transform: translateY(-1px);
                    }

                    .role-nav a.active {
                        background: #4F46E5;
                        color: white;
                    }

            /* Logout as a nav-link-styled button, distinct via red hover */
            .role-nav-logout-form {
                display: inline-flex;
                margin: 0;
            }

            .role-nav-logout {
                background: none;
                border: none;
                color: #E2E8F0;
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 40px;
                font-size: 14px;
                font-weight: 500;
                transition: all .2s;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                cursor: pointer;
                font-family: inherit;
            }

                .role-nav-logout:hover {
                    background: rgba(220, 38, 38, 0.15);
                    color: #FCA5A5;
                    transform: translateY(-1px);
                }

            .nav-divider {
                width: 1px;
                height: 20px;
                background: rgba(255, 255, 255, 0.15);
                margin: 0 2px;
            }

            .delivery-nav {
                background: #1E3A5F;
            }

            .customer-nav {
                background: #2D3748;
            }

            /* =========================
                                   ADMIN SHELL
                                   ========================= */
            .admin-shell {
                display: grid;
                grid-template-columns: var(--sidebar-w) 1fr;
                grid-template-rows: var(--topbar-h) 1fr;
                grid-template-areas:
                    "sidebar topbar"
                    "sidebar main";
                min-height: 100vh;
                transition: grid-template-columns .3s ease;
            }

                .admin-shell.collapsed {
                    grid-template-columns: var(--sidebar-w-collapsed) 1fr;
                }

                /* Prevent grid items from overflowing */
                .admin-shell > * {
                    min-width: 0;
                }

            /* =========================
                                   ADMIN SIDEBAR
                                   ========================= */
            .admin-sidebar {
                grid-area: sidebar;
                width: var(--sidebar-w);
                position: sticky;
                top: 0;
                height: 100vh;
                background: var(--admin-sidebar-bg);
                padding: 20px 14px 16px;
                overflow-y: auto;
                overflow-x: hidden;
                display: flex;
                flex-direction: column;
                gap: 1px;
                transition: width .3s ease, transform .3s ease;
                z-index: 1000;
                scrollbar-width: thin;
                scrollbar-color: rgba(255,255,255,0.2) transparent;
            }

            .admin-shell.collapsed .admin-sidebar {
                width: var(--sidebar-w-collapsed);
            }

            .admin-sidebar::-webkit-scrollbar {
                width: 4px;
            }

            .admin-sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            .admin-sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.2);
                border-radius: 20px;
            }

            /* Sidebar Title */
            .admin-sidebar .sidebar-title {
                color: #ffffff;
                font-size: 18px;
                font-weight: 800;
                margin-bottom: 18px;
                padding: 4px 10px 16px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.10);
                letter-spacing: -0.3px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .admin-sidebar .sidebar-title i {
                    color: rgba(255, 255, 255, 0.8);
                    font-size: 20px;
                }

                .admin-sidebar .sidebar-title span {
                    letter-spacing: -0.2px;
                }

            /* Section Titles */
            .sidebar-section-title {
                color: rgba(255, 255, 255, 0.40);
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                margin-top: 18px;
                margin-bottom: 6px;
                padding: 0 14px;
            }

            /* Sidebar Links */
            .admin-sidebar a {
                color: rgba(255, 255, 255, 0.65);
                text-decoration: none;
                padding: 10px 14px;
                border-radius: var(--radius);
                display: flex;
                align-items: center;
                gap: 14px;
                transition: all .2s ease;
                margin-bottom: 1px;
                font-weight: 500;
                font-size: 14px;
                position: relative;
            }

                .admin-sidebar a:hover {
                    background: var(--admin-sidebar-bg-hover);
                    color: #ffffff;
                    transform: translateX(2px);
                }

                .admin-sidebar a.active {
                    background: var(--admin-sidebar-active);
                    color: #ffffff;
                    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
                }

                    .admin-sidebar a.active i {
                        color: #ffffff;
                    }

                .admin-sidebar a i {
                    min-width: 20px;
                    text-align: center;
                    font-size: 15px;
                    flex-shrink: 0;
                    transition: color .2s ease;
                    color: rgba(255, 255, 255, 0.50);
                }

                .admin-sidebar a:hover i {
                    color: #ffffff;
                }

                .admin-sidebar a span {
                    white-space: nowrap;
                    overflow: hidden;
                }

            /* Collapsed state */
            .admin-shell.collapsed .admin-sidebar .sidebar-title span,
            .admin-shell.collapsed .admin-sidebar a span,
            .admin-shell.collapsed .admin-sidebar .sidebar-section-title {
                display: none;
            }

            .admin-shell.collapsed .admin-sidebar a {
                justify-content: center;
                padding: 10px 0;
            }

                .admin-shell.collapsed .admin-sidebar a i {
                    font-size: 18px;
                }

            .admin-shell.collapsed .admin-sidebar .sidebar-title {
                justify-content: center;
                padding: 4px 0 16px;
            }

                .admin-shell.collapsed .admin-sidebar .sidebar-title i {
                    font-size: 24px;
                }

            /* Logout link */
            .logout-link {
                color: rgba(255, 255, 255, 0.55) !important;
            }

                .logout-link:hover {
                    color: #FCA5A5 !important;
                }

                .logout-link i {
                    color: rgba(255, 255, 255, 0.45) !important;
                }

                .logout-link:hover i {
                    color: #FCA5A5 !important;
                }

            /* Sidebar Footer */
            .sidebar-footer {
                margin-top: auto;
                padding-top: 14px;
                border-top: 1px solid rgba(255, 255, 255, 0.08);
            }

                .sidebar-footer form {
                    margin-bottom: 6px;
                }

                .sidebar-footer .user-info {
                    padding: 4px 8px;
                }

                    .sidebar-footer .user-info div:first-child {
                        font-weight: 600;
                        font-size: 13px;
                        color: #ffffff;
                    }

                    .sidebar-footer .user-info div:last-child {
                        font-size: 11px;
                        color: rgba(255, 255, 255, 0.50);
                    }

            .admin-shell.collapsed .sidebar-footer .user-info {
                display: none;
            }

            .admin-shell.collapsed .sidebar-footer > div:last-child {
                justify-content: center;
            }

            /* =========================
                                   ADMIN TOP BAR
                                   ========================= */
            .admin-topbar {
                grid-area: topbar;
                position: sticky;
                top: 0;
                z-index: 900;
                height: var(--topbar-h);
                background: #ffffff;
                border-bottom: 1px solid var(--admin-border);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
                gap: 16px;
                box-shadow: var(--shadow-topbar);
            }

                .admin-topbar .topbar-left {
                    display: flex;
                    align-items: center;
                    gap: 16px;
                    min-width: 0;
                }

            /* Toggle Buttons */
            .mobile-sidebar-toggle,
            .desktop-sidebar-toggle {
                width: 38px;
                height: 38px;
                border: 1px solid var(--admin-border);
                border-radius: var(--radius);
                background: var(--admin-bg);
                color: var(--admin-text);
                cursor: pointer;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
                transition: all .2s ease;
            }

            .mobile-sidebar-toggle {
                display: none;
            }

                .desktop-sidebar-toggle:hover,
                .mobile-sidebar-toggle:hover {
                    background: var(--admin-accent-soft);
                    color: var(--admin-accent);
                    border-color: var(--admin-accent);
                }

            /* Topbar Title */
            .topbar-title-group {
                display: flex;
                flex-direction: column;
                line-height: 1.2;
                min-width: 0;
            }

            .topbar-title {
                font-size: 17px;
                font-weight: 700;
                color: var(--admin-text);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                letter-spacing: -0.3px;
            }

            /* Topbar Right */
            .admin-topbar .topbar-right {
                display: flex;
                align-items: center;
                gap: 10px;
                flex-shrink: 0;
            }

            .topbar-icon-btn {
                position: relative;
                width: 38px;
                height: 38px;
                border-radius: var(--radius);
                border: 1px solid var(--admin-border);
                background: var(--admin-bg);
                color: var(--admin-text-muted);
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 15px;
                transition: all .2s ease;
            }

                .topbar-icon-btn:hover {
                    background: var(--admin-accent-soft);
                    color: var(--admin-accent);
                    border-color: var(--admin-accent);
                }

            .topbar-badge {
                position: absolute;
                top: -5px;
                right: -5px;
                background: #DC2626;
                color: white;
                font-size: 9px;
                font-weight: 700;
                min-width: 18px;
                height: 18px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                border: 2px solid #ffffff;
                box-shadow: 0 2px 6px rgba(220, 38, 38, 0.3);
                animation: pulse-badge 2s ease-in-out infinite;
            }

            @@keyframes pulse-badge {
                0%, 100% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.05);
                }
            }

            .topbar-divider {
                width: 1px;
                height: 28px;
                background: var(--admin-border);
                margin: 0 4px;
            }

            /* =========================
                                   SEARCH
                                   ========================= */
            .topbar-search {
                position: relative;
                display: flex;
                align-items: center;
            }

            .topbar-search-form {
                position: absolute;
                right: 0;
                top: 50%;
                transform: translateY(-50%);
                display: flex;
                align-items: center;
                gap: 10px;
                width: 0;
                padding: 0;
                overflow: hidden;
                background: var(--admin-bg);
                border: 1px solid var(--admin-border);
                border-radius: var(--radius);
                opacity: 0;
                pointer-events: none;
                transition: width .25s ease, opacity .2s ease, padding .25s ease;
                box-shadow: 0 4px 16px rgba(15, 23, 42, 0.08);
            }

            .topbar-search.open .topbar-search-form {
                width: 340px;
                padding: 0 14px;
                opacity: 1;
                pointer-events: auto;
            }

            .topbar-search.open #searchToggleBtn {
                visibility: hidden;
            }

            .topbar-search-form-icon {
                color: var(--admin-text-muted);
                font-size: 14px;
                flex-shrink: 0;
            }

            .topbar-search-input {
                border: none;
                background: transparent;
                outline: none;
                font-size: 13.5px;
                font-family: inherit;
                color: var(--admin-text);
                padding: 10px 0;
                flex: 1;
                min-width: 0;
            }

                .topbar-search-input::placeholder {
                    color: var(--admin-text-muted);
                }

            .topbar-search-close {
                border: none;
                background: transparent;
                color: var(--admin-text-muted);
                cursor: pointer;
                flex-shrink: 0;
                width: 24px;
                height: 24px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 6px;
                transition: all .2s ease;
            }

                .topbar-search-close:hover {
                    color: var(--admin-accent);
                    background: var(--admin-accent-soft);
                }

            @@media (max-width: 768px) {
                .topbar-search.open .topbar-search-form {
                    width: 220px;
                }
            }

            /* =========================
                                   NOTIFICATION PANEL
                                   ========================= */
            .topbar-notif-wrap {
                position: relative;
            }

            .notif-panel {
                position: absolute;
                top: calc(100% + 12px);
                right: -8px;
                width: 360px;
                max-width: calc(100vw - 24px);
                background: #ffffff;
                border: 1px solid var(--admin-border);
                border-radius: var(--radius);
                box-shadow: 0 12px 40px rgba(15, 23, 42, 0.16);
                opacity: 0;
                transform: translateY(-6px);
                pointer-events: none;
                transition: opacity .2s ease, transform .2s ease;
                z-index: 950;
                overflow: hidden;
            }

                .notif-panel.open {
                    opacity: 1;
                    transform: translateY(0);
                    pointer-events: auto;
                }

            .notif-panel-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 14px 18px;
                border-bottom: 1px solid var(--admin-border);
                font-size: 13.5px;
                font-weight: 700;
                color: var(--admin-text);
            }

            .notif-mark-read {
                border: none;
                background: none;
                color: var(--admin-accent);
                font-size: 11.5px;
                font-weight: 600;
                cursor: pointer;
                padding: 4px 8px;
                border-radius: 6px;
                transition: all .2s ease;
            }

                .notif-mark-read:hover {
                    background: var(--admin-accent-soft);
                    text-decoration: none;
                }

            .notif-panel-list {
                max-height: 340px;
                overflow-y: auto;
            }

                .notif-panel-list::-webkit-scrollbar {
                    width: 4px;
                }

                .notif-panel-list::-webkit-scrollbar-track {
                    background: transparent;
                }

                .notif-panel-list::-webkit-scrollbar-thumb {
                    background: var(--admin-border);
                    border-radius: 20px;
                }

            .notif-item {
                display: flex;
                align-items: flex-start;
                gap: 14px;
                padding: 12px 18px;
                text-decoration: none;
                border-bottom: 1px solid var(--admin-border);
                transition: background .15s ease;
            }

                .notif-item:hover {
                    background: var(--admin-bg);
                }

                .notif-item.unread {
                    background: #F5F8FF;
                }

                    .notif-item.unread:hover {
                        background: #EDF2FF;
                    }

            .notif-icon {
                width: 34px;
                height: 34px;
                border-radius: var(--radius);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                flex-shrink: 0;
            }

                .notif-icon.warn {
                    background: rgba(220, 38, 38, 0.12);
                    color: #DC2626;
                }

                .notif-icon.info {
                    background: rgba(99, 102, 241, 0.12);
                    color: var(--admin-accent);
                }

                .notif-icon.accent {
                    background: rgba(16, 185, 129, 0.12);
                    color: #10B981;
                }

            .notif-text {
                font-size: 13px;
                font-weight: 600;
                color: var(--admin-text);
                line-height: 1.3;
            }

            .notif-time {
                font-size: 11px;
                color: var(--admin-text-muted);
                margin-top: 3px;
            }

            .notif-empty {
                padding: 32px 16px;
                text-align: center;
                font-size: 13px;
                color: var(--admin-text-muted);
            }

            .notif-panel-footer {
                display: block;
                text-align: center;
                padding: 12px;
                font-size: 12.5px;
                font-weight: 600;
                color: var(--admin-accent);
                text-decoration: none;
                background: var(--admin-bg);
                border-top: 1px solid var(--admin-border);
                transition: all .2s ease;
            }

                .notif-panel-footer:hover {
                    background: var(--admin-accent-soft);
                    color: var(--admin-accent-hover);
                }

            /* =========================
                                   USER PROFILE (topbar)
                                   ========================= */
            .topbar-user {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 4px 14px 4px 4px;
                border-radius: 40px;
                border: 1px solid var(--admin-border);
                background: var(--admin-bg);
                cursor: pointer;
                transition: all .2s ease;
            }

                .topbar-user:hover {
                    border-color: var(--admin-accent);
                    box-shadow: 0 0 0 3px var(--admin-accent-soft);
                }

                .topbar-user .avatar-circle {
                    width: 32px;
                    height: 32px;
                    border-radius: 50%;
                    background: var(--admin-accent);
                    color: #fff;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 13px;
                    font-weight: 700;
                    flex-shrink: 0;
                }

                .topbar-user .user-meta {
                    line-height: 1.15;
                }

                    .topbar-user .user-meta .name {
                        font-size: 12.5px;
                        font-weight: 700;
                        color: var(--admin-text);
                    }

                    .topbar-user .user-meta .role {
                        font-size: 10.5px;
                        color: var(--admin-text-muted);
                    }

            /* =========================
                                   MAIN CONTENT
                                   ========================= */
            .admin-main {
                grid-area: main;
                padding: 28px 32px;
                background: var(--admin-bg);
                min-height: calc(100vh - var(--topbar-h));
                min-width: 0; /* Prevents overflow from child content */
                overflow-x: hidden; /* No horizontal scroll on main area */
            }

            /* =========================
                                   MOBILE OVERLAY
                                   ========================= */
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(15, 23, 42, 0.50);
                z-index: 999;
                backdrop-filter: blur(2px);
                opacity: 0;
                transition: opacity .3s ease;
            }

                .sidebar-overlay.show {
                    display: block;
                    opacity: 1;
                }

            /* =========================
                                   MOBILE RESPONSIVE
                                   ========================= */
            @@media (max-width: 992px) {
                .admin-main {
                    padding: 20px;
                }
            }

            @@media (max-width: 768px) {
                .role-nav .nav-links {
                    justify-content: center;
                }

                .role-nav a {
                    padding: 6px 12px;
                    font-size: 12px;
                }

                .role-nav-logout {
                    padding: 6px 12px;
                    font-size: 12px;
                }

                .admin-shell {
                    grid-template-columns: 1fr;
                    grid-template-areas:
                        "topbar"
                        "main";
                }

                .admin-sidebar {
                    position: fixed;
                    left: 0;
                    top: 0;
                    width: var(--sidebar-w);
                    transform: translateX(-100%);
                    box-shadow: none;
                    border-radius: 0 16px 16px 0;
                }

                    .admin-sidebar.mobile-open {
                        transform: translateX(0);
                        box-shadow: 4px 0 32px rgba(0,0,0,0.35);
                    }

                .desktop-sidebar-toggle {
                    display: none;
                }

                .mobile-sidebar-toggle {
                    display: flex;
                }

                .admin-main {
                    padding: 16px;
                    overflow-x: hidden;
                }

                .admin-topbar {
                    padding: 0 16px;
                }

                .topbar-user .user-meta {
                    display: none;
                }

                .topbar-divider {
                    display: none;
                }

                .notif-panel {
                    right: -12px;
                    width: calc(100vw - 24px);
                    max-width: 360px;
                }
            }

            @@media (max-width: 480px) {
                .admin-topbar .topbar-left {
                    gap: 8px;
                }

                .topbar-title {
                    font-size: 14px;
                }

                .topbar-icon-btn {
                    width: 34px;
                    height: 34px;
                    font-size: 13px;
                }

                .topbar-user {
                    padding: 3px 8px 3px 3px;
                }

                    .topbar-user .avatar-circle {
                        width: 28px;
                        height: 28px;
                        font-size: 11px;
                    }
            }
    </style>
</head>

<body>

    @{
        var showAdminShell = false;
        var bodyRendered = false;
        string adminUserInitial = "A";
    }

    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);

        if (user != null)
        {
            var roles = await UserManager.GetRolesAsync(user);

            if (roles.Contains("Admin"))
            {
                showAdminShell = true;
                bodyRendered = true;
                var displayName = User.Identity?.Name ?? "Admin";
                adminUserInitial = displayName.Substring(0, 1).ToUpper();
                var currentPage = Context.Request.Path.Value ?? "";

                Func<string, bool> isActive = prefix =>
                    currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);

                <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeMobileSidebar()"></div>

