@using Microsoft.AspNetCore.Identity
@using Multi_Store.Core.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Multi Store</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
    .role-nav {
    background: #1e293b;
    padding: 8px 0;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
    position: sticky;
    top: 0;
    z-index: 99;
}

.role-nav .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

.role-nav a {
    color: #e2e8f0;
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 500;
    transition: all .2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.role-nav a:hover {
    background: rgba(255,255,255,.1);
    color: white;
    transform: translateY(-1px);
}

.role-nav a.active {
    background: #4f46e5;
    color: white;
}

/* =========================
   ROLE COLORS
   ========================= */
.admin-nav { background: #0f172a; }
.store-nav { background: #2d3e2b; }
.delivery-nav { background: #1e3a5f; }
.customer-nav { background: #2d3748; }

/* =========================
   ADMIN SIDEBAR
   ========================= */

.admin-sidebar {
    width: 260px;
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    background: #0f172a;
    padding: 20px 15px;
    overflow-y: auto;
    overflow-x: hidden;

    display: flex;
    flex-direction: column;
    gap: 8px;

    transition: width .3s ease;
    z-index: 1000;

    box-shadow: 4px 0 20px rgba(0, 0, 0, 0.2);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
}

/* =========================
   SIDEBAR TITLE
   ========================= */

.admin-sidebar .sidebar-title {
    color: white;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 15px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,.1);

    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* =========================
   LINKS
   ========================= */

.admin-sidebar a {
    color: #e2e8f0;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 12px;

    display: flex;
    align-items: center;
    gap: 12px;

    transition: all .25s ease;
    margin-bottom: 4px;
    font-weight: 500;
    letter-spacing: 0.3px;
    position: relative;
    overflow: hidden;
}

/* hover */
.admin-sidebar a:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateX(6px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.25);
    color: white;
}

/* active */
.admin-sidebar a.active {
    background: #1d4ed8; /* deep blue */
    color: white;
    box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35);
    border-left: 4px solid #c7d2fe;
}
.admin-sidebar a:hover {
    background: rgba(29, 78, 216, 0.10); /* change to match chosen color */
    transform: translateX(6px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    color: white;
}
/* active indicator glow line */
.admin-sidebar a.active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 15%;
    height: 70%;
    width: 4px;
    background: #c7d2fe;
    border-radius: 10px;
}

/* icons */
.admin-sidebar a i {
    min-width: 24px;
    text-align: center;
    font-size: 18px;
}

/* text */
.admin-sidebar a span {
    white-space: nowrap;
    transition: all .2s ease;
}

/* =========================
   TOGGLE BUTTON
   ========================= */

.sidebar-toggle {
    width: 42px;
    height: 42px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;

    background: rgba(255, 255, 255, 0.05);
    color: white;
    cursor: pointer;

    margin-bottom: 15px;

    transition: all 0.3s ease;
}

.sidebar-toggle:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: rotate(90deg) scale(1.05);
}

.sidebar-toggle i {
    font-size: 18px;
}

/* =========================
   COLLAPSED MODE
   ========================= */

.admin-sidebar.collapsed {
    width: 80px;
}

.admin-sidebar.collapsed .sidebar-title,
.admin-sidebar.collapsed a span {
    opacity: 0;
    width: 0;
    overflow: hidden;
    display: none;
}

.admin-sidebar.collapsed a {
    justify-content: center;
}

/* =========================
   SECTION TITLES
   ========================= */

.sidebar-section-title {
    color: #94a3b8;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 18px;
    margin-bottom: 8px;
    padding-left: 10px;
}

.admin-sidebar.collapsed .sidebar-section-title {
    display: none;
}

/* =========================
   PAGE SHIFT
   ========================= */

.page-content {
        min-height: 100vh;
    transition: margin-left .35s cubic-bezier(.4,0,.2,1);
}

.page-content.admin-shift {
    margin-left: 260px;
}

.page-content.admin-shift-collapsed {
    margin-left: 80px;
}

/* =========================
   SCROLLBAR
   ========================= */

.admin-sidebar::-webkit-scrollbar {
    width: 6px;
}

.admin-sidebar::-webkit-scrollbar-track {
    background: transparent;
}

.admin-sidebar::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,.2);
    border-radius: 20px;
}

.admin-sidebar::-webkit-scrollbar-thumb:hover {
    background: rgba(255,255,255,.4);
}


.page-content {
    padding: 0 24px;
}


/* =========================
   MOBILE
   ========================= */

@@media (max-width: 768px) {

    .role-nav .nav-links {
        justify-content: center;
    }

    .role-nav a {
        padding: 6px 12px;
        font-size: 12px;
    }

    .admin-sidebar {
        width: 220px;
    }

    .admin-sidebar.collapsed {
        width: 60px;
    }

    .admin-sidebar a {
        padding: 10px 8px;
        font-size: 13px;
    }

    .admin-sidebar .sidebar-title {
        font-size: 15px;
    }

    .page-content.admin-shift {
        margin-left: 220px;
    }

    .page-content.admin-shift-collapsed {
        margin-left: 60px;
    }
}

/* =========================
   FOOTER
   ========================= */

.admin-sidebar.collapsed .sidebar-footer {
    justify-content: center;
}

.admin-sidebar.collapsed .sidebar-footer .user-info {
    display: none;
}

/* =========================
   LOGOUT
   ========================= */

.logout-link {
    margin-top: 10px;
    color: #f87171 !important;
}

.sidebar-footer {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
}
</style>
</head>

<body>

    <header>
       
        <!-- Role-based navigation -->
        @if (SignInManager.IsSignedIn(User))
        {
            var user = await UserManager.GetUserAsync(User);

            if (user != null)
            {
                var roles = await UserManager.GetRolesAsync(user);

                if (roles.Contains("Admin"))
                {
                    <div class="admin-layout">
    <aside class="admin-sidebar" id="adminSidebar">

<button class="sidebar-toggle"
        type="button"
        onclick="toggleSidebar()"
        aria-expanded="true"
        aria-controls="adminSidebar">        <i class="fas fa-bars"></i>
    </button>

    <div class="sidebar-title">
    <i class="fas fa-shield-alt"></i>
    <span>Admin Panel</span>
</div>


@{
    var currentPage = Context.Request.Path.Value ?? "";
}

<!-- MAIN -->
<div class="sidebar-section-title">Main</div>

<a href="/Admin1"
