    <span>Analytics</span>
</a>

<!-- MANAGEMENT -->
<div class="sidebar-section-title">Management</div>

<a href="/AdminStores"
   data-title="Stores"
   class="@(currentPage.StartsWith("/AdminStores", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-store"></i>
    <span>Stores</span>
</a>

<a href="/AdminUsers"
   data-title="Users"
   class="@(currentPage.StartsWith("/AdminUsers", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-users"></i>
    <span>Users</span>
</a>

<a href="/AdminOrders"
   data-title="Orders"
   class="@(currentPage.StartsWith("/AdminOrders", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-shopping-cart"></i>
    <span>Orders</span>
</a>
<li class="nav-item">
    <a class="nav-link" asp-page="/AdminRevenue">
        <i class="fas fa-file-invoice-dollar"></i> Revenue Report
    </a>
</li>
<a href="/AdminCategories"
   data-title="Categories"
   class="@(currentPage.StartsWith("/AdminCategories", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-tags"></i>
    <span>Categories</span>
</a>

<a href="/AdminComplaints"
   data-title="Complaints"
   class="@(currentPage.StartsWith("/AdminComplaints", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-flag"></i>
    <span>Complaints</span>
</a>
<a href="/AdminReports"
   data-title="Reports"
   class="@(currentPage.StartsWith("/AdminReports", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-flag"></i>
    <span>Reports</span>
</a>

<!-- DELIVERY -->
<div class="sidebar-section-title">Delivery</div>

<a href="/AdminDelivery"
   data-title="Delivery Requests"
   class="@(currentPage.StartsWith("/AdminDelivery", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-truck"></i>
    <span>Delivery Requests</span>
</a>

<a href="/AdminAssignDelivery"
   data-title="Assign Delivery"
   class="@(currentPage.StartsWith("/AdminAssignDelivery", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-route"></i>
    <span>Assign Delivery</span>
</a>

<!-- SYSTEM -->
<div class="sidebar-section-title">System</div>

<a href="/AdminAuditLogs"
   data-title="Audit Logs"
   class="@(currentPage.StartsWith("/AdminAuditLogs", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-history"></i>
    <span>Audit Logs</span>
</a>

<a href="/AdminSettings"
   data-title="Settings"
   class="@(currentPage.StartsWith("/AdminSettings", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
    <i class="fas fa-cog"></i>
    <span>Settings</span>
</a>

<!-- LOGOUT -->
<div class="sidebar-section-title">Account</div>

<form asp-area="Identity"
      asp-page="/Account/Logout"
      asp-route-returnUrl="/"
      method="post">
    <button type="submit"
            class="logout-link"
            style="background:none;border:none;width:100%;text-align:left;">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
