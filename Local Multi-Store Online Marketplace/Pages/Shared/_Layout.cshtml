    @if (!bodyRendered)
    {
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Local_Multi_Store_Online_Marketplace -
            <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Shared toast and confirmation HTML -->
    <partial name="_AppFeedback" />

    <!-- Shared toast and confirmation JavaScript -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Applies persisted collapsed/expanded state as early as possible
        // (before the rest of the page paints) to avoid a flash of the wrong layout.
        (function applySidebarState() {
        var shell = document.getElementById("adminShell");
        if (!shell) return;

        var isCollapsed = localStorage.getItem("adminSidebarCollapsedV2") === "true";
        if (isCollapsed) {
        shell.classList.add("collapsed");
        }
        })();

        function toggleSidebar() {
        var shell = document.getElementById("adminShell");
        if (!shell) return;

        var isCollapsed = shell.classList.toggle("collapsed");

        document.querySelector(".desktop-sidebar-toggle")
        .setAttribute("aria-expanded", !isCollapsed);

        localStorage.setItem("adminSidebarCollapsedV2", isCollapsed ? "true" : "false");
        }

        function toggleSearch(forceOpen) {
        var wrap = document.getElementById("topbarSearch");
        var input = document.getElementById("topbarSearchInput");
        if (!wrap || !input) return;

        var shouldOpen = typeof forceOpen === "boolean" ? forceOpen : !wrap.classList.contains("open");

        if (shouldOpen) {
        closeNotifications();
        wrap.classList.add("open");
        setTimeout(function () { input.focus(); }, 150);
        } else {
        wrap.classList.remove("open");
        input.value = "";
        }
        }

        function handleSearchSubmit(e) {
        var input = document.getElementById("topbarSearchInput");
        var query = input ? input.value.trim() : "";
        if (!query) {
        e.preventDefault();
        return false;
        }
        // Submits a normal GET to /AdminSearch?q=... — wire that page up
        // (or change the form's action) to actually return results.
        return true;
        }

        function toggleNotifications() {
        var panel = document.getElementById("notifPanel");
        var btn = document.getElementById("notifToggleBtn");
        if (!panel || !btn) return;

        var isOpen = panel.classList.contains("open");
        if (isOpen) {
        closeNotifications();
        } else {
        toggleSearch(false);
        panel.classList.add("open");
        btn.setAttribute("aria-expanded", "true");
        }
        }

        function closeNotifications() {
        var panel = document.getElementById("notifPanel");
        var btn = document.getElementById("notifToggleBtn");
        if (!panel || !btn) return;
        panel.classList.remove("open");
        btn.setAttribute("aria-expanded", "false");
        }

        var notificationsLoaded = false;

        function notifTypeMeta(type) {
        switch ((type || "").toLowerCase()) {
        case "complaint":
        return { icon: "fa-flag", cls: "warn" };
        case "delivery":
        return { icon: "fa-truck", cls: "accent" };
        case "store":
        case "user":
        return { icon: "fa-user-plus", cls: "info" };
        default:
        return { icon: "fa-bell", cls: "info" };
        }
        }

        function notifLinkFor(type, referenceId) {
        switch ((type || "").toLowerCase()) {
        case "complaint": return "/AdminComplaints" + (referenceId ? ("?id=" + referenceId) : "");
        case "delivery": return "/AdminDelivery" + (referenceId ? ("?id=" + referenceId) : "");
        case "store": return "/AdminStores" + (referenceId ? ("?id=" + referenceId) : "");
        case "user": return "/AdminUsers" + (referenceId ? ("?id=" + referenceId) : "");
        case "order": return "/AdminOrders" + (referenceId ? ("?id=" + referenceId) : "");
        default: return "/AdminReports";
        }
        }

        function timeAgo(dateStr) {
        var then = new Date(dateStr);
        var diffMs = Date.now() - then.getTime();
        var mins = Math.floor(diffMs / 60000);
        if (mins < 1) return "just now";
        if (mins < 60) return mins + (mins === 1 ? " minute ago" : " minutes ago");
        var hrs = Math.floor(mins / 60);
        if (hrs < 24) return hrs + (hrs === 1 ? " hour ago" : " hours ago");
        var days = Math.floor(hrs / 24);
        return days + (days === 1 ? " day ago" : " days ago");
        }

        function renderNotifications(items, unreadCount) {
        var list = document.getElementById("notifList");
        var badge = document.getElementById("notifBadge");
        if (!list || !badge) return;

        if (unreadCount > 0) {
        badge.textContent = unreadCount > 9 ? "9+" : String(unreadCount);
        badge.style.display = "flex";
        } else {
        badge.style.display = "none";
        }

        if (!items || items.length === 0) {
        list.innerHTML = '<div class="notif-empty">You\'re all caught up.</div>';
        return;
        }

        list.innerHTML = items.map(function (n) {
        var meta = notifTypeMeta(n.type);
        var href = notifLinkFor(n.type, n.referenceID);
        var unreadClass = n.isRead ? "" : " unread";
        var title = (n.title || n.message || "Notification").replace(/</g, "&lt;");
        return '' +
        '<a href="' + href + '" class="notif-item' + unreadClass + '">' +
        '<i class="fas ' + meta.icon + ' notif-icon ' + meta.cls + '"></i>' +
        '<div>' +
        '<div class="notif-text">' + title + '</div>' +
        '<div class="notif-time">' + timeAgo(n.sentAt) + '</div>' +
        '</div>' +
        '</a>';
        }).join("");
        }

        function loadNotifications() {
        var list = document.getElementById("notifList");
        fetch("/AdminNotifications?handler=List", { credentials: "same-origin" })
        .then(function (res) { return res.json(); })
        .then(function (data) {
        renderNotifications(data.items, data.unreadCount);
        notificationsLoaded = true;
        })
        .catch(function () {
        if (list) list.innerHTML = '<div class="notif-empty">Couldn\'t load notifications.</div>';
        });
        }

        function markAllNotificationsRead() {
        var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenInput ? tokenInput.value : "";

        fetch("/AdminNotifications?handler=MarkAllRead", {
        method: "POST",
        credentials: "same-origin",
        headers: {
        "RequestVerificationToken": token,
        "Content-Type": "application/x-www-form-urlencoded"
        }
        })
        .then(function (res) { return res.json(); })
        .then(function () {
        loadNotifications();
        });
        }

        document.addEventListener("DOMContentLoaded", function () {
        if (document.getElementById("notifPanel")) {
        loadNotifications();
        // Refresh periodically so new complaints/orders/delivery events show up
        // without the admin needing to reload the page.
        setInterval(loadNotifications, 60000);
        }
        });


        // Close search / notifications when clicking outside, or pressing Escape
        document.addEventListener("click", function (e) {
        var searchWrap = document.getElementById("topbarSearch");
        var notifWrap = document.querySelector(".topbar-notif-wrap");

        if (searchWrap && !searchWrap.contains(e.target)) {
        toggleSearch(false);
        }
        if (notifWrap && !notifWrap.contains(e.target)) {
        closeNotifications();
        }
        });

        document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
        toggleSearch(false);
        closeNotifications();
        }
        });

        function openMobileSidebar() {
        var sidebar = document.getElementById("adminSidebar");
        var overlay = document.getElementById("sidebarOverlay");
        if (!sidebar || !overlay) return;
        sidebar.classList.add("mobile-open");
        overlay.classList.add("show");
        }

        function closeMobileSidebar() {
        var sidebar = document.getElementById("adminSidebar");
        var overlay = document.getElementById("sidebarOverlay");
        if (!sidebar || !overlay) return;
        sidebar.classList.remove("mobile-open");
        overlay.classList.remove("show");
        }
    </script>

</body>
