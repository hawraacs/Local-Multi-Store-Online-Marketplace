</form>

<div class="sidebar-footer">
    <div style="display: flex; align-items: center; gap: 12px; color: #e2e8f0;">
        <i class="fas fa-user-circle" style="font-size: 32px;"></i>
        <div>
            <div style="font-weight: 600;">@User.Identity?.Name</div>
            <div style="font-size: 12px; opacity: 0.7;">Administrator</div>
        </div>
    </div>
</div>

</aside>

</div>
                }
                else if (roles.Contains("StoreOwner"))
                {
                    // ------------------------------------------------------------
                    // GREEN NAVBAR REMOVED – StoreOwner now uses its own layout
                    // with a sidebar.  No navigation bar is rendered here.
                    // ------------------------------------------------------------
                    <!-- StoreOwner navigation has been removed -->
                }
                else if (roles.Contains("Delivery"))
                {
                    <nav class="role-nav delivery-nav">
                        <div class="container">
                            <div class="nav-links">

                                <a href="/DeliveryDashboard">
                                    <i class="fas fa-tachometer-alt"></i> Dashboard
                                </a>

                                <a href="/DeliveryDashboard">
                                    <i class="fas fa-box"></i> Orders
                                </a>

                                <a href="/Chat">
                                    <i class="fas fa-comments"></i> Chat
                                </a>

                                <a href="/DeliveryProfile">
                                    <i class="fas fa-user-circle"></i> Profile
                                </a>

                            </div>
                        </div>
                    </nav>
                }
                else if (roles.Contains("Customer"))
                {
                    <nav class="role-nav customer-nav">
                        <div class="container">
                            <div class="nav-links">
                                <a href="/Customer1">
                                    <i class="fas fa-home"></i> Dashboard
                                </a>

                                <a href="/CustomerProducts">
                                    <i class="fas fa-search"></i> Products
                                </a>

                                <a href="/CustomerWishlist">
                                    <i class="fas fa-heart"></i> Wishlist
                                </a>
                                <a href="/CustomerPromotions">
                                    <i class="fas fa-bullhorn"></i> Promotions
                                </a>

                                <a href="/CustomerCart">
                                    <i class="fas fa-shopping-cart"></i> Cart
                                </a>

                                <a href="/CustomerOrders">
                                    <i class="fas fa-truck-fast"></i> Orders
                                </a>

                                <a href="/CustomerProfile">
                                    <i class="fas fa-user-circle"></i> Profile
                                </a>
                            </div>
                        </div>
                    </nav>
