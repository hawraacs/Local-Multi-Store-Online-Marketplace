@using Microsoft.AspNetCore.Identity
@using Multi_Store.Core.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Multi Store</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<header>

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(user);

    <!-- ================= ADMIN ================= -->
    if (roles.Contains("Admin"))
    {
        <nav style="background:#222;padding:15px;color:white;display:flex;gap:20px;">
            <a href="/Admin1" style="color:white;">Dashboard</a>
            <a href="/AdminStores" style="color:white;">Stores</a>
            <a href="/AdminUsers" style="color:white;">Users</a>
            <a href="/AdminOrders" style="color:white;">Orders</a>
        </nav>
    }

   
    else if (roles.Contains("StoreOwner"))
    {
        <nav style="background:#111;padding:15px;color:white;display:flex;gap:20px;">
            <a href="/StoreOwner/Dashboard" style="color:white;">Dashboard</a>
            <a href="/StoreOwner/Products" style="color:white;">Products</a>
            <a href="/StoreOrders" style="color:white;">Orders</a>
            <a href="/StoreAnalytics" style="color:white;">Analytics</a>
       
        </nav>
    }

    
    else if (roles.Contains("Delivery"))
    {
        <nav style="background:#0d6efd;padding:15px;color:white;display:flex;gap:20px;">
            <a href="/Delivery1" style="color:white;">Dashboard</a>
            <a href="/DeliveryOrders" style="color:white;">My Deliveries</a>
            <a href="/DeliveryEarnings" style="color:white;">Earnings</a>
            <a href="/DeliveryProfile" style="color:white;">Profile</a>
        </nav>
    }

   
    else if (roles.Contains("Customer"))
    {
        <nav style="background:#111;padding:15px;color:white;display:flex;gap:20px;">
            <a href="/Customer1" style="color:white;">Dashboard</a>
            <a href="/CustomerProducts" style="color:white;">Products</a>
            <a href="/CustomerCart" style="color:white;">Cart</a>
            <a href="/CustomerOrders" style="color:white;">Orders</a>
            <a href="/CustomerProfile" style="color:white;">Profile</a>
        </nav>
    }
}

</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Multi Store
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>