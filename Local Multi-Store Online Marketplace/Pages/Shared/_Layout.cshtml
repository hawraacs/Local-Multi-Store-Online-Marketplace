    <i class="fas fa-tachometer-alt"></i>
    <span>Dashboard</span>
</a>

<a href="/AdminAnalytics"
   data-title="Analytics"
   class="@(currentPage.StartsWith("/AdminAnalytics", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
