                                    <span class="topbar-badge" id="notifBadge" style="display:none;">0</span>
                                </button>

                                <div class="notif-panel" id="notifPanel" role="menu" aria-label="Notifications">
                                    <div class="notif-panel-header">
                                        <span>Notifications</span>
                                        <button type="button" class="notif-mark-read" onclick="markAllNotificationsRead()">Mark all as read</button>
                                    </div>
                                    <div class="notif-panel-list" id="notifList">
                                        <div class="notif-empty" id="notifEmpty">Loading notifications…</div>
