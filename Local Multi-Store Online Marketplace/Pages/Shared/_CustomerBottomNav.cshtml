@using System.Security.Claims
@using Multi_Store.Services.Managers
@inject Multi_Store.Services.Managers.UserManager UserManagerService
@inject Multi_Store.Services.Managers.MessagingManager MessagingManagerService
@{
    var currentPath = ViewContext.HttpContext.Request.Path.Value ?? string.Empty;

    string ActiveIf(string path) =>
        currentPath.Equals(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    int currentUserId = 0;
    var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int.TryParse(userIdClaim, out currentUserId);

    bool hasChatUnread = false;

    if (currentUserId > 0)
    {
        var myMessages = await MessagingManagerService.GetMessagesForUserAsync(currentUserId);
        hasChatUnread = myMessages != null &&
                        myMessages.Any(m => m.ReceiverID == currentUserId && !m.IsRead);
    }
}

<style>
    /* ============================================================
    BASE STYLES for the bottom nav — self-contained so this
    partial works on any page regardless of Layout (including
    pages that set Layout = null and don't pull in site.css).
    ============================================================ */
    .mobile-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: #ffffff;
    border-top: 1px solid #ece8f6;
    padding: 8px 4px;
    font-family: Inter, Arial, sans-serif;
    }

    .mobile-bottom-nav a {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-decoration: none;
    color: #9691a4;
    font-size: 10px;
    font-weight: 600;
    padding: 6px 8px;
    border-radius: 12px;
    position: relative;
    transition: color .2s ease, background .2s ease;
    }

    .mobile-bottom-nav a i {
    font-size: 18px;
    line-height: 1;
    }

    .mobile-bottom-nav a:hover {
    color: #6d28d9;
    }

    .mobile-bottom-nav a.active {
    color: #6d28d9;
    background: #f3effe;
    }

    .chat-icon-wrap {
    position: relative;
    display: inline-flex;
    }

    .chat-nav-dot {
    position: absolute;
    top: -2px;
    right: -3px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #dc2626;
    border: 2px solid #ffffff;
    }

    @@media (max-width: 480px) {
    .mobile-bottom-nav a {
    font-size: 9px;
    padding: 6px 5px;
    }

    .mobile-bottom-nav a i {
    font-size: 16px;
    }
    }

    /* ============================================================
    OVERRIDE — centered floating pill bar at ~75% of page width
    instead of edge-to-edge. nav.mobile-bottom-nav (tag + class)
    beats a plain .mobile-bottom-nav rule on specificity, so this
    reliably wins over the base rules above and any page-level
    styles like Customer1's own <style> block.
    ============================================================ */
    nav.mobile-bottom-nav {
    left: 50% !important;
    right: auto !important;
    transform: translateX(-50%) !important;
    width: 75vw !important;
    border-radius: 20px !important;
    border: 1px solid #ece8f6 !important;
    bottom: 10px !important;
    box-shadow: 0 6px 24px rgba(30, 27, 46, 0.12) !important;
    }
</style>

<nav class="mobile-bottom-nav" aria-label="Customer navigation">

    <a href="/Customer1" class="@ActiveIf("/Customer1")">
        <i class="fa-solid fa-compass"></i>
        <span>Explore</span>
    </a>

    <a href="/CustomerFeed" class="@ActiveIf("/CustomerFeed")">
        <i class="fa-solid fa-house"></i>
        <span>Feed</span>
    </a>

    <a href="/CustomerCart" class="@ActiveIf("/CustomerCart")" style="position:relative;">
        <i class="fa-solid fa-cart-shopping"></i>
        <partial name="_CartCountBadge" />
        <span>Cart</span>
    </a>

    <a href="/CustomerPromotions" class="@ActiveIf("/CustomerPromotions")">
        <i class="fa-solid fa-tags"></i>
        <span>Promos</span>
    </a>

    <a href="/CustomerOrders" class="@ActiveIf("/CustomerOrders")">
        <i class="fa-solid fa-box"></i>
        <span>Orders</span>
    </a>

    <a href="/ReportUpdates" class="@ActiveIf("/ReportUpdates")">
        <i class="fa-solid fa-bell"></i>
        <span>Notifications</span>
    </a>

    <a href="/Chat" class="@ActiveIf("/Chat")">
        <span class="chat-icon-wrap">
            <i class="fa-solid fa-paper-plane"></i>
            @if (hasChatUnread)
            {
                <span class="chat-nav-dot"></span>
            }
        </span>
        <span>Chat</span>
    </a>

    <a href="/CustomerProfile" class="@ActiveIf("/CustomerProfile")">
        <i class="fa-solid fa-user"></i>
        <span>Profile</span>
    </a>

</nav>
