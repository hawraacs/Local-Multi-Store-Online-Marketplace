@model List<Multi_Store.Core.Entities.Notification>

@{
    var notifications = Model ?? new List<Multi_Store.Core.Entities.Notification>();
}

<div class="activity-section">
    <h3 class="activity-section-title"><i class="fas fa-bell"></i> Notifications</h3>

    @if (notifications.Any())
    {
        <div class="ig-notif-list">
            @foreach (var n in notifications)
            {
                string icon = n.Type switch
                {
                    "ReportUpdate" => "fa-flag",
                    "OrderUpdate" => "fa-box",
                    "Message" => "fa-comment",
                    _ => "fa-info-circle"
                };

                <form method="post" asp-page-handler="OpenNotification" class="ig-notif-form">
                    <input type="hidden" name="notificationId" value="@n.NotificationID" />
                    <button type="submit" class="ig-notif-row @(n.IsRead ? "" : "unread")">
                        <div class="ig-notif-icon">
                            <i class="fas @icon"></i>
                        </div>
                        <div class="ig-notif-body">
                            <div class="ig-notif-text">
                                <strong>@n.Title</strong>
                                <span>@n.Message</span>
                            </div>
                            <div class="ig-notif-time">@n.SentAt.ToString("MMM d, h:mm tt")</div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <span class="ig-notif-dot"></span>
                        }
                    </button>
                </form>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="padding: 40px 20px;">
            <div class="empty-icon" style="font-size: 40px;"><i class="fas fa-bell"></i></div>
            <h3 style="font-size: 17px;">No Notifications Yet</h3>
            <p style="font-size: 13px;">Updates about your reports, orders, and messages will show up here.</p>
        </div>
    }
</div>

<style>
    .ig-notif-list {
        display: flex;
        flex-direction: column;
    }

    .ig-notif-form {
        margin: 0;
    }

    .ig-notif-row {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 14px;
        background: none;
        border: none;
        border-bottom: 1px solid var(--border-color);
        padding: 14px 4px;
        cursor: pointer;
        text-align: left;
        transition: background-color 0.15s ease;
    }

        .ig-notif-row:hover {
            background-color: var(--bg-color);
        }

        .ig-notif-row.unread {
            background-color: var(--accent-light);
        }

    .ig-notif-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: var(--accent-gradient);
        color: #fff;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }

    .ig-notif-body {
        flex-grow: 1;
        min-width: 0;
    }

    .ig-notif-text {
        font-size: 13.5px;
        line-height: 1.4;
        color: var(--text-primary);
    }

        .ig-notif-text strong {
            font-weight: 800;
            margin-right: 4px;
        }

        .ig-notif-text span {
            color: var(--text-secondary);
        }

    .ig-notif-time {
        font-size: 11.5px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    .ig-notif-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--accent-color);
        flex-shrink: 0;
    }
</style>