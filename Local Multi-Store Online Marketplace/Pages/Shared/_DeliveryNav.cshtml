@using System
@{
    var currentPath = Context.Request.Path.Value ?? "";

    string NavActiveClass(string path) =>
        currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase)
            ? "bottom-link active"
            : "bottom-link";
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Delivery"))
{
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --secondary: #38bdf8;
            --nav-bg-1: #0f172a;
            --nav-bg-2: #1e3a8a;
            --bg: #f8fafc;
        }

        body {
            background: var(--bg);
        }

        /* ================= BOTTOM NAV ALIGNED TO CONTENT WIDTH ================= */
        .bottom-nav-bar {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 18px;
            width: calc(100% - 48px);
            max-width: 1180px;
            margin: 0 auto;
            background: linear-gradient(135deg, var(--nav-bg-1), var(--nav-bg-2));
            border-radius: 22px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.3), 0 0 0 1px rgba(56, 189, 248, 0.1);
            display: flex;
            align-items: center;
            justify-content: space-around;
            padding: 14px 30px;
            z-index: 999;
        }

        .bottom-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            color: #94a3b8;
            text-decoration: none;
            padding: 10px 22px;
            border-radius: 14px;
            font-family: 'Inter', sans-serif;
            font-size: 12px;
            font-weight: 600;
            transition: all .2s ease;
            flex: 1;
            max-width: 180px;
        }

            .bottom-link .bottom-icon {
                font-size: 21px;
                line-height: 1;
                transition: transform .2s ease;
            }

            .bottom-link:hover {
                color: #e2e8f0;
            }

                .bottom-link:hover .bottom-icon {
                    transform: translateY(-2px);
                }

            .bottom-link.active {
                color: #ffffff;
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                box-shadow: 0 8px 20px rgba(37, 99, 235, 0.5), 0 0 0 4px rgba(56, 189, 248, 0.15);
            }

                .bottom-link.active .bottom-icon {
                    transform: translateY(-1px) scale(1.08);
                }

        /* ================= PAGE OFFSET FOR BOTTOM NAV ================= */
        .page {
            margin-left: 0 !important;
            padding-bottom: 110px !important;
        }

        @@media (max-width: 560px) {
            .bottom-nav-bar {
                padding: 10px 12px;
            }

            .bottom-link {
                padding: 8px 10px;
                font-size: 10px;
            }

                .bottom-link .bottom-icon {
                    font-size: 19px;
                }
        }
    </style>

    <nav class="bottom-nav-bar">

        <a href="/DeliveryDashboard" class="@NavActiveClass("/DeliveryDashboard")">
            <span class="bottom-icon">🏠</span>
            <span class="label">Dashboard</span>
        </a>

        <a href="/DeliveryOrders" class="@NavActiveClass("/DeliveryOrders")">
            <span class="bottom-icon">📦</span>
            <span class="label">Orders</span>
        </a>

        <a href="/Chat" class="@NavActiveClass("/Chat")">
            <span class="bottom-icon">💬</span>
            <span class="label">Chat</span>
        </a>

        <a href="/DeliveryProfile" class="@NavActiveClass("/DeliveryProfile")">
            <span class="bottom-icon">👤</span>
            <span class="label">Profile</span>
        </a>

    </nav>
}
