@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Delivery"))
{
    <style>
        .delivery-navbar {
            background: #1e3a5f;
            padding: 12px 20px;
            box-shadow: 0 4px 14px rgba(15, 23, 42, 0.16);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .delivery-navbar-inner {
            max-width: 1150px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 15px;
            flex-wrap: wrap;
        }

        .delivery-brand {
            color: white;
            font-weight: 900;
            font-size: 16px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .delivery-links {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

            .delivery-links a {
                color: #dbeafe;
                text-decoration: none;
                padding: 9px 14px;
                border-radius: 999px;
                font-size: 14px;
                font-weight: 800;
                transition: .2s;
                background: rgba(255, 255, 255, 0.06);
            }

                .delivery-links a:hover {
                    background: #ff6b35;
                    color: white;
                    transform: translateY(-1px);
                }

        @@media (max-width: 650px) {
            .delivery-navbar-inner {
                justify-content: center;
            }

            .delivery-brand {
                width: 100%;
                justify-content: center;
            }

            .delivery-links {
                justify-content: center;
            }

                .delivery-links a {
                    font-size: 12px;
                    padding: 8px 11px;
                }
        }
    </style>

    <nav class="delivery-navbar">
        <div class="delivery-navbar-inner">

            <a href="/DeliveryDashboard" class="delivery-brand">
                🚚 Delivery Panel
            </a>

            <div class="delivery-links">
                <a href="/DeliveryDashboard">
                    🏠 Dashboard
                </a>

                <a href="/DeliveryOrders">
                    📦 Orders
                </a>

                <a href="/Chat">
                    💬 Chat
                </a>

                <a href="/DeliveryProfile">
                    👤 Profile
                </a>
            </div>

        </div>
    </nav>
}