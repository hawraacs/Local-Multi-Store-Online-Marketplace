@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminReportsModel
@{
    ViewData["Title"] = "Reports";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --brand: #0EA5E9;
            --brand-dark: #0284C7;
            --brand-light: #7DD3FC;
            --brand-gradient: linear-gradient(135deg, #0EA5E9 0%, #2563EB 100%);
            --brand-soft: rgba(14, 165, 233, 0.10);
            --navy: #0B1437;
            --bg: #F0F4FA;
            --surface: #FFFFFF;
            --surface-2: #F8FAFE;
            --surface-hover: #F1F6FD;
            --border: #E4ECF6;
            --text: #0B1A33;
            --text-secondary: #4A5A7A;
            --muted: #7A8AA8;
            --positive: #10B981;
            --positive-bg: #D1FAE5;
            --positive-txt: #065F46;
            --warning: #F59E0B;
            --warning-bg: #FEF3C7;
            --warning-txt: #92400E;
            --danger: #EF4444;
            --danger-bg: #FEE2E2;
            --danger-txt: #991B1B;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --shadow: 0 1px 3px rgba(11, 20, 55, 0.06), 0 6px 20px -8px rgba(11, 20, 55, 0.10);
            --shadow-lg: 0 12px 40px -12px rgba(11, 20, 55, 0.18);
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        body {
            background: var(--bg);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
        }

        .dashboard {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px 48px;
        }

        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            padding: 32px 0 24px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 8px;
        }

        .header-left h1 {
            font-size: 28px;
            font-weight: 900;
            letter-spacing: -0.04em;
            background: var(--brand-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
        }

        .header-left p {
            font-size: 14px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .status-tabs {
            display: flex;
            gap: 10px;
            margin: 26px 0 22px;
            flex-wrap: wrap;
        }

        .status-tab {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            transition: all var(--transition);
        }

            .status-tab:hover {
                border-color: var(--brand-light);
                color: var(--brand-dark);
            }

            .status-tab.active {
                background: var(--brand-gradient);
                color: #fff;
                border-color: transparent;
                box-shadow: 0 6px 16px rgba(14, 165, 233, 0.25);
            }

            .status-tab .count-pill {
                background: rgba(255,255,255,0.25);
                padding: 1px 8px;
                border-radius: 999px;
                font-size: 11px;
            }

            .status-tab:not(.active) .count-pill {
                background: var(--surface-2);
                border: 1px solid var(--border);
            }

        .report-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 22px 24px;
            box-shadow: var(--shadow);
            margin-bottom: 16px;
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .report-card:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

        .report-top-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .report-parties {
            font-size: 14.5px;
            font-weight: 600;
            color: var(--text);
        }

            .report-parties .arrow {
                color: var(--muted);
                margin: 0 8px;
                font-weight: 400;
            }

            .report-parties .target-type-tag {
                display: inline-block;
                margin-left: 8px;
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: var(--brand-dark);
                background: var(--brand-soft);
                padding: 2px 9px;
                border-radius: 999px;
            }

        .report-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .report-type-badge {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 4px 12px;
            border-radius: 999px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            white-space: nowrap;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 700;
        }

            .status-badge::before {
                content: "";
                width: 5px;
                height: 5px;
                border-radius: 50%;
            }

        .status-pending-review {
            background: var(--warning-bg);
            color: var(--warning-txt);
        }

            .status-pending-review::before {
                background: var(--warning);
            }

        .status-resolved {
            background: var(--positive-bg);
            color: var(--positive-txt);
        }

            .status-resolved::before {
                background: var(--positive);
            }

        .status-dismissed {
            background: var(--danger-bg);
            color: var(--danger-txt);
        }

            .status-dismissed::before {
                background: var(--danger);
            }

        .report-description {
            font-size: 13.5px;
            color: var(--text-secondary);
            line-height: 1.6;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 14px;
        }

        .report-admin-notes {
            font-size: 12.5px;
            color: var(--text-secondary);
            margin-bottom: 12px;
        }

            .report-admin-notes strong {
                color: var(--text);
            }

        .report-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .report-date {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
        }

        .report-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

            .report-actions form {
                margin: 0;
                display: flex;
                gap: 8px;
            }

        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 10px;
            border: none;
            font-size: 12.5px;
            font-weight: 700;
            cursor: pointer;
            transition: all var(--transition);
        }

        .action-resolve {
            background: var(--positive-bg);
            color: var(--positive-txt);
        }

            .action-resolve:hover {
                background: var(--positive);
                color: #fff;
            }

        .action-dismiss {
            background: var(--danger-bg);
            color: var(--danger-txt);
        }

            .action-dismiss:hover {
                background: var(--danger);
                color: #fff;
            }

        .action-reopen {
            background: var(--surface-2);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

            .action-reopen:hover {
                border-color: var(--brand-light);
                color: var(--brand-dark);
            }

        .notes-input {
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 10px;
            font-size: 12.5px;
            font-family: var(--font);
            min-width: 220px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 16px;
            color: var(--muted);
            font-size: 14px;
            font-weight: 500;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }

            .empty-state i {
                font-size: 32px;
                color: var(--border);
                display: block;
                margin-bottom: 12px;
            }

        @@media (max-width: 700px) {
            .report-footer {
                flex-direction: column;
                align-items: stretch;
            }

            .report-actions form {
                flex-direction: column;
            }

            .notes-input {
                min-width: 0;
                width: 100%;
            }
        }
    </style>
}

<div class="dashboard">

    <div class="dashboard-header">
        <div class="header-left">
            <h1>Reports</h1>
            <p>Review reports filed by customers and store owners across the marketplace</p>
        </div>
    </div>

    <div class="status-tabs">
        <a class="status-tab @(Model.StatusFilter == "Pending Review" ? "active" : "")"
           href="@Url.Page("AdminReports", new { StatusFilter = "Pending Review" })">
            <i class="fas fa-hourglass-half"></i> Pending
            <span class="count-pill">@Model.PendingCount</span>
        </a>
        <a class="status-tab @(Model.StatusFilter == "Resolved" ? "active" : "")"
           href="@Url.Page("AdminReports", new { StatusFilter = "Resolved" })">
            <i class="fas fa-circle-check"></i> Resolved
            <span class="count-pill">@Model.ResolvedCount</span>
        </a>
        <a class="status-tab @(Model.StatusFilter == "Dismissed" ? "active" : "")"
           href="@Url.Page("AdminReports", new { StatusFilter = "Dismissed" })">
            <i class="fas fa-ban"></i> Dismissed
            <span class="count-pill">@Model.DismissedCount</span>
        </a>
        <a class="status-tab @(Model.StatusFilter == "All" ? "active" : "")"
           href="@Url.Page("AdminReports", new { StatusFilter = "All" })">
            <i class="fas fa-layer-group"></i> All
        </a>
    </div>

    @if (!Model.Reports.Any())
    {
        <div class="empty-state">
            <i class="fas fa-flag"></i>
            No reports in this category.
        </div>
    }
    else
    {
        @foreach (var r in Model.Reports)
        {
            var statusClass = r.Status switch
            {
                "Resolved" => "status-resolved",
                "Dismissed" => "status-dismissed",
                _ => "status-pending-review"
            };

            <div class="report-card">
                <div class="report-top-row">
                    <div class="report-parties">
                        @r.ReporterLabel
                        <span class="arrow">reported</span>
                        @r.TargetLabel
                        <span class="target-type-tag">@r.TargetType</span>
                    </div>

                    <div class="report-meta">
                        <span class="report-type-badge">@r.Reason</span>
                        <span class="status-badge @statusClass">@r.Status</span>
                    </div>
                </div>

                <div class="report-description">"@r.Description"</div>

                @if (!string.IsNullOrWhiteSpace(r.AdminNotes))
                {
                    <div class="report-admin-notes">
                        <strong>Admin notes:</strong> @r.AdminNotes
                    </div>
                }

                <div class="report-footer">
                    <span class="report-date">
                        Filed @r.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                        @if (r.ResolvedAt.HasValue)
                        {
                            <text> &middot; Closed @r.ResolvedAt.Value.ToString("dd MMM yyyy")</text>
                        }
                    </span>

                    <div class="report-actions">
                        @if (r.Status == "Pending Review")
                        {
                            <form method="post" asp-page-handler="Resolve" asp-route-reportId="@r.ReportID">
                                <input type="text" name="adminNotes" class="notes-input" placeholder="Optional note..." />
                                <button type="submit" class="action-btn action-resolve">
                                    <i class="fas fa-check"></i> Resolve
                                </button>
                            </form>

                            <form method="post" asp-page-handler="Dismiss" asp-route-reportId="@r.ReportID">
                                <input type="text" name="adminNotes" class="notes-input" placeholder="Optional note..." />
                                <button type="submit" class="action-btn action-dismiss">
                                    <i class="fas fa-xmark"></i> Dismiss
                                </button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Reopen" asp-route-reportId="@r.ReportID">
                                <button type="submit" class="action-btn action-reopen">
                                    <i class="fas fa-rotate-left"></i> Reopen
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }

</div>