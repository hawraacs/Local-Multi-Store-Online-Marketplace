@page
@model Local_Multi_Store_Online_Marketplace.Pages.Admin1Model
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" rel="preload" as="script">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand:        #0EA5E9;
            --brand-dark:   #0284C7;
            --brand-soft:   rgba(14, 165, 233, 0.10);
            --navy:         #0B1437;
            --navy-mid:     #162050;
            --bg:           #F1F5FB;
            --surface:      #FFFFFF;
            --surface-2:    #F8FAFD;
            --border:       #E4EAF4;
            --text:         #0F172A;
            --muted:        #64748B;
            --positive:     #10B981;
            --positive-bg:  #D1FAE5;
            --positive-txt: #065F46;
            --warn-bg:      #FEF3C7;
            --warn-txt:     #92400E;
            --radius-sm:    10px;
            --radius:       16px;
            --radius-lg:    22px;
            --shadow-sm:    0 1px 2px rgba(15,23,42,0.05);
            --shadow:       0 1px 3px rgba(15,23,42,0.06), 0 6px 20px -8px rgba(15,23,42,0.10);
            --shadow-lg:    0 12px 32px -8px rgba(15,23,42,0.16);
            --font:         'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; }

        .dashboard {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 4px 48px;
            color: var(--text);
            font-family: var(--font);
            background: transparent;
        }

        /* ── Header ─────────────────────────────────────────── */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px;
            padding: 28px 4px 24px;
            margin-bottom: 4px;
            border-bottom: 1px solid var(--border);
        }

        .header-left h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin: 0 0 4px;
            color: var(--text);
        }

        .header-left p {
            font-size: 13.5px;
            color: var(--muted);
            margin: 0;
            font-weight: 400;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-badge {
            display: flex;
            align-items: center;
            gap: 7px;
            background: var(--navy);
            color: #fff;
            border-radius: 999px;
            padding: 8px 16px 8px 12px;
            font-size: 12.5px;
            font-weight: 600;
            letter-spacing: 0.01em;
            box-shadow: 0 2px 10px rgba(11,20,55,0.18);
        }

        .header-badge::before {
            content: "";
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--brand);
            flex-shrink: 0;
        }

        /* ── Stat Cards ──────────────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 18px;
            margin: 28px 0;
        }

        .stat-card {
            position: relative;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px 22px 20px;
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: transform 0.22s ease, box-shadow 0.22s ease;
        }

        .stat-card::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: var(--radius);
            background: linear-gradient(135deg, var(--brand-soft) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card:hover::after { opacity: 1; }

        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-sm);
            background: var(--brand-soft);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }

        .stat-icon svg {
            width: 20px;
            height: 20px;
            stroke: var(--brand);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .stat-title {
            color: var(--muted);
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: var(--text);
            line-height: 1;
            margin-bottom: 12px;
        }

        .stat-change {
            font-size: 12.5px;
            color: var(--muted);
            font-weight: 500;
            border-top: 1px solid var(--border);
            padding-top: 10px;
            margin-top: 2px;
        }

        .stat-change .positive {
            color: var(--positive);
            font-weight: 700;
        }

        /* ── Chart Panels ────────────────────────────────────── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 26px 26px 22px;
            box-shadow: var(--shadow);
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .panel-header h3 {
            font-size: 15px;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin: 0;
            color: var(--text);
        }

        .panel-tag {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--brand);
            background: var(--brand-soft);
            padding: 4px 10px;
            border-radius: 999px;
        }

        .panel canvas {
            max-height: 290px;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media (max-width: 860px) {
            .grid-2 { grid-template-columns: 1fr; }
        }

        /* ── Tables ──────────────────────────────────────────── */
        .table-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 26px 26px 10px;
            box-shadow: var(--shadow);
            margin-bottom: 20px;
        }

        .table-panel .panel-header {
            margin-bottom: 16px;
        }

        .table-responsive { overflow-x: auto; }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        thead th:first-child { border-radius: var(--radius-sm) 0 0 0; }
        thead th:last-child  { border-radius: 0 var(--radius-sm) 0 0; }

        tbody td {
            padding: 14px;
            text-align: left;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-weight: 500;
        }

        tbody tr {
            transition: background 0.14s ease;
        }

        tbody tr:hover td { background: var(--surface-2); }
        tbody tr:last-child td { border-bottom: none; }

        .store-name {
            font-weight: 600;
            color: var(--navy);
        }

        .amount {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--text);
        }

        .order-num {
            font-family: 'Courier New', monospace;
            font-size: 12.5px;
            color: var(--muted);
            background: var(--surface-2);
            padding: 3px 8px;
            border-radius: 5px;
            border: 1px solid var(--border);
        }

        /* ── Badges ──────────────────────────────────────────── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .badge::before {
            content: "";
            width: 5px;
            height: 5px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .badge-delivered {
            background: var(--positive-bg);
            color: var(--positive-txt);
        }
        .badge-delivered::before { background: var(--positive); }

        .badge-pending {
            background: var(--warn-bg);
            color: var(--warn-txt);
        }
        .badge-pending::before { background: #F59E0B; }

        /* ── Section divider ─────────────────────────────────── */
        .section-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin: 28px 0 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-label::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--border);
        }
    </style>
}

<div class="dashboard">

    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-left">
            <h1>Admin Dashboard</h1>
            <p>Marketplace performance overview &amp; activity monitor</p>
        </div>
        <div class="header-right">
            <span class="header-badge">Marketplace Overview</span>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div class="stat-title">Platform Revenue</div>
            <div class="stat-value">$@Model.TotalPlatformRevenue.ToString("N0")</div>
            <div class="stat-change">
                $@Model.TotalCommission.ToString("N0") commission &middot;
                $@Model.TotalSubscriptionRevenue.ToString("N0") subscriptions
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            </div>
            <div class="stat-title">Total Orders</div>
            <div class="stat-value">@Model.TotalOrders</div>
            <div class="stat-change">
                <span class="positive">↑ @Model.RevenueGrowthPercentage.ToString("N1")%</span>
                vs previous month
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div class="stat-title">Active Stores</div>
            <div class="stat-value">@Model.ActiveStores</div>
            <div class="stat-change">
                <span class="positive">↑ +3 new</span> this month
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div class="stat-title">Total Users</div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-change">
                <span class="positive">↑ +15%</span> growth
            </div>
        </div>

    </div>

    <!-- Charts -->
    <div class="section-label">Analytics</div>
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header">
                <h3>Platform Revenue</h3>
                <span class="panel-tag">Last 12 Months</span>
            </div>
            <canvas id="revenueChart"></canvas>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h3>Orders Per Month</h3>
                <span class="panel-tag">Last 12 Months</span>
            </div>
            <canvas id="ordersChart"></canvas>
        </div>
    </div>

    <!-- Top Stores -->
    <div class="section-label">Store Performance</div>
    <div class="table-panel">
        <div class="panel-header">
            <h3>Top Performing Stores</h3>
        </div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Store Name</th>
                    <th>Total Revenue</th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var store in Model.TopStores)
                {
                    <tr>
                        <td style="color:var(--muted);font-size:12px;font-weight:700;">@(rank++)</td>
                        <td><span class="store-name">@store.StoreName</span></td>
                        <td><span class="amount">$@store.Revenue.ToString("N2")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Recent Orders -->
    <div class="section-label">Activity</div>
    <div class="table-panel">
        <div class="panel-header">
            <h3>Recent Orders</h3>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Store</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td><span class="order-num">@order.OrderNumber</span></td>
                            <td>@order.CustomerName</td>
                            <td><span class="store-name">@order.StoreName</span></td>
                            <td><span class="amount">$@order.Amount</span></td>
                            <td>
                                <span class="badge @(order.Status == "Delivered" ? "badge-delivered" : "badge-pending")">
                                    @order.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <script>
        const revenueLabels =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueLabels));

        const revenueData =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueData));

        new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: revenueLabels,
                datasets: [{
                    label: 'Revenue',
                    data: revenueData,
                    borderColor: '#0EA5E9',
                    backgroundColor: 'rgba(14,165,233,0.10)',
                    fill: true,
                    tension: 0.40,
                    borderWidth: 2.5,
                    pointRadius: 3,
                    pointBackgroundColor: '#0EA5E9',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#E4EAF4', drawBorder: false },
                        ticks: { color: '#64748B', font: { size: 11, family: 'Inter' } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748B', font: { size: 11, family: 'Inter' } }
                    }
                }
            }
        });

        const orderLabels =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderLabels));

        const orderData =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderData));

        new Chart(document.getElementById('ordersChart'), {
            type: 'bar',
            data: {
                labels: orderLabels,
                datasets: [{
                    label: 'Orders',
                    data: orderData,
                    backgroundColor: 'rgba(14,165,233,0.85)',
                    hoverBackgroundColor: '#0284C7',
                    borderRadius: 8,
                    maxBarThickness: 32
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#E4EAF4', drawBorder: false },
                        ticks: { color: '#64748B', font: { size: 11, family: 'Inter' } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748B', font: { size: 11, family: 'Inter' } }
                    }
                }
            }
        });
    </script>
}