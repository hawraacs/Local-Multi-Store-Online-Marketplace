@page
@model Local_Multi_Store_Online_Marketplace.Pages.Admin1Model
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            min-height: 100vh;
        }

        .topbar {
            background: rgba(10, 15, 25, 0.92);
            backdrop-filter: blur(12px);
            color: white;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

            .topbar > div:first-child {
                font-size: 26px;
                font-weight: 700;
                letter-spacing: -0.5px;
                background: linear-gradient(135deg, #FFFFFF 0%, #B0C4DE 100%);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

            .topbar div:last-child {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
            }

            .topbar a {
                color: #eef2ff;
                text-decoration: none;
                font-weight: 500;
                padding: 8px 16px;
                border-radius: 40px;
                transition: all 0.2s ease;
                font-size: 15px;
            }

                .topbar a:hover {
                    background: rgba(255, 255, 255, 0.15);
                    transform: translateY(-1px);
                }

        .container {
            max-width: 1200px;
            width: 90%;
            margin: 48px auto;
            padding: 0 20px;
        }

        .page-header {
            margin-bottom: 32px;
        }

            .page-header h1 {
                font-size: 32px;
                font-weight: 700;
                color: #0f172a;
                letter-spacing: -0.3px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .page-header h1 i {
                    color: #FF6B35;
                    font-size: 32px;
                }

        .menu {
            display: flex;
            flex-wrap: wrap;
            gap: 28px;
            margin-top: 20px;
        }

        .card {
            background: white;
            padding: 28px 24px;
            border-radius: 28px;
            text-decoration: none;
            color: #0f172a;
            width: 260px;
            box-shadow: 0 12px 24px -12px rgba(0, 0, 0, 0.1);
            transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(0, 0, 0, 0.04);
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

            .card:hover {
                transform: translateY(-6px);
                box-shadow: 0 24px 36px -12px rgba(0, 0, 0, 0.2);
                border-color: #FF6B3520;
            }

        .card-icon {
            font-size: 48px;
            margin-bottom: 8px;
        }

        .card h3 {
            font-size: 24px;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.2px;
        }

        .card p {
            font-size: 14px;
            color: #475569;
            line-height: 1.5;
            margin: 0;
        }

        .admin-badge {
            display: inline-block;
            background: #FF6B3510;
            color: #FF6B35;
            border-radius: 40px;
            padding: 6px 14px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        @@media (max-width: 640px) {
            .topbar {
                padding: 12px 24px;
                flex-direction: column;
                gap: 12px;
            }

            .container {
                width: 95%;
                margin: 32px auto;
            }

            .menu {
                justify-content: center;
            }

            .card {
                width: 100%;
                text-align: center;
                align-items: center;
            }

            .page-header h1 {
                font-size: 28px;
            }
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            animation: fadeUp 0.5s ease forwards;
        }

        footer {
            text-align: center;
            padding: 32px 20px 40px;
            color: #5b6e8c;
            font-size: 13px;
            border-top: 1px solid rgba(0,0,0,0.05);
            margin-top: 40px;
        }

        .admin-logout-btn {
            color: white;
            background: rgba(239, 68, 68, 0.18);
            border: 1px solid rgba(239, 68, 68, 0.45);
            padding: 8px 14px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.2s ease;
        }

            .admin-logout-btn:hover {
                background: #ef4444;
                transform: translateY(-1px);
            }
    </style>
</head>
<body>

    <div class="topbar">
        <div>realnest</div>
        <div>
            <a href="/Admin1"><i class="fas fa-chalkboard-user"></i> Dashboard</a>
            <a href="/AdminUsers"><i class="fas fa-users"></i> Users</a>
            <a href="/AdminStores"><i class="fas fa-store"></i> Stores</a>
            <a href="/AdminDelivery"><i class="fas fa-truck-fast"></i> Delivery</a>
            <form method="post"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="/"
                  style="display:inline;">
                <button type="submit" class="admin-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <div class="container">
        <div class="page-header">
            <div class="admin-badge">
                <i class="fas fa-shield-alt"></i> Administrator Access
            </div>
            <h1>
                <i class="fas fa-gauge-high"></i>
                Admin Panel
            </h1>
        </div>

        <div class="menu">

            <a asp-page="/AdminUsers" class="card">
                <div class="card-icon">👥</div>
                <h3>Users</h3>
                <p>Approve new customers, manage active accounts, and control platform access.</p>
            </a>

            <a asp-page="/AdminStores" class="card">
                <div class="card-icon">🏪</div>
                <h3>Stores</h3>
                <p>Manage store approvals, verify seller accounts, and oversee store listings.</p>
            </a>

            <a asp-page="/AdminDelivery" class="card">
                <div class="card-icon">🚚</div>
                <h3>Delivery</h3>
                <p>Manage delivery staff, track performance, and handle delivery requests.</p>
            </a>

        </div>
    </div>

    <footer>
        <span>✨ Realnest Admin — control center ✨</span>
    </footer>

</body>
</html>