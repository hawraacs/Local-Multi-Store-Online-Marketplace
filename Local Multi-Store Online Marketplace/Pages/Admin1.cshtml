@page
@model Local_Multi_Store_Online_Marketplace.Pages.Admin1Model
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ── Reset & Variables ── */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --brand: #0EA5E9;
            --brand-dark: #0284C7;
            --brand-light: #7DD3FC;
            --brand-gradient: linear-gradient(135deg, #0EA5E9 0%, #2563EB 100%);
            --brand-soft: rgba(14, 165, 233, 0.10);
            --brand-soft-hover: rgba(14, 165, 233, 0.18);
            --navy: #0B1437;
            --navy-light: #1A2745;
            --bg: #F0F4FA;
            --surface: #FFFFFF;
            --surface-2: #F8FAFE;
            --surface-hover: #F1F6FD;
            --border: #E4ECF6;
            --text: #0B1A33;
            --text-secondary: #4A5A7A;
            --muted: #7A8AA8;
            --positive: #10B981;
            --positive-bg: #D1FAE5;
            --positive-txt: #065F46;
            --warning: #F59E0B;
            --warning-bg: #FEF3C7;
            --warning-txt: #92400E;
            --danger: #EF4444;
            --danger-bg: #FEE2E2;
            --danger-txt: #991B1B;
            --info: #3B82F6;
            --info-bg: #DBEAFE;
            --info-txt: #1E40AF;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --shadow: 0 1px 3px rgba(11, 20, 55, 0.06), 0 6px 20px -8px rgba(11, 20, 55, 0.10);
            --shadow-lg: 0 12px 40px -12px rgba(11, 20, 55, 0.18);
            --shadow-hover: 0 16px 48px -12px rgba(11, 20, 55, 0.22);
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        html {
            font-size: 16px;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            background: var(--bg);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
        }

        /* ── Layout ── */
        .dashboard {
            max-width: 1360px;
            margin: 0 auto;
            padding: 0 20px 48px;
        }

        /* ── Header ── */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            padding: 32px 0 24px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 8px;
        }

        .header-left {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .header-left h1 {
                font-size: 28px;
                font-weight: 900;
                letter-spacing: -0.04em;
                line-height: 1.1;
                background: var(--brand-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

            .header-left p {
                font-size: 14px;
                color: var(--text-secondary);
                font-weight: 500;
                margin: 0;
            }

        .header-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--navy);
            color: #fff;
            border-radius: 999px;
            padding: 8px 18px 8px 14px;
            font-size: 12.5px;
            font-weight: 600;
            letter-spacing: 0.02em;
            box-shadow: 0 4px 16px rgba(11, 20, 55, 0.20);
            white-space: nowrap;
        }

            .header-badge .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--brand);
                flex-shrink: 0;
                animation: pulse-dot 2s ease-in-out infinite;
            }

        @@keyframes pulse-dot {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.85);
            }
        }

        /* ── Stat Cards ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
            margin: 28px 0 32px;
        }

        @@media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .stats-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
        }

        .stat-card {
            position: relative;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 22px 20px 18px;
            box-shadow: var(--shadow);
            transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--brand-gradient);
                opacity: 0;
                transition: opacity var(--transition);
            }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-hover);
                border-color: var(--brand-light);
            }

                .stat-card:hover::before {
                    opacity: 1;
                }

        .stat-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--radius-sm);
            background: var(--brand-soft);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background var(--transition), transform var(--transition);
            font-size: 20px;
            color: var(--brand);
        }

        .stat-card:hover .stat-icon {
            background: var(--brand-soft-hover);
            transform: scale(1.05);
        }

        .stat-trend {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--muted);
            background: var(--surface-2);
            padding: 2px 10px;
            border-radius: 999px;
            border: 1px solid var(--border);
            white-space: nowrap;
        }

        .stat-body {
            flex: 1;
        }

        .stat-title {
            color: var(--text-secondary);
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -0.03em;
            line-height: 1.1;
            margin-bottom: 10px;
            color: var(--text);
        }

            .stat-value .currency {
                font-size: 18px;
                font-weight: 700;
                color: var(--text-secondary);
                margin-right: 2px;
            }

        .stat-footer {
            display: flex;
            align-items: center;
            gap: 8px;
            border-top: 1px solid var(--border);
            padding-top: 10px;
            margin-top: auto;
            font-size: 12.5px;
            font-weight: 500;
            color: var(--text-secondary);
            flex-wrap: wrap;
        }

            .stat-footer .positive {
                color: var(--positive);
                font-weight: 700;
                display: inline-flex;
                align-items: center;
                gap: 4px;
            }

                .stat-footer .positive i {
                    font-size: 11px;
                }

            .stat-footer .neutral {
                color: var(--muted);
                font-weight: 500;
            }

        /* ── Section Label ── */
        .section-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--muted);
            margin: 32px 0 16px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .section-label::after {
                content: "";
                flex: 1;
                height: 1.5px;
                background: var(--border);
                border-radius: 2px;
            }

            .section-label .label-icon {
                color: var(--brand);
                font-size: 14px;
            }

        /* ── Panels ── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px 28px 28px;
            box-shadow: var(--shadow);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .panel:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
        }

            .panel-header h3 {
                font-size: 16px;
                font-weight: 700;
                letter-spacing: -0.02em;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .panel-header h3 i {
                    color: var(--brand);
                    font-size: 18px;
                }

        .panel-tag {
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--brand);
            background: var(--brand-soft);
            padding: 4px 12px;
            border-radius: 999px;
            border: 1px solid rgba(14, 165, 233, 0.15);
        }

        .panel canvas {
            max-height: 280px;
        }

        /* ── Grid for charts ── */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media (max-width: 860px) {
            .grid-2 {
                grid-template-columns: 1fr;
                gap: 16px;
            }
        }

        /* ── Tables ── */
        .table-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px 28px 12px;
            box-shadow: var(--shadow);
            margin-bottom: 24px;
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .table-panel:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

            .table-panel .panel-header {
                margin-bottom: 16px;
            }

        .table-responsive {
            overflow-x: auto;
            margin: 0 -4px;
            padding: 0 4px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13.5px;
        }

        thead th {
            padding: 12px 16px;
            text-align: left;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            background: var(--surface-2);
            border-bottom: 1.5px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 2;
        }

            thead th:first-child {
                border-radius: var(--radius-sm) 0 0 0;
                padding-left: 20px;
            }

            thead th:last-child {
                border-radius: 0 var(--radius-sm) 0 0;
                padding-right: 20px;
            }

        tbody td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-weight: 500;
            vertical-align: middle;
            transition: background var(--transition);
        }

            tbody td:first-child {
                padding-left: 20px;
            }

            tbody td:last-child {
                padding-right: 20px;
            }

        tbody tr {
            transition: background var(--transition);
        }

            tbody tr:hover td {
                background: var(--surface-hover);
            }

            tbody tr:last-child td {
                border-bottom: none;
            }

        .store-name {
            font-weight: 600;
            color: var(--navy);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .store-name .avatar {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                background: var(--brand-soft);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 700;
                color: var(--brand);
                flex-shrink: 0;
            }

        .amount {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--text);
        }

        .order-num {
            font-family: 'Courier New', monospace;
            font-size: 12.5px;
            color: var(--text-secondary);
            background: var(--surface-2);
            padding: 2px 10px;
            border-radius: 6px;
            border: 1px solid var(--border);
            display: inline-block;
        }

        .rank-num {
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            text-align: center;
            width: 32px;
            display: inline-block;
        }

        /* ── Badges ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: 0.02em;
            text-transform: capitalize;
        }

            .badge::before {
                content: "";
                width: 5px;
                height: 5px;
                border-radius: 50%;
                flex-shrink: 0;
            }

        .badge-delivered {
            background: var(--positive-bg);
            color: var(--positive-txt);
        }

            .badge-delivered::before {
                background: var(--positive);
            }

        .badge-processing {
            background: var(--info-bg);
            color: var(--info-txt);
        }

            .badge-processing::before {
                background: var(--info);
            }

        .badge-pending {
            background: var(--warning-bg);
            color: var(--warning-txt);
        }

            .badge-pending::before {
                background: var(--warning);
            }

        .badge-cancelled {
            background: var(--danger-bg);
            color: var(--danger-txt);
        }

            .badge-cancelled::before {
                background: var(--danger);
            }

        /* ── Status styles for stores ── */
        .status-active {
            color: var(--positive);
            font-weight: 600;
        }

        .status-inactive {
            color: var(--muted);
            font-weight: 500;
        }

        .status-pending {
            color: var(--warning);
            font-weight: 600;
        }

        /* ── Responsive tweaks ── */
        @@media (max-width: 600px) {
            .dashboard {
                padding: 0 12px 32px;
            }

            .panel, .table-panel {
                padding: 16px 14px 18px;
            }

            .stat-card {
                padding: 16px 14px 14px;
            }

            .stat-value {
                font-size: 24px;
            }

            .stat-icon {
                width: 36px;
                height: 36px;
                font-size: 16px;
            }

            .dashboard-header h1 {
                font-size: 22px;
            }

            .header-badge {
                font-size: 11px;
                padding: 6px 14px 6px 10px;
            }
        }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 32px 16px;
            color: var(--muted);
            font-size: 14px;
            font-weight: 500;
        }

            .empty-state i {
                font-size: 28px;
                color: var(--border);
                display: block;
                margin-bottom: 10px;
            }
    </style>
}

<div class="dashboard">

    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-left">
            <h1>Admin Dashboard</h1>
            <p>Marketplace performance overview &amp; activity monitor</p>
        </div>
        <div class="header-badge">
            <span class="dot"></span>
            Marketplace Overview
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon"><i class="fas fa-chart-pie"></i></div>
                <span class="stat-trend">Platform</span>
            </div>
            <div class="stat-body">
                <div class="stat-title">Platform Revenue</div>
                <div class="stat-value">
                    <span class="currency">$</span>@Model.TotalPlatformRevenue.ToString("N0")
                </div>
            </div>
            <div class="stat-footer">
                <span class="neutral"><i class="fas fa-percent"></i> $@Model.TotalCommission.ToString("N0") commission</span>
                <span>·</span>
                <span class="neutral"><i class="fas fa-calendar-check"></i> $@Model.TotalSubscriptionRevenue.ToString("N0") subscriptions</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
                <span class="stat-trend">All time</span>
            </div>
            <div class="stat-body">
                <div class="stat-title">Total Orders</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
            <div class="stat-footer">
                <span class="positive"><i class="fas fa-arrow-up"></i> @Model.RevenueGrowthPercentage.ToString("N1")%</span>
                <span>vs previous month</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon"><i class="fas fa-store"></i></div>
                <span class="stat-trend">Active</span>
            </div>
            <div class="stat-body">
                <div class="stat-title">Active Stores</div>
                <div class="stat-value">@Model.ActiveStores</div>
            </div>
            <div class="stat-footer">
                <span class="positive"><i class="fas fa-plus-circle"></i> +@Model.NewStoresThisMonth new</span>
                <span>this month</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <span class="stat-trend">Total</span>
            </div>
            <div class="stat-body">
                <div class="stat-title">Total Users</div>
                <div class="stat-value">@Model.TotalUsers</div>
            </div>
            <div class="stat-footer">
                <span class="positive"><i class="fas fa-arrow-up"></i> @Model.UserGrowthPercentage.ToString("N1")%</span>
                <span>growth</span>
            </div>
        </div>

    </div>

    <!-- Charts -->
    <div class="section-label">
        <span class="label-icon"><i class="fas fa-chart-line"></i></span>
        Analytics
    </div>
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header">
                <h3><i class="fas fa-dollar-sign"></i> Platform Revenue</h3>
                <span class="panel-tag">Last 12 Months</span>
            </div>
            <canvas id="revenueChart"></canvas>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h3><i class="fas fa-boxes"></i> Orders Per Month</h3>
                <span class="panel-tag">Last 12 Months</span>
            </div>
            <canvas id="ordersChart"></canvas>
        </div>
    </div>

    <!-- Top Stores -->
    <div class="section-label">
        <span class="label-icon"><i class="fas fa-trophy"></i></span>
        Store Performance
    </div>
    <div class="table-panel">
        <div class="panel-header">
            <h3><i class="fas fa-crown"></i> Top Performing Stores</h3>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th style="width:50px;">#</th>
                        <th>Store Name</th>
                        <th style="text-align:right;">Total Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.TopStores.Any())
                    {
                        <tr>
                            <td colspan="3" class="empty-state">
                                <i class="fas fa-store-alt-slash"></i> No store data available.
                            </td>
                        </tr>
                    }
                    else
                    {
                        int rank = 1;
                        @foreach (var store in Model.TopStores)
                        {
                            var initials = string.Join("", store.StoreName.Split(' ').Where(w => w.Length > 0).Select(w => w[0])).ToUpper();
                            if (initials.Length > 2) initials = initials.Substring(0, 2);
                            <tr>
                                <td><span class="rank-num">@(rank++)</span></td>
                                <td>
                                    <span class="store-name">
                                        <span class="avatar">@initials</span>
                                        @store.StoreName
                                    </span>
                                </td>
                                <td style="text-align:right;"><span class="amount">$@store.Revenue.ToString("N2")</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="section-label">
        <span class="label-icon"><i class="fas fa-clock"></i></span>
        Activity
    </div>
    <div class="table-panel">
        <div class="panel-header">
            <h3><i class="fas fa-list-ul"></i> Recent Orders</h3>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Store</th>
                        <th style="text-align:right;">Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentOrders.Any())
                    {
                        <tr>
                            <td colspan="5" class="empty-state">
                                <i class="fas fa-box-open"></i> No recent orders.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model.RecentOrders)
                        {
                            var badgeClass = order.Status switch
                            {
                                "Delivered" => "badge-delivered",
                                "Processing" => "badge-processing",
                                "Cancelled" => "badge-cancelled",
                                _ => "badge-pending"
                            };
                            <tr>
                                <td><span class="order-num">@order.OrderNumber</span></td>
                                <td>@order.CustomerName</td>
                                <td><span class="store-name">@order.StoreName</span></td>
                                <td style="text-align:right;"><span class="amount">$@order.Amount</span></td>
                                <td><span class="badge @badgeClass">@order.Status</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Stores -->
    <div class="section-label">
        <span class="label-icon"><i class="fas fa-store-alt"></i></span>
        Stores
    </div>
    <div class="table-panel">
        <div class="panel-header">
            <h3><i class="fas fa-plus-circle"></i> Latest Registered Stores</h3>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Store Name</th>
                        <th>Created</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentStores.Any())
                    {
                        <tr>
                            <td colspan="3" class="empty-state">
                                <i class="fas fa-store-slash"></i> No stores registered yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var store in Model.RecentStores)
                        {
                            var statusClass = store.Status?.ToLower() switch
                            {
                                "active" => "status-active",
                                "pending" => "status-pending",
                                _ => "status-inactive"
                            };
                            <tr>
                                <td>
                                    <span class="store-name">
                                        @{
                                            var initials = string.Join("", store.StoreName.Split(' ').Where(w => w.Length > 0).Select(w => w[0])).ToUpper();
                                            if (initials.Length > 2) initials = initials.Substring(0, 2);
                                        }
                                        <span class="avatar">@initials</span>
                                        @store.StoreName
                                    </span>
                                </td>
                                <td>@store.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td><span class="@statusClass">@store.Status</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <script>
        (function() {
        'use strict';

        // ── Revenue Chart ──
        const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueLabels));
        const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueData));

        const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        const gradientRev = ctxRevenue.createLinearGradient(0, 0, 0, 280);
        gradientRev.addColorStop(0, 'rgba(14, 165, 233, 0.25)');
        gradientRev.addColorStop(0.5, 'rgba(14, 165, 233, 0.08)');
        gradientRev.addColorStop(1, 'rgba(14, 165, 233, 0.01)');

        new Chart(ctxRevenue, {
        type: 'line',
        data: {
        labels: revenueLabels,
        datasets: [{
        label: 'Revenue',
        data: revenueData,
        borderColor: '#0EA5E9',
        backgroundColor: gradientRev,
        fill: true,
        tension: 0.40,
        borderWidth: 2.5,
        pointRadius: 3.5,
        pointBackgroundColor: '#0EA5E9',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointHoverRadius: 7,
        pointHoverBackgroundColor: '#2563EB',
        pointHoverBorderColor: '#fff',
        pointHoverBorderWidth: 2.5,
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
        legend: { display: false },
        tooltip: {
        backgroundColor: 'rgba(11,20,55,0.92)',
        titleFont: { size: 12, weight: '600', family: 'Inter' },
        bodyFont: { size: 13, weight: '700', family: 'Inter' },
        padding: 12,
        cornerRadius: 10,
        titleColor: '#fff',
        bodyColor: '#fff',
        callbacks: {
        label: function(ctx) {
        return '$' + ctx.parsed.y.toLocaleString();
        }
        }
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        grid: { color: 'rgba(228,236,246,0.6)', drawBorder: false },
        ticks: {
        color: '#7A8AA8',
        font: { size: 11, family: 'Inter', weight: '500' },
        padding: 8,
        callback: function(val) { return '$' + val.toLocaleString(); }
        }
        },
        x: {
        grid: { display: false },
        ticks: {
        color: '#7A8AA8',
        font: { size: 11, family: 'Inter', weight: '500' },
        padding: 6,
        maxTicksLimit: 20,
        }
        }
        }
        }
        });

        // ── Orders Chart ──
        const orderLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderLabels));
        const orderData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderData));

        new Chart(document.getElementById('ordersChart'), {
        type: 'bar',
        data: {
        labels: orderLabels,
        datasets: [{
        label: 'Orders',
        data: orderData,
        backgroundColor: 'rgba(14,165,233,0.85)',
        hoverBackgroundColor: '#0284C7',
        borderRadius: 8,
        maxBarThickness: 32,
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false },
        tooltip: {
        backgroundColor: 'rgba(11,20,55,0.92)',
        titleFont: { size: 12, weight: '600', family: 'Inter' },
        bodyFont: { size: 13, weight: '700', family: 'Inter' },
        padding: 12,
        cornerRadius: 10,
        titleColor: '#fff',
        bodyColor: '#fff',
        callbacks: {
        label: function(ctx) {
        return ctx.parsed.y + ' orders';
        }
        }
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        grid: { color: 'rgba(228,236,246,0.6)', drawBorder: false },
        ticks: {
        color: '#7A8AA8',
        font: { size: 11, family: 'Inter', weight: '500' },
        padding: 8,
        stepSize: 1,
        }
        },
        x: {
        grid: { display: false },
        ticks: {
        color: '#7A8AA8',
        font: { size: 11, family: 'Inter', weight: '500' },
        padding: 6,
        maxTicksLimit: 20,
        }
        }
        }
        }
        });

        })();
    </script>
}