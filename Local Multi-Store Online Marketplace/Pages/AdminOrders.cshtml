@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminOrdersModel

@{
    ViewData["Title"] = "Order Management";

    var ordersJson =
        System.Text.Json.JsonSerializer.Serialize(
            Model.Orders,
            new System.Text.Json.JsonSerializerOptions
            {
                PropertyNamingPolicy =
                    System.Text.Json.JsonNamingPolicy.CamelCase
            });
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ============================================================
                   ADMIN THEME — matches Admin Dashboard (light / indigo+sky)
                   ============================================================ */
        :root {
            /* ── Backgrounds ── */
            --bg-color: #F8FAFC;
            --bg-soft: #F1F5F9;
            --card-bg: #FFFFFF;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --surface-hover: #F1F5F9;
            /* ── Text ── */
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            --text: #0F172A;
            /* ── Borders ── */
            --border-color: #E2E8F0;
            --border: #E2E8F0;
            /* ── Accent (Indigo + Sky) ── */
            --accent-color: #6366F1;
            --accent-hover: #4F46E5;
            --accent-light: #EEF2FF;
            --accent-gradient: linear-gradient(135deg, #6366F1 0%, #0EA5E9 100%);
            --brand: #6366F1;
            --brand-dark: #4338CA;
            --brand-light: #A5B4FC;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --brand-soft-hover: rgba(99, 102, 241, 0.15);
            /* ── Semantic States ── */
            --success: #16A34A;
            --success-bg: #DCFCE7;
            --success-txt: #15803D;
            --warning: #D97706;
            --warning-bg: #FEF3C7;
            --warning-txt: #B45309;
            --danger: #DC2626;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --info: #6366F1;
            --info-bg: #EEF2FF;
            --info-txt: #4338CA;
            /* ── Shadows ── */
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 3px rgba(15, 23, 42, 0.06);
            --shadow-md: 0 4px 12px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 12px 32px rgba(15, 23, 42, 0.10);
            --shadow-hover: 0 16px 40px rgba(15, 23, 42, 0.14);
            /* ── Radius / Font / Transition ── */
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 1.5rem;
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            --transition: 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            --navy: #0F172A;
            --navy-light: #1E293B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-color);
            font-family: var(--font);
            color: var(--text);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Container: full width inside admin-main, but constrained ── */
        .orders-container {
            width: 100%;
            max-width: 100%;
            margin: 0;
            padding: 0;
            min-width: 0; /* Allows container to shrink */
            overflow-x: hidden; /* Prevents container from scrolling */
        }

        /* ── Stats Grid ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 18px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 20px 22px;
            box-shadow: var(--shadow-sm);
            transition: all var(--transition);
            position: relative;
            overflow: hidden;
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--accent-gradient);
                opacity: 0;
                transition: opacity var(--transition);
            }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-hover);
                border-color: var(--brand-light);
            }

                .stat-card:hover::before {
                    opacity: 1;
                }

        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 8px;
        }

            .stat-header i {
                font-size: 28px;
                color: var(--brand);
                opacity: 0.7;
                transition: all var(--transition);
            }

        .stat-card:hover .stat-header i {
            opacity: 1;
            transform: scale(1.05);
        }

        .stat-value {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            line-height: 1.2;
        }

        .stat-label {
            font-size: 12.5px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .stat-trend {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 6px;
            font-weight: 500;
        }

        /* ── Filter Bar ── */
        .filter-bar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 14px 20px;
            margin-bottom: 24px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .filter-bar:hover {
                box-shadow: var(--shadow-md);
                border-color: var(--brand-light);
            }

        .filter-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-input {
            padding: 0.55rem 1rem;
            border-radius: 999px;
            border: 1px solid var(--border);
            font-size: 0.85rem;
            background: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font);
            transition: border-color var(--transition), box-shadow var(--transition);
            min-width: 130px;
        }

            .filter-input:focus {
                outline: none;
                border-color: var(--brand);
                box-shadow: 0 0 0 3px var(--brand-soft);
                background: var(--surface);
            }

            .filter-input::placeholder {
                color: var(--text-muted);
            }

            .filter-input[type="date"] {
                min-width: 140px;
            }

        /* ── Export Button ── */
        .btn-export {
            background: var(--brand);
            color: white;
            border: none;
            padding: 0.55rem 1.25rem;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font);
            box-shadow: var(--shadow-sm);
            white-space: nowrap;
        }

            .btn-export:hover {
                background: var(--brand-dark);
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

            .btn-export i {
                font-size: 0.8rem;
            }

        /* ── Table ── */
        .table-wrapper {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            overflow-x: auto; /* Makes table scrollable */
            box-shadow: var(--shadow-sm);
            transition: box-shadow var(--transition), border-color var(--transition);
        }

            .table-wrapper:hover {
                box-shadow: var(--shadow-lg);
                border-color: var(--brand-light);
            }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
            min-width: 1050px; /* Ensures horizontal scroll if needed */
        }

            .orders-table th {
                background: var(--surface-2);
                padding: 0.9rem 1.2rem;
                text-align: left;
                font-weight: 600;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: var(--text-muted);
                border-bottom: 1.5px solid var(--border);
                white-space: nowrap;
            }

            .orders-table td {
                padding: 0.9rem 1.2rem;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
                vertical-align: middle;
                transition: background var(--transition);
            }

            .orders-table tbody tr:last-child td {
                border-bottom: none;
            }

            .orders-table tbody tr:hover td {
                background: var(--surface-hover);
            }

            .orders-table td:first-child {
                font-weight: 600;
                color: var(--text-primary);
            }

        /* ── Badges ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.25rem 0.8rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid transparent;
            white-space: nowrap;
        }

            .badge i {
                font-size: 0.65rem;
            }

        .badge-delivered {
            background: var(--success-bg);
            color: var(--success-txt);
            border-color: #86EFAC;
        }

        .badge-pending,
        .badge-pendingconfirmation {
            background: var(--warning-bg);
            color: var(--warning-txt);
            border-color: #FCD34D;
        }

        .badge-confirmed {
            background: var(--info-bg);
            color: var(--info-txt);
            border-color: #C7D2FE;
        }

        .badge-preparing {
            background: #FED7AA;
            color: #9A3412;
            border-color: #FDBA74;
        }

        .badge-readyforpickup {
            background: #E0E7FF;
            color: #3730A3;
            border-color: #A5B4FC;
        }

        .badge-assigned {
            background: #EDE9FE;
            color: #6D28D9;
            border-color: #C4B5FD;
        }

        .badge-outfordelivery {
            background: #C7D2FE;
            color: #3730A3;
            border-color: #818CF8;
        }

        .badge-cancelled {
            background: var(--danger-bg);
            color: var(--danger-txt);
            border-color: #FCA5A5;
        }

        /* ── Action Buttons ── */
        .action-group {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .action-btn {
            border: none;
            padding: 0.3rem 0.8rem;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-family: var(--font);
            transition: all var(--transition);
            box-shadow: var(--shadow-sm);
            white-space: nowrap;
        }

            .action-btn i {
                font-size: 0.7rem;
            }

        .btn-view {
            background: var(--brand);
            color: white;
        }

            .btn-view:hover {
                background: var(--brand-dark);
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .btn-status {
            background: var(--warning);
            color: white;
        }

            .btn-status:hover {
                background: #B45309;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .btn-cancel {
            background: var(--danger);
            color: white;
        }

            .btn-cancel:hover {
                background: #B91C1C;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        /* ── Commission Column ── */
        .commission-value {
            font-weight: 700;
            color: var(--brand);
        }

        /* ── Empty State ── */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
            font-size: 0.95rem;
        }

            .empty-state i {
                font-size: 48px;
                color: var(--border);
                margin-bottom: 0.5rem;
                display: block;
            }

            .empty-state p {
                margin-top: 0.5rem;
            }

        /* ── Modals ── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.60);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 100000;
            padding: 20px;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

            .modal-overlay.show {
                display: flex;
                opacity: 1;
            }

        .modal-content {
            background: var(--surface);
            border-radius: var(--radius-xl);
            max-width: 560px;
            width: 100%;
            max-height: 88vh;
            overflow-y: auto;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            transform: scale(0.96) translateY(12px);
            transition: transform 0.25s ease, opacity 0.25s ease;
            opacity: 0;
        }

        .modal-overlay.show .modal-content {
            transform: scale(1) translateY(0);
            opacity: 1;
        }

        .modal-content::-webkit-scrollbar {
            width: 4px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 20px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: var(--surface-2);
            border-radius: var(--radius-xl) var(--radius-xl) 0 0;
        }

            .modal-header h4 {
                font-size: 16px;
                font-weight: 700;
                color: var(--text-primary);
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .modal-header h4 i {
                    color: var(--brand);
                }

        .modal-close {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: var(--text-muted);
            line-height: 1;
            transition: all var(--transition);
            padding: 0 4px;
        }

            .modal-close:hover {
                color: var(--danger);
                transform: rotate(90deg);
            }

        .modal-body {
            padding: 24px;
        }

        .detail-row {
            display: flex;
            gap: 15px;
            margin-bottom: 12px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }

            .detail-row:last-child {
                border-bottom: none;
                margin-bottom: 0;
                padding-bottom: 0;
            }

        .detail-label {
            font-weight: 700;
            width: 130px;
            color: var(--text-secondary);
            font-size: 0.85rem;
            flex-shrink: 0;
        }

        .detail-value {
            flex: 1;
            color: var(--text-primary);
            word-break: break-word;
            font-weight: 500;
        }

        .modal-label {
            display: block;
            margin-bottom: 6px;
            font-weight: 700;
            color: var(--text-primary);
            font-size: 0.9rem;
        }

        .modal-control {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-family: var(--font);
            background: var(--bg-color);
            color: var(--text-primary);
            transition: border-color var(--transition), box-shadow var(--transition);
        }

            .modal-control:focus {
                outline: none;
                border-color: var(--brand);
                box-shadow: 0 0 0 3px var(--brand-soft);
                background: var(--surface);
            }

        textarea.modal-control {
            min-height: 100px;
            resize: vertical;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 16px;
        }

        .modal-btn {
            border: none;
            padding: 10px 18px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-weight: 700;
            font-size: 0.85rem;
            font-family: var(--font);
            transition: all var(--transition);
        }

        .modal-btn-secondary {
            background: var(--bg-soft);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

            .modal-btn-secondary:hover {
                background: var(--border);
                transform: translateY(-1px);
            }

        .modal-btn-primary {
            background: var(--warning);
            color: white;
        }

            .modal-btn-primary:hover {
                background: #B45309;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        .modal-btn-danger {
            background: var(--danger);
            color: white;
        }

            .modal-btn-danger:hover {
                background: #B91C1C;
                transform: translateY(-1px);
                box-shadow: var(--shadow-md);
            }

        #statusOrderText,
        #cancelOrderText {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 16px;
            padding: 12px 16px;
            background: var(--bg-soft);
            border-radius: var(--radius-sm);
            border-left: 4px solid var(--brand);
        }

        /* ── Responsive ── */
        @@media (max-width: 992px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }

            .stat-value {
                font-size: 22px;
            }

            .filter-bar {
                padding: 12px 16px;
                flex-direction: column;
                align-items: stretch;
            }

            .filter-group {
                flex-direction: column;
                align-items: stretch;
            }

            .filter-input {
                width: 100%;
                min-width: unset;
            }

                .filter-input[type="date"] {
                    min-width: unset;
                }

            .btn-export {
                width: 100%;
                justify-content: center;
            }

            .orders-table {
                font-size: 0.8rem;
                min-width: 800px;
            }

                .orders-table th,
                .orders-table td {
                    padding: 0.6rem 0.8rem;
                }

            .detail-row {
                flex-direction: column;
                gap: 4px;
            }

            .detail-label {
                width: auto;
            }

            .modal-content {
                max-width: 100%;
                margin: 10px;
                border-radius: var(--radius);
            }

            .modal-header {
                padding: 14px 18px;
            }

            .modal-body {
                padding: 18px;
            }

            .action-group {
                gap: 4px;
            }

            .action-btn {
                padding: 0.2rem 0.6rem;
                font-size: 0.7rem;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat-card {
                padding: 16px 18px;
            }

            .stat-value {
                font-size: 20px;
            }

            .modal-actions {
                flex-direction: column;
            }

            .modal-btn {
                width: 100%;
                justify-content: center;
            }
        }

        button:focus-visible,
        input:focus-visible,
        select:focus-visible,
        textarea:focus-visible {
            outline: 2px solid var(--brand);
            outline-offset: 2px;
        }
    </style>
}

<div class="orders-container">

    <!-- ── Stats Grid ── -->
    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-value">@Model.TotalOrders</span>
                <i class="fas fa-shopping-bag"></i>
            </div>
            <div class="stat-label">Total Orders</div>
            <div class="stat-trend">Live database data</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-value">$@Model.TotalRevenue.ToString("N2")</span>
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-label">Paid Revenue</div>
            <div class="stat-trend">Paid orders only</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-value" style="color: var(--brand);">$@Model.TotalCommission.ToString("N2")</span>
                <i class="fas fa-percent" style="color: var(--brand);"></i>
            </div>
            <div class="stat-label">Total Commission</div>
            <div class="stat-trend">Platform earnings from orders</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-value">@Model.PendingCount</span>
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-label">Pending Orders</div>
            <div class="stat-trend">Waiting for confirmation</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-value">@Model.DeliveredCount</span>
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-label">Delivered</div>
            <div class="stat-trend">Completed deliveries</div>
        </div>

    </div>

    <!-- ── Filter Bar ── -->
    <div class="filter-bar">

        <div class="filter-group">
            <input type="text"
                   id="searchOrder"
                   class="filter-input"
                   placeholder="🔍 Order # or customer..." />

            <select id="statusFilterOrder"
                    class="filter-input">
                <option value="">All Status</option>
                <option value="pending">Pending</option>
                <option value="pending confirmation">Pending Confirmation</option>
                <option value="confirmed">Confirmed</option>
                <option value="preparing">Preparing</option>
                <option value="ready for pickup">Ready for Pickup</option>
                <option value="assigned">Assigned</option>
                <option value="out for delivery">Out for Delivery</option>
                <option value="delivered">Delivered</option>
                <option value="cancelled">Cancelled</option>
            </select>

            <input type="date"
                   id="dateFrom"
                   class="filter-input" />

            <input type="date"
                   id="dateTo"
                   class="filter-input" />
        </div>

        <button type="button"
                id="exportOrdersBtn"
                class="btn-export">
            <i class="fas fa-download"></i>
            Export CSV
        </button>

    </div>

    <!-- ── Table ── -->
    <div class="table-wrapper">

        <table class="orders-table"
               id="ordersTable">

            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Store</th>
                    <th>Total</th>
                    <th>Commission</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Orders.Any())
                {
                    foreach (var order in Model.Orders)
                    {
                        var normalizedStatus =
                            order.Status
                                .Trim()
                                .ToLowerInvariant();

                        var statusClass =
                            normalizedStatus
                                .Replace(" ", "");

                        var canUpdate =
                            normalizedStatus == "pending" ||
                            normalizedStatus == "pending confirmation" ||
                            normalizedStatus == "confirmed" ||
                            normalizedStatus == "preparing";

                        var canCancel =
                            normalizedStatus != "out for delivery" &&
                            normalizedStatus != "delivered" &&
                            normalizedStatus != "cancelled";

                        <tr data-status="@normalizedStatus"
                            data-date="@order.OrderDate.ToString("yyyy-MM-dd")">

                            <td>
                                <strong>@order.OrderNumber</strong>
                            </td>

                            <td>@order.CustomerName</td>

                            <td>@order.StoreName</td>

                            <td>$@order.TotalAmount.ToString("N2")</td>

                            <td class="commission-value">
                                $@order.Commission.ToString("N2")
                            </td>

                            <td>
                                <span class="badge badge-@statusClass">
                                    <i class="fas @GetStatusIcon(normalizedStatus)"></i>
                                    @order.Status
                                </span>
                            </td>

                            <td>
                                @order.PaymentStatus
                            </td>

                            <td>
                                @order.OrderDate
                                .ToLocalTime()
                                .ToString("dd MMM yyyy")
                            </td>

                            <td>
                                <div class="action-group">

                                    <button type="button"
                                            class="action-btn btn-view"
                                            data-id="@order.OrderId">
                                        <i class="fas fa-eye"></i>
                                        View
                                    </button>

                                    @if (canUpdate)
                                    {
                                        <button type="button"
                                                class="action-btn btn-status"
                                                data-id="@order.OrderId"
                                                data-status="@order.Status"
                                                data-number="@order.OrderNumber">
                                            <i class="fas fa-sync-alt"></i>
                                            Status
                                        </button>
                                    }

                                    @if (canCancel)
                                    {
                                        <button type="button"
                                                class="action-btn btn-cancel"
                                                data-id="@order.OrderId"
                                                data-number="@order.OrderNumber">
                                            <i class="fas fa-times"></i>
                                            Cancel
                                        </button>
                                    }

                                </div>
                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <p>No orders found</p>
                            </div>
                        </td>
                    </tr>
                }

            </tbody>
        </table>

    </div>
</div>

<!-- ── Details Modal ── -->
<div id="orderDetailsModal"
     class="modal-overlay">

    <div class="modal-content">

        <div class="modal-header">
            <h4>
                <i class="fas fa-receipt"></i>
                Order Details
            </h4>

            <button type="button"
                    class="modal-close"
                    data-close-modal>
                &times;
            </button>
        </div>

        <div class="modal-body"
             id="orderDetailsBody">
        </div>

    </div>
</div>

<!-- ── Status Modal ── -->
<div id="statusModal"
     class="modal-overlay">

    <div class="modal-content">

        <div class="modal-header">
            <h4>
                <i class="fas fa-sync-alt"></i>
                Update Order Status
            </h4>

            <button type="button"
                    class="modal-close"
                    data-close-modal>
                &times;
            </button>
        </div>

        <form method="post"
              asp-page-handler="UpdateStatus">

            @Html.AntiForgeryToken()

            <div class="modal-body">

                <input type="hidden"
                       name="orderId"
                       id="statusOrderId" />

                <p id="statusOrderText"
                   style="margin-bottom:18px;">
                </p>

                <label class="modal-label"
                       for="newStatus">
                    Next Status
                </label>

                <select name="newStatus"
                        id="newStatus"
                        class="modal-control"
                        required>
                </select>

                <div class="modal-actions">

                    <button type="button"
                            class="modal-btn modal-btn-secondary"
                            data-close-modal>
                        Cancel
                    </button>

                    <button type="submit"
                            class="modal-btn modal-btn-primary">
                        Update Status
                    </button>

                </div>

            </div>
        </form>

    </div>
</div>

<!-- ── Cancel Modal ── -->
<div id="cancelModal"
     class="modal-overlay">

    <div class="modal-content">

        <div class="modal-header">
            <h4>
                <i class="fas fa-times-circle" style="color: var(--danger);"></i>
                Cancel Order
            </h4>

            <button type="button"
                    class="modal-close"
                    data-close-modal>
                &times;
            </button>
        </div>

        <form method="post"
              asp-page-handler="Cancel">

            @Html.AntiForgeryToken()

            <div class="modal-body">

                <input type="hidden"
                       name="orderId"
                       id="cancelOrderId" />

                <p id="cancelOrderText"
                   style="margin-bottom:18px;">
                </p>

                <label class="modal-label"
                       for="cancellationReason">
                    Cancellation Reason
                </label>

                <textarea name="cancellationReason"
                          id="cancellationReason"
                          class="modal-control"
                          maxlength="500"
                          required
                          placeholder="Explain why this order is being cancelled..."></textarea>

                <div class="modal-actions">

                    <button type="button"
                            class="modal-btn modal-btn-secondary"
                            data-close-modal>
                        Keep Order
                    </button>

                    <button type="submit"
                            class="modal-btn modal-btn-danger">
                        Cancel Order
                    </button>

                </div>

            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        const ordersData =
            @Html.Raw(ordersJson);

        const searchInput =
            document.getElementById("searchOrder");

        const statusSelect =
            document.getElementById("statusFilterOrder");

        const dateFrom =
            document.getElementById("dateFrom");

        const dateTo =
            document.getElementById("dateTo");

        const tableRows =
            document.querySelectorAll(
                "#ordersTable tbody tr[data-status]");

        function filterOrders() {
            const term =
                searchInput.value
                    .trim()
                    .toLowerCase();

            const selectedStatus =
                statusSelect.value
                    .trim()
                    .toLowerCase();

            const from =
                dateFrom.value;

            const to =
                dateTo.value;

            tableRows.forEach(function (row) {
                const orderNumber =
                    row.cells[0]
                        .innerText
                        .toLowerCase();

                const customer =
                    row.cells[1]
                        .innerText
                        .toLowerCase();

                const rowStatus =
                    row.dataset.status;

                const rowDate =
                    row.dataset.date;

                let visible =
                    orderNumber.includes(term) ||
                    customer.includes(term);

                if (selectedStatus &&
                    rowStatus !== selectedStatus) {
                    visible = false;
                }

                if (from &&
                    rowDate < from) {
                    visible = false;
                }

                if (to &&
                    rowDate > to) {
                    visible = false;
                }

                row.style.display =
                    visible
                        ? ""
                        : "none";
            });
        }

        searchInput.addEventListener(
            "input",
            filterOrders);

        statusSelect.addEventListener(
            "change",
            filterOrders);

        dateFrom.addEventListener(
            "change",
            filterOrders);

        dateTo.addEventListener(
            "change",
            filterOrders);

        // ─── EXPORT CSV (now includes Commission) ───
        document
            .getElementById("exportOrdersBtn")
            .addEventListener(
                "click",
                function () {

                    let csv =
                        "Order Number,Customer,Store,Total,Commission,Status,Payment,Date\n";

                    tableRows.forEach(function (row) {
                        if (row.style.display === "none") {
                            return;
                        }

                        // cells: Order#, Customer, Store, Total, Commission, Status, Payment, Date, Actions
                        const cells = Array.from(row.cells);
                        const values = cells.slice(0, 8).map(cell =>
                            `"${cell.innerText
                                .trim()
                                .replaceAll('"', '""')}"`);

                        csv +=
                            values.join(",") +
                            "\n";
                    });

                    const blob =
                        new Blob(
                            [csv],
                            {
                                type:
                                    "text/csv;charset=utf-8"
                            });

                    const url =
                        URL.createObjectURL(blob);

                    const link =
                        document.createElement("a");

                    link.href =
                        url;

                    link.download =
                        `orders_${new Date()
                            .toISOString()
                            .slice(0, 10)}.csv`;

                    document.body.appendChild(link);

                    link.click();
                    link.remove();

                    URL.revokeObjectURL(url);
                });

        // ─── MODAL HELPERS ───
        function openModal(modal) {
            if (modal) {
                modal.classList.add("show");
                document.body.style.overflow = "hidden";
            }
        }

        function closeModal(modal) {
            if (modal) {
                modal.classList.remove("show");
                document.body.style.overflow = "";
            }
        }

        document
            .querySelectorAll("[data-close-modal]")
            .forEach(function (button) {
                button.addEventListener(
                    "click",
                    function () {
                        closeModal(
                            button.closest(
                                ".modal-overlay"));
                    });
            });

        document
            .querySelectorAll(".modal-overlay")
            .forEach(function (modal) {
                modal.addEventListener(
                    "click",
                    function (event) {
                        if (event.target === modal) {
                            closeModal(modal);
                        }
                    });
            });

        // ─── VIEW ORDER DETAIL (now includes Commission) ───
        document
            .querySelectorAll(".btn-view")
            .forEach(function (button) {
                button.addEventListener(
                    "click",
                    function () {

                        const orderId =
                            Number(button.dataset.id);

                        const order =
                            ordersData.find(item =>
                                item.orderId === orderId);

                        if (!order) {
                            return;
                        }

                        const detailsBody =
                            document.getElementById(
                                "orderDetailsBody");

                        detailsBody.innerHTML = `
                            <div class="detail-row">
                                <div class="detail-label">Order #</div>
                                <div class="detail-value">${escapeHtml(order.orderNumber)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Customer</div>
                                <div class="detail-value">${escapeHtml(order.customerName)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Store</div>
                                <div class="detail-value">${escapeHtml(order.storeName)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Items</div>
                                <div class="detail-value">${escapeHtml(order.items)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Total</div>
                                <div class="detail-value">$${Number(order.totalAmount).toFixed(2)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Commission</div>
                                <div class="detail-value" style="color:#6366f1; font-weight:700;">
                                    $${Number(order.commission).toFixed(2)}
                                </div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Status</div>
                                <div class="detail-value">${escapeHtml(order.status)}</div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Payment</div>
                                <div class="detail-value">
                                    ${escapeHtml(order.paymentMethod)}
                                    — ${escapeHtml(order.paymentStatus)}
                                </div>
                            </div>

                            <div class="detail-row">
                                <div class="detail-label">Delivery</div>
                                <div class="detail-value">
                                    ${escapeHtml(order.deliveryPersonName || "Not assigned")}
                                    ${order.deliveryAssignmentStatus
                                        ? `— ${escapeHtml(order.deliveryAssignmentStatus)}`
                                        : ""}
                                </div>
                            </div>
                        `;

                        openModal(
                            document.getElementById(
                                "orderDetailsModal"));
                    });
            });

        // ─── STATUS UPDATE ───
        document
            .querySelectorAll(".btn-status")
            .forEach(function (button) {
                button.addEventListener(
                    "click",
                    function () {
                        const currentStatus =
                            button.dataset.status
                                .trim()
                                .toLowerCase();

                        const nextStatusMap = {
                            "pending":
                                "Confirmed",

                            "pending confirmation":
                                "Confirmed",

                            "confirmed":
                                "Preparing",

                            "preparing":
                                "Ready for Pickup"
                        };

                        const nextStatus =
                            nextStatusMap[currentStatus];

                        if (!nextStatus) {
                            return;
                        }

                        document.getElementById(
                            "statusOrderId").value =
                                button.dataset.id;

                        document.getElementById(
                            "statusOrderText").textContent =
                                `Order ${button.dataset.number} will move from ${button.dataset.status} to ${nextStatus}.`;

                        const select =
                            document.getElementById(
                                "newStatus");

                        select.innerHTML = "";

                        const option =
                            document.createElement(
                                "option");

                        option.value =
                            nextStatus;

                        option.textContent =
                            nextStatus;

                        select.appendChild(option);

                        openModal(
                            document.getElementById(
                                "statusModal"));
                    });
            });

        // ─── CANCEL ORDER ───
        document
            .querySelectorAll(".btn-cancel")
            .forEach(function (button) {
                button.addEventListener(
                    "click",
                    function () {

                        document.getElementById(
                            "cancelOrderId").value =
                                button.dataset.id;

                        document.getElementById(
                            "cancelOrderText").textContent =
                                `You are about to cancel order ${button.dataset.number}.`;

                        document.getElementById(
                            "cancellationReason").value =
                                "";

                        openModal(
                            document.getElementById(
                                "cancelModal"));
                    });
            });

        function escapeHtml(value) {
            const element =
                document.createElement("div");

            element.textContent =
                value ?? "";

            return element.innerHTML;
        }
    </script>
}

@functions {
    string GetStatusIcon(string status)
    {
        return status switch
        {
            "delivered" =>
                "fa-check-circle",

            "pending" or
            "pending confirmation" =>
                "fa-hourglass-half",

            "cancelled" =>
                "fa-ban",

            "confirmed" =>
                "fa-check",

            "preparing" =>
                "fa-box",

            "ready for pickup" =>
                "fa-box-open",

            "assigned" =>
                "fa-user-check",

            "out for delivery" =>
                "fa-truck",

            _ =>
                "fa-circle"
        };
    }
}