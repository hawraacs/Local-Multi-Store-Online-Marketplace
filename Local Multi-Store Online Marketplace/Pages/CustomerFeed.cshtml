@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerFeedModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>My Feed</title>

    <style>
        body {
            background: #f5f5f5;
            font-family: Arial;
            margin: 0;
        }

        .feed-container {
            width: 700px;
            margin: 30px auto;
        }

        .post {
            background: white;
            border-radius: 15px;
            margin-bottom: 25px;
            overflow: hidden;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
        }

        .post-header {
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .store-name {
            font-weight: bold;
            text-decoration: none;
            color: black;
        }

        .post-image {
            width: 100%;
            height: 350px;
            object-fit: cover;
        }

        .post-body {
            padding: 15px;
        }

        .product-name {
            font-size: 20px;
            font-weight: bold;
        }

        .product-price {
            color: #ff6600;
            font-weight: bold;
            margin: 5px 0;
        }

        .actions {
            margin-top: 15px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 14px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-size: 14px;
        }

        .btn-review {
            background: #2563eb;
            color: white;
        }

        .btn-cart {
            background: #16a34a;
            color: white;
        }

        .btn-share {
            background: #111827;
            color: white;
        }

        .btn-follow {
            background: #dcfce7;
            color: #166534;
        }

        .btn-unfollow {
            background: #fee2e2;
            color: #991b1b;
        }

        .comments-section {
            margin-top: 15px;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }

        .comment {
            padding: 10px 0;
            border-bottom: 1px solid #f1f1f1;
        }

            .comment strong {
                margin-right: 8px;
            }

            .comment span {
                color: #f59e0b;
            }
    </style>
</head>

<body>

    <div class="feed-container">

        @foreach (var product in Model.Products)
        {
            var img = product.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
            var isFollowing = Model.FollowingStoreIds.Contains(product.StoreID);

            <div class="post">

                <div class="post-header">

                    <!-- STORE NAME → PROFILE -->
                    <a class="store-name"
                       asp-page="/StoreCustomerProfile"
                       asp-route-id="@product.StoreID">
                        @product.Store?.StoreName
                    </a>

                    <!-- FOLLOW / UNFOLLOW -->
                    @if (isFollowing)
                    {
                        <form method="post"
                              asp-page-handler="UnfollowStore"
                              asp-route-storeId="@product.StoreID">
                            <button class="btn btn-unfollow">Unfollow</button>
                        </form>
                    }
                    else
                    {
                        <form method="post"
                              asp-page-handler="FollowStore"
                              asp-route-storeId="@product.StoreID">
                            <button class="btn btn-follow">Follow</button>
                        </form>
                    }

                </div>

                <img class="post-image" src="@img" />

                <div class="post-body">

                    <div class="product-name">@product.ProductName</div>
                    <div class="product-price">$@product.Price</div>
                    <p>@product.Description</p>

                    <div class="actions">

                        <form method="post"
                              asp-page-handler="AddReview">

                            <input type="hidden"
                                   name="productId"
                                   value="@product.ProductID" />

                            <input type="number"
                                   name="rating"
                                   min="1"
                                   max="5"
                                   placeholder="Rating"
                                   required />

                            <input type="text"
                                   name="comment"
                                   placeholder="Write a comment..."
                                   required />

                            <button class="btn btn-review">
                                Post Comment
                            </button>

                        </form>

                        <form method="post"
                              asp-page="/Customer1"
                              asp-page-handler="AddToCart"
                              asp-route-productId="@product.ProductID">
                            <button class="btn btn-cart">🛒 Add</button>
                        </form>

                        <!-- ✅ FIXED SHARE BUTTON (WILL WORK WITH YOUR HANDLER) -->
                        <form method="post"
                              asp-page-handler="ShareToStore"
                              asp-route-productId="@product.ProductID"
                              asp-route-storeOwnerId="@product.Store.OwnerUserID">

                            <button type="submit" class="btn btn-share">
                                🔗 Share
                            </button>

                        </form>

                    </div>
                    <div class="comments-section">

                        @if (product.Reviews.Any())
                        {
                            @foreach (var review in product.Reviews
                           .Where(r => r.Status == "Approved")
                           .OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="comment">

                                    <strong>
                                        
                                            @review.Customer.User.FullName
                                       
                                    </strong>

                                    <span>
                                        ⭐ @review.Rating
                                    </span>

                                    <div>
                                        @review.Comment
                                    </div>

                                </div>
                            }
                        }

                    </div>

                </div>
            </div>
        }

    </div>

</body>
</html>