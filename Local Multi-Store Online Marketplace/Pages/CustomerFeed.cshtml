@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerFeedModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>My Feed</title>

    <style>
        body {
            background: #f5f5f5;
            font-family: Arial;
            margin: 0;
        }

        .feed-container {
            width: 700px;
            margin: 30px auto;
        }

        .post {
            background: white;
            border-radius: 15px;
            margin-bottom: 25px;
            overflow: hidden;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
        }

        .post-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
        }

        .store-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .store-logo {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
        }

        .store-name {
            font-weight: bold;
            font-size: 18px;
            text-decoration: none;
            color: black;
        }

        .follow-status {
            color: green;
            font-weight: bold;
        }

        .post-image {
            width: 100%;
            height: 350px;
            object-fit: cover;
        }

        .post-body {
            padding: 15px;
        }

        .product-name {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .product-price {
            color: #ff6600;
            font-size: 20px;
            font-weight: bold;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn {
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .btn-review {
            background: #2563eb;
            color: white;
        }

        .btn-cart {
            background: #16a34a;
            color: white;
        }

        .empty {
            text-align: center;
            background: white;
            padding: 50px;
            border-radius: 15px;
        }
    </style>
</head>

<body>

    <div class="feed-container">

        @if (!Model.Products.Any())
        {
            <div class="empty">
                <h2>Your feed is empty</h2>
                <p>Follow some stores first.</p>
            </div>
        }
        else
        {
            @foreach (var product in Model.Products)
            {
                var imageUrl = "/images/no-image.png";

                if (product.Images != null && product.Images.Any())
                {
                    imageUrl = product.Images.First().ImageUrl;
                }

                <div class="post">

                    <!-- STORE HEADER -->
                    <div class="post-header">

                        <div class="store-info">

                            <img class="store-logo"
                                 src="@(product.Store?.LogoURL ?? "/images/store.png")" />

                            <!-- ✅ STORE NAME NOW CLICKABLE (PROFILE ROUTE) -->
                            <a class="store-name"
                               asp-page="/StoreCustomerProfile"
                               asp-route-id="@product.StoreID">
                                @product.Store?.StoreName
                            </a>

                        </div>

                    </div>

                    <!-- PRODUCT IMAGE -->
                    <img class="post-image" src="@imageUrl" />

                    <!-- BODY -->
                    <div class="post-body">

                        <div class="product-name">
                            @product.ProductName
                        </div>

                        <div class="product-price">
                            $@product.Price
                        </div>

                        <p>
                            @product.Description
                        </p>

                        <!-- ACTIONS (SAME STYLE AS Customer1) -->
                        <div class="actions">

                            <!-- LIKE / REVIEW PRODUCT -->
                            <form method="get"
                                  asp-page="/CreateProductReview"
                                  asp-route-productId="@product.ProductID">
                                <button class="btn btn-review">
                                    ⭐ Review
                                </button>
                            </form>

                            <!-- ADD TO CART -->
                            <form method="post"
                                  asp-page="/Customer1"
                                  asp-page-handler="AddToCart"
                                  asp-route-productId="@product.ProductID">

                                <button class="btn btn-cart">
                                    🛒 Add To Cart
                                </button>

                            </form>

                        </div>

                    </div>

                </div>
            }
        }

    </div>

</body>
</html>