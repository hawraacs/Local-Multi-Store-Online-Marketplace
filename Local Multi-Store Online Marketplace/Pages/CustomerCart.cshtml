@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerCartModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Your Cart | realnest</title>

    <!-- Google Fonts & FontAwesome Icons (Consistent with Customer Feed) -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #faf9fc;
            --card-bg: #ffffff;
            --border-color: #ece8f6;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            /* Purple / Indigo palette, matching the Feed */
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --like-color: #ef4444;
            --success-color: #10b981;
            --error-color: #dc2626;
            --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.04);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.08);
            --shadow-lg: 0 20px 40px rgba(109, 40, 217, 0.12);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            padding-bottom: 100px; /* Offset to prevent overlap with the bottom nav */
        }

            body.modal-open {
                overflow: hidden;
            }

        /* BOTTOM NAV - identical to the Feed page, updated to set 'Cart' as active */
        .bottom-nav {
            display: flex !important;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 68px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(15px);
            border-top: 1px solid var(--border-color);
            z-index: 1000;
            justify-content: space-around;
            align-items: center;
            box-shadow: 0 -4px 20px rgba(30, 27, 46, 0.06);
            padding-bottom: env(safe-area-inset-bottom);
        }

            .bottom-nav a {
                color: var(--text-secondary);
                text-decoration: none;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 4px;
                font-size: 10px;
                font-weight: 600;
                flex: 1;
                border-radius: 12px;
                transition: color 0.2s ease, background-color 0.2s ease;
            }

                .bottom-nav a i {
                    font-size: 20px;
                    transition: transform 0.2s ease;
                }

                .bottom-nav a:hover {
                    color: var(--accent-color);
                    background: var(--accent-light);
                }

                .bottom-nav a:active i {
                    transform: scale(0.85);
                }

                .bottom-nav a.active {
                    color: var(--accent-color);
                    font-weight: 700;
                }

                    .bottom-nav a.active i {
                        transform: scale(1.1);
                    }

        /* PAGE HEADER */
        .cart-page {
            padding: 40px 16px;
            min-height: 100vh;
        }

        .cart-header {
            text-align: center;
            margin-bottom: 40px;
        }

            .cart-header h2 {
                font-family: 'Playfair Display', Georgia, serif;
                font-size: 34px;
                font-weight: 800;
                margin: 0 0 8px;
                color: var(--text-primary);
            }

            .cart-header p {
                margin: 0;
                color: var(--text-secondary);
                font-size: 15px;
                font-weight: 500;
            }

        /* CONTAINER GRID */
        .cart-container {
            max-width: 950px;
            margin: auto;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 30px;
            align-items: start;
        }

        /* CART PRODUCTS LIST */
        .cart-list {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-color);
        }

        .cart-item {
            display: grid;
            grid-template-columns: 95px 1fr;
            gap: 20px;
            padding: 20px 0;
            border-bottom: 1px solid var(--border-color);
        }

            .cart-item:last-child {
                border-bottom: none;
            }

            .cart-item img {
                width: 95px;
                height: 95px;
                border-radius: 14px;
                object-fit: cover;
                background: #f3f0fa;
                display: block;
                border: 1px solid var(--border-color);
            }

        .item-name {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .item-store {
            color: var(--text-secondary);
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .item-price {
            color: var(--accent-color);
            font-weight: 800;
            font-size: 17px;
            margin-bottom: 12px;
        }

        .item-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
        }

        .qty-form {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .qty-input {
            width: 75px;
            padding: 8px 12px;
            border-radius: 50px;
            border: 1px solid var(--border-color);
            font-weight: 700;
            background: var(--bg-color);
            font-family: var(--font-family);
            color: var(--accent-color);
            outline: none;
            text-align: center;
            transition: all 0.2s ease;
        }

            .qty-input:focus {
                border-color: var(--accent-color);
                background: #ffffff;
            }

        .update-btn {
            background: var(--accent-light);
            color: var(--accent-color);
            border: 1px solid var(--border-color);
            border-radius: 50px;
            padding: 8px 16px;
            font-weight: 700;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s ease;
        }

            .update-btn:hover {
                background: var(--accent-color);
                color: #ffffff;
                border-color: var(--accent-color);
            }

        .remove-btn {
            background: #fff5f5;
            color: var(--like-color);
            border: 1px solid #ffd1cc;
            border-radius: 50px;
            padding: 8px 16px;
            font-weight: 700;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s ease;
        }

            .remove-btn:hover {
                background: #ffe3e1;
                border-color: var(--like-color);
            }

        /* ORDER SUMMARY BOX */
        .summary-box {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-color);
            position: sticky;
            top: 20px;
        }

            .summary-box h3 {
                margin: 0 0 18px;
                color: var(--text-primary);
                font-size: 22px;
                font-weight: 800;
            }

        .summary-row {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-bottom: 12px;
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 14px;
        }

        .summary-note {
            background: #fff7ed;
            border: 1px solid #fed7aa;
            color: #9a3412;
            padding: 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            margin: 12px 0;
            line-height: 1.5;
        }

        .summary-free {
            background: #dcfce7;
            border: 1px solid #86efac;
            color: #166534;
            padding: 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            margin: 12px 0;
            line-height: 1.5;
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            border-top: 1px solid var(--border-color);
            padding-top: 15px;
            margin-top: 15px;
            color: var(--text-primary);
            font-size: 22px;
            font-weight: 800;
        }

        /* COUPONS & PAYMENT */
        .coupon-form {
            margin: 15px 0;
        }

        .coupon-label,
        .payment-label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .coupon-row {
            display: flex;
            gap: 8px;
        }

        .coupon-input {
            flex: 1;
            min-width: 0;
            padding: 10px 16px;
            border: 1px solid var(--border-color);
            border-radius: 50px;
            font-weight: 700;
            font-family: var(--font-family);
            background: var(--bg-color);
            outline: none;
            transition: all 0.2s ease;
        }

            .coupon-input:focus {
                border-color: var(--accent-color);
                background: #ffffff;
            }

        .coupon-btn {
            background: var(--accent-color);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 10px 18px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .coupon-btn:hover {
                background: var(--accent-hover);
            }

        .remove-coupon-btn {
            width: 100%;
            margin-bottom: 10px;
            padding: 10px;
            background: #fff5f5;
            color: var(--like-color);
            border: 1px solid #ffd1cc;
            border-radius: 50px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .remove-coupon-btn:hover {
                background: #ffe3e1;
                border-color: var(--like-color);
            }

        .discount-row {
            color: var(--success-color);
        }

        .payment-section {
            margin-top: 15px;
        }

        .payment-select {
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            font-weight: 700;
            background: white;
            font-family: var(--font-family);
            outline: none;
            transition: all 0.2s ease;
        }

            .payment-select:focus {
                border-color: var(--accent-color);
            }

        .payment-note {
            margin-top: 10px;
            padding: 12px;
            background: var(--accent-light);
            color: var(--text-secondary);
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.5;
        }

        .checkout-btn {
            width: 100%;
            margin-top: 20px;
            padding: 14px;
            background: var(--accent-gradient);
            color: white;
            border: none;
            border-radius: 50px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px rgba(109, 40, 217, 0.25);
        }

            .checkout-btn:hover {
                opacity: 0.95;
                box-shadow: 0 6px 15px rgba(109, 40, 217, 0.35);
                transform: translateY(-1px);
            }

        /* EMPTY STATE STYLE */
        .empty-cart {
            max-width: 700px;
            margin: 40px auto;
            background: var(--card-bg);
            text-align: center;
            color: var(--text-secondary);
            padding: 60px 40px;
            border-radius: 20px;
            border: 2px dashed #ded4f5;
            box-shadow: var(--shadow-sm);
        }

            .empty-cart h3 {
                color: var(--text-primary);
                font-size: 22px;
                font-weight: 800;
                margin-bottom: 10px;
            }

        .shop-link {
            display: inline-block;
            margin-top: 20px;
            background: var(--accent-gradient);
            color: white;
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 800;
            box-shadow: 0 4px 12px rgba(109, 40, 217, 0.25);
            transition: all 0.25s ease;
        }

            .shop-link:hover {
                opacity: 0.95;
                box-shadow: 0 6px 15px rgba(109, 40, 217, 0.35);
            }

        /* =====================================================
                   TOAST NOTIFICATIONS
                   ===================================================== */
        .toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 30000;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .app-toast {
            width: min(390px, calc(100vw - 40px));
            padding: 16px 20px;
            border-radius: 14px;
            background: var(--card-bg);
            display: flex;
            align-items: flex-start;
            gap: 12px;
            box-shadow: 0 15px 35px rgba(30, 27, 46, 0.12);
            opacity: 0;
            transform: translateX(45px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            pointer-events: auto;
            border-left: 5px solid var(--border-color);
        }

            .app-toast.show {
                opacity: 1;
                transform: translateX(0);
            }

            .app-toast.success {
                border-left-color: var(--success-color);
                color: var(--text-primary);
            }

                .app-toast.success .toast-icon {
                    background: #e6f7f0;
                    color: var(--success-color);
                }

            .app-toast.error {
                border-left-color: var(--error-color);
                color: var(--text-primary);
            }

                .app-toast.error .toast-icon {
                    background: #fee2e2;
                    color: var(--error-color);
                }

        .toast-icon {
            width: 28px;
            height: 28px;
            flex: 0 0 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            display: block;
            margin-bottom: 3px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .toast-message {
            display: block;
            font-size: 13px;
            font-weight: 600;
            line-height: 1.45;
            color: var(--text-secondary);
        }

        .toast-close {
            border: none;
            background: transparent;
            color: var(--text-secondary);
            padding: 0;
            font-size: 22px;
            cursor: pointer;
            line-height: 1;
            transition: color 0.15s ease;
        }

            .toast-close:hover {
                color: var(--text-primary);
            }

        /* =====================================================
                   CUSTOM MODALS
                   ===================================================== */
        .app-modal {
            position: fixed;
            inset: 0;
            z-index: 20000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(30, 27, 46, 0.6);
            backdrop-filter: blur(5px);
        }

            .app-modal.open {
                display: flex;
            }

        .modal-card {
            width: min(440px, 100%);
            background: var(--card-bg);
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--shadow-lg);
            transform: translateY(15px) scale(0.98);
            opacity: 0;
            transition: 0.2s ease;
            border: 1px solid var(--border-color);
        }

        .app-modal.open .modal-card {
            transform: translateY(0) scale(1);
            opacity: 1;
        }

        .modal-icon {
            width: 58px;
            height: 58px;
            margin: 0 auto 15px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 27px;
            background: var(--accent-light);
            color: var(--accent-color);
        }

            .modal-icon.danger {
                background: #fee2e2;
                color: var(--error-color);
            }

        .modal-title {
            margin: 0 0 8px;
            text-align: center;
            color: var(--text-primary);
            font-size: 23px;
            font-weight: 800;
        }

        .modal-description {
            margin: 0 0 20px;
            text-align: center;
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.55;
        }

        .modal-summary {
            margin-bottom: 20px;
            padding: 16px;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 14px;
        }

        .modal-summary-row {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-bottom: 10px;
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 700;
        }

            .modal-summary-row:last-child {
                margin-bottom: 0;
                padding-top: 10px;
                border-top: 1px solid var(--border-color);
                color: var(--text-primary);
                font-size: 16px;
                font-weight: 800;
            }

        .modal-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .modal-cancel,
        .modal-confirm,
        .modal-danger {
            border: none;
            border-radius: 50px;
            padding: 12px 16px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .modal-cancel {
            background: #f1eef8;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
        }

        .modal-confirm {
            background: var(--accent-gradient);
            color: white;
        }

        .modal-danger {
            background: var(--error-color);
            color: white;
        }

        .modal-cancel:hover {
            background: #e7e1f5;
            color: var(--text-primary);
        }

        .modal-confirm:hover {
            opacity: 0.95;
        }

        .modal-danger:hover {
            background: #b91c1c;
        }

        .modal-confirm:disabled,
        .modal-danger:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

        @@media (max-width: 850px) {
            .cart-container {
                grid-template-columns: 1fr;
            }

            .summary-box {
                position: static;
            }
        }

        @@media (max-width: 550px) {
            .cart-page {
                padding: 20px 12px;
            }

            .cart-item {
                grid-template-columns: 1fr;
            }

                .cart-item img {
                    width: 100%;
                    height: 180px;
                }

            .coupon-row {
                flex-direction: column;
            }

            .coupon-btn {
                width: 100%;
            }

            .modal-actions {
                grid-template-columns: 1fr;
            }

            .toast-container {
                top: 15px;
                right: 15px;
                left: 15px;
            }

            .app-toast {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <!-- =====================================================
         SUCCESS AND ERROR TOASTERS
         ===================================================== -->
    <div id="toastContainer"
         class="toast-container"
         aria-live="polite"
         aria-atomic="true">

        @if (TempData["Success"] is string successMessage &&
        !string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="app-toast success" data-toast>
                <span class="toast-icon">✓</span>

                <div class="toast-content">
                    <span class="toast-title">
                        Success
                    </span>

                    <span class="toast-message">
                        @successMessage
                    </span>
                </div>

                <button type="button"
                        class="toast-close"
                        aria-label="Close notification">
                    &times;
                </button>
            </div>
        }

        @if (TempData["Error"] is string errorMessage &&
        !string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="app-toast error" data-toast>
                <span class="toast-icon">!</span>

                <div class="toast-content">
                    <span class="toast-title">
                        Unable to continue
                    </span>

                    <span class="toast-message">
                        @errorMessage
                    </span>
                </div>

                <button type="button"
                        class="toast-close"
                        aria-label="Close notification">
                    &times;
                </button>
            </div>
        }
    </div>

    <!-- BOTTOM NAVIGATION (Shared with Feed page, styled with 'Cart' link active) -->
    <div class="bottom-nav">
        <a href="/Customer1"><i class="fa-solid fa-compass"></i><span>Explore</span></a>
        <a href="/CustomerFeed"><i class="fa-solid fa-house"></i><span>Feed</span></a>
        <a href="/CustomerProducts"><i class="fa-solid fa-bag-shopping"></i><span>Shop</span></a>
        <a href="/CustomerCart" class="active"><i class="fa-solid fa-cart-shopping"></i><span>Cart</span></a>
        <a href="/CustomerOrders"><i class="fa-solid fa-receipt"></i><span>Orders</span></a>
        <a href="/Chat"><i class="fa-solid fa-paper-plane"></i><span>Chat</span></a>
        <a href="/CustomerProfile"><i class="fa-solid fa-user"></i><span>Profile</span></a>
    </div>

    <div class="cart-page">

        <div class="cart-header">
            <h2>🛒 Your Cart</h2>

            <p>
                Review your selected products before checkout.
            </p>
        </div>

        @if (Model.CartItems == null ||
        !Model.CartItems.Any())
        {
            <div class="empty-cart">
                <h3>Your cart is empty</h3>

                <p>
                    Add products to your cart before checkout.
                </p>

                <a href="/CustomerProducts"
                   class="shop-link">
                    Continue Shopping
                </a>
            </div>
        }
        else
        {
            <div class="cart-container">

                <!-- =================================================
                     CART ITEMS
                     ================================================= -->
                <div class="cart-list">

                    @foreach (var item in Model.CartItems)
                    {
                        var removeFormId =
                        $"removeForm-{item.CartItemID}";

                        <div class="cart-item">

                            <img src="@item.ImageUrl"
                                 alt="@item.ProductName"
                                 onerror="this.onerror=null;this.src='/images/no-image.png';" />

                            <div>
                                <div class="item-name">
                                    @item.ProductName
                                </div>

                                <div class="item-store">
                                    Store: @item.StoreName
                                </div>

                                <div class="item-price">
                                    $@item.UnitPrice.ToString("N2") each
                                </div>

                                <div class="item-actions">

                                    <!-- UPDATE QUANTITY -->
                                    <form method="post"
                                          asp-page-handler="UpdateQuantity"
                                          class="qty-form">

                                        <input type="hidden"
                                               name="cartItemId"
                                               value="@item.CartItemID" />

                                        <input type="hidden"
                                               name="AppliedCouponCode"
                                               value="@Model.AppliedCouponCode" />

                                        <input type="number"
                                               name="quantity"
                                               value="@item.Quantity"
                                               min="1"
                                               max="@item.AvailableStock"
                                               class="qty-input" />

                                        <button type="submit"
                                                class="update-btn">
                                            Update
                                        </button>
                                    </form>

                                    <!-- REMOVE ITEM -->
                                    <form id="@removeFormId"
                                          method="post"
                                          asp-page-handler="Remove">

                                        <input type="hidden"
                                               name="cartItemId"
                                               value="@item.CartItemID" />

                                        <input type="hidden"
                                               name="AppliedCouponCode"
                                               value="@Model.AppliedCouponCode" />

                                        <button type="button"
                                                class="remove-btn remove-trigger"
                                                data-form-id="@removeFormId"
                                                data-product-name="@item.ProductName">
                                            Remove
                                        </button>
                                    </form>

                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- =================================================
                     ORDER SUMMARY
                     ================================================= -->
                <div class="summary-box">

                    <h3>Order Summary</h3>

                    <div class="summary-row">
                        <span>Items</span>

                        <span>
                            @Model.CartItems.Sum(item => item.Quantity)
                        </span>
                    </div>

                    <div class="summary-row">
                        <span>Subtotal</span>

                        <span>
                            $@Model.TotalAmount.ToString("N2")
                        </span>
                    </div>

                    <!-- APPLY COUPON -->
                    <form method="post"
                          asp-page-handler="ApplyCoupon"
                          class="coupon-form">

                        <label class="coupon-label">
                            Coupon Code
                        </label>

                        <div class="coupon-row">

                            <input type="text"
                                   name="couponCode"
                                   value="@Model.AppliedCouponCode"
                                   placeholder="Enter coupon code"
                                   class="coupon-input" />

                            <button type="submit"
                                    class="coupon-btn">
                                Apply
                            </button>
                        </div>
                    </form>

                    <!-- REMOVE COUPON -->
                    @if (!string.IsNullOrWhiteSpace(
                   Model.AppliedCouponCode))
                    {
                        <form method="post"
                              asp-page-handler="RemoveCoupon">

                            <button type="submit"
                                    class="remove-coupon-btn">
                                Remove Coupon
                            </button>
                        </form>
                    }

                    <!-- COUPON MESSAGE -->
                    @if (!string.IsNullOrWhiteSpace(
                   Model.CouponMessage))
                    {
                        <div class="summary-free">
                            @Model.CouponMessage
                        </div>
                    }

                    <!-- DISCOUNT -->
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="summary-row discount-row">
                            <span>Discount</span>

                            <span>
                                -$@Model.DiscountAmount.ToString("N2")
                            </span>
                        </div>
                    }

                    <!-- DELIVERY FEE -->
                    @if (Model.HasActiveAddress)
                    {
                        <div class="summary-row">
                            <span>Delivery Fee</span>

                            <span>
                                $@Model.EstimatedDeliveryFee.ToString("N2")
                            </span>
                        </div>

                        @if (Model.TotalAmount > 50)
                        {
                            <div class="summary-free">
                                Free delivery applied because your
                                subtotal is above $50.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="summary-note">
                            Add a delivery address to calculate
                            the delivery fee.
                        </div>
                    }

                    <!-- GRAND TOTAL -->
                    <div class="summary-total">
                        <span>Total</span>

                        <span>
                            $@Model.GrandTotal.ToString("N2")
                        </span>
                    </div>

                    <!-- CHECKOUT FORM -->
                    <form id="checkoutForm"
                          method="post"
                          asp-page-handler="Checkout">

                        <input type="hidden"
                               name="appliedCouponCode"
                               value="@Model.AppliedCouponCode" />

                        <div class="payment-section">

                            <label for="paymentMethodSelect"
                                   class="payment-label">
                                Payment Method
                            </label>

                            <select id="paymentMethodSelect"
                                    name="paymentMethod"
                                    class="payment-select">

                                <option value="Cash On Delivery">
                                    Cash On Delivery
                                </option>

                                <option value="Online Payment">
                                    Online Payment
                                </option>
                            </select>

                            <div class="payment-note">
                                Online payment is simulated for demo.
                                Cash on Delivery will be marked as paid
                                when the order is delivered.
                            </div>
                        </div>

                        <!-- IMPORTANT:
                             This is type="button", not type="submit".
                             It opens the custom confirmation modal. -->
                        <button id="openCheckoutModalButton"
                                type="button"
                                class="checkout-btn">
                            Checkout
                        </button>
                    </form>

                </div>
            </div>
        }
    </div>

    <!-- =====================================================
         CHECKOUT CONFIRMATION MODAL
         ===================================================== -->
    <div id="checkoutModal"
         class="app-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="checkoutModalTitle"
         aria-hidden="true">

        <div class="modal-card">

            <div class="modal-icon">
                🛒
            </div>

            <h3 id="checkoutModalTitle"
                class="modal-title">
                Confirm Your Order
            </h3>

            <p class="modal-description">
                Please review your order details before
                placing the order.
            </p>

            <div class="modal-summary">

                <div class="modal-summary-row">
                    <span>Items</span>

                    <strong>
                        @Model.CartItems.Sum(item => item.Quantity)
                    </strong>
                </div>

                <div class="modal-summary-row">
                    <span>Payment</span>

                    <strong id="checkoutModalPayment">
                        Cash On Delivery
                    </strong>
                </div>

                <div class="modal-summary-row">
                    <span>Total</span>

                    <strong>
                        $@Model.GrandTotal.ToString("N2")
                    </strong>
                </div>
            </div>

            <div class="modal-actions">

                <button id="cancelCheckoutButton"
                        type="button"
                        class="modal-cancel">
                    Cancel
                </button>

                <button id="confirmCheckoutButton"
                        type="button"
                        class="modal-confirm">
                    Place Order
                </button>
            </div>
        </div>
    </div>

    <!-- =====================================================
         REMOVE ITEM CONFIRMATION MODAL
         ===================================================== -->
    <div id="removeModal"
         class="app-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="removeModalTitle"
         aria-hidden="true">

        <div class="modal-card">

            <div class="modal-icon danger">
                🗑
            </div>

            <h3 id="removeModalTitle"
                class="modal-title">
                Remove Item?
            </h3>

            <p id="removeModalDescription"
               class="modal-description">
                Are you sure you want to remove this item
                from your cart?
            </p>

            <div class="modal-actions">

                <button id="cancelRemoveButton"
                        type="button"
                        class="modal-cancel">
                    Cancel
                </button>

                <button id="confirmRemoveButton"
                        type="button"
                        class="modal-danger">
                    Remove Item
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener(
            "DOMContentLoaded",
            function () {
                initializeToasts();
                initializeCheckoutModal();
                initializeRemoveModal();
            });

        // =====================================================
        // TOASTS
        // =====================================================
        function initializeToasts() {
            const toasts =
                document.querySelectorAll("[data-toast]");

            toasts.forEach(function (toast, index) {
                window.setTimeout(function () {
                    toast.classList.add("show");
                }, 100 + (index * 100));

                const closeButton =
                    toast.querySelector(".toast-close");

                if (closeButton) {
                    closeButton.addEventListener(
                        "click",
                        function () {
                            removeToast(toast);
                        });
                }

                window.setTimeout(function () {
                    removeToast(toast);
                }, 5000 + (index * 300));
            });
        }

        function removeToast(toast) {
            if (!toast || !toast.isConnected) {
                return;
            }

            toast.classList.remove("show");

            window.setTimeout(function () {
                toast.remove();
            }, 300);
        }

        // =====================================================
        // SHARED MODAL FUNCTIONS
        // =====================================================
        function openModal(modal) {
            if (!modal) {
                return;
            }

            modal.classList.add("open");
            modal.setAttribute("aria-hidden", "false");

            document.body.classList.add("modal-open");
        }

        function closeModal(modal) {
            if (!modal) {
                return;
            }

            modal.classList.remove("open");
            modal.setAttribute("aria-hidden", "true");

            if (!document.querySelector(".app-modal.open")) {
                document.body.classList.remove("modal-open");
            }
        }

        // =====================================================
        // CHECKOUT MODAL
        // =====================================================
        function initializeCheckoutModal() {
            const modal =
                document.getElementById("checkoutModal");

            const checkoutForm =
                document.getElementById("checkoutForm");

            const openButton =
                document.getElementById(
                    "openCheckoutModalButton");

            const cancelButton =
                document.getElementById(
                    "cancelCheckoutButton");

            const confirmButton =
                document.getElementById(
                    "confirmCheckoutButton");

            const paymentSelect =
                document.getElementById(
                    "paymentMethodSelect");

            const paymentDisplay =
                document.getElementById(
                    "checkoutModalPayment");

            if (!modal ||
                !checkoutForm ||
                !openButton ||
                !cancelButton ||
                !confirmButton ||
                !paymentSelect ||
                !paymentDisplay) {
                return;
            }

            openButton.addEventListener(
                "click",
                function () {
                    const selectedOption =
                        paymentSelect.options[
                            paymentSelect.selectedIndex
                        ];

                    paymentDisplay.textContent =
                        selectedOption
                            ? selectedOption.textContent.trim()
                            : "Not selected";

                    openModal(modal);

                    cancelButton.focus();
                });

            cancelButton.addEventListener(
                "click",
                function () {
                    closeModal(modal);

                    openButton.focus();
                });

            confirmButton.addEventListener(
                "click",
                function () {
                    confirmButton.disabled = true;

                    confirmButton.textContent =
                        "Placing Order...";

                    checkoutForm.requestSubmit();
                });

            modal.addEventListener(
                "click",
                function (event) {
                    if (event.target === modal) {
                        closeModal(modal);
                    }
                });
        }

        // =====================================================
        // REMOVE ITEM MODAL
        // =====================================================
        function initializeRemoveModal() {
            const modal =
                document.getElementById("removeModal");

            const description =
                document.getElementById(
                    "removeModalDescription");

            const cancelButton =
                document.getElementById(
                    "cancelRemoveButton");

            const confirmButton =
                document.getElementById(
                    "confirmRemoveButton");

            const removeButtons =
                document.querySelectorAll(
                    ".remove-trigger");

            if (!modal ||
                !description ||
                !cancelButton ||
                !confirmButton) {
                return;
            }

            let pendingRemoveForm = null;
            let lastRemoveButton = null;

            removeButtons.forEach(function (button) {
                button.addEventListener(
                    "click",
                    function () {
                        const formId =
                            button.dataset.formId;

                        const productName =
                            button.dataset.productName ||
                            "this item";

                        pendingRemoveForm =
                            document.getElementById(formId);

                        lastRemoveButton =
                            button;

                        description.textContent =
                            `Are you sure you want to remove ` +
                            `"${productName}" from your cart?`;

                        openModal(modal);

                        cancelButton.focus();
                    });
            });

            cancelButton.addEventListener(
                "click",
                function () {
                    pendingRemoveForm = null;

                    closeModal(modal);

                    if (lastRemoveButton) {
                        lastRemoveButton.focus();
                    }
                });

            confirmButton.addEventListener(
                "click",
                function () {
                    if (!pendingRemoveForm) {
                        closeModal(modal);
                        return;
                    }

                    confirmButton.disabled = true;

                    confirmButton.textContent =
                        "Removing...";

                    pendingRemoveForm.requestSubmit();
                });

            modal.addEventListener(
                "click",
                function (event) {
                    if (event.target === modal) {
                        pendingRemoveForm = null;

                        closeModal(modal);
                    }
                });
        }

        // =====================================================
        // CLOSE MODAL WITH ESCAPE
        // =====================================================
        document.addEventListener(
            "keydown",
            function (event) {
                if (event.key !== "Escape") {
                    return;
                }

                document
                    .querySelectorAll(".app-modal.open")
                    .forEach(function (modal) {
                        closeModal(modal);
                    });
            });
    </script>

</body>
</html>