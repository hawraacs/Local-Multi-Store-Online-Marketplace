@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminSettingsModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="settings-card" style="background:white; border-radius:24px; padding:24px; margin-top:20px;">
    <h3>Platform Configuration</h3>
    <form method="post">
        <div class="mb-3">
            <label>Platform Name</label>
            <input type="text" name="PlatformName" class="form-control" value="@Model.PlatformName" />
        </div>
        <div class="mb-3">
            <label>Global Commission Rate (%)</label>
            <input type="number" step="0.1" name="CommissionRate" class="form-control" value="@Model.CommissionRate" />
        </div>
        <div class="mb-3">
            <label>Base Delivery Fee ($)</label>
            <input type="number" step="0.5" name="BaseDeliveryFee" class="form-control" value="@Model.BaseDeliveryFee" />
        </div>
        <div class="mb-3">
            <label>Free Delivery Threshold ($)</label>
            <input type="number" step="1" name="FreeDeliveryThreshold" class="form-control" value="@Model.FreeDeliveryThreshold" />
        </div>
        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" name="MaintenanceMode" @(Model.MaintenanceMode ? "checked" : "") />
            <label class="form-check-label">Enable Maintenance Mode</label>
        </div>
        <button type="submit" class="btn btn-primary">Save Settings</button>
    </form>
</div>