@page "{storeId:int}"
@model  Local_Multi_Store_Online_Marketplace.Pages.StoreReviewsModel

@{
    ViewData["Title"] = "Store Reviews";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

<h2>Store Reviews</h2>

@if (!Model.Reviews.Any())
{
    <p>No reviews yet.</p>
}
else
{
    @foreach (var r in Model.Reviews)
    {
        <div style="border:1px solid #ddd; padding:12px; margin-bottom:10px; border-radius:8px;">

            <!-- Customer Name -->
            <strong>
                @(r.CustomerName ?? "Unknown Customer")
            </strong>

            <br />

            <!-- Rating -->
            <span>
                @for (int i = 0; i < r.Rating; i++)
                {
                    <span>⭐</span>
                }
            </span>

            <p>@r.Comment</p>

            <small>@r.CreatedAt.ToString("yyyy-MM-dd")</small>

            <form method="post" asp-page-handler="Delete">
                <input type="hidden" name="reviewId" value="@r.ReviewID" />

                <button type="submit"
                        style="background:red;color:white;border:none;padding:5px 10px;margin-top:5px;">
                    Delete
                </button>
            </form>

        </div>
    }
}