@page "{storeId:int}"
@model Local_Multi_Store_Online_Marketplace.Pages.StoreReviewsModel

@{
    ViewData["Title"] = "Store Reviews";
    Layout = "/Pages/StoreOwner/Shared/_StoreOwnerLayout.cshtml";
}

@section Styles {
    <style>
        /* ============================================================
                   ROOT VARIABLES — Exactly matching your Dashboard
                   ============================================================ */
        :root {
            --accent-color: #6d28d9;
            --accent-hover: #5b21b6;
            --accent-light: #f3effe;
            --accent-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 55%, #4f46e5 100%);
            --bg-color: #f8f7fc;
            --card-bg: #ffffff;
            --text-primary: #1e1b2e;
            --text-secondary: #6b6478;
            --text-muted: #9691a4;
            --border-color: #ece8f6;
            --star-color: #f59e0b;
            --error-color: #dc2626;
            --shadow-sm: 0 4px 12px rgba(109, 40, 217, 0.06);
            --shadow-md: 0 10px 30px rgba(109, 40, 217, 0.10);
            --radius-md: 16px;
            --radius-lg: 24px;
            --transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }

        /* ============================================================
                   HEADER BANNER
                   ============================================================ */
        .reviews-hero {
            background: var(--accent-gradient);
            color: #ffffff;
            padding: 32px 40px;
            border-radius: var(--radius-lg);
            margin-bottom: 32px;
            box-shadow: var(--shadow-md), 0 8px 32px rgba(109, 40, 217, 0.20);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .hero-text h2 {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 4px;
            letter-spacing: -0.4px;
        }

        .hero-text p {
            font-size: 15px;
            opacity: 0.9;
            margin: 0;
        }

        .reviews-stats-summary {
            display: flex;
            gap: 20px;
        }

        .summary-pill {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
            padding: 10px 20px;
            border-radius: 14px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

            .summary-pill span {
                display: block;
                font-size: 11px;
                text-transform: uppercase;
                font-weight: 700;
                opacity: 0.8;
            }

            .summary-pill strong {
                font-size: 20px;
                font-weight: 800;
            }

        /* ============================================================
                   REVIEW CARDS
                   ============================================================ */
        .reviews-container {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .review-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 24px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

            .review-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--accent-gradient);
                opacity: 0;
                transition: var(--transition);
            }

            .review-card:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
                border-color: var(--accent-color);
            }

                .review-card:hover::before {
                    opacity: 1;
                }

        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .customer-info {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .customer-avatar {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: var(--accent-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 18px;
            box-shadow: 0 4px 10px rgba(109, 40, 217, 0.2);
        }

        .customer-name-meta {
            display: flex;
            flex-direction: column;
        }

        .customer-name {
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
            font-size: 16px;
            transition: var(--transition);
        }

            .customer-name:hover {
                color: var(--accent-color);
            }

        .review-date {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Star Rating Styling */
        .stars-container {
            display: flex;
            gap: 2px;
            color: var(--star-color);
            font-size: 14px;
        }

        .review-body {
            color: var(--text-secondary);
            line-height: 1.6;
            font-size: 15px;
            margin-bottom: 20px;
            padding-left: 62px; /* aligns with the text next to avatar */
        }

        /* ============================================================
                   FOOTER / ACTIONS
                   ============================================================ */
        .review-footer {
            display: flex;
            justify-content: flex-end;
            padding-top: 16px;
            border-top: 1px solid var(--border-color);
        }

        .btn-delete-review {
            background: #fff1f2;
            color: var(--error-color);
            border: 1px solid #fee2e2;
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-delete-review:hover {
                background: var(--error-color);
                color: white;
                border-color: var(--error-color);
            }

        /* ============================================================
                   EMPTY STATE
                   ============================================================ */
        .empty-state {
            background: var(--card-bg);
            border: 2px dashed var(--border-color);
            border-radius: var(--radius-lg);
            padding: 60px 20px;
            text-align: center;
        }

            .empty-state i {
                font-size: 48px;
                color: var(--accent-light);
                margin-bottom: 16px;
                display: block;
            }

            .empty-state h3 {
                color: var(--text-primary);
                font-weight: 700;
                margin-bottom: 8px;
            }

            .empty-state p {
                color: var(--text-muted);
            }

        @@media (max-width: 768px) {
            .reviews-hero {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
                padding: 24px;
            }

            .review-body {
                padding-left: 0;
            }
        }
    </style>
}

<!-- ========== HERO BANNER ========== -->
<div class="reviews-hero">
    <div class="hero-text">
        <h2>Customer Feedback</h2>
        <p>Monitor and manage your store's reputation.</p>
    </div>
    <div class="reviews-stats-summary">
        <div class="summary-pill">
            <span>Total Reviews</span>
            <strong>@Model.Reviews.Count</strong>
        </div>
        @if (Model.Reviews.Any())
        {
            <div class="summary-pill">
                <span>Avg. Rating</span>
                <strong>@(Model.Reviews.Average(r => r.Rating).ToString("F1")) <i class="fas fa-star" style="font-size: 14px; color: var(--star-color);"></i></strong>
            </div>
        }
    </div>
</div>

<!-- ========== REVIEWS LIST ========== -->
<div class="reviews-container">
    @if (!Model.Reviews.Any())
    {
        <div class="empty-state">
            <i class="fas fa-comment-slash"></i>
            <h3>No Reviews Yet</h3>
            <p>Customer feedback will appear here once orders are completed.</p>
        </div>
    }
    else
    {
        @foreach (var r in Model.Reviews)
        {
            var customerName = r.CustomerName ?? "Verified Customer";
            var initial = customerName.Length > 0 ? customerName.Substring(0, 1).ToUpper() : "?";

            <div class="review-card">
                <div class="review-header">
                    <div class="customer-info">
                        <div class="customer-avatar">@initial</div>
                        <div class="customer-name-meta">
                            <a asp-page="/StoreViewCustomer" asp-route-customerId="@r.CustomerID" class="customer-name">
                                @customerName
                            </a>
                            <span class="review-date">@r.CreatedAt.ToString("MMMM dd, yyyy")</span>
                        </div>
                    </div>

                    <div class="stars-container">
                        @for (int i = 0; i < 5; i++)
                        {
                            if (i < r.Rating)
                            {
                                <i class="fa-solid fa-star"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-star" style="opacity: 0.3;"></i>
                            }
                        }
                    </div>
                </div>

                <div class="review-body">
                    @r.Comment
                </div>

                <div class="review-footer">
                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Are you sure you want to delete this review?');">
                        <input type="hidden" name="reviewId" value="@r.ReviewID" />
                        <button type="submit" class="btn-delete-review">
                            <i class="fa-solid fa-trash-can"></i>
                            Delete Review
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>