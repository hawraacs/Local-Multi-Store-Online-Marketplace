@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAnalyticsModel
@{
    ViewData["Title"] = "Analytics & Reports";
}

@section Styles {
    <style>
        .analytics-card {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-top: 20px;
            margin-bottom: 24px;
        }

        .chart-container {
            height: 300px;
            margin-top: 20px;
        }

        .btn-export {
            background: #2563eb;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 40px;
            cursor: pointer;
        }
    </style>
}

<div class="analytics-card">
    <h3>Sales Overview</h3>
    <div>
        <label>Date Range:</label>
        <select id="dateRange">
            <option value="7">Last 7 days</option>
            <option value="30" selected>Last 30 days</option>
            <option value="90">Last 90 days</option>
        </select>
        <button id="refreshChart" class="btn-export">Refresh</button>
        <button id="exportReportBtn" class="btn-export">Export Report</button>
    </div>
    <div class="chart-container">
        <canvas id="salesChart"></canvas>
    </div>
</div>

<div class="analytics-card">
    <h3>Top Performing Stores</h3>
    <div class="table-responsive">
        <table id="topStoresTable">
            <thead><tr><th>Store Name</th><th>Revenue</th><th>Orders</th><th>Rating</th></tr></thead>
            <tbody>
                @foreach (var store in Model.TopStores)
                {
                    <tr><td>@store.Name</td><td>$@store.Revenue</td><td>@store.OrderCount</td><td>⭐ @store.Rating</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let salesChart;
        async function loadChart(days) {
        // Replace with API call to your backend
        const response = await fetch(`/api/analytics/sales?days=${days}`);
        const data = await response.json(); // expects { labels: [], values: [] }
        if (salesChart) salesChart.destroy();
        const ctx = document.getElementById('salesChart').getContext('2d');
        salesChart = new Chart(ctx, {
        type: 'line',
        data: { labels: data.labels, datasets: [{ label: 'Sales ($)', data: data.values, borderColor: '#FF6B35' }] }
        });
        }
        document.getElementById('refreshChart').addEventListener('click', () => {
        const days = document.getElementById('dateRange').value;
        loadChart(days);
        });
        loadChart(30);
    </script>
}