@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAnalyticsModel
@{
    ViewData["Title"] = "Analytics & Reports";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #6366F1;
            --brand-dark: #4F46E5;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --navy: #0F172A;
            --bg: #F8FAFC;
            --surface: #FFFFFF;
            --surface-2: #F8FAFC;
            --border: #E2E8F0;
            --text: #0F172A;
            --muted: #64748B;
            --positive: #16A34A;
            --positive-bg: #DCFCE7;
            --positive-txt: #15803D;
            --warn-bg: #FEF3C7;
            --warn-txt: #B45309;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 22px;
            --shadow: 0 1px 3px rgba(15,23,42,0.06), 0 6px 20px -8px rgba(15,23,42,0.10);
            --shadow-lg: 0 12px 32px -8px rgba(15,23,42,0.16);
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        .analytics {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 4px 48px;
            color: var(--text);
            font-family: var(--font);
        }

        /* ── Header ── */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px;
            padding: 28px 4px 24px;
            margin-bottom: 4px;
            border-bottom: 1px solid var(--border);
        }

        .header-left h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin: 0 0 4px;
        }

        .header-left p {
            font-size: 13.5px;
            color: var(--muted);
            margin: 0;
        }

        .header-badge {
            display: flex;
            align-items: center;
            gap: 7px;
            background: var(--navy);
            color: #fff;
            border-radius: 999px;
            padding: 8px 16px 8px 12px;
            font-size: 12.5px;
            font-weight: 600;
            box-shadow: 0 2px 10px rgba(11,20,55,0.18);
        }

            .header-badge::before {
                content: "";
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background: var(--brand);
                flex-shrink: 0;
            }

        /* ── Stat Cards ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 18px;
            margin: 28px 0;
        }

        .stat-card {
            position: relative;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px 22px 20px;
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: transform 0.22s ease, box-shadow 0.22s ease;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
            }

        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-sm);
            background: var(--brand-soft);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }

            .stat-icon svg {
                width: 20px;
                height: 20px;
                stroke: var(--brand);
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .stat-title {
            color: var(--muted);
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 12px;
        }

        .stat-change {
            font-size: 12.5px;
            color: var(--muted);
            font-weight: 500;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }

            .stat-change .positive {
                color: var(--positive);
                font-weight: 700;
            }

        /* ── Panel ── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 26px 26px 22px;
            box-shadow: var(--shadow);
            margin-bottom: 20px;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
        }

            .panel-header h3 {
                font-size: 15px;
                font-weight: 700;
                letter-spacing: -0.02em;
                margin: 0;
            }

        .panel-controls {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .panel-tag {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--brand);
            background: var(--brand-soft);
            padding: 4px 10px;
            border-radius: 999px;
        }

        select#dateRange {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 10px;
            font-size: 12.5px;
            font-family: var(--font);
            color: var(--text);
            background: var(--surface-2);
            cursor: pointer;
            outline: none;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            border-radius: 999px;
            padding: 7px 16px;
            font-size: 12.5px;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: opacity 0.18s ease;
        }

            .btn:hover {
                opacity: 0.85;
            }

        .btn-primary {
            background: var(--brand);
            color: #fff;
        }

        .btn-outline {
            background: var(--surface);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .chart-container {
            height: 300px;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media (max-width:900px) {
            .grid-2 {
                grid-template-columns: 1fr;
            }
        }

        /* ── Table ── */
        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

            thead th:first-child {
                border-radius: var(--radius-sm) 0 0 0;
            }

            thead th:last-child {
                border-radius: 0 var(--radius-sm) 0 0;
            }

        tbody td {
            padding: 14px;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-weight: 500;
        }

        tbody tr {
            transition: background 0.14s ease;
        }

            tbody tr:hover td {
                background: var(--surface-2);
            }

            tbody tr:last-child td {
                border-bottom: none;
            }

        .store-name {
            font-weight: 600;
            color: var(--navy);
        }

        .amount {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }

        .rank-num {
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
        }

        .stars {
            color: #F59E0B;
            font-size: 13px;
        }

        /* ── Section label ── */
        .section-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin: 28px 0 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .section-label::after {
                content: "";
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--muted);
            font-size: 13.5px;
        }

        /* ── Growth table extras ── */
        .growth-table td {
            padding: 8px 12px;
            border-bottom: 1px solid var(--border);
        }

        .growth-table .positive {
            color: var(--positive);
            font-weight: 700;
        }

        .growth-table .negative {
            color: #DC2626;
            font-weight: 700;
        }

        @@media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat-card {
                padding: 16px 14px 14px;
            }

            .stat-value {
                font-size: 24px;
            }

            .stat-icon {
                width: 36px;
                height: 36px;
            }

                .stat-icon svg {
                    width: 16px;
                    height: 16px;
                }

            .dashboard-header h1 {
                font-size: 22px;
            }
        }

        @@media (max-width: 600px) {
            .chart-container {
                height: 220px;
            }

            .panel {
                padding: 16px 14px 18px;
            }
        }
    </style>
}

<div class="analytics">

    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-left">
            <h1>Analytics &amp; Reports</h1>
            <p>Sales trends, store performance, and platform insights</p>
        </div>
        <div>
            <span class="header-badge">Last 30 Days</span>
        </div>
    </div>

    <!-- ── KPI Cards ── -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg></div>
            <div class="stat-title">Revenue (30 days)</div>
            <div class="stat-value">$@Model.RevenueInRange.ToString("N0")</div>
            <div class="stat-change">
                <span class="positive">↑ @Model.RevenueGrowth.ToString("N1")%</span> vs previous period
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 01-8 0" /></svg></div>
            <div class="stat-title">Orders (30 days)</div>
            <div class="stat-value">@Model.OrdersInRange</div>
            <div class="stat-change">Avg <span class="positive">$@Model.AvgOrderValue.ToString("N0")</span> per order</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" /></svg></div>
            <div class="stat-title">Total Customers</div>
            <div class="stat-value">@Model.TotalCustomers</div>
            <div class="stat-change">@Model.NewCustomersCurrent new this month</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg></div>
            <div class="stat-title">Active Stores</div>
            <div class="stat-value">@Model.ActiveStores</div>
            <div class="stat-change">With at least one order this period</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg></div>
            <div class="stat-title">Active Subscriptions</div>
            <div class="stat-value">@Model.ActiveSubscriptions</div>
            <div class="stat-change">Currently subscribed stores</div>
        </div>
    </div>

    <!-- ── Sales Trend (dynamic) ── -->
    <div class="section-label">Sales Trend</div>
    <div class="panel">
        <div class="panel-header">
            <h3>Sales Overview</h3>
            <div class="panel-controls">
                <select id="dateRange">
                    <option value="7">Last 7 days</option>
                    <option value="30" selected>Last 30 days</option>
                    <option value="90">Last 90 days</option>
                </select>
                <button id="refreshChart" class="btn btn-primary">Refresh</button>
                <button id="exportReportBtn" class="btn btn-outline">Export CSV</button>
            </div>
        </div>
        <div class="chart-container"><canvas id="salesChart"></canvas></div>
    </div>

    <!-- ── Financial Analytics ── -->
    <div class="section-label">Financial Analytics</div>
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header"><h3>Revenue (12 Months)</h3><span class="panel-tag">Trend</span></div>
            <div class="chart-container"><canvas id="revenueChart"></canvas></div>
        </div>
        <div class="panel">
            <div class="panel-header"><h3>Orders (12 Months)</h3><span class="panel-tag">Trend</span></div>
            <div class="chart-container"><canvas id="ordersChart"></canvas></div>
        </div>
    </div>

    <!-- ── Revenue Breakdown (Pie) ── -->
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header"><h3>Revenue Breakdown</h3><span class="panel-tag">Last 30 Days</span></div>
            <div class="chart-container" style="height:260px;"><canvas id="revenueBreakdownChart"></canvas></div>
        </div>
        <div class="panel">
            <div class="panel-header"><h3>Order Status</h3><span class="panel-tag">Distribution</span></div>
            <div class="chart-container" style="height:260px;"><canvas id="orderStatusChart"></canvas></div>
        </div>
    </div>

    <!-- ── Growth Analytics ── -->
    <div class="section-label">Marketplace Growth</div>
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header"><h3>New Stores Per Month</h3><span class="panel-tag">12 Months</span></div>
            <div class="chart-container"><canvas id="storesChart"></canvas></div>
        </div>
        <div class="panel">
            <div class="panel-header"><h3>New Customers Per Month</h3><span class="panel-tag">12 Months</span></div>
            <div class="chart-container"><canvas id="customersChart"></canvas></div>
        </div>
    </div>

    <!-- ── Monthly Growth Comparison ── -->
    <div class="section-label">Business Reports</div>
    <div class="panel">
        <div class="panel-header">
            <h3>Monthly Growth Comparison</h3>
            <span class="panel-tag">Current vs Previous Month</span>
        </div>
        <div class="table-responsive">
            <table class="growth-table" style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th>Previous Month</th>
                        <th>Current Month</th>
                        <th>Growth</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Revenue</strong></td>
                        <td>$@Model.RevenuePrevious.ToString("N0")</td>
                        <td>$@Model.RevenueInRange.ToString("N0")</td>
                        <td class="@(Model.RevenueGrowth >= 0 ? "positive" : "negative")">
                            @(Model.RevenueGrowth >= 0 ? "↑" : "↓") @Math.Abs(Model.RevenueGrowth).ToString("N1")%
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Orders</strong></td>
                        <td>@Model.OrdersPrevious</td>
                        <td>@Model.OrdersInRange</td>
                        <td class="@(Model.OrdersInRange >= Model.OrdersPrevious ? "positive" : "negative")">
                            @(Model.OrdersInRange >= Model.OrdersPrevious ? "↑" : "↓") @(((decimal)(Model.OrdersInRange - Model.OrdersPrevious) / (Model.OrdersPrevious == 0 ? 1 : Model.OrdersPrevious) * 100).ToString("N1"))%
                        </td>
                    </tr>
                    <tr>
                        <td><strong>New Stores</strong></td>
                        <td>@Model.NewStoresPrevious</td>
                        <td>@Model.NewStoresCurrent</td>
                        <td class="@(Model.NewStoresCurrent >= Model.NewStoresPrevious ? "positive" : "negative")">
                            @(Model.NewStoresCurrent >= Model.NewStoresPrevious ? "↑" : "↓") @(((decimal)(Model.NewStoresCurrent - Model.NewStoresPrevious) / (Model.NewStoresPrevious == 0 ? 1 : Model.NewStoresPrevious) * 100).ToString("N1"))%
                        </td>
                    </tr>
                    <tr>
                        <td><strong>New Customers</strong></td>
                        <td>@Model.NewCustomersPrevious</td>
                        <td>@Model.NewCustomersCurrent</td>
                        <td class="@(Model.NewCustomersCurrent >= Model.NewCustomersPrevious ? "positive" : "negative")">
                            @(Model.NewCustomersCurrent >= Model.NewCustomersPrevious ? "↑" : "↓") @(((decimal)(Model.NewCustomersCurrent - Model.NewCustomersPrevious) / (Model.NewCustomersPrevious == 0 ? 1 : Model.NewCustomersPrevious) * 100).ToString("N1"))%
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Store Performance (Top Stores) ── -->
    <div class="section-label">Store Performance</div>
    <div class="panel">
        <div class="panel-header">
            <h3>Top Performing Stores</h3>
            <span class="panel-tag">Last 30 Days</span>
        </div>
        <div class="table-responsive">
            <table id="topStoresTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Store Name</th>
                        <th>Revenue</th>
                        <th>Orders</th>
                        <th>Avg Order</th>
                        <th>Rating</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.TopStores.Any())
                    {
                        <tr><td colspan="6" class="empty-state">No store data available.</td></tr>
                    }
                    else
                    {
                        int rank = 1;
                        @foreach (var store in Model.TopStores)
                        {
                            <tr>
                                <td class="rank-num">@(rank++)</td>
                                <td><span class="store-name">@store.Name</span></td>
                                <td><span class="amount">$@store.Revenue.ToString("N2")</span></td>
                                <td>@store.OrderCount</td>
                                <td><span class="amount">$@store.AvgOrderValue.ToString("N0")</span></td>
                                <td><span class="stars">★</span> @store.Rating.ToString("N1")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // ── Helper: Initialize a chart ──
        function initChart(id, config) {
        const ctx = document.getElementById(id).getContext('2d');
        return new Chart(ctx, config);
        }

        // ── Data from server ──
        const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueLabels));
        const revenueData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueData));

        const orderLabels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderLabels));
        const orderData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyOrderData));

        const storeLabels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyStoreLabels));
        const storeData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyStoreData));

        const customerLabels= @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyCustomerLabels));
        const customerData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyCustomerData));

        const statusLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderStatusDistribution.Keys));
        const statusData    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderStatusDistribution.Values));

        const commissionRev = @Model.CommissionRevenue;
        const subscriptionRev = @Model.SubscriptionRevenue;

        // ── 1. Revenue (12 months) ──
        initChart('revenueChart', {
        type: 'line',
        data: {
        labels: revenueLabels,
        datasets: [{
        label: 'Revenue',
        data: revenueData,
        borderColor: '#6366F1',
        backgroundColor: 'rgba(99,102,241,0.10)',
        fill: true,
        tension: 0.4,
        borderWidth: 3
        }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // ── 2. Orders (12 months) ──
        initChart('ordersChart', {
        type: 'bar',
        data: {
        labels: orderLabels,
        datasets: [{ data: orderData, backgroundColor: '#6366F1' }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // ── 3. New Stores per month ──
        initChart('storesChart', {
        type: 'bar',
        data: {
        labels: storeLabels,
        datasets: [{ data: storeData, backgroundColor: '#16A34A' }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // ── 4. New Customers per month ──
        initChart('customersChart', {
        type: 'bar',
        data: {
        labels: customerLabels,
        datasets: [{ data: customerData, backgroundColor: '#D97706' }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // ── 5. Revenue Breakdown (Pie) ──
        initChart('revenueBreakdownChart', {
        type: 'pie',
        data: {
        labels: ['Commission', 'Subscription'],
        datasets: [{
        data: [commissionRev, subscriptionRev],
        backgroundColor: ['#6366F1', '#8B5CF6'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
        }
        }
        });

        // ── 6. Order Status Distribution (Doughnut) ──
        const statusColors = ['#16A34A', '#D97706', '#DC2626', '#6B7280', '#6366F1'];
        initChart('orderStatusChart', {
        type: 'doughnut',
        data: {
        labels: statusLabels,
        datasets: [{
        data: statusData,
        backgroundColor: statusColors.slice(0, statusLabels.length),
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
        }
        }
        });

        // ── 7. Dynamic Sales Chart (interactive) ──
        let salesChart;
        async function loadSalesChart(days) {
        const res = await fetch(`/AdminAnalytics?handler=Sales&days=${days}`);
        if (!res.ok) return;
        const data = await res.json();
        if (salesChart) salesChart.destroy();

        const ctx = document.getElementById('salesChart').getContext('2d');
        salesChart = new Chart(ctx, {
        type: 'line',
        data: {
        labels: data.labels,
        datasets: [{
        label: 'Sales ($)',
        data: data.values,
        borderColor: '#6366F1',
        backgroundColor: 'rgba(99,102,241,0.10)',
        fill: true,
        tension: 0.4,
        borderWidth: 2.5,
        pointRadius: 3,
        pointBackgroundColor: '#6366F1',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointHoverRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        y: { beginAtZero: true, grid: { color: '#E2E8F0' }, ticks: { color: '#64748B', font: { size: 11 } } },
        x: { grid: { display: false }, ticks: { color: '#64748B', font: { size: 11 } } }
        }
        }
        });
        }

        document.getElementById('refreshChart').addEventListener('click', () => {
        loadSalesChart(document.getElementById('dateRange').value);
        });

        // ── Export CSV (Top Stores) ──
        document.getElementById('exportReportBtn').addEventListener('click', () => {
        const rows = [['#', 'Store', 'Revenue', 'Orders', 'Avg Order', 'Rating']];
        document.querySelectorAll('#topStoresTable tbody tr').forEach(tr => {
        rows.push([...tr.querySelectorAll('td')].map(td => td.innerText.trim()));
        });
        const csv = rows.map(r => r.join(',')).join('\n');
        const a = document.createElement('a');
        a.href = 'data:text/csv,' + encodeURIComponent(csv);
        a.download = 'analytics-report.csv';
        a.click();
        });

        // ── Initial load ──
        loadSalesChart(30);
    </script>
}
