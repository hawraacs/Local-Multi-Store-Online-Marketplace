@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    body {
        background: #f8fafc;
        font-family: Arial, sans-serif;
        color: #1f2937;
    }

    .hero {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .title {
        font-size: 3rem;
        font-weight: 800;
        color: #111827;
    }

    .subtitle {
        font-size: 1.2rem;
        color: #6b7280;
        margin-top: 10px;
    }

    .btn-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 25px;
        align-items: center;
    }

    .btn-login {
        background: #22c55e; /* soft green */
        color: white;
        padding: 12px 28px;
        width: 220px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.25s;
        box-shadow: 0 5px 15px rgba(34,197,94,0.2);
    }

        .btn-login:hover {
            background: #16a34a;
            transform: translateY(-2px);
        }

    .btn-register {
        background: #ef4444; /* soft red */
        color: white;
        padding: 12px 28px;
        width: 220px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.25s;
        box-shadow: 0 5px 15px rgba(239,68,68,0.2);
    }

        .btn-register:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

    .card-row {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 50px;
        flex-wrap: wrap;
    }

    .card {
        background: white;
        padding: 20px;
        width: 250px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .green {
        color: #22c55e;
        font-weight: bold;
    }

    .red {
        color: #ef4444;
        font-weight: bold;
    }
</style>

<div class="hero">

    <div>

        <div class="title">Welcome To Your Dream Shop</div>

        <div class="subtitle">
            Buy • Sell • Discover products easily
        </div>

        <div class="btn-stack">

            <a asp-area="Identity" asp-page="/Account/Login" class="btn-login">
                Login
            </a>

            <a asp-area="Identity" asp-page="/Account/Register" class="btn-register">
                Sign Up
            </a>

        </div>

        <div class="card-row">

            <div class="card">
                <div class="green">Multi Store</div>
                Manage different shops easily
            </div>

            <div class="card">
                <div class="red">Secure</div>
                Safe login & protected data
            </div>

            <div class="card">
                <div class="green">Fast</div>
                Quick browsing experience
            </div>

        </div>

    </div>

</div>