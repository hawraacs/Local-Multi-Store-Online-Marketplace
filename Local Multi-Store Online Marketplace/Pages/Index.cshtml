@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --bg-color: #fdfbf7; /* Cozy warm white canvas */
            --card-bg: #ffffff;
            --border-color: #f3ece3; /* Soft warm borders */
            --text-primary: #1c1917; /* Slate dark brown/black */
            --text-secondary: #78716c; /* Elegant muted stone gray */
            /* White & Orange Sunset Palette */
            --accent-color: #ff6b35; /* Radiant bright orange */
            --accent-hover: #f05a22; /* Rich dark orange */
            --accent-light: #fff1eb; /* Pastel orange tint */
            --accent-gradient: linear-gradient(135deg, #ff9f43 0%, #ff6b35 50%, #f05a22 100%); /* Orange-to-coral punch */

            --success-color: #10b981; /* Healthy green */
            --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --shadow-sm: 0 4px 12px rgba(255, 107, 53, 0.04);
            --shadow-md: 0 10px 30px rgba(255, 107, 53, 0.08);
            --shadow-lg: 0 20px 40px rgba(255, 107, 53, 0.12);
        }

        .home-wrapper {
            margin-left: calc(50% - 50vw);
            margin-right: calc(50% - 50vw);
            background: var(--bg-color);
            color: var(--text-primary);
            overflow: hidden;
            font-family: var(--font-family);
        }

        .home-hero {
            min-height: 86vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 24px;
            background: radial-gradient(circle at 12% 18%, rgba(255, 107, 53, 0.08), transparent 38%), radial-gradient(circle at 88% 28%, rgba(245, 158, 11, 0.06), transparent 34%), #fdfbf7;
        }

            .home-hero::before {
                content: "";
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255, 107, 53, 0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 107, 53, 0.015) 1px, transparent 1px);
                background-size: 58px 58px;
                opacity: 1;
                pointer-events: none;
            }

            .home-hero::after {
                content: "";
                position: absolute;
                width: 520px;
                height: 520px;
                border-radius: 50%;
                background: rgba(255, 107, 53, 0.04);
                filter: blur(100px);
                bottom: -190px;
                right: -130px;
                pointer-events: none;
            }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 1120px;
            width: 100%;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            align-items: center;
            gap: 50px;
        }

        .hero-text-panel {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--border-color);
            border-radius: 30px;
            padding: 52px 46px;
            box-shadow: var(--shadow-lg);
            backdrop-filter: blur(14px);
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--accent-light);
            border: 1px solid rgba(255, 107, 53, 0.15);
            color: var(--accent-color);
            padding: 10px 18px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 24px;
        }

            .hero-badge i {
                color: var(--accent-color);
            }

        .hero-title {
            font-size: 58px;
            line-height: 1.1;
            letter-spacing: -1.6px;
            font-weight: 900;
            margin-bottom: 24px;
            color: var(--text-primary);
        }

            .hero-title span {
                background: var(--accent-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .hero-description {
            font-size: 17px;
            line-height: 1.7;
            color: var(--text-secondary);
            margin-bottom: 34px;
            max-width: 620px;
        }

        .hero-actions {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: center;
        }

        .hero-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: 800;
            text-decoration: none;
            transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-size: 15px;
        }

        .hero-btn-primary {
            background: var(--accent-gradient);
            color: white;
            box-shadow: 0 10px 25px rgba(255, 107, 53, 0.3);
        }

            .hero-btn-primary:hover {
                box-shadow: 0 14px 30px rgba(255, 107, 53, 0.4);
                transform: translateY(-3px);
            }

        .hero-btn-secondary {
            background: var(--card-bg);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
        }

            .hero-btn-secondary:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                transform: translateY(-3px);
                background: var(--accent-light);
            }

        .hero-card {
            position: relative;
            background: rgba(255, 255, 255, 0.5);
            border: 1px solid var(--border-color);
            border-radius: 30px;
            padding: 24px;
            box-shadow: var(--shadow-md);
            backdrop-filter: blur(18px);
        }

            .hero-card::before {
                content: "";
                position: absolute;
                inset: -1px;
                border-radius: 30px;
                background: linear-gradient(135deg, rgba(255,161,67,0.2), transparent, rgba(255,107,53,0.15));
                z-index: -1;
            }

        .market-card {
            background: #ffffff;
            color: var(--text-primary);
            border-radius: 24px;
            padding: 24px;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(255, 107, 53, 0.05);
        }

        .market-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
        }

        .market-card-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .market-pill {
            background: var(--accent-light);
            color: var(--accent-color);
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .market-pill::before {
                content: "";
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background-color: var(--accent-color);
                display: inline-block;
            }

        .product-preview {
            display: grid;
            grid-template-columns: 82px 1fr;
            gap: 16px;
            align-items: center;
            padding: 14px;
            border-radius: 20px;
            background: var(--bg-color);
            margin-bottom: 14px;
            border: 1px solid var(--border-color);
            transition: all 0.25s ease;
        }

            .product-preview:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md);
                border-color: var(--accent-color);
            }

        .product-icon {
            width: 82px;
            height: 82px;
            border-radius: 16px;
            background: var(--accent-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: var(--accent-color);
            box-shadow: var(--shadow-sm);
        }

        .product-preview h4 {
            margin: 0 0 6px;
            font-size: 15px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .product-preview p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 12px;
        }

        .product-preview strong {
            display: block;
            margin-top: 6px;
            color: var(--accent-color);
            font-size: 13px;
            font-weight: 800;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 18px;
        }

        .stat-box {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 14px;
            text-align: center;
            transition: border-color 0.2s ease;
        }

            .stat-box:hover {
                border-color: var(--accent-color);
            }

            .stat-box strong {
                display: block;
                font-size: 18px;
                color: var(--accent-color);
                font-weight: 800;
            }

            .stat-box span {
                font-size: 11px;
                color: var(--text-secondary);
                font-weight: 700;
            }

        /* FEATURES SECTION */
        .home-features {
            background: #faf8f5;
            padding: 80px 24px;
            border-top: 1px solid var(--border-color);
        }

        .features-container {
            max-width: 1120px;
            margin: auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
        }

        .feature-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 38px 28px;
            text-align: center;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: var(--shadow-sm);
        }

            .feature-card:hover {
                transform: translateY(-6px);
                border-color: var(--accent-color);
                box-shadow: var(--shadow-lg);
            }

            .feature-card i {
                width: 66px;
                height: 66px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: var(--accent-light);
                color: var(--accent-color);
                border-radius: 20px;
                font-size: 26px;
                margin-bottom: 22px;
                box-shadow: var(--shadow-sm);
            }

            .feature-card h3 {
                color: var(--text-primary);
                font-size: 20px;
                font-weight: 800;
                margin-bottom: 12px;
            }

            .feature-card p {
                color: var(--text-secondary);
                line-height: 1.6;
                margin: 0;
                font-size: 14px;
            }

        /* RESPONSIVE STYLES */
        @@media (max-width: 950px) {
            .hero-content {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .hero-title {
                font-size: 44px;
            }

            .hero-text-panel {
                text-align: center;
                padding: 42px 24px;
            }

            .hero-description {
                margin-left: auto;
                margin-right: auto;
            }

            .hero-actions {
                justify-content: center;
            }

            .features-container {
                grid-template-columns: 1fr;
                gap: 20px;
            }
        }

        @@media (max-width: 560px) {
            .home-hero {
                padding: 48px 16px;
            }

            .hero-title {
                font-size: 34px;
            }

            .hero-card {
                padding: 12px;
            }

            .stats-row {
                grid-template-columns: 1fr;
            }

            .hero-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="home-wrapper">

    <!-- HERO SECTION -->
    <section class="home-hero">

        <div class="hero-content">

            <!-- TEXT PANEL -->
            <div class="hero-text-panel">

                <div class="hero-badge">
                    <i class="fas fa-bolt"></i>
                    Fast, secure, and local marketplace
                </div>

                <h1 class="hero-title">
                    Multi Store Online <span>Marketplace</span>
                </h1>

                <p class="hero-description">
                    Discover trusted local stores, shop products easily,
                    track your orders, and enjoy a smooth marketplace
                    experience built for customers, store owners, and delivery teams.
                </p>

                <div class="hero-actions">
                    <a asp-area="Identity"
                       asp-page="/Account/Register"
                       class="hero-btn hero-btn-primary">
                        <i class="fas fa-user-plus"></i>
                        Get Started
                    </a>

                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="hero-btn hero-btn-secondary">
                        <i class="fas fa-right-to-bracket"></i>
                        Sign In
                    </a>
                </div>

            </div>

            <!-- LIVE CARD PREVIEW -->
            <div class="hero-card">

                <div class="market-card">

                    <div class="market-card-header">
                        <div class="market-card-title">
                            Marketplace Preview
                        </div>

                        <div class="market-pill">
                            Live
                        </div>
                    </div>

                    <div class="product-preview">
                        <div class="product-icon">
                            <i class="fas fa-store"></i>
                        </div>

                        <div>
                            <h4>Local Stores</h4>
                            <p>Browse multiple trusted sellers in one place.</p>
                            <strong>Fast access</strong>
                        </div>
                    </div>

                    <div class="product-preview">
                        <div class="product-icon">
                            <i class="fas fa-cart-shopping"></i>
                        </div>

                        <div>
                            <h4>Easy Shopping</h4>
                            <p>Add items to cart, checkout, and track orders.</p>
                            <strong>Secure checkout</strong>
                        </div>
                    </div>

                    <div class="product-preview">
                        <div class="product-icon">
                            <i class="fas fa-truck-fast"></i>
                        </div>

                        <div>
                            <h4>Fast Delivery</h4>
                            <p>Delivery workflow for customers and delivery teams.</p>
                            <strong>Reliable service</strong>
                        </div>
                    </div>

                    <div class="stats-row">
                        <div class="stat-box">
                            <strong>24/7</strong>
                            <span>Access</span>
                        </div>

                        <div class="stat-box">
                            <strong>Multi</strong>
                            <span>Stores</span>
                        </div>

                        <div class="stat-box">
                            <strong>Safe</strong>
                            <span>Shopping</span>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- CORE FEATURES GRID -->
    <section class="home-features">

        <div class="features-container">

            <div class="feature-card">
                <i class="fas fa-store"></i>
                <h3>Multi Stores</h3>
                <p>
                    Customers can browse products from many stores inside one organized marketplace.
                </p>
            </div>

            <div class="feature-card">
                <i class="fas fa-truck"></i>
                <h3>Fast Delivery</h3>
                <p>
                    Orders can be managed and delivered through a clear delivery workflow.
                </p>
            </div>

            <div class="feature-card">
                <i class="fas fa-shield-alt"></i>
                <h3>Secure Shopping</h3>
                <p>
                    Role-based access, authentication, and protected customer experience.
                </p>
            </div>

        </div>

    </section>

</div>