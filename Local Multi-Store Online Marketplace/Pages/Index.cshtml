@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial;
    }

    body {
        background: #0f172a;
        color: white;
    }

    .hero {
        width: 100%;
        min-height: 100vh;
        background: linear-gradient(rgba(0,0,0,.65), rgba(0,0,0,.65)), url('/images/home-bg.jpg');
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
    }

    .navbar {
        width: 100%;
        padding: 25px 80px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .logo {
        font-size: 32px;
        font-weight: bold;
        color: white;
    }

    .nav-links {
        display: flex;
        gap: 25px;
        align-items: center;
    }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 16px;
            transition: .3s;
        }

            .nav-links a:hover {
                color: #60a5fa;
            }

    .btn-login {
        padding: 10px 25px;
        background: #2563eb;
        border-radius: 30px;
        color: white !important;
    }

    .hero-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 20px;
    }

    .hero-box {
        max-width: 850px;
    }

        .hero-box h1 {
            font-size: 70px;
            margin-bottom: 25px;
            line-height: 1.2;
        }

        .hero-box p {
            font-size: 22px;
            color: #d1d5db;
            margin-bottom: 40px;
            line-height: 1.8;
        }

    .buttons {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

        .buttons a {
            padding: 16px 40px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 18px;
            font-weight: bold;
            transition: .3s;
        }

    .btn-shop {
        background: #2563eb;
        color: white;
    }

    .btn-register {
        border: 2px solid white;
        color: white;
    }

    .buttons a:hover {
        transform: translateY(-5px);
    }

    .features {
        width: 100%;
        background: #111827;
        padding: 80px;
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 30px;
    }

    .feature-card {
        background: #1e293b;
        padding: 40px;
        border-radius: 18px;
        text-align: center;
        transition: .3s;
    }

        .feature-card:hover {
            transform: translateY(-8px);
        }

        .feature-card i {
            font-size: 45px;
            color: #60a5fa;
            margin-bottom: 25px;
        }

        .feature-card h3 {
            margin-bottom: 15px;
            font-size: 25px;
        }

        .feature-card p {
            color: #cbd5e1;
            line-height: 1.8;
            font-size: 16px;
        }

    @@media(max-width:900px) {

        .navbar {
            padding: 20px;
            flex-direction: column;
            gap: 20px;
        }

        .hero-box h1 {
            font-size: 45px;
        }

        .features {
            grid-template-columns: 1fr;
            padding: 40px 20px;
        }
    }

</style>

<div class="hero">

    <div class="navbar">

        <div class="logo">
            RealNest
        </div>

        <div class="nav-links">

            <a href="/">Home</a>

            <a href="#">Stores</a>

            <a href="#">Products</a>

            <a href="#">About</a>

            <a asp-area="Identity"
               asp-page="/Account/Login"
               class="btn-login">

                Login

            </a>

        </div>

    </div>

    <div class="hero-content">

        <div class="hero-box">

            <h1>
                Multi Store Online Marketplace
            </h1>

            <p>
                Buy products from multiple stores with fast delivery,
                secure shopping, and the best online marketplace experience.
            </p>

            <div class="buttons">

                <a asp-area="Identity"
                   asp-page="/Account/Register"
                   class="btn-shop">

                    Get Started

                </a>

                <a asp-area="Identity"
                   asp-page="/Account/Login"
                   class="btn-register">

                    Sign In

                </a>

            </div>

        </div>

    </div>

</div>

<div class="features">

    <div class="feature-card">

        <i class="fas fa-store"></i>

        <h3>Multi Stores</h3>

        <p>
            Browse products from many stores in one place easily.
        </p>

    </div>

    <div class="feature-card">

        <i class="fas fa-truck"></i>

        <h3>Fast Delivery</h3>

        <p>
            Quick and reliable delivery for all customer orders.
        </p>

    </div>

    <div class="feature-card">

        <i class="fas fa-shield-alt"></i>

        <h3>Secure Shopping</h3>

        <p>
            Protected accounts and secure online payment experience.
        </p>

    </div>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />