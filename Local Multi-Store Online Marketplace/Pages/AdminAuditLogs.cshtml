@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminAuditLogsModel
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="audit-card" style="background:white; border-radius:24px; padding:24px; margin-top:20px;">
    <h3>System Audit Trail</h3>
    <div class="filter-bar" style="display:flex; gap:12px; margin-bottom:20px;">
        <input type="text" id="searchLog" placeholder="User or Action...">
        <input type="date" id="dateFrom">
        <input type="date" id="dateTo">
        <button id="exportAuditBtn" class="btn-export" style="background:#2563eb; color:white; border:none; padding:8px 16px; border-radius:40px;">Export CSV</button>
    </div>
    <div class="table-responsive">
        <table id="auditTable">
            <thead><tr><th>Timestamp</th><th>User</th><th>Action</th><th>Entity</th><th>IP Address</th></tr></thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr><td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td><td>@log.UserName</td><td>@log.Action</td><td>@log.EntityName</td><td>@log.IPAddress</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // simple client‑side filtering
    const searchLog = document.getElementById('searchLog');
    const auditRows = document.querySelectorAll('#auditTable tbody tr');
    searchLog.addEventListener('keyup', () => {
        const term = searchLog.value.toLowerCase();
        auditRows.forEach(row => {
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(term) ? '' : 'none';
        });
    });
</script>