@page "/DeliveryOrderDetails"
@model Local_Multi_Store_Online_Marketplace.Pages.Deliverypages.DeliveryOrderDetailsModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Details</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --primary-light: #dbeafe;
            --success: #22c55e;
            --success-bg: #dcfce7;
            --warning: #f59e0b;
            --warning-bg: #fef3c7;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --bg: #f8fafc;
            --bg-2: #eef2f7;
            --surface: #ffffff;
            --ink-900: #0f172a;
            --ink-600: #64748b;
            --ink-400: #94a3b8;
            --border: #e2e8f0;
            --shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.05);
            --shadow-md: 0 12px 32px rgba(15, 23, 42, 0.08);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            background: var(--bg);
            font-family: 'Inter', Arial, sans-serif;
            color: var(--ink-900);
        }

        .page { padding: 24px 24px 60px; min-height: 100vh; }
        .shell { max-width: 960px; margin: auto; }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 700;
            color: var(--ink-600);
            text-decoration: none;
            margin-bottom: 18px;
        }
            .back-link:hover { color: var(--primary); }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 14px;
            margin-bottom: 22px;
        }

        .header-row h1 {
            font-family: 'Sora', sans-serif;
            font-size: 24px;
            font-weight: 800;
            margin: 0 0 6px;
        }

        .badges { display: flex; gap: 8px; flex-wrap: wrap; }

        .badge {
            padding: 5px 12px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .badge-assigned { background: var(--primary-light); color: var(--primary-hover); }
        .badge-out { background: var(--warning-bg); color: #92400e; }
        .badge-delivered { background: var(--success-bg); color: #166534; }
        .badge-default { background: var(--bg-2); color: var(--ink-600); }
        .badge-paid { background: var(--success-bg); color: #166534; }
        .badge-pending-pay { background: var(--warning-bg); color: #92400e; }

        .message {
            padding: 14px 18px;
            border-radius: 14px;
            font-size: 13.5px;
            font-weight: 600;
            margin-bottom: 18px;
        }
        .message.success { background: var(--success-bg); color: #166534; }
        .message.error { background: var(--danger-bg); color: #991b1b; }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--shadow-sm);
            margin-bottom: 20px;
        }

        .card h2 {
            font-family: 'Sora', sans-serif;
            font-size: 15px;
            font-weight: 700;
            margin: 0 0 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .info-item span {
            display: block;
            font-size: 11.5px;
            color: var(--ink-400);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .03em;
            margin-bottom: 4px;
        }
        .info-item strong {
            font-size: 14px;
            font-weight: 700;
            color: var(--ink-900);
        }

        table.products {
            width: 100%;
            border-collapse: collapse;
            margin-top: 6px;
        }
        table.products th {
            text-align: left;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .03em;
            color: var(--ink-400);
            font-weight: 700;
            padding: 8px 6px;
            border-bottom: 1px solid var(--border);
        }
        table.products td {
            padding: 10px 6px;
            font-size: 13.5px;
            border-bottom: 1px solid #f1f5f9;
        }
        table.products td.num { text-align: right; font-family: 'JetBrains Mono', monospace; }

        .totals-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 6px;
            font-size: 13.5px;
        }
        .totals-row.grand {
            font-weight: 800;
            font-size: 15px;
            border-top: 1px solid var(--border);
            margin-top: 6px;
            padding-top: 14px;
        }

        .payment-summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 14px;
        }

        .collect-btn {
            background: var(--warning);
            color: #fff;
            border: none;
            border-radius: 14px;
            padding: 13px 20px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
        }
            .collect-btn:hover { filter: brightness(0.95); }

        .start-btn, .done-btn {
            border: none;
            border-radius: 14px;
            padding: 13px 20px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            color: #fff;
        }
        .start-btn { background: var(--primary); }
        .start-btn:hover { background: var(--primary-hover); }
        .done-btn { background: var(--success); }
        .done-btn:hover { filter: brightness(0.95); }

        .action-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--ink-600);
        }

        @@media (max-width: 650px) {
            .info-grid { grid-template-columns: 1fr; }
            .page { padding: 16px 14px; }
        }
    </style>
</head>
<body>

    <partial name="_DeliveryNav" />

    <div class="page">
        <div class="shell">

            <a class="back-link" href="/DeliveryDashboard">&larr; Back to Dashboard</a>

            @if (TempData["Success"] != null)
            {
                <div class="message success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="message error">@TempData["Error"]</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="empty">
                    <h3>@Model.ErrorMessage</h3>
                </div>
            }
            else if (Model.Details != null)
            {
                var d = Model.Details;

                var assignmentBadgeClass = d.AssignmentStatus switch
                {
                    "Assigned" => "badge-assigned",
                    "OutForDelivery" => "badge-out",
                    "Delivered" => "badge-delivered",
                    _ => "badge-default"
                };

                <div class="header-row">
                    <div>
                        <h1>Order @d.OrderNumber</h1>
                        <div class="badges">
                            <span class="badge @assignmentBadgeClass">@d.AssignmentStatus</span>
                            <span class="badge badge-default">@d.OrderStatus</span>
                        </div>
                    </div>
                </div>

                <!-- ================= CUSTOMER INFO ================= -->
                <div class="card">
                    <h2>👤 Customer Information</h2>
                    <div class="info-grid">
                        <div class="info-item">
                            <span>Customer Name</span>
                            <strong>@d.CustomerName</strong>
                        </div>
                        <div class="info-item">
                            <span>Phone Number</span>
                            <strong>@d.CustomerPhone</strong>
                        </div>
                        <div class="info-item" style="grid-column: 1 / -1;">
                            <span>Delivery Address</span>
                            <strong>@d.FullAddress</strong>
                        </div>
                    </div>
                </div>

                <!-- ================= ORDER INFO ================= -->
                <div class="card">
                    <h2>📦 Order Information</h2>

                    <div class="info-grid" style="margin-bottom: 18px;">
                        <div class="info-item">
                            <span>Store</span>
                            <strong>@(string.IsNullOrWhiteSpace(d.StoreNames) ? "N/A" : d.StoreNames)</strong>
                        </div>
                        <div class="info-item">
                            <span>Order Date</span>
                            <strong>@d.OrderDate.ToString("dd MMM yyyy - HH:mm")</strong>
                        </div>
                    </div>

                    <table class="products">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th style="text-align:right;">Qty</th>
                                <th style="text-align:right;">Price</th>
                                <th style="text-align:right;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in d.Products)
                            {
                                <tr>
                                    <td>@p.ProductName</td>
                                    <td class="num">@p.Quantity</td>
                                    <td class="num">$@p.ProductPrice.ToString("0.00")</td>
                                    <td class="num">$@p.TotalPrice.ToString("0.00")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div style="margin-top: 14px;">
                        <div class="totals-row"><span>Subtotal</span><span>$@d.Subtotal.ToString("0.00")</span></div>
                        <div class="totals-row"><span>Delivery Fee</span><span>$@d.DeliveryFee.ToString("0.00")</span></div>
                        <div class="totals-row"><span>Discount</span><span>-$@d.DiscountAmount.ToString("0.00")</span></div>
                        <div class="totals-row"><span>Tax</span><span>$@d.TaxAmount.ToString("0.00")</span></div>
                        <div class="totals-row grand"><span>Total Amount</span><span>$@d.TotalAmount.ToString("0.00")</span></div>
                    </div>
                </div>

                <!-- ================= PAYMENT INFO ================= -->
                <div class="card">
                    <h2>💳 Payment</h2>

                    <div class="payment-summary">
                        <div class="info-grid" style="flex: 1; min-width: 220px;">
                            <div class="info-item">
                                <span>Payment Method</span>
                                <strong>@d.PaymentMethod</strong>
                            </div>
                            <div class="info-item">
                                <span>Payment Status</span>
                                <strong>
                                    <span class="badge @(d.PaymentStatus.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "badge-paid" : "badge-pending-pay")">
                                        @d.PaymentStatus
                                    </span>
                                </strong>
                            </div>
                        </div>

                        @if (d.NeedsCashCollection)
                        {
                            <form method="post" asp-page-handler="ConfirmCashCollection">
                                <input type="hidden" name="assignmentId" value="@d.AssignmentID" />
                                <button type="submit" class="collect-btn">
                                    Confirm Cash Collection ($@d.TotalAmount.ToString("0.00"))
                                </button>
                            </form>
                        }
                    </div>

                    @if (d.IsCashOnDelivery && d.NeedsCashCollection)
                    {
                        <p style="color: var(--ink-600); font-size: 12.5px; margin-top: 10px;">
                            This order cannot be marked delivered until cash collection is confirmed.
                        </p>
                    }
                </div>

                <!-- ================= ACTIONS ================= -->
                <div class="action-row">
                    @if (d.AssignmentStatus == "Assigned")
                    {
                        <form method="post" asp-page-handler="StartDelivery">
                            <input type="hidden" name="assignmentId" value="@d.AssignmentID" />
                            <button type="submit" class="start-btn">Start Delivery</button>
                        </form>
                    }
                    else if (d.AssignmentStatus == "OutForDelivery" && !d.NeedsCashCollection)
                    {
                        <form method="post" asp-page-handler="MarkDelivered">
                            <input type="hidden" name="assignmentId" value="@d.AssignmentID" />
                            <button type="submit" class="done-btn">Mark Delivered</button>
                        </form>
                    }
                </div>
            }

        </div>
    </div>

</body>
</html>