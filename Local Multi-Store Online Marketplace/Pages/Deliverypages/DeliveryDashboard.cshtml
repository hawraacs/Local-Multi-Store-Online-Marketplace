@page "/DeliveryDashboard"
@model Local_Multi_Store_Online_Marketplace.Pages.Deliverypages.DeliveryDashboardModel
@using System.Linq

@{
    Layout = null;

    var notificationCount = Model.Notifications != null
        ? Model.Notifications.Count
        : 0;

    var totalAssignments = Model.Assignments != null
        ? Model.Assignments.Count
        : 0;

    var assignedCount = Model.Assignments != null
        ? Model.Assignments.Count(a => a.AssignmentStatus == "Assigned")
        : 0;

    var outForDeliveryCount = Model.Assignments != null
        ? Model.Assignments.Count(a => a.AssignmentStatus == "OutForDelivery")
        : 0;

    var deliveredCount = Model.Assignments != null
        ? Model.Assignments.Count(a => a.AssignmentStatus == "Delivered")
        : 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delivery Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --primary-light: #dbeafe;
            --secondary: #38bdf8;
            --success: #22c55e;
            --success-bg: #dcfce7;
            --warning: #f59e0b;
            --warning-bg: #fef3c7;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --info: #0ea5e9;
            --bg: #f8fafc;
            --bg-2: #eef2f7;
            --surface: #ffffff;
            --ink-900: #0f172a;
            --ink-600: #64748b;
            --ink-400: #94a3b8;
            --border: #e2e8f0;
            --shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.04);
            --shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.05);
            --shadow-md: 0 12px 32px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 24px 60px rgba(15, 23, 42, 0.14);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: 'Inter', Arial, sans-serif;
            color: var(--ink-900);
        }

        .page {
            padding: 24px 24px 60px;
            min-height: 100vh;
        }

        .shell {
            max-width: 1220px;
            margin: auto;
        }

        /* ================= TOP UTILITY BAR ================= */
        .util-bar {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 220px;
            position: relative;
        }

            .search-box input {
                width: 100%;
                padding: 13px 16px 13px 42px;
                border-radius: 999px;
                border: 1px solid var(--border);
                background: var(--surface);
                font-family: 'Inter', sans-serif;
                font-size: 13.5px;
                outline: none;
                box-shadow: var(--shadow-xs);
                transition: all .16s ease;
            }

                .search-box input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px var(--primary-light);
                }

            .search-box .search-icon {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--ink-400);
                font-size: 14px;
                pointer-events: none;
            }

        .notification-wrapper {
            position: relative;
        }

        .notification-bell {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--ink-900);
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-xs);
            position: relative;
            transition: all .16s ease;
        }

            .notification-bell:hover {
                border-color: var(--primary);
                box-shadow: var(--shadow-sm);
            }

        .notification-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger);
            color: white;
            min-width: 18px;
            height: 18px;
            border-radius: 999px;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            border: 2px solid var(--surface);
        }

        .notification-dropdown {
            display: none;
            position: absolute;
            top: 54px;
            right: 0;
            width: 360px;
            max-height: 400px;
            overflow-y: auto;
            background: var(--surface);
            border-radius: 18px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-lg);
            z-index: 100;
        }

            .notification-dropdown.show {
                display: block;
            }

        .notification-head {
            padding: 16px 18px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--surface);
            position: sticky;
            top: 0;
            border-radius: 18px 18px 0 0;
        }

            .notification-head h4 {
                margin: 0;
                font-size: 14px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
            }

        .notification-pill {
            background: var(--danger-bg);
            color: #991b1b;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 10.5px;
            font-weight: 700;
        }

        .notification-item {
            padding: 15px 18px;
            background: #fbfcfe;
            border-bottom: 1px solid #f1f5f9;
        }

        .notification-title {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .notification-dot {
            width: 7px;
            height: 7px;
            background: var(--primary);
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 0 3px var(--primary-light);
        }

        .notification-message {
            margin: 0;
            color: var(--ink-600);
            font-size: 12.5px;
            line-height: 1.5;
        }

        .notification-time {
            display: block;
            margin-top: 8px;
            color: var(--ink-400);
            font-size: 11px;
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
        }

        .notification-link {
            display: inline-block;
            margin-top: 10px;
            background: var(--ink-900);
            color: white;
            padding: 7px 12px;
            border-radius: 9px;
            text-decoration: none;
            font-size: 11.5px;
            font-weight: 700;
            transition: background .16s ease;
        }

            .notification-link:hover {
                background: var(--primary);
            }

        .notification-empty {
            padding: 28px 15px;
            text-align: center;
            color: var(--ink-400);
            font-weight: 600;
            font-size: 13px;
        }

        /* ================= HERO BANNER ================= */
        .hero-banner {
            background: linear-gradient(120deg, var(--primary), #1e40af 120%);
            border-radius: 26px;
            padding: 32px 34px;
            margin-bottom: 22px;
            position: relative;
            overflow: hidden;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

            .hero-banner::before {
                content: "";
                position: absolute;
                top: -80px;
                right: -60px;
                width: 260px;
                height: 260px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.08);
            }

            .hero-banner::after {
                content: "";
                position: absolute;
                bottom: -100px;
                right: 120px;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(56, 189, 248, 0.18);
            }

        .hero-text {
            position: relative;
            z-index: 1;
            max-width: 460px;
        }

            .hero-text h1 {
                margin: 0 0 10px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
                font-size: 25px;
                letter-spacing: -0.3px;
                line-height: 1.3;
            }

            .hero-text p {
                margin: 0;
                color: #dbeafe;
                font-size: 13.5px;
                line-height: 1.6;
            }

        .hero-illustration {
            position: relative;
            z-index: 1;
            width: 120px;
            height: 90px;
            flex-shrink: 0;
        }

            .hero-illustration .van-body {
                width: 100px;
                height: 56px;
                background: #ffffff;
                border-radius: 14px 14px 6px 6px;
                position: relative;
                box-shadow: 0 10px 24px rgba(0,0,0,0.18);
            }

                .hero-illustration .van-body::before {
                    content: "";
                    position: absolute;
                    top: 10px;
                    left: 12px;
                    width: 30px;
                    height: 22px;
                    background: var(--secondary);
                    border-radius: 6px;
                }

            .hero-illustration .van-wheel {
                width: 18px;
                height: 18px;
                background: #0f172a;
                border-radius: 50%;
                position: absolute;
                bottom: -6px;
                border: 3px solid #cbd5e1;
            }

                .hero-illustration .van-wheel.left {
                    left: 12px;
                }

                .hero-illustration .van-wheel.right {
                    right: 20px;
                }

        /* ================= LAYOUT GRID ================= */
        .content-grid {
            display: grid;
            grid-template-columns: 1.7fr 1fr;
            gap: 20px;
            align-items: start;
        }

        /* ================= MESSAGES ================= */
        .message {
            padding: 13px 16px;
            border-radius: 14px;
            margin-bottom: 16px;
            font-weight: 700;
            text-align: center;
            font-size: 13.5px;
        }

        .success {
            background: var(--success-bg);
            color: #166534;
            border: 1px solid #86efac;
        }

        .error {
            background: var(--danger-bg);
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        /* ================= SECTION HEADER ================= */
        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

            .section-head h2 {
                margin: 0;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
                font-size: 16.5px;
            }

        .section-count {
            background: var(--bg-2);
            color: var(--ink-600);
            padding: 5px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        /* ================= ASSIGNMENT CARDS ================= */
        .assignments-list {
            display: grid;
            gap: 12px;
        }

        .assignment {
            border: 1px solid var(--border);
            background: var(--surface);
            padding: 18px 20px;
            border-radius: 18px;
            transition: all .18s ease;
            position: relative;
            box-shadow: var(--shadow-xs);
        }

            .assignment:hover {
                box-shadow: var(--shadow-sm);
                border-color: #cbd5e1;
            }

            .assignment.highlight {
                border-color: var(--primary);
                box-shadow: 0 0 0 4px var(--primary-light);
            }

            .assignment.search-hidden {
                display: none;
            }

        .assignment-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px dashed var(--border);
        }

        .assignment-id-group {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .assignment-icon {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .assignment-order-no {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 14.5px;
        }

        .assignment-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .assignment-details {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 12px;
        }

        .assignment-detail-item {
            background: var(--bg);
            border: 1px solid #eef2f7;
            padding: 9px 12px;
            border-radius: 12px;
        }

            .assignment-detail-item span {
                display: block;
                color: var(--ink-400);
                font-size: 10.5px;
                font-weight: 600;
                margin-bottom: 4px;
            }

            .assignment-detail-item strong {
                color: var(--ink-900);
                font-size: 12.5px;
                font-family: 'JetBrains Mono', monospace;
            }

        .badge {
            display: inline-block;
            padding: 5px 11px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 0.2px;
        }

        .badge-assigned {
            background: var(--warning-bg);
            color: #92400e;
        }

        .badge-out {
            background: #e0f2fe;
            color: #0369a1;
        }

        .badge-delivered {
            background: var(--success-bg);
            color: #166534;
        }

        .badge-default {
            background: var(--bg-2);
            color: var(--ink-600);
        }

        .actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        button {
            border: none;
            border-radius: 12px;
            padding: 10px 17px;
            font-weight: 700;
            cursor: pointer;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all .16s ease;
        }

        .start-btn {
            background: var(--primary);
            color: white;
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.25);
        }

            .start-btn:hover {
                background: var(--primary-hover);
                transform: translateY(-1px);
            }

        .done-btn {
            background: var(--success-bg);
            color: #166534;
        }

            .done-btn:hover {
                background: #bbf7d0;
            }

        .empty {
            text-align: center;
            color: var(--ink-400);
            padding: 50px 20px;
            background: var(--surface);
            border: 1px dashed var(--border);
            border-radius: 20px;
        }

            .empty h3 {
                font-family: 'Sora', sans-serif;
                color: var(--ink-900);
                margin: 0 0 8px;
            }

        .gps-good {
            color: var(--success);
        }

        .gps-bad {
            color: var(--danger);
        }

        /* ================= SIDE PANEL (ASIDE) ================= */
        .side-col {
            position: sticky;
            top: 20px;
            display: grid;
            gap: 16px;
        }

        .panel-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .panel-card-head {
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border);
            background: var(--bg-2);
        }

            .panel-card-head .icon-box {
                width: 32px;
                height: 32px;
                border-radius: 10px;
                background: var(--primary-light);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
            }

            .panel-card-head h3 {
                margin: 0;
                font-size: 13.5px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
            }

        .panel-card-body {
            padding: 18px;
        }

        .location-live-dot {
            width: 9px;
            height: 9px;
            min-width: 9px;
            border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.5);
            animation: livePulse 1.6s infinite;
            display: inline-block;
            margin-right: 8px;
        }

        @@keyframes livePulse {
            0% {
                box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.5);
            }

            70% {
                box-shadow: 0 0 0 9px rgba(37, 99, 235, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(37, 99, 235, 0);
            }
        }

        .location-status {
            font-weight: 600;
            color: var(--ink-600);
            font-size: 12.5px;
            font-family: 'JetBrains Mono', monospace;
            line-height: 1.6;
        }

        .kpi-mini-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
        }

            .kpi-mini-row:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .kpi-mini-row:first-child {
                padding-top: 0;
            }

        .kpi-mini-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .kpi-mini-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
        }

            .kpi-mini-dot.total {
                background: var(--ink-400);
            }

            .kpi-mini-dot.assigned {
                background: var(--warning);
            }

            .kpi-mini-dot.out {
                background: var(--info);
            }

            .kpi-mini-dot.delivered {
                background: var(--success);
            }

        .kpi-mini-label {
            font-size: 12.5px;
            font-weight: 600;
            color: var(--ink-600);
        }

        .kpi-mini-value {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 16px;
        }

        /* ================= PAYMENT / DETAILS ADDITIONS ================= */
        .assignment-meta-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 10px 0 4px;
        }

        .meta-chip {
            background: var(--bg-2);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 5px 12px;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--ink-600);
        }

        .badge-paid {
            background: var(--success-bg);
            color: #166534;
        }

        .badge-pending-pay {
            background: var(--warning-bg);
            color: #92400e;
        }

        .collect-btn {
            background: var(--warning);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 11px 18px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all .15s ease;
        }

            .collect-btn:hover {
                filter: brightness(0.95);
            }

        .details-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            font-weight: 700;
            color: var(--primary);
            text-decoration: none;
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: 12px;
            transition: all .15s ease;
        }

            .details-link:hover {
                border-color: var(--primary);
                background: var(--primary-light);
            }

        /* ================= DELIVERED MODAL ================= */
        .delivery-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            padding: 20px;
            background: rgba(15, 23, 42, 0.5);
            backdrop-filter: blur(6px);
            align-items: center;
            justify-content: center;
            z-index: 999999;
        }

            .delivery-modal-overlay.show {
                display: flex;
            }

        .delivery-modal-card {
            width: min(440px, 100%);
            background: var(--surface);
            border-radius: 24px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            animation: deliveryModalOpen 0.2s ease;
        }

        @@keyframes deliveryModalOpen {
            from {
                opacity: 0;
                transform: translateY(16px) scale(0.96);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .delivery-modal-header {
            padding: 28px 24px 14px;
            text-align: center;
        }

        .delivery-modal-icon {
            width: 58px;
            height: 58px;
            margin: 0 auto 14px;
            border-radius: 50%;
            background: var(--success-bg);
            color: #166534;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            font-weight: 700;
        }

        .delivery-modal-title {
            margin: 0;
            font-size: 19px;
            font-weight: 700;
            font-family: 'Sora', sans-serif;
        }

        .delivery-modal-body {
            padding: 0 24px 24px;
            text-align: center;
        }

        .delivery-modal-message {
            margin: 0;
            color: var(--ink-600);
            font-size: 13.5px;
            line-height: 1.6;
        }

        .delivery-modal-order {
            display: block;
            margin-top: 10px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12.5px;
        }

        .delivery-modal-actions {
            display: flex;
            gap: 10px;
            padding: 18px 24px 26px;
        }

        .delivery-modal-button {
            flex: 1;
            border: none;
            border-radius: 13px;
            padding: 13px 16px;
            cursor: pointer;
            font-weight: 700;
            font-size: 13.5px;
            transition: all .16s ease;
        }

        .delivery-modal-cancel {
            background: var(--bg-2);
            color: var(--ink-600);
        }

            .delivery-modal-cancel:hover {
                background: #e2e8f0;
            }

        .delivery-modal-confirm {
            background: var(--success);
            color: white;
        }

            .delivery-modal-confirm:hover {
                background: #16a34a;
            }

            .delivery-modal-confirm:disabled {
                cursor: wait;
                opacity: 0.7;
            }

        @@media (max-width: 980px) {
            .content-grid {
                grid-template-columns: 1fr;
            }

            .side-col {
                position: static;
            }
        }

        @@media (max-width: 650px) {
            .page {
                padding: 16px 14px;
            }

            .hero-banner {
                padding: 24px 22px;
            }

            .hero-illustration {
                display: none;
            }

            .assignment-details {
                grid-template-columns: 1fr;
            }

            .notification-dropdown {
                width: 300px;
                right: -5px;
            }

            .delivery-modal-actions {
                flex-direction: column-reverse;
            }

            .delivery-modal-button {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <partial name="_DeliveryNav" />

    <div class="page">
        <div class="shell">

            <!-- ================= TOP UTILITY BAR ================= -->
            <div class="util-bar">

                <div class="search-box">
                    <span class="search-icon">🔍</span>
                    <input type="text"
                           id="assignmentSearchInput"
                           placeholder="Search by order number or address..."
                           oninput="filterAssignments(this.value)" />
                </div>

                <div class="notification-wrapper">

                    <button type="button"
                            class="notification-bell"
                            onclick="toggleNotifications()">
                        🔔

                        @if (notificationCount > 0)
                        {
                            <span class="notification-count">
                                @notificationCount
                            </span>
                        }
                    </button>

                    <div id="notificationDropdown"
                         class="notification-dropdown">

                        <div class="notification-head">

                            <h4>
                                Notifications
                            </h4>

                            <span class="notification-pill">
                                @notificationCount new
                            </span>

                        </div>

                        @if (Model.Notifications == null ||
                        !Model.Notifications.Any())
                        {
                            <div class="notification-empty">
                                No new assigned orders.
                            </div>
                        }
                        else
                        {
                            @foreach (var notification in Model.Notifications)
                            {
                                <div class="notification-item">

                                    <div class="notification-title">

                                        <span class="notification-dot">
                                        </span>

                                        @notification.Title

                                    </div>

                                    <p class="notification-message">
                                        @notification.Message
                                    </p>

                                    <span class="notification-time">
                                        @notification.SentAt.ToString(
                                                 "dd MMM yyyy HH:mm")
                                    </span>

                                    @if (notification.ReferenceID.HasValue)
                                    {
                                        <a href="#order_@notification.ReferenceID.Value"
                                           class="notification-link"
                                           onclick="highlightOrder(@notification.ReferenceID.Value)">
                                            View Assigned Order
                                        </a>
                                    }

                                </div>
                            }
                        }

                    </div>

                </div>

            </div>
            <div class="hero-banner">

                <div class="hero-text">
                    <h1>Keep every delivery moving</h1>
                    <p>
                        Your location updates automatically every second while
                        this page stays open. Start deliveries and mark them
                        complete right from here.
                    </p>
                </div>

                <div class="hero-illustration">
                    <div class="van-body">
                        <div class="van-wheel left"></div>
                        <div class="van-wheel right"></div>
                    </div>
                </div>

            </div>

            @if (TempData["Success"] != null)
            {
                <div class="message success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message error">
                    @TempData["Error"]
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="message error">
                    @Model.ErrorMessage
                </div>
            }

            <!-- ================= CONTENT GRID ================= -->
            <div class="content-grid">

                <!-- MAIN COLUMN: assignments -->
                <div class="main-col">

                    <div class="section-head">
                        <h2>Active Assignments</h2>
                        <span class="section-count" id="assignmentVisibleCount">
                            @totalAssignments total
                        </span>
                    </div>

                    @if (Model.Assignments == null ||
                    !Model.Assignments.Any())
                    {
                        <div class="empty">
                            <h3>No active assignments</h3>
                            <p>Your assigned deliveries will appear here.</p>
                        </div>
                    }
                    else
                    {
                        <div class="assignments-list" id="assignmentsList">

                            @foreach (var item in Model.Assignments)
                            {
                                var badgeClass =
                                item.AssignmentStatus == "Assigned"
                                ? "badge-assigned"
                                : item.AssignmentStatus == "OutForDelivery"
                                ? "badge-out"
                                : item.AssignmentStatus == "Delivered"
                                ? "badge-delivered"
                                : "badge-default";

                                <div class="assignment"
                                     id="order_@item.OrderID"
                                     data-search="@($"{item.OrderNumber} {item.CustomerAddress}".ToLower())">

                                    <div class="assignment-top">

                                        <div class="assignment-id-group">
                                            <div class="assignment-icon">📦</div>
                                            <div class="assignment-order-no">
                                                Order @item.OrderNumber
                                            </div>
                                        </div>

                                        <div class="assignment-badges">
                                            <span class="badge @badgeClass">
                                                @item.AssignmentStatus
                                            </span>

                                            <span class="badge badge-default">
                                                @item.OrderStatus
                                            </span>
                                        </div>

                                    </div>

                                    <div class="assignment-details">

                                        <div class="assignment-detail-item">
                                            <span>Customer</span>
                                            <strong>@item.CustomerName</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Phone</span>
                                            <strong>@item.CustomerPhone</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Address</span>
                                            <strong>@item.CustomerAddress</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Store</span>
                                            <strong>@(string.IsNullOrWhiteSpace(item.StoreNames) ? "N/A" : item.StoreNames)</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Products</span>
                                            <strong>@(string.IsNullOrWhiteSpace(item.ProductSummary) ? "N/A" : item.ProductSummary)</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Order Date</span>
                                            <strong>@item.OrderDate.ToString("dd MMM yyyy")</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Total Amount</span>
                                            <strong>$@item.TotalAmount.ToString("0.00")</strong>
                                        </div>

                                        <div class="assignment-detail-item">
                                            <span>Assigned</span>
                                            <strong>
                                                @item.AssignedAt.ToString("dd MMM yyyy HH:mm")
                                            </strong>
                                        </div>

                                    </div>

                                    <div class="assignment-meta-row">
                                        <span class="meta-chip">@item.PaymentMethod</span>
                                        <span class="meta-chip @(item.PaymentStatus.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "badge-paid" : "badge-pending-pay")">
                                            @item.PaymentStatus
                                        </span>
                                    </div>

                                    <div class="actions">

                                        <a class="details-link"
                                           href="/DeliveryOrderDetails?assignmentId=@item.AssignmentID">
                                            View Details
                                        </a>

                                        @if (item.AssignmentStatus == "Assigned")
                                        {
                                            <form method="post"
                                                  asp-page-handler="StartDelivery">

                                                <input type="hidden"
                                                       name="assignmentId"
                                                       value="@item.AssignmentID" />

                                                <button type="submit"
                                                        class="start-btn">
                                                    Start Delivery
                                                </button>

                                            </form>
                                        }
                                        else if (item.AssignmentStatus == "OutForDelivery")
                                        {
                                            @if (item.NeedsCashCollection)
                                            {
                                                <form method="post"
                                                      asp-page-handler="ConfirmCashCollection">

                                                    <input type="hidden"
                                                           name="assignmentId"
                                                           value="@item.AssignmentID" />

                                                    <button type="submit"
                                                            class="collect-btn">
                                                        Confirm Cash Collection ($@item.TotalAmount.ToString("0.00"))
                                                    </button>

                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post"
                                                      asp-page-handler="MarkDelivered"
                                                      id="markDeliveredForm_@item.AssignmentID">

                                                    <input type="hidden"
                                                           name="assignmentId"
                                                           value="@item.AssignmentID" />

                                                    <button type="button"
                                                            class="done-btn"
                                                            onclick="openDeliveredModal(
                                                                'markDeliveredForm_@item.AssignmentID',
                                                                '@item.OrderNumber')">
                                                        Mark Delivered
                                                    </button>

                                                </form>
                                            }
                                        }

                                    </div>

                                </div>
                            }

                        </div>

                        <div class="empty"
                             id="assignmentSearchEmpty"
                             style="display:none;">
                            <h3>No matching orders</h3>
                            <p>Try a different order number or address.</p>
                        </div>
                    }

                </div>

                <!-- SIDE COLUMN: live location + kpi summary -->
                <aside class="side-col">

                    <div class="panel-card">
                        <div class="panel-card-head">
                            <div class="icon-box">📍</div>
                            <h3>Live Location</h3>
                        </div>

                        <div class="panel-card-body">
                            <span class="location-live-dot"></span>
                            <span class="location-status"
                                  id="locationStatus">
                                Location tracking will update automatically every second.
                            </span>
                        </div>
                    </div>

                    <div class="panel-card">
                        <div class="panel-card-head">
                            <div class="icon-box">📊</div>
                            <h3>Assignment Summary</h3>
                        </div>

                        <div class="panel-card-body">

                            <div class="kpi-mini-row">
                                <div class="kpi-mini-left">
                                    <span class="kpi-mini-dot total"></span>
                                    <span class="kpi-mini-label">Total</span>
                                </div>
                                <span class="kpi-mini-value">@totalAssignments</span>
                            </div>

                            <div class="kpi-mini-row">
                                <div class="kpi-mini-left">
                                    <span class="kpi-mini-dot assigned"></span>
                                    <span class="kpi-mini-label">Assigned</span>
                                </div>
                                <span class="kpi-mini-value">@assignedCount</span>
                            </div>

                            <div class="kpi-mini-row">
                                <div class="kpi-mini-left">
                                    <span class="kpi-mini-dot out"></span>
                                    <span class="kpi-mini-label">Out for Delivery</span>
                                </div>
                                <span class="kpi-mini-value">@outForDeliveryCount</span>
                            </div>

                            <div class="kpi-mini-row">
                                <div class="kpi-mini-left">
                                    <span class="kpi-mini-dot delivered"></span>
                                    <span class="kpi-mini-label">Delivered</span>
                                </div>
                                <span class="kpi-mini-value">@deliveredCount</span>
                            </div>

                        </div>
                    </div>

                </aside>

            </div>

        </div>
    </div>

    <!-- =====================================================
         CUSTOM MARK DELIVERED MODAL
         ===================================================== -->

    <div id="deliveredModal"
         class="delivery-modal-overlay"
         role="dialog"
         aria-modal="true"
         aria-labelledby="deliveredModalTitle">

        <div class="delivery-modal-card">

            <div class="delivery-modal-header">

                <div class="delivery-modal-icon">
                    ✓
                </div>

                <h3 id="deliveredModalTitle"
                    class="delivery-modal-title">
                    Mark Order as Delivered?
                </h3>

            </div>

            <div class="delivery-modal-body">

                <p class="delivery-modal-message">
                    Confirm that the customer received this order.

                    For Cash On Delivery orders, the payment will
                    also be marked as paid.

                    <span id="deliveredModalOrder"
                          class="delivery-modal-order">
                    </span>
                </p>

            </div>

            <div class="delivery-modal-actions">

                <button type="button"
                        class="delivery-modal-button delivery-modal-cancel"
                        onclick="closeDeliveredModal()">
                    Cancel
                </button>

                <button type="button"
                        id="confirmDeliveredButton"
                        class="delivery-modal-button delivery-modal-confirm"
                        onclick="submitDeliveredForm()">
                    Confirm Delivered
                </button>

            </div>

        </div>
    </div>

    <script>
        /* ================= SEARCH FILTER (new, additive, client-side only) ================= */
        function filterAssignments(rawQuery) {
            const query = (rawQuery || "").trim().toLowerCase();

            const cards =
                document.querySelectorAll(
                    "#assignmentsList .assignment");

            const emptyState =
                document.getElementById(
                    "assignmentSearchEmpty");

            const visibleCountLabel =
                document.getElementById(
                    "assignmentVisibleCount");

            let visibleCount = 0;

            cards.forEach(function (card) {
                const haystack =
                    card.getAttribute("data-search") || "";

                const matches =
                    query === "" ||
                    haystack.includes(query);

                card.classList.toggle(
                    "search-hidden",
                    !matches);

                if (matches) {
                    visibleCount++;
                }
            });

            if (emptyState) {
                emptyState.style.display =
                    (cards.length > 0 && visibleCount === 0)
                        ? "block"
                        : "none";
            }

            if (visibleCountLabel) {
                visibleCountLabel.textContent =
                    query === ""
                        ? cards.length + " total"
                        : visibleCount + " match" + (visibleCount === 1 ? "" : "es");
            }
        }

        let pendingDeliveredFormId = null;

        function openDeliveredModal(
            formId,
            orderNumber) {

            const modal =
                document.getElementById(
                    "deliveredModal");

            const orderText =
                document.getElementById(
                    "deliveredModalOrder");

            const confirmButton =
                document.getElementById(
                    "confirmDeliveredButton");

            const form =
                document.getElementById(
                    formId);

            if (!modal ||
                !form) {

                return;
            }

            pendingDeliveredFormId =
                formId;

            if (orderText) {
                orderText.textContent =
                    "Order: " +
                    orderNumber;
            }

            if (confirmButton) {
                confirmButton.disabled =
                    false;

                confirmButton.textContent =
                    "Confirm Delivered";
            }

            modal.classList.add(
                "show");

            document.body.style.overflow =
                "hidden";
        }

        function closeDeliveredModal() {
            const modal =
                document.getElementById(
                    "deliveredModal");

            if (modal) {
                modal.classList.remove(
                    "show");
            }

            pendingDeliveredFormId =
                null;

            document.body.style.overflow =
                "";
        }

        function submitDeliveredForm() {
            if (!pendingDeliveredFormId) {
                return;
            }

            const form =
                document.getElementById(
                    pendingDeliveredFormId);

            const confirmButton =
                document.getElementById(
                    "confirmDeliveredButton");

            if (!form) {
                closeDeliveredModal();
                return;
            }

            if (confirmButton) {
                confirmButton.disabled =
                    true;

                confirmButton.textContent =
                    "Updating...";
            }

            form.submit();
        }

        const deliveredModal =
            document.getElementById(
                "deliveredModal");

        if (deliveredModal) {
            deliveredModal.addEventListener(
                "click",
                function (event) {
                    if (event.target === deliveredModal) {
                        closeDeliveredModal();
                    }
                });
        }

        document.addEventListener(
            "keydown",
            function (event) {
                if (event.key === "Escape") {
                    closeDeliveredModal();
                }
            });

        function toggleNotifications() {
            const dropdown =
                document.getElementById(
                    "notificationDropdown");

            if (dropdown) {
                dropdown.classList.toggle(
                    "show");
            }
        }

        function highlightOrder(orderId) {
            const dropdown =
                document.getElementById(
                    "notificationDropdown");

            if (dropdown) {
                dropdown.classList.remove(
                    "show");
            }

            setTimeout(
                function () {
                    const orderCard =
                        document.getElementById(
                            "order_" + orderId);

                    if (orderCard) {
                        document
                            .querySelectorAll(
                                ".assignment")
                            .forEach(
                                function (card) {
                                    card.classList.remove(
                                        "highlight");
                                });

                        orderCard.classList.add(
                            "highlight");

                        setTimeout(
                            function () {
                                orderCard.classList.remove(
                                    "highlight");
                            },
                            3500);
                    }
                },
                150);
        }

        document.addEventListener(
            "click",
            function (event) {
                const wrapper =
                    document.querySelector(
                        ".notification-wrapper");

                const dropdown =
                    document.getElementById(
                        "notificationDropdown");

                if (wrapper &&
                    dropdown &&
                    !wrapper.contains(event.target)) {

                    dropdown.classList.remove(
                        "show");
                }
            });

        document.addEventListener(
            "DOMContentLoaded",
            function () {
                updateMyLocation();

                window.setInterval(
                    updateMyLocation,
                    1000);
            });

        function updateMyLocation() {
            const status =
                document.getElementById(
                    "locationStatus");

            if (!status) {
                return;
            }

            if (!navigator.geolocation) {
                status.className =
                    "location-status gps-bad";

                status.innerText =
                    "GPS is not supported on this device.";

                return;
            }

            status.className =
                "location-status";

            status.innerText =
                "Getting GPS location...";

            navigator.geolocation.getCurrentPosition(
                async function (position) {
                    const lat =
                        position.coords.latitude;

                    const lng =
                        position.coords.longitude;

                    const accuracy =
                        position.coords.accuracy;

                    try {
                        const response =
                            await fetch(
                                "/api/delivery-tracking/update-location",
                                {
                                    method: "POST",

                                    credentials:
                                        "same-origin",

                                    headers: {
                                        "Content-Type":
                                            "application/json"
                                    },

                                    body:
                                        JSON.stringify({
                                            latitude: lat,
                                            longitude: lng
                                        })
                                });

                        let data = null;

                        try {
                            data =
                                await response.json();
                        }
                        catch {
                            data = null;
                        }

                        if (!response.ok) {
                            status.className =
                                "location-status gps-bad";

                            status.innerText =
                                data?.message ||
                                "Could not update location. Please login as approved delivery staff.";

                            return;
                        }

                        if (data &&
                            data.success) {

                            status.className =
                                "location-status gps-good";

                            status.innerText =
                                "Location updated: " +
                                lat.toFixed(6) +
                                ", " +
                                lng.toFixed(6) +
                                " | Accuracy: " +
                                Math.round(accuracy) +
                                "m | Time: " +
                                (data.updatedAt || "now");
                        }
                        else {
                            status.className =
                                "location-status gps-bad";

                            status.innerText =
                                data?.message ||
                                "Could not update location.";
                        }
                    }
                    catch {
                        status.className =
                            "location-status gps-bad";

                        status.innerText =
                            "Could not update location. Check your connection.";
                    }
                },

                function (error) {
                    status.className =
                        "location-status gps-bad";

                    if (error.code ===
                        error.PERMISSION_DENIED) {

                        status.innerText =
                            "GPS permission denied. Click the lock icon near the URL and allow Location.";
                    }
                    else if (error.code ===
                             error.POSITION_UNAVAILABLE) {

                        status.innerText =
                            "GPS position unavailable. Enable device location and try again.";
                    }
                    else if (error.code ===
                             error.TIMEOUT) {

                        status.innerText =
                            "GPS timeout. Trying again in 1 second.";
                    }
                    else {
                        status.innerText =
                            "GPS is off. Location update temporarily unavailable.";
                    }
                },

                {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 500
                });
        }
    </script>

</body>
</html>
