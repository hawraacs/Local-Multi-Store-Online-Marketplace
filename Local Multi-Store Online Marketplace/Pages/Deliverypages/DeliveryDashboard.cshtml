@page "/DeliveryDashboard"
@model Local_Multi_Store_Online_Marketplace.Pages.Deliverypages.DeliveryDashboardModel
@{
    Layout = null;

    var notificationCount = Model.Notifications != null
        ? Model.Notifications.Count
        : 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Delivery Dashboard</title>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .page {
            padding: 35px;
            min-height: 100vh;
        }

        .box {
            max-width: 1000px;
            margin: auto;
            background: white;
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
            position: relative;
        }

        .dashboard-header {
            display: grid;
            grid-template-columns: 50px 1fr 50px;
            align-items: start;
            gap: 12px;
            margin-bottom: 22px;
        }

        .delivery-icon {
            width: 42px;
            height: 42px;
            background: #111827;
            color: white;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            box-shadow: 0 8px 18px rgba(0,0,0,0.14);
        }

        .title-area {
            text-align: center;
        }

        h2 {
            margin: 0 0 10px 0;
            color: #111827;
        }

        .subtitle {
            text-align: center;
            color: #6b7280;
            margin: 0;
            font-size: 13px;
        }

        .notification-wrapper {
            position: relative;
            display: flex;
            justify-content: flex-end;
        }

        .notification-bell {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid #e5e7eb;
            background: white;
            color: #111827;
            cursor: pointer;
            font-size: 20px;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 18px rgba(0,0,0,0.10);
            position: relative;
        }

            .notification-bell:hover {
                background: #f9fafb;
            }

        .notification-count {
            position: absolute;
            top: -6px;
            right: -6px;
            background: #ef4444;
            color: white;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            font-size: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            border: 2px solid white;
        }

        .notification-dropdown {
            display: none;
            position: absolute;
            top: 52px;
            right: 0;
            width: 350px;
            max-height: 380px;
            overflow-y: auto;
            background: white;
            border-radius: 18px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 18px 45px rgba(0,0,0,0.18);
            z-index: 100;
        }

            .notification-dropdown.show {
                display: block;
            }

        .notification-head {
            padding: 14px 15px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            position: sticky;
            top: 0;
            z-index: 2;
        }

            .notification-head h4 {
                margin: 0;
                font-size: 15px;
                color: #111827;
            }

        .notification-pill {
            background: #fee2e2;
            color: #991b1b;
            padding: 5px 9px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
        }

        .notification-item {
            padding: 14px 15px;
            background: #eff6ff;
            border-bottom: 1px solid #dbeafe;
        }

        .notification-title {
            font-size: 13px;
            font-weight: 900;
            color: #111827;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .notification-dot {
            width: 8px;
            height: 8px;
            background: #2563eb;
            border-radius: 50%;
            display: inline-block;
        }

        .notification-message {
            margin: 0;
            color: #374151;
            font-size: 12px;
            line-height: 1.45;
            font-weight: 700;
        }

        .notification-time {
            display: block;
            margin-top: 7px;
            color: #6b7280;
            font-size: 11px;
            font-weight: 700;
        }

        .notification-link {
            display: inline-block;
            margin-top: 10px;
            background: #111827;
            color: white;
            padding: 8px 11px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
        }

        .notification-empty {
            padding: 25px 15px;
            text-align: center;
            color: #6b7280;
            font-weight: 800;
            font-size: 13px;
        }

        .location-box {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 18px;
        }

        .location-status {
            font-weight: 800;
            color: #374151;
            line-height: 1.5;
        }

        .message {
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 15px;
            font-weight: 800;
            text-align: center;
        }

        .success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .assignment {
            border: 1px solid #e5e7eb;
            background: #f9fafb;
            padding: 16px;
            border-radius: 14px;
            margin-bottom: 14px;
            transition: 0.2s ease;
        }

            .assignment.highlight {
                border-color: #2563eb;
                box-shadow: 0 0 0 4px rgba(37,99,235,0.12);
                background: #eff6ff;
            }

            .assignment strong {
                color: #111827;
            }

            .assignment p {
                margin: 7px 0;
                color: #374151;
            }

        .badge {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
            background: #fef3c7;
            color: #92400e;
        }

        .actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 12px;
        }

        button {
            border: none;
            border-radius: 10px;
            padding: 10px 14px;
            font-weight: 900;
            cursor: pointer;
        }

        .start-btn {
            background: #111827;
            color: white;
        }

            .start-btn:hover {
                background: #ff6b35;
            }

        .done-btn {
            background: #dcfce7;
            color: #166534;
        }

        .empty {
            text-align: center;
            color: #6b7280;
            padding: 35px;
        }

        .gps-good {
            color: #166534;
        }

        .gps-bad {
            color: #991b1b;
        }

        @@media (max-width: 650px) {
            .page {
                padding: 18px;
            }

            .dashboard-header {
                grid-template-columns: 45px 1fr 45px;
            }

            .notification-dropdown {
                width: 310px;
                right: -5px;
            }
        }
    </style>
</head>

<body>
    <div class="page">
        <div class="box">
            <div class="dashboard-header">
                <div class="delivery-icon">🚚</div>

                <div class="title-area">
                    <h2>Delivery Dashboard</h2>
                    <p class="subtitle">
                        Keep this page open while delivering. Your location updates every second for demo tracking.
                    </p>
                </div>

                <div class="notification-wrapper">
                    <button type="button"
                            class="notification-bell"
                            onclick="toggleNotifications()">
                        🔔

                        @if (notificationCount > 0)
                        {
                            <span class="notification-count">@notificationCount</span>
                        }
                    </button>

                    <div id="notificationDropdown" class="notification-dropdown">
                        <div class="notification-head">
                            <h4>Notifications</h4>
                            <span class="notification-pill">@notificationCount new</span>
                        </div>

                        @if (Model.Notifications == null || !Model.Notifications.Any())
                        {
                            <div class="notification-empty">
                                No new assigned orders.
                            </div>
                        }
                        else
                        {
                            @foreach (var n in Model.Notifications)
                            {
                                <div class="notification-item">
                                    <div class="notification-title">
                                        <span class="notification-dot"></span>
                                        @n.Title
                                    </div>

                                    <p class="notification-message">@n.Message</p>

                                    <span class="notification-time">
                                        @n.SentAt.ToString("dd MMM yyyy HH:mm")
                                    </span>

                                    @if (n.ReferenceID.HasValue)
                                    {
                                        <a href="#order_@n.ReferenceID.Value"
                                           class="notification-link"
                                           onclick="highlightOrder(@n.ReferenceID.Value)">
                                            View Assigned Order
                                        </a>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="message success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message error">@TempData["Error"]</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="message error">@Model.ErrorMessage</div>
            }

            <div class="location-box">
                <div class="location-status" id="locationStatus">
                    Location tracking will update automatically every second.
                </div>
            </div>

            @if (Model.Assignments == null || !Model.Assignments.Any())
            {
                <div class="empty">
                    <h3>No active assignments</h3>
                    <p>Your assigned deliveries will appear here.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model.Assignments)
                {
                    <div class="assignment" id="order_@item.OrderID">
                        <p><strong>Order:</strong> @item.OrderNumber</p>
                        <p><strong>Order Status:</strong> <span class="badge">@item.OrderStatus</span></p>
                        <p><strong>Assignment Status:</strong> <span class="badge">@item.AssignmentStatus</span></p>
                        <p><strong>Address:</strong> @item.CustomerAddress</p>
                        <p><strong>Assigned:</strong> @item.AssignedAt.ToString("dd MMM yyyy HH:mm")</p>

                        <div class="actions">
                            @if (item.AssignmentStatus == "Assigned")
                            {
                                <form method="post" asp-page-handler="StartDelivery">
                                    <input type="hidden" name="assignmentId" value="@item.AssignmentID" />
                                    <button type="submit" class="start-btn">
                                        Start Delivery
                                    </button>
                                </form>
                            }
                            else if (item.AssignmentStatus == "OutForDelivery")
                            {
                                <form method="post" asp-page-handler="MarkDelivered">
                                    <input type="hidden" name="assignmentId" value="@item.AssignmentID" />
                                    <button type="submit"
                                            class="done-btn"
                                            onclick="return confirm('Mark this order as delivered?')">
                                        Mark Delivered
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <script>
        function toggleNotifications() {
            const dropdown = document.getElementById("notificationDropdown");
            dropdown.classList.toggle("show");
        }

        function highlightOrder(orderId) {
            const dropdown = document.getElementById("notificationDropdown");
            dropdown.classList.remove("show");

            setTimeout(function () {
                const orderCard = document.getElementById("order_" + orderId);

                if (orderCard) {
                    document.querySelectorAll(".assignment").forEach(function (card) {
                        card.classList.remove("highlight");
                    });

                    orderCard.classList.add("highlight");

                    setTimeout(function () {
                        orderCard.classList.remove("highlight");
                    }, 3500);
                }
            }, 150);
        }

        document.addEventListener("click", function (event) {
            const wrapper = document.querySelector(".notification-wrapper");
            const dropdown = document.getElementById("notificationDropdown");

            if (wrapper && dropdown && !wrapper.contains(event.target)) {
                dropdown.classList.remove("show");
            }
        });

        document.addEventListener("DOMContentLoaded", function () {
            updateMyLocation();
            setInterval(updateMyLocation, 1000);
        });

        function updateMyLocation() {
            const status = document.getElementById("locationStatus");

            if (!navigator.geolocation) {
                status.className = "location-status gps-bad";
                status.innerText = "GPS is not supported on this device.";
                return;
            }

            status.className = "location-status";
            status.innerText = "Getting GPS location...";

            navigator.geolocation.getCurrentPosition(
                async function (position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    const accuracy = position.coords.accuracy;

                    try {
                        const response = await fetch("/api/delivery-tracking/update-location", {
                            method: "POST",
                            credentials: "same-origin",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                latitude: lat,
                                longitude: lng
                            })
                        });

                        let data = null;

                        try {
                            data = await response.json();
                        } catch {
                            data = null;
                        }

                        if (!response.ok) {
                            status.className = "location-status gps-bad";
                            status.innerText =
                                data?.message || "Could not update location. Please login as approved delivery staff.";
                            return;
                        }

                        if (data && data.success) {
                            status.className = "location-status gps-good";
                            status.innerText =
                                "Location updated: " +
                                lat.toFixed(6) +
                                ", " +
                                lng.toFixed(6) +
                                " | Accuracy: " +
                                Math.round(accuracy) +
                                "m | Time: " +
                                (data.updatedAt || "now");
                        } else {
                            status.className = "location-status gps-bad";
                            status.innerText =
                                data?.message || "Could not update location.";
                        }
                    } catch {
                        status.className = "location-status gps-bad";
                        status.innerText = "Could not update location. Check your connection.";
                    }
                },
                function (error) {
                    status.className = "location-status gps-bad";

                    if (error.code === error.PERMISSION_DENIED) {
                        status.innerText = "GPS permission denied. Click the lock icon near the URL and allow Location.";
                    } else if (error.code === error.POSITION_UNAVAILABLE) {
                        status.innerText = "GPS position unavailable. Enable device location and try again.";
                    } else if (error.code === error.TIMEOUT) {
                        status.innerText = "GPS timeout. Trying again in 1 second.";
                    } else {
                        status.innerText = "GPS is off. Location update temporarily unavailable.";
                    }
                },
                {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 500
                }
            );
        }
    </script>
</body>
</html>