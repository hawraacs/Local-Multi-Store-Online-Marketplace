@page "/DeliveryOrders"
@model Local_Multi_Store_Online_Marketplace.Pages.Deliverypages.DeliveryOrdersModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Delivery Orders</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #1e3a5f;
            --primary-hover: #16283f;
            --primary-light: #dce6ef;
            --secondary: #ff6b35;
            --success: #22c55e;
            --success-bg: #dcfce7;
            --warning: #f59e0b;
            --warning-bg: #fef3c7;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --info: #4a6fa5;
            --bg: #f4f6f9;
            --bg-2: #eef2f7;
            --surface: #ffffff;
            --ink-900: #0f172a;
            --ink-600: #64748b;
            --ink-400: #94a3b8;
            --border: #e2e8f0;
            --shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.04);
            --shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.05);
            --shadow-md: 0 12px 32px rgba(15, 23, 42, 0.08);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: radial-gradient(circle at top left, rgba(30, 58, 95, 0.05), transparent 45%), var(--bg);
            font-family: 'Inter', Arial, sans-serif;
            color: var(--ink-900);
        }

        .page {
            min-height: 100vh;
            padding: 32px 24px 60px;
        }

        .shell {
            max-width: 1180px;
            margin: auto;
        }

        /* ================= HEADER ================= */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

            .page-header h1 {
                margin: 0 0 6px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
                font-size: 24px;
                letter-spacing: -0.3px;
            }

            .page-header p {
                margin: 0;
                color: var(--ink-600);
                font-size: 13.5px;
            }

        .dashboard-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--ink-900);
            padding: 11px 18px;
            border-radius: 13px;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            box-shadow: var(--shadow-xs);
            transition: all .16s ease;
        }

            .dashboard-link:hover {
                border-color: var(--primary);
                box-shadow: var(--shadow-sm);
                transform: translateY(-1px);
            }

        /* ================= KPI ROW ================= */
        .kpi-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .kpi-chip {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 14px 16px;
            box-shadow: var(--shadow-xs);
            transition: all .18s ease;
        }

            .kpi-chip:hover {
                box-shadow: var(--shadow-sm);
                transform: translateY(-1px);
            }

            .kpi-chip span {
                display: block;
                color: var(--ink-400);
                font-size: 11px;
                font-weight: 600;
                margin-bottom: 6px;
            }

            .kpi-chip strong {
                font-size: 22px;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
            }

        /* ================= FILTERS ================= */
        .filters {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .filter-link {
            text-decoration: none;
            padding: 9px 16px;
            border-radius: 999px;
            font-size: 12.5px;
            font-weight: 700;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--ink-600);
            transition: all .16s ease;
        }

            .filter-link:hover {
                border-color: var(--primary);
                color: var(--primary);
            }

            .filter-link.active {
                background: var(--primary);
                border-color: var(--primary);
                color: white;
                box-shadow: 0 6px 16px rgba(30, 58, 95, 0.25);
            }

        .message {
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-weight: 700;
            font-size: 13.5px;
        }

        .error {
            background: var(--danger-bg);
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        /* ================= ORDER LIST PANEL ================= */
        .list-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
        }

        .list-panel-head {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-2);
        }

            .list-panel-head h2 {
                margin: 0;
                font-family: 'Sora', sans-serif;
                font-weight: 700;
                font-size: 15px;
            }

        .order-row {
            display: grid;
            grid-template-columns: 44px 1.4fr 1fr 1fr 100px 130px;
            align-items: center;
            gap: 16px;
            padding: 18px 22px;
            border-bottom: 1px solid #f1f5f9;
            transition: background .15s ease;
        }

            .order-row:last-child {
                border-bottom: none;
            }

            .order-row:hover {
                background: var(--bg);
            }

        .order-icon {
            width: 44px;
            height: 44px;
            border-radius: 13px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
        }

        .order-main .order-number {
            font-weight: 700;
            font-size: 14px;
            font-family: 'JetBrains Mono', monospace;
        }

        .order-main .order-id {
            color: var(--ink-400);
            font-size: 11.5px;
            margin-top: 3px;
        }

        .order-address {
            color: var(--ink-600);
            font-size: 12.5px;
            line-height: 1.4;
        }

        .order-meta {
            font-size: 12.5px;
            color: var(--ink-600);
        }

            .order-meta .meta-label {
                display: block;
                color: var(--ink-400);
                font-size: 10.5px;
                font-weight: 600;
                text-transform: uppercase;
                margin-bottom: 3px;
            }

        .order-amount {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 15px;
            text-align: right;
        }

        .order-badges {
            display: flex;
            flex-direction: column;
            gap: 6px;
            align-items: flex-end;
        }

        .badge {
            display: inline-block;
            padding: 5px 11px;
            border-radius: 999px;
            font-size: 10.5px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 0.2px;
            white-space: nowrap;
        }

        .badge-assigned {
            background: var(--warning-bg);
            color: #92400e;
        }

        .badge-out {
            background: #e0f2fe;
            color: #0369a1;
        }

        .badge-delivered {
            background: var(--success-bg);
            color: #166534;
        }

        .badge-cancelled {
            background: var(--danger-bg);
            color: #991b1b;
        }

        .badge-default {
            background: var(--bg-2);
            color: var(--ink-600);
        }

        .expand-details {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 10px;
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px dashed var(--border);
        }

        .expand-item {
            background: var(--bg);
            border: 1px solid #eef2f7;
            border-radius: 12px;
            padding: 10px 12px;
        }

            .expand-item span {
                display: block;
                color: var(--ink-400);
                font-size: 10.5px;
                font-weight: 600;
                margin-bottom: 4px;
            }

            .expand-item strong {
                color: var(--ink-900);
                font-size: 12.5px;
                font-family: 'JetBrains Mono', monospace;
            }

        .order-actions {
            grid-column: 1 / -1;
            margin-top: 14px;
        }

        .action-link {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 12px;
            font-size: 12.5px;
            font-weight: 700;
            background: var(--primary);
            color: white;
            transition: all .16s ease;
        }

            .action-link:hover {
                background: var(--primary-hover);
                transform: translateY(-1px);
                box-shadow: 0 8px 18px rgba(30, 58, 95, 0.28);
            }

        .empty-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 60px 20px;
            text-align: center;
            color: var(--ink-400);
            box-shadow: var(--shadow-sm);
        }

            .empty-box h3 {
                margin: 0 0 8px;
                color: var(--ink-900);
                font-family: 'Sora', sans-serif;
            }

        @@media (max-width: 900px) {
            .kpi-row {
                grid-template-columns: repeat(2, 1fr);
            }

            .order-row {
                grid-template-columns: 1fr;
                grid-template-areas:
                    "icon"
                    "main"
                    "address"
                    "meta"
                    "amount"
                    "badges"
                    "expand"
                    "actions";
            }

            .order-badges {
                align-items: flex-start;
            }

            .order-amount {
                text-align: left;
            }

            .expand-details {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 650px) {
            .page {
                padding: 20px 12px;
            }

            .kpi-row {
                grid-template-columns: 1fr;
            }

            .expand-details {
                grid-template-columns: 1fr;
            }

            .list-panel-head {
                padding: 16px;
            }

            .order-row {
                padding: 16px;
            }
        }
    </style>
</head>

<body>

    <partial name="_DeliveryNav" />

    <div class="page">
        <div class="shell">

            <div class="page-header">
                <div>
                    <h1>My Delivery Orders</h1>
                    <p>
                        View assigned, active, completed, and cancelled deliveries.
                    </p>
                </div>

                <a href="/DeliveryDashboard" class="dashboard-link">
                    🚚 Open Dashboard
                </a>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="message error">
                    @Model.ErrorMessage
                </div>
            }

            <div class="kpi-row">
                <div class="kpi-chip">
                    <span>Total Orders</span>
                    <strong>@Model.TotalCount</strong>
                </div>

                <div class="kpi-chip">
                    <span>Assigned</span>
                    <strong>@Model.AssignedCount</strong>
                </div>

                <div class="kpi-chip">
                    <span>Out for Delivery</span>
                    <strong>@Model.OutForDeliveryCount</strong>
                </div>

                <div class="kpi-chip">
                    <span>Delivered</span>
                    <strong>@Model.DeliveredCount</strong>
                </div>

                <div class="kpi-chip">
                    <span>Cancelled / Failed</span>
                    <strong>@Model.CancelledCount</strong>
                </div>
            </div>

            <div class="filters">
                <a href="/DeliveryOrders?StatusFilter=All"
                   class="filter-link @(Model.StatusFilter == "All" ? "active" : "")">
                    All
                </a>

                <a href="/DeliveryOrders?StatusFilter=Assigned"
                   class="filter-link @(Model.StatusFilter == "Assigned" ? "active" : "")">
                    Assigned
                </a>

                <a href="/DeliveryOrders?StatusFilter=OutForDelivery"
                   class="filter-link @(Model.StatusFilter == "OutForDelivery" ? "active" : "")">
                    Out for Delivery
                </a>

                <a href="/DeliveryOrders?StatusFilter=Delivered"
                   class="filter-link @(Model.StatusFilter == "Delivered" ? "active" : "")">
                    Delivered
                </a>

                <a href="/DeliveryOrders?StatusFilter=Cancelled"
                   class="filter-link @(Model.StatusFilter == "Cancelled" ? "active" : "")">
                    Cancelled / Failed
                </a>
            </div>

            @if (Model.Orders == null || !Model.Orders.Any())
            {
                <div class="empty-box">
                    <h3>No delivery orders found</h3>
                    <p>
                        Orders assigned by the admin will appear here.
                    </p>
                </div>
            }
            else
            {
                <div class="list-panel">

                    <div class="list-panel-head">
                        <h2>Order List</h2>
                    </div>

                    @foreach (var order in Model.Orders)
                    {
                        var cleanStatus = order.AssignmentStatus?.Trim();

                        var badgeClass =
                        cleanStatus == "Assigned"
                        ? "badge-assigned"
                        : cleanStatus == "OutForDelivery"
                        ? "badge-out"
                        : cleanStatus == "Delivered"
                        ? "badge-delivered"
                        : cleanStatus == "Cancelled" ||
                        cleanStatus == "Failed"
                        ? "badge-cancelled"
                        : "badge-default";

                        var displayStatus =
                        cleanStatus == "OutForDelivery"
                        ? "Out for Delivery"
                        : cleanStatus;

                        <div class="order-row">

                            <div class="order-icon">📦</div>

                            <div class="order-main">
                                <div class="order-number">
                                    @order.OrderNumber
                                </div>

                                <div class="order-id">
                                    Order ID: @order.OrderID
                                </div>
                            </div>

                            <div class="order-address">
                                @order.CustomerAddress
                            </div>

                            <div class="order-meta">
                                <span class="meta-label">Assigned</span>
                                @Model.FormatLocalTime(order.AssignedAt)
                            </div>

                            <div class="order-amount">
                                $@order.TotalAmount.ToString("0.00")
                            </div>

                            <div class="order-badges">
                                <span class="badge @badgeClass">
                                    @displayStatus
                                </span>

                                <span class="badge badge-default">
                                    @order.OrderStatus
                                </span>
                            </div>

                            <div class="expand-details">

                                <div class="expand-item">
                                    <span>Payment Method</span>
                                    <strong>@order.PaymentMethod</strong>
                                </div>

                                <div class="expand-item">
                                    <span>Payment Status</span>
                                    <strong>@order.PaymentStatus</strong>
                                </div>

                                <div class="expand-item">
                                    <span>Pickup Time</span>
                                    <strong>@Model.FormatLocalTime(order.PickupTime)</strong>
                                </div>

                                <div class="expand-item">
                                    <span>Delivery Time</span>
                                    <strong>@Model.FormatLocalTime(order.DeliveryTime)</strong>
                                </div>

                                <div class="expand-item">
                                    <span>Assignment Number</span>
                                    <strong>#@order.AssignmentID</strong>
                                </div>

                            </div>

                            @if (cleanStatus == "Assigned" ||
                           cleanStatus == "OutForDelivery")
                            {
                                <div class="order-actions">
                                    <a href="/DeliveryDashboard"
                                       class="action-link">
                                        Manage Delivery
                                    </a>
                                </div>
                            }

                        </div>
                    }

                </div>
            }

        </div>
    </div>

</body>
</html>
