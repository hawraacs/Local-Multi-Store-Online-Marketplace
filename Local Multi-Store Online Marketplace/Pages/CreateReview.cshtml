@page "{storeId:int}"
@model Local_Multi_Store_Online_Marketplace.Pages.CreateReviewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Review Store</title>

    <style>
        body {
            font-family: Arial;
            background: #f5f5f5;
            margin: 0;
        }

        .container {
            max-width: 520px;
            margin: 60px auto;
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            font-weight: bold;
            margin-bottom: 6px;
        }

        input, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        textarea {
            height: 110px;
            resize: none;
        }

        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: #16a34a;
            color: white;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
        }

            .btn:hover {
                background: #15803d;
            }

        .back {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: #666;
            text-decoration: none;
        }

            .back:hover {
                color: black;
            }

        .title {
            text-align: center;
            font-size: 20px;
            margin-bottom: 10px;
            color: #333;
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>⭐ Review Store</h2>

        <div class="title">
            Share your experience with this store
        </div>

        <form method="post">

            <input type="hidden" asp-for="StoreId" />

            <div class="form-group">
                <label>Rating (1 - 5)</label>
                <input asp-for="Rating" type="number" min="1" max="5" />
            </div>

            <div class="form-group">
                <label>Comment</label>
                <textarea asp-for="Comment" placeholder="Write your experience..."></textarea>
            </div>

            <button type="submit" class="btn">
                Submit Review
            </button>

        </form>

        <a href="javascript:history.back()" class="back">← Back</a>

    </div>

</body>
</html>