@page "{storeId:int}"
@model Local_Multi_Store_Online_Marketplace.Pages.CreateReviewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Store Reviews</title>

    <style>
        body {
            font-family: Arial;
            background: #f5f5f5;
            margin: 0;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            background: white;
            padding: 20px;
            border-radius: 12px;
        }

        h2 {
            text-align: center;
        }

        .review-box {
            border: 1px solid #eee;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .stars {
            color: gold;
        }

        textarea, input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 10px;
        }

        button {
            width: 100%;
            padding: 10px;
            background: green;
            color: white;
            border: none;
            border-radius: 8px;
        }

        .section-title {
            margin-top: 20px;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>⭐ Store Reviews</h2>

        <!-- ✅ ADD REVIEW FORM -->
        <form method="post">

            <input type="hidden" asp-for="StoreId" />

            <label>Rating (1-5)</label>
            <input asp-for="Rating" type="number" min="1" max="5" />

            <label>Comment</label>
            <textarea asp-for="Comment" placeholder="Write your review..."></textarea>

            <button type="submit">Submit Review</button>

        </form>

        <!-- ✅ EXISTING REVIEWS -->
        <div class="section-title">Other Reviews</div>

        @if (!Model.Reviews.Any())
        {
            <p>No reviews yet.</p>
        }
        else
        {
            @foreach (var r in Model.Reviews)
            {
                <div class="review-box">
                    <strong>@(r.Customer?.CustomerID.ToString() ?? "Unknown Customer")</strong>

                    <div class="stars">
                        @for (int i = 0; i < r.Rating; i++)
                        {
                            <span>⭐</span>
                        }
                    </div>

                    <p>@r.Comment</p>

                    <small>@r.CreatedAt.ToString("yyyy-MM-dd")</small>

                </div>
            }
        }

    </div>

</body>
</html>