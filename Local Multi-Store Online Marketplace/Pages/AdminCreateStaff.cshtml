@page
@model Local_Multi_Store_Online_Marketplace.Pages.AdminCreateStaffModel
@{
    ViewData["Title"] = "Create Staff Account";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #6366F1;
            --brand-dark: #4F46E5;
            --brand-soft: rgba(99, 102, 241, 0.08);
            --navy: #0F172A;
            --bg: #F8FAFC;
            --surface: #FFFFFF;
            --border: #E2E8F0;
            --text: #0F172A;
            --muted: #64748B;
            --positive-bg: #DCFCE7;
            --positive-txt: #15803D;
            --danger-bg: #FEE2E2;
            --danger-txt: #B91C1C;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 22px;
            --shadow: 0 1px 3px rgba(15,23,42,0.06), 0 6px 20px -8px rgba(15,23,42,0.10);
            --font: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
        }

        .staff-page {
            max-width: 640px;
            margin: 0 auto;
            padding: 28px 4px 48px;
            font-family: var(--font);
            color: var(--text);
        }

        .staff-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .staff-card-header {
            padding: 22px 26px;
            border-bottom: 1px solid var(--border);
            background: var(--surface);
        }

            .staff-card-header h4 {
                margin: 0;
                font-size: 18px;
                font-weight: 800;
                letter-spacing: -0.02em;
                color: var(--text);
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .staff-card-header h4 i {
                    color: var(--brand);
                    font-size: 18px;
                }

            .staff-card-header p {
                margin: 4px 0 0;
                font-size: 13px;
                color: var(--muted);
            }

        .staff-card-body {
            padding: 26px;
        }

        .alert {
            border-radius: var(--radius-sm);
            font-size: 13.5px;
            font-weight: 600;
            padding: 12px 16px;
            border: 1px solid transparent;
        }

        .alert-success {
            background: var(--positive-bg);
            color: var(--positive-txt);
            border-color: #86efac;
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger-txt);
            border-color: #fca5a5;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
        }

        .form-control,
        .form-select {
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            padding: 10px 14px;
            font-size: 14px;
            font-family: var(--font);
            color: var(--text);
            background: var(--surface);
            transition: border-color 0.18s ease, box-shadow 0.18s ease;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: var(--brand);
                box-shadow: 0 0 0 3px var(--brand-soft);
                outline: none;
            }

        .form-text,
        small.text-muted {
            font-size: 12px;
            color: var(--muted) !important;
        }

        .text-danger {
            color: #dc2626 !important;
            font-size: 12.5px;
        }

        .btn-primary-brand {
            background: var(--brand);
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 13.5px;
            font-family: var(--font);
            cursor: pointer;
            transition: background 0.18s ease;
        }

            .btn-primary-brand:hover {
                background: var(--brand-dark);
                color: #fff;
            }

        .btn-outline-brand {
            background: var(--surface);
            color: var(--text);
            border: 1px solid var(--border);
            padding: 10px 22px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 13.5px;
            font-family: var(--font);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
        }

            .btn-outline-brand:hover {
                border-color: var(--brand);
                color: var(--brand);
                background: var(--brand-soft);
            }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }
    </style>
}

<div class="staff-page">
    <div class="staff-card">
        <div class="staff-card-header">
            <h4><i class="fas fa-user-plus"></i> Create Staff Account Manually</h4>
            <p>Add a Store Owner or Delivery account with a temporary password</p>
        </div>

        <div class="staff-card-body">

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="alert alert-success mb-3">
                    @Model.SuccessMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger mb-3">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.FullName" class="form-label"></label>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Enter full name" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="example@email.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.PhoneNumber" class="form-label"></label>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Enter phone number" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Role" class="form-label"></label>
                    <select asp-for="Input.Role" class="form-select">
                        <option value="">-- Select Role --</option>
                        <option value="StoreOwner">Store Owner</option>
                        <option value="Delivery">Delivery</option>
                    </select>
                    <span asp-validation-for="Input.Role" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.TemporaryPassword" class="form-label"></label>
                    <input asp-for="Input.TemporaryPassword" class="form-control" />
                    <span asp-validation-for="Input.TemporaryPassword" class="text-danger"></span>
                    <small class="text-muted">
                        This password is temporary. The user should change it after first login.
                    </small>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary-brand">
                        Create Account
                    </button>

                    <a asp-page="/AdminUsers" class="btn-outline-brand">
                        Back
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
