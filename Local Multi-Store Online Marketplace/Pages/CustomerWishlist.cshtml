@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerWishlistModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>My Wishlist</title>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .wishlist-page {
            padding: 40px;
            min-height: 100vh;
        }

        .wishlist-header {
            text-align: center;
            margin-bottom: 35px;
        }

            .wishlist-header h2 {
                font-size: 34px;
                margin-bottom: 8px;
                color: #111827;
            }

            .wishlist-header p {
                color: #6b7280;
                font-size: 15px;
            }

        .message {
            max-width: 700px;
            margin: 0 auto 25px auto;
            padding: 14px 18px;
            border-radius: 12px;
            font-weight: 700;
            text-align: center;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            max-width: 1100px;
            margin: auto;
        }

        .wishlist-card {
            background: white;
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
            transition: 0.2s ease;
        }

            .wishlist-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 18px 38px rgba(0,0,0,0.12);
            }

            .wishlist-card img {
                width: 100%;
                height: 240px;
                object-fit: cover;
                border-radius: 14px;
                background: #f3f4f6;
            }

        .product-name {
            font-size: 19px;
            font-weight: 800;
            color: #111827;
            margin: 15px 0 5px;
        }

        .store-name {
            color: #6b7280;
            font-size: 13px;
            margin-bottom: 10px;
        }

        .price {
            font-size: 20px;
            font-weight: 900;
            color: #FF6B35;
            margin: 14px 0;
        }

        .actions {
            display: flex;
            gap: 10px;
        }

        .move-btn,
        .remove-btn {
            flex: 1;
            border: none;
            padding: 12px;
            border-radius: 12px;
            font-weight: 800;
            cursor: pointer;
        }

        .move-btn {
            background: #111827;
            color: white;
        }

        .remove-btn {
            background: #fee2e2;
            color: #991b1b;
        }

        .empty-box {
            max-width: 700px;
            margin: 40px auto;
            background: white;
            padding: 45px;
            text-align: center;
            border-radius: 18px;
            border: 1px solid #e5e7eb;
            color: #6b7280;
        }

        .shop-link {
            display: inline-block;
            margin-top: 15px;
            background: #111827;
            color: white;
            padding: 12px 18px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 800;
        }

        @@media (max-width: 900px) {
            .wishlist-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .wishlist-grid {
                grid-template-columns: 1fr;
            }

            .wishlist-page {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="wishlist-page">

        <div class="wishlist-header">
            <h2>❤️ My Wishlist</h2>
            <p>Products you saved for future purchase.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="message error-message">
                @TempData["Error"]
            </div>
        }

        @if (Model.WishlistItems == null || !Model.WishlistItems.Any())
        {
            <div class="empty-box">
                <h3>Your wishlist is empty</h3>
                <p>Save products you like and view them later.</p>

                <a href="/CustomerProducts" class="shop-link">
                    Browse Products
                </a>
            </div>
        }
        else
        {
            <div class="wishlist-grid">
                @foreach (var item in Model.WishlistItems)
                {
                    <div class="wishlist-card">
                        <img src="@item.ImageUrl"
                             alt="@item.ProductName"
                             onerror="this.src='/images/no-image.png'" />

                        <div class="product-name">
                            @item.ProductName
                        </div>

                        <div class="store-name">
                            Store: @item.StoreName
                        </div>

                        <div class="price">
                            $@item.Price.ToString("N2")
                        </div>

                        <div class="actions">
                            @if (!item.IsOutOfStock)
                            {
                                <form method="post"
                                      asp-page-handler="MoveToCart"
                                      asp-route-productId="@item.ProductID"
                                      style="flex:1;">
                                    <button type="submit" class="move-btn">
                                        Move to Cart
                                    </button>
                                </form>
                            }

                            <form method="post"
                                  asp-page-handler="Remove"
                                  asp-route-productId="@item.ProductID"
                                  style="flex:1;">
                                <button type="submit" class="remove-btn">
                                    Remove
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</body>
</html>