@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProductsModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Shop</title>
    <style>
            body {
                margin: 0;
                background: #f4f6f9;
                font-family: Arial, sans-serif;
            }

            .shop-page {
                padding: 40px;
                min-height: 100vh;
            }

            .shop-header {
                text-align: center;
                margin-bottom: 35px;
            }

                .shop-header h2 {
                    font-size: 34px;
                    margin-bottom: 8px;
                    color: #111827;
                }

                .shop-header p {
                    color: #6b7280;
                    font-size: 15px;
                }

            .message {
                max-width: 700px;
                margin: 0 auto 25px auto;
                padding: 14px 18px;
                border-radius: 12px;
                font-weight: 700;
                text-align: center;
            }

            .success-message {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #86efac;
            }

            .error-message {
                background: #fee2e2;
                color: #991b1b;
                border: 1px solid #fca5a5;
            }

            .debug-box {
                background: #f0f0f0;
                padding: 15px;
                margin-bottom: 20px;
                border: 1px solid #ccc;
                border-radius: 8px;
                font-family: monospace;
                font-size: 13px;
                overflow-x: auto;
                max-width: 1100px;
                margin-left: auto;
                margin-right: auto;
            }

            .products-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 25px;
                max-width: 1100px;
                margin: auto;
            }

            .product-card {
                background: white;
                border-radius: 18px;
                padding: 18px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
                border: 1px solid #e5e7eb;
                transition: 0.2s ease;
            }

                .product-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 18px 38px rgba(0,0,0,0.12);
                }

                .product-card img {
                    width: 100%;
                    height: 240px;
                    object-fit: cover;
                    border-radius: 14px;
                    background: #f3f4f6;
                }

            .product-name {
                font-size: 19px;
                font-weight: 800;
                color: #111827;
                margin: 15px 0 5px;
            }

            .product-price {
                font-size: 18px;
                font-weight: bold;
                color: #FF6B35;
                margin-bottom: 8px;
            }

            .product-store {
                font-size: 13px;
                color: #6c757d;
                margin-bottom: 15px;
            }

            .wishlist-btn {
                width: 100%;
                background: #111827;
                color: white;
                border: none;
                padding: 12px;
                border-radius: 12px;
                font-weight: 800;
                cursor: pointer;
                transition: 0.2s ease;
            }

                .wishlist-btn:hover {
                    background: #2563eb;
                }

            @@media (max-width: 900px) {
                .products-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @@media (max-width: 600px) {
                .products-grid {
                    grid-template-columns: 1fr;
                }

                .shop-page {
                    padding: 20px;
                }
            }
    </style>
</head>

<body>
    <div class="shop-page">
        <div class="shop-header">
            <h2>🛍️ All Products</h2>
            <p>Browse products from our stores</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="message error-message">@TempData["Error"]</div>
        }

        <!-- Debug Information Box (remove after fixing) -->
        <div class="debug-box">
            @Html.Raw(Model.DebugInfo)
        </div>

        <div class="products-grid">
            @foreach (var product in Model.Products)
            {
                <div class="product-card">
                    <img src="@product.PrimaryImageUrl" alt="@product.ProductName" />
                    <div class="product-name">@product.ProductName</div>
                    <div class="product-price">$@product.Price.ToString("N2")</div>
                    <div class="product-store">
                        <i class="fas fa-store"></i> @product.StoreName
                    </div>
                    <form method="post" asp-page-handler="AddWishlist">
                        <input type="hidden" name="productId" value="@product.ProductID" />
                        <button type="submit" class="wishlist-btn">
                            ❤️ Add to Wishlist
                        </button>
                    </form>
                </div>
            }
        </div>

        @if (!Model.Products.Any())
        {
            <div style="text-align: center; margin-top: 50px; color: #6c757d;">
                <p>No products available yet. Check back later!</p>
            </div>
        }
    </div>
</body>
</html>