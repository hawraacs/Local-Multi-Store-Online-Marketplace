@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProductsModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Shop | Realnest</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f3f5f8;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .shop-page {
            min-height: 100vh;
            padding: 45px 28px;
        }

        .shop-header {
            max-width: 1150px;
            margin: 0 auto 35px auto;
            background: linear-gradient(135deg, #111827, #1f2937);
            border-radius: 26px;
            padding: 35px;
            color: white;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

            .shop-header h2 {
                margin: 0;
                font-size: 36px;
                font-weight: 900;
            }

            .shop-header p {
                margin: 10px 0 0;
                color: #d1d5db;
                font-size: 15px;
            }

        .shop-badge {
            background: #ff5a2c;
            padding: 13px 18px;
            border-radius: 999px;
            font-weight: 900;
            white-space: nowrap;
            box-shadow: 0 10px 25px rgba(255, 90, 44, 0.35);
        }

        .message {
            max-width: 750px;
            margin: 0 auto 25px auto;
            padding: 14px 18px;
            border-radius: 14px;
            font-weight: 800;
            text-align: center;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .filter-card {
            max-width: 1150px;
            margin: 0 auto 30px auto;
            background: white;
            border-radius: 24px;
            padding: 22px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
        }

        .filter-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
            gap: 12px;
            align-items: end;
        }

        .filter-group label {
            display: block;
            font-size: 12px;
            font-weight: 900;
            color: #374151;
            margin-bottom: 6px;
            text-transform: uppercase;
        }

        .filter-input,
        .filter-select {
            width: 100%;
            padding: 12px 13px;
            border: 1px solid #d1d5db;
            border-radius: 12px;
            font-weight: 700;
            color: #111827;
            background: white;
        }

        .filter-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

        .filter-btn,
        .clear-btn {
            border: none;
            padding: 12px 18px;
            border-radius: 12px;
            font-weight: 900;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .filter-btn {
            background: #111827;
            color: white;
        }

        .clear-btn {
            background: #e5e7eb;
            color: #374151;
        }

        .results-count {
            max-width: 1150px;
            margin: 0 auto 18px auto;
            color: #6b7280;
            font-weight: 800;
        }

        .products-grid {
            max-width: 1150px;
            margin: auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 26px;
        }

        .product-card {
            background: white;
            border-radius: 24px;
            padding: 18px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
            transition: box-shadow 0.2s ease, border-color 0.2s ease;
            position: relative;
        }

            .product-card:hover {
                border-color: #ffb199;
                box-shadow: 0 22px 55px rgba(15, 23, 42, 0.13);
            }

        .image-box {
            height: 230px;
            border-radius: 20px;
            background: linear-gradient(135deg, #f9fafb, #e5e7eb);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 16px;
            position: relative;
        }

            .image-box img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                display: block;
            }

        .stock-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
            padding: 7px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
        }

        .product-category {
            display: inline-block;
            background: #eef2ff;
            color: #2563eb;
            padding: 6px 11px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .product-name {
            font-size: 21px;
            font-weight: 900;
            margin-bottom: 6px;
            color: #111827;
        }

        .product-price {
            color: #ff5a2c;
            font-size: 22px;
            font-weight: 900;
            margin-bottom: 8px;
        }

        .product-store {
            color: #6b7280;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .product-description {
            color: #4b5563;
            font-size: 14px;
            line-height: 1.45;
            min-height: 42px;
            margin-bottom: 18px;
        }

        .details-btn {
            display: block;
            width: 100%;
            background: #111827;
            color: white;
            text-align: center;
            text-decoration: none;
            padding: 13px;
            border-radius: 14px;
            font-weight: 900;
            margin-bottom: 12px;
        }

            .details-btn:hover {
                background: #2563eb;
            }

        .product-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

            .product-actions form {
                margin: 0;
            }

        .wishlist-btn,
        .cart-btn,
        .out-stock-btn {
            width: 100%;
            border: none;
            padding: 13px;
            border-radius: 14px;
            font-weight: 900;
            color: white;
            transition: background 0.2s ease, box-shadow 0.2s ease;
        }

        .wishlist-btn {
            background: #111827;
            cursor: pointer;
        }

            .wishlist-btn:hover {
                background: #2563eb;
                box-shadow: 0 10px 22px rgba(37, 99, 235, 0.25);
            }

        .cart-btn {
            background: #ff5a2c;
            cursor: pointer;
        }

            .cart-btn:hover {
                background: #e64a1f;
                box-shadow: 0 10px 22px rgba(255, 90, 44, 0.28);
            }

        .out-stock-btn {
            background: #e5e7eb;
            color: #6b7280;
            cursor: not-allowed;
        }

        .empty-box {
            max-width: 750px;
            margin: 45px auto;
            background: white;
            padding: 50px 35px;
            border-radius: 24px;
            border: 1px solid #e5e7eb;
            text-align: center;
            color: #6b7280;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
        }

            .empty-box h3 {
                color: #111827;
                font-size: 25px;
                margin-bottom: 10px;
            }

        @@media (max-width: 1100px) {
            .filter-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 950px) {
            .products-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .shop-header {
                flex-direction: column;
                text-align: center;
            }
        }

        @@media (max-width: 600px) {
            .shop-page {
                padding: 22px 15px;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }

            .shop-header h2 {
                font-size: 29px;
            }

            .product-actions {
                grid-template-columns: 1fr;
            }

            .filter-grid {
                grid-template-columns: 1fr;
            }

            .filter-actions {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>
    <div class="shop-page">

        <div class="shop-header">
            <div>
                <h2>🛍️ Discover Products</h2>
                <p>Browse trusted local stores, save favorites, or add items directly to your cart.</p>
            </div>

            <div class="shop-badge">
                Realnest Marketplace
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="message error-message">
                @TempData["Error"]
            </div>
        }

        <div class="filter-card">
            <form method="get">
                <div class="filter-grid">

                    <div class="filter-group">
                        <label>Search</label>
                        <input asp-for="SearchTerm"
                               class="filter-input"
                               placeholder="Search product, store, category..." />
                    </div>

                    <div class="filter-group">
                        <label>Category</label>
                        <select asp-for="CategoryId" class="filter-select">
                            <option value="">All Categories</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.CategoryID">
                                    @category.CategoryName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label>Store</label>
                        <select asp-for="StoreId" class="filter-select">
                            <option value="">All Stores</option>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.StoreID">
                                    @store.StoreName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label>Area</label>
                        <select asp-for="Area" class="filter-select">
                            <option value="">All Areas</option>
                            @foreach (var area in Model.Areas)
                            {
                                <option value="@area">
                                    @area
                                </option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label>Min Price</label>
                        <input asp-for="MinPrice"
                               class="filter-input"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="Min" />
                    </div>

                    <div class="filter-group">
                        <label>Max Price</label>
                        <input asp-for="MaxPrice"
                               class="filter-input"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="Max" />
                    </div>

                </div>

                <div class="filter-actions">
                    <button type="submit" class="filter-btn">
                        Search / Filter
                    </button>

                    <a href="/CustomerProducts" class="clear-btn">
                        Clear Filters
                    </a>
                </div>
            </form>
        </div>

        <div class="results-count">
            Showing @Model.Products.Count product(s)
        </div>

        @if (Model.Products == null || !Model.Products.Any())
        {
            <div class="empty-box">
                <h3>No products found</h3>
                <p>Try changing the search or filter options.</p>
            </div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var product in Model.Products)
                {
                    <div class="product-card">

                        <div class="image-box">
                            <img src="@product.PrimaryImageUrl"
                                 alt="@product.ProductName"
                                 onerror="this.onerror=null;this.src='/images/no-image.png';" />

                            @if (product.IsOutOfStock)
                            {
                                <div class="stock-badge">
                                    Out of Stock
                                </div>
                            }
                        </div>

                        <div class="product-category">
                            @product.CategoryName
                        </div>

                        <div class="product-name">
                            @product.ProductName
                        </div>

                        <div class="product-price">
                            $@product.Price.ToString("N2")
                        </div>

                        <div class="product-store">
                            Store: @product.StoreName
                        </div>

                        <div class="product-description">
                            @(product.Description.Length > 90
                                ? product.Description.Substring(0, 90) + "..."
                                : product.Description)
                        </div>

                        <a asp-page="/CustomerProductDetails"
                           asp-route-id="@product.ProductID"
                           class="details-btn">
                            View Details
                        </a>

                        <div class="product-actions">
                            <form method="post"
                                  asp-page-handler="AddWishlist"
                                  asp-route-searchTerm="@Model.SearchTerm"
                                  asp-route-categoryId="@Model.CategoryId"
                                  asp-route-storeId="@Model.StoreId"
                                  asp-route-area="@Model.Area"
                                  asp-route-minPrice="@Model.MinPrice"
                                  asp-route-maxPrice="@Model.MaxPrice">
                                <input type="hidden"
                                       name="productId"
                                       value="@product.ProductID" />

                                <button type="submit" class="wishlist-btn">
                                    ❤️ Wishlist
                                </button>
                            </form>

                            @if (!product.IsOutOfStock)
                            {
                                <form method="post"
                                      asp-page-handler="AddCart"
                                      asp-route-searchTerm="@Model.SearchTerm"
                                      asp-route-categoryId="@Model.CategoryId"
                                      asp-route-storeId="@Model.StoreId"
                                      asp-route-area="@Model.Area"
                                      asp-route-minPrice="@Model.MinPrice"
                                      asp-route-maxPrice="@Model.MaxPrice">
                                    <input type="hidden"
                                           name="productId"
                                           value="@product.ProductID" />

                                    <button type="submit" class="cart-btn">
                                        🛒 Add Cart
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="out-stock-btn" disabled>
                                    Out of Stock
                                </button>
                            }
                        </div>

                    </div>
                }
            </div>
        }
    </div>
</body>
</html>