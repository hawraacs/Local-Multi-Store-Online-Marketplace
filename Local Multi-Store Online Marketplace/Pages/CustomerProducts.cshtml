@page
@model Local_Multi_Store_Online_Marketplace.Pages.CustomerProductsModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Shop | Realnest</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f3f5f8;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .shop-page {
            min-height: 100vh;
            padding: 45px 28px;
        }

        .shop-header {
            max-width: 1150px;
            margin: 0 auto 35px auto;
            background: linear-gradient(135deg, #111827, #1f2937);
            border-radius: 26px;
            padding: 35px;
            color: white;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

            .shop-header h2 {
                margin: 0;
                font-size: 36px;
                font-weight: 900;
            }

            .shop-header p {
                margin: 10px 0 0;
                color: #d1d5db;
                font-size: 15px;
            }

        .shop-badge {
            background: #ff5a2c;
            padding: 13px 18px;
            border-radius: 999px;
            font-weight: 900;
            white-space: nowrap;
            box-shadow: 0 10px 25px rgba(255, 90, 44, 0.35);
        }

        .message {
            max-width: 750px;
            margin: 0 auto 25px auto;
            padding: 14px 18px;
            border-radius: 14px;
            font-weight: 800;
            text-align: center;
        }

        .success-message {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .error-message {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .products-grid {
            max-width: 1150px;
            margin: auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 26px;
        }

        .product-card {
            background: white;
            border-radius: 24px;
            padding: 18px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
            transition: box-shadow 0.2s ease, border-color 0.2s ease;
        }

            .product-card:hover {
                border-color: #ffb199;
                box-shadow: 0 22px 55px rgba(15, 23, 42, 0.13);
            }

        .image-box {
            height: 230px;
            border-radius: 20px;
            background: linear-gradient(135deg, #f9fafb, #e5e7eb);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 16px;
        }

            .image-box img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                display: block;
            }

        .product-category {
            display: inline-block;
            background: #eef2ff;
            color: #2563eb;
            padding: 6px 11px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .product-name {
            font-size: 21px;
            font-weight: 900;
            margin-bottom: 6px;
            color: #111827;
        }

        .product-price {
            color: #ff5a2c;
            font-size: 22px;
            font-weight: 900;
            margin-bottom: 8px;
        }

        .product-store {
            color: #6b7280;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .product-description {
            color: #4b5563;
            font-size: 14px;
            line-height: 1.45;
            min-height: 42px;
            margin-bottom: 18px;
        }

        .product-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

            .product-actions form {
                margin: 0;
            }

        .wishlist-btn,
        .cart-btn {
            width: 100%;
            border: none;
            padding: 13px;
            border-radius: 14px;
            font-weight: 900;
            cursor: pointer;
            color: white;
            transition: background 0.2s ease, box-shadow 0.2s ease;
        }

        .wishlist-btn {
            background: #111827;
        }

            .wishlist-btn:hover {
                background: #2563eb;
                box-shadow: 0 10px 22px rgba(37, 99, 235, 0.25);
            }

        .cart-btn {
            background: #ff5a2c;
        }

            .cart-btn:hover {
                background: #e64a1f;
                box-shadow: 0 10px 22px rgba(255, 90, 44, 0.28);
            }

        .empty-box {
            max-width: 750px;
            margin: 45px auto;
            background: white;
            padding: 50px 35px;
            border-radius: 24px;
            border: 1px solid #e5e7eb;
            text-align: center;
            color: #6b7280;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
        }

            .empty-box h3 {
                color: #111827;
                font-size: 25px;
                margin-bottom: 10px;
            }

        @@media (max-width: 950px) {
            .products-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .shop-header {
                flex-direction: column;
                text-align: center;
            }
        }

        @@media (max-width: 600px) {
            .shop-page {
                padding: 22px 15px;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }

            .shop-header h2 {
                font-size: 29px;
            }

            .product-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="shop-page">

        <div class="shop-header">
            <div>
                <h2>🛍️ Discover Products</h2>
                <p>Browse trusted local stores, save favorites, or add items directly to your cart.</p>
            </div>

            <div class="shop-badge">
                Realnest Marketplace
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="message success-message">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="message error-message">
                @TempData["Error"]
            </div>
        }

        @if (Model.Products == null || !Model.Products.Any())
        {
            <div class="empty-box">
                <h3>No products available yet</h3>
                <p>Products added by store owners will appear here.</p>
            </div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var product in Model.Products)
                {
                    <div class="product-card">

                        <div class="image-box">
                            <img src="@product.PrimaryImageUrl"
                                 alt="@product.ProductName"
                                 onerror="this.onerror=null;this.src='/images/no-image.png';" />
                        </div>

                        <div class="product-category">
                            @product.CategoryName
                        </div>

                        <div class="product-name">
                            @product.ProductName
                        </div>

                        <div class="product-price">
                            $@product.Price.ToString("N2")
                        </div>

                        <div class="product-store">
                            Store: @product.StoreName
                        </div>

                        <div class="product-description">
                            @(product.Description.Length > 90
                                ? product.Description.Substring(0, 90) + "..."
                                : product.Description)
                        </div>

                        <div class="product-actions">
                            <form method="post" asp-page-handler="AddWishlist">
                                <input type="hidden"
                                       name="productId"
                                       value="@product.ProductID" />

                                <button type="submit" class="wishlist-btn">
                                    ❤️ Wishlist
                                </button>
                            </form>

                            <form method="post" asp-page-handler="AddCart">
                                <input type="hidden"
                                       name="productId"
                                       value="@product.ProductID" />

                                <button type="submit" class="cart-btn">
                                    🛒 Add Cart
                                </button>
                            </form>
                        </div>

                    </div>
                }
            </div>
        }
    </div>
</body>
</html>