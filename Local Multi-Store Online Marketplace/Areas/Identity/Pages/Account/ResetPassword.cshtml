@page
@model ResetPasswordModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <title>Reset Password</title>

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial;
        }

        body {
            background: #1f1f1f;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 500px;
            background: white;
            padding: 50px;
            border-radius: 15px;
        }

        h1 {
            color: #1f2b6c;
            margin-bottom: 10px;
        }

        p {
            color: gray;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-control {
            width: 100%;
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #ccc;
        }

        .btn {
            width: 100%;
            padding: 15px;
            background: #1f2b6c;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 16px;
        }

            .btn:hover {
                background: black;
            }

        .text-danger {
            color: red;
            font-size: 13px;
        }

    </style>

</head>

<body>

    <div class="container">

        <h1>Reset Password</h1>

        <p>
            Create your new password
        </p>

        <form method="post">

            <div asp-validation-summary="All"
                 class="text-danger"></div>

            <input asp-for="Input.Code" type="hidden" />

            <div class="form-group">

                <input asp-for="Input.Email"
                       class="form-control"
                       placeholder="Email Address" />

            </div>

            <div class="form-group">

                <input asp-for="Input.Password"
                       class="form-control"
                       placeholder="New Password"
                       type="password" />

            </div>

            <div class="form-group">

                <input asp-for="Input.ConfirmPassword"
                       class="form-control"
                       placeholder="Confirm Password"
                       type="password" />

            </div>

            <button type="submit" class="btn">
                Reset Password
            </button>

        </form>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>