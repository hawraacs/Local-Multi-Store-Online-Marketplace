@page
@model Multi_Store.Pages.Customer.WishlistModel
@{
    ViewData["Title"] = "My Wishlist";
}

<link rel="stylesheet" href="~/css/customer-dashboard.css" />

<div class="customer-page">
    <div class="customer-header">
        <div>
            <h2>My Wishlist</h2>
            <p>Products saved for future purchase.</p>
        </div>
    </div>

    @if (Model.WishlistItems == null || !Model.WishlistItems.Any())
    {
        <div class="empty-state">
            <h4>Your wishlist is empty</h4>
            <p>Save products you like and view them later.</p>
        </div>
    }
    else
    {
        <div class="customer-grid">
            @foreach (var item in Model.WishlistItems)
            {
                <div class="customer-card product-card">
                    <img src="@item.ImageUrl" alt="@item.ProductName" />

                    <div class="card-title">@item.ProductName</div>
                    <div class="card-text">@item.StoreName</div>
                    <div class="price">$@item.Price</div>

                    @if (item.IsOutOfStock)
                    {
                        <span class="badge-danger">Out of Stock</span>
                    }

                    <div class="card-actions">
                        @if (!item.IsOutOfStock)
                        {
                            <form method="post"
                                  asp-page-handler="MoveToCart"
                                  asp-route-productId="@item.ProductID">
                                <button type="submit" class="btn-secondary-action">
                                    Move to Cart
                                </button>
                            </form>
                        }

                        <form method="post"
                              asp-page-handler="Remove"
                              asp-route-productId="@item.ProductID">
                            <button type="submit" class="btn-delete">
                                Remove
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>