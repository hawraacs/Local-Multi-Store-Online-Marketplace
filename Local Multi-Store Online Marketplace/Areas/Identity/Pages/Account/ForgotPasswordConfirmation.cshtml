@page
@model ForgotPasswordConfirmationModel

@{
    ViewData["Title"] = "OTP Created";
    Layout = null;

    var resetIdentifier = TempData["ResetIdentifier"]?.ToString();
    var demoOtp = TempData["DemoOtp"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>OTP Created | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Poppins, Arial, sans-serif;
            background: #1f1f1f;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #111827;
        }

        .card {
            width: 560px;
            max-width: 100%;
            background: white;
            border-radius: 20px;
            padding: 45px;
            text-align: center;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.40);
        }

        .icon {
            width: 76px;
            height: 76px;
            margin: 0 auto 24px;
            border-radius: 50%;
            background: #dcfce7;
            color: #166534;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 34px;
            font-weight: 800;
        }

        h1 {
            color: #222260;
            margin-bottom: 14px;
            font-size: 30px;
            font-weight: 800;
        }

        p {
            color: #6b7280;
            line-height: 1.7;
            font-size: 14px;
            margin-bottom: 12px;
        }

        .target-box, .otp-box {
            margin: 18px 0;
            padding: 14px;
            border-radius: 12px;
            background: #f3f4f6;
            color: #111827;
            font-size: 14px;
            font-weight: 700;
            word-break: break-word;
        }

        .otp-box {
            font-size: 24px;
            letter-spacing: 6px;
            color: #222260;
        }

        .note {
            margin-top: 18px;
            font-size: 12px;
            color: #9ca3af;
            line-height: 1.6;
        }

        .actions {
            margin-top: 28px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-block;
            padding: 13px 24px;
            background: #181818;
            color: white;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            transition: 0.2s ease;
        }

            .btn:hover {
                background: #ff6b35;
                color: white;
            }

        .btn-light {
            background: #f3f4f6;
            color: #111827;
        }

            .btn-light:hover {
                background: #e5e7eb;
                color: #111827;
            }
    </style>
</head>

<body>

    <div class="card">

        <div class="icon">✓</div>

        <h1>OTP Created</h1>

        <p>
            @(TempData["ResetMessage"] ?? "A password reset OTP was created.")
        </p>

        @if (TempData["ResetTarget"] != null)
        {
            <div class="target-box">
                @TempData["ResetTarget"]
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(demoOtp))
        {
            <p class="note">
                Demo OTP:
            </p>

            <div class="otp-box">
                @demoOtp
            </div>
        }

        <p class="note">
            Email/SMS sender is not configured, so the OTP is shown here for local demo only.
        </p>

        <div class="actions">
            <a asp-page="./VerifyResetOtp"
               asp-route-identifier="@resetIdentifier"
               class="btn">
                Verify OTP
            </a>

            <a href="/Identity/Account/Login" class="btn btn-light">
                Back to Login
            </a>
        </div>

    </div>

</body>
</html>