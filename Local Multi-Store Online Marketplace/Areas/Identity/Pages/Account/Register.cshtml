@page
@model Local_Multi_Store_Online_Marketplace.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Register - Realnest</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial;
        }

        body {
            width: 100%;
            min-height: 100vh;
            background: #1f1f1f;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            width: 1200px;
            min-height: 750px;
            background: white;
            display: flex;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .left-side {
            width: 50%;
            background: url('/images/register-bg.jpg');
            background-size: cover;
            background-position: center;
            position: relative;
        }

            .left-side::before {
                content: "";
                position: absolute;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.4);
            }

        .overlay {
            position: absolute;
            bottom: 60px;
            left: 50px;
            color: white;
            z-index: 2;
        }

            .overlay h1 {
                font-size: 50px;
                margin-bottom: 15px;
                line-height: 1.1;
            }

            .overlay p {
                font-size: 18px;
                width: 80%;
            }

        .right-side {
            width: 50%;
            padding: 60px;
            overflow-y: auto;
        }

        .top-btn {
            text-align: right;
            margin-bottom: 30px;
        }

            .top-btn a {
                background: black;
                color: white;
                padding: 10px 25px;
                border-radius: 30px;
                text-decoration: none;
                transition: .3s;
            }

                .top-btn a:hover {
                    background: #1f2b6c;
                }

        .title {
            font-size: 42px;
            font-weight: bold;
            color: #1f2b6c;
            margin-bottom: 10px;
        }

        .subtitle {
            color: gray;
            margin-bottom: 20px;
            font-size: 15px;
        }

        .approval-note {
            background: #fff7ed;
            color: #9a3412;
            border: 1px solid #fed7aa;
            padding: 12px 14px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 18px;
        }

            .form-group input,
            .form-group select {
                width: 100%;
                padding: 15px;
                border: 1px solid #ccc;
                border-radius: 10px;
                font-size: 16px;
                transition: .3s;
                background: white;
            }

                .form-group input:focus,
                .form-group select:focus {
                    outline: none;
                    border-color: #1f2b6c;
                    box-shadow: 0 0 5px rgba(31,43,108,0.2);
                }

        .phone-row {
            display: grid;
            grid-template-columns: 190px 1fr;
            gap: 10px;
        }

        .btn-register {
            width: 100%;
            padding: 15px;
            background: #1f2b6c;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            cursor: pointer;
            transition: .3s;
            margin-top: 10px;
        }

            .btn-register:hover {
                background: black;
            }

        .text-danger {
            color: red;
            font-size: 13px;
        }

        @@media(max-width: 900px) {
            .left-side {
                display: none;
            }

            .right-side {
                width: 100%;
                padding: 35px;
            }

            .container {
                height: auto;
            }

            .phone-row {
                grid-template-columns: 1fr;
            }
        }

    </style>

</head>

<body>

    <div class="container">

        <div class="left-side">

            <div class="overlay">

                <h1>Local Multi Store Marketplace</h1>

                <p>
                    Discover trusted stores around your area
                </p>

            </div>

        </div>

        <div class="right-side">

            <div class="top-btn">
                <a asp-page="./Login">Sign In</a>
            </div>

            <div class="title">
                Create Account
            </div>

            <div class="subtitle">
                Register your customer account
            </div>

            

            <form method="post">

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group">
                    <input asp-for="FullName" placeholder="Full Name" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input asp-for="Email" placeholder="Email Address" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <div class="phone-row">
                        <select asp-for="CountryCode">
                            <option value="">Select Country</option>
                            <option value="+961">Lebanon +961</option>
                            <option value="+966">Saudi Arabia +966</option>
                            <option value="+971">United Arab Emirates +971</option>
                            <option value="+974">Qatar +974</option>
                            <option value="+965">Kuwait +965</option>
                            <option value="+973">Bahrain +973</option>
                            <option value="+968">Oman +968</option>
                            <option value="+962">Jordan +962</option>
                            <option value="+20">Egypt +20</option>
                            <option value="+90">Turkey +90</option>
                            <option value="+33">France +33</option>
                            <option value="+49">Germany +49</option>
                            <option value="+44">United Kingdom +44</option>
                            <option value="+1">United States / Canada +1</option>
                        </select>

                        <input asp-for="PhoneNumber" placeholder="Phone Number" />
                    </div>

                    <span asp-validation-for="CountryCode" class="text-danger"></span>
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input asp-for="Password" type="password" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-register">
                    Create Account
                </button>

            </form>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>