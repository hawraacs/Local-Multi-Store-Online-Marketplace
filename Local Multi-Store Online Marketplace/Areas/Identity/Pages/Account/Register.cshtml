@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: #f8fafc;
    }

    .register-box {
        max-width: 420px;
        margin: 60px auto;
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .btn-register {
        width: 100%;
        background: #ef4444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-register:hover {
            background: #dc2626;
        }

    input {
        border-radius: 10px !important;
    }
</style>

<div class="register-box">

    <div class="title">Create Account</div>

    <form method="post">

        <div class="mb-3">
            <label>Full Name</label>
            <input asp-for="Input.FullName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Input.Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Phone</label>
            <input asp-for="Input.PhoneNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Password</label>
            <input asp-for="Input.Password" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Confirm Password</label>
            <input asp-for="Input.ConfirmPassword" class="form-control" />
        </div>

        <button type="submit" class="btn-register">
            Register
        </button>

    </form>

</div>