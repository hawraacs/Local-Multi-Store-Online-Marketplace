@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Realnest Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
            background: #1f1f1f;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .login-container {
            width: 1400px;
            max-width: 100%;
            height: 820px;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        }

        /* LEFT SIDE */

        .left-side {
            width: 50%;
            position: relative;
            background: linear-gradient(rgba(0,0,0,0.15), rgba(0,0,0,0.3)),
                        url('/images/marketplace-login.jpg');

            background-size: cover;
            background-position: center;
            color: white;
        }

        .brand {
            position: absolute;
            top: 35px;
            left: 35px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: white;
            color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
        }

        .brand span {
            font-size: 22px;
            font-weight: 600;
        }

        .left-content {
            position: absolute;
            bottom: 70px;
            left: 55px;
        }

        .left-content h1 {
            font-size: 54px;
            line-height: 1.1;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .left-content p {
            font-size: 18px;
            opacity: 0.95;
            line-height: 1.6;
        }

        .dots {
            margin-top: 25px;
            display: flex;
            gap: 10px;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255,255,255,0.5);
        }

        .dot.active {
            width: 30px;
            border-radius: 30px;
            background: white;
        }

        /* RIGHT SIDE */

        .right-side {
            width: 50%;
            padding: 60px;
            position: relative;
        }

        .signin-btn-top {
            position: absolute;
            top: 35px;
            right: 35px;
        }

        .signin-btn-top button {
            border: none;
            background: #111;
            color: white;
            padding: 12px 30px;
            border-radius: 30px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.3s;
        }

        .signin-btn-top button:hover {
            background: #333;
        }

        .form-wrapper {
            max-width: 500px;
            margin: auto;
            margin-top: 90px;
        }

        .form-wrapper h2 {
            font-size: 42px;
            color: #222260;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #888;
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-size: 14px;
            color: #444;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            padding: 16px;
            border: 1px solid #dcdcdc;
            border-radius: 10px;
            font-size: 15px;
            transition: 0.3s;
        }

        .form-control:focus {
            outline: none;
            border-color: #222260;
            box-shadow: 0 0 0 3px rgba(34,34,96,0.08);
        }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            font-size: 14px;
        }

        .remember-row a {
            text-decoration: none;
            color: #888;
        }

        .remember-row a:hover {
            color: #222260;
        }

        .login-btn {
            width: 100%;
            border: none;
            background: #181818;
            color: white;
            padding: 16px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .login-btn:hover {
            background: #2c2c2c;
        }

        .divider {
            margin: 35px 0;
            position: relative;
            text-align: center;
            color: #aaa;
            font-size: 14px;
        }

        .divider::before,
        .divider::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 38%;
            height: 1px;
            background: #ddd;
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .social-buttons {
            display: flex;
            gap: 15px;
        }

        .social-btn {
            flex: 1;
            border: 1px solid #ddd;
            background: white;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 14px;
        }

        .social-btn:hover {
            background: #f7f7f7;
        }

        .register-link {
            text-align: center;
            margin-top: 40px;
            font-size: 14px;
            color: #777;
        }

        .register-link a {
            color: #222260;
            font-weight: 600;
            text-decoration: none;
        }

        .text-danger {
            color: red;
            font-size: 13px;
        }

        @@media(max-width: 1100px) {

            .left-side {
                display: none;
            }

            .right-side {
                width: 100%;
            }

            .login-container {
                height: auto;
            }
        }

    </style>

</head>

<body>

    <div class="login-container">

        <!-- LEFT SIDE -->

        <div class="left-side">

            <div class="brand">

                <div class="brand-icon">
                    <i class="fas fa-store"></i>
                </div>

                <span>Realnest</span>

            </div>

            <div class="left-content">

                <h1>
                    Shop Smart <br />
                    Across Your City
                </h1>

                <p>
                    Discover trusted local stores, fast delivery,
                    and thousands of products in one marketplace.
                </p>

                <div class="dots">
                    <div class="dot active"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="right-side">

            <div class="signin-btn-top">
                <button>Sign in</button>
            </div>

            <div class="form-wrapper">

                <h2>Welcome Back to Realnest!</h2>

                <p class="subtitle">
                    Sign in to continue shopping from your favorite stores
                </p>

                <form method="post">

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="form-group">

                        <label>Email Address</label>

                        <input asp-for="Input.Email"
                               class="form-control"
                               placeholder="Enter your email" />

                        <span asp-validation-for="Input.Email"
                              class="text-danger"></span>

                    </div>

                    <div class="form-group">

                        <label>Password</label>

                        <input asp-for="Input.Password"
                               class="form-control"
                               placeholder="Enter password" />

                        <span asp-validation-for="Input.Password"
                              class="text-danger"></span>

                    </div>

                    <div class="remember-row">

                        <label>
                            <input asp-for="Input.RememberMe" />
                            Remember Me
                        </label>

                        <a asp-page="./ForgotPassword">
                            Forgot Password?
                        </a>

                    </div>

                    <button type="submit" class="login-btn">
                        Login
                    </button>

                </form>

                <div class="divider">
                    Instant Login
                </div>

                <div class="social-buttons">

                    <button class="social-btn">
                        <i class="fab fa-google"></i>
                        Continue with Google
                    </button>

                    <button class="social-btn">
                        <i class="fab fa-facebook"></i>
                        Continue with Facebook
                    </button>

                </div>

                <div class="register-link">

                    Don’t have any account?

                    <a asp-page="./Register">
                        Register
                    </a>

                </div>

            </div>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />
S
</body>

</html>

