@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Realnest Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
            background: #1f1f1f;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            margin-bottom: 0;
        }

        .login-container {
            width: 1400px;
            max-width: 100%;
            height: 820px;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
        }

        .left-side {
            width: 50%;
            position: relative;
            background:
                linear-gradient(
                    rgba(0, 0, 0, 0.15),
                    rgba(0, 0, 0, 0.3)
                ),
                url('/images/marketplace-login.jpg');
            background-size: cover;
            background-position: center;
            color: white;
        }

        .brand {
            position: absolute;
            top: 35px;
            left: 35px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: white;
            color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
        }

        .brand span {
            font-size: 22px;
            font-weight: 600;
        }

        .left-content {
            position: absolute;
            bottom: 70px;
            left: 55px;
            right: 40px;
        }

        .left-content h1 {
            font-size: 54px;
            line-height: 1.1;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .left-content p {
            font-size: 18px;
            opacity: 0.95;
            line-height: 1.6;
        }

        .dots {
            margin-top: 25px;
            display: flex;
            gap: 10px;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.5);
        }

        .dot.active {
            width: 30px;
            border-radius: 30px;
            background: white;
        }

        .right-side {
            width: 50%;
            padding: 60px;
            position: relative;
        }

        .signin-btn-top {
            position: absolute;
            top: 35px;
            right: 35px;
        }

        .signin-btn-top button {
            border: none;
            background: #111;
            color: white;
            padding: 12px 30px;
            border-radius: 30px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.3s;
        }

        .signin-btn-top button:hover {
            background: #333;
        }

        .form-wrapper {
            max-width: 500px;
            margin: 90px auto 0;
        }

        .form-wrapper h2 {
            font-size: 42px;
            color: #222260;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #888;
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-size: 14px;
            color: #444;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            padding: 16px;
            border: 1px solid #dcdcdc;
            border-radius: 10px;
            font-size: 15px;
            transition: 0.3s;
        }

        .form-control:focus {
            outline: none;
            border-color: #222260;
            box-shadow: 0 0 0 3px rgba(34, 34, 96, 0.08);
        }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            font-size: 14px;
            width: 100%;
            position: relative;
            z-index: 5;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            color: #333;
            margin: 0;
        }

        #forgotPasswordLink {
            color: #888;
            text-decoration: none;
            font-weight: 500;
            padding: 6px 0;
            cursor: pointer;
            position: relative;
            z-index: 10;
            pointer-events: auto;
        }

        #forgotPasswordLink:hover {
            color: #222260;
            text-decoration: underline;
        }

        .login-btn {
            width: 100%;
            border: none;
            background: #181818;
            color: white;
            padding: 16px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .login-btn:hover {
            background: #2c2c2c;
        }

        .divider {
            margin: 35px 0;
            position: relative;
            text-align: center;
            color: #aaa;
            font-size: 14px;
        }

        .divider::before,
        .divider::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 38%;
            height: 1px;
            background: #ddd;
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .social-buttons {
            display: flex;
            gap: 15px;
        }

        .social-btn {
            flex: 1;
            border: 1px solid #ddd;
            background: white;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 14px;
        }

        .social-btn:hover:not(:disabled) {
            background: #f7f7f7;
        }

        .social-btn:disabled {
            cursor: not-allowed;
            opacity: 0.65;
        }

        .google-btn i {
            color: #db4437;
        }

        .facebook-btn i {
            color: #1877f2;
        }

        .register-link {
            text-align: center;
            margin-top: 40px;
            font-size: 14px;
            color: #777;
        }

        .register-link a {
            color: #222260;
            font-weight: 600;
            text-decoration: none;
        }

        .text-danger {
            color: #dc2626;
            font-size: 13px;
        }

        .validation-summary-valid {
            display: none;
        }

        .validation-summary-errors {
            margin-bottom: 18px;
            padding: 12px 14px;
            background: #fee2e2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            color: #991b1b;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }

        /* =====================================================
           LOGIN TOAST
           ===================================================== */

        .login-toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 999999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .login-toast {
            width: min(390px, calc(100vw - 40px));
            padding: 16px;
            border-radius: 14px;
            color: #ffffff;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: linear-gradient(135deg, #b45309, #d97706);
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.30);
            opacity: 0;
            transform: translateX(45px);
            transition:
                opacity 0.3s ease,
                transform 0.3s ease;
            pointer-events: auto;
        }

        .login-toast.show {
            opacity: 1;
            transform: translateX(0);
        }

        .login-toast-icon {
            width: 32px;
            height: 32px;
            flex: 0 0 32px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.20);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 900;
        }

        .login-toast-content {
            flex: 1;
            min-width: 0;
        }

        .login-toast-title {
            display: block;
            margin-bottom: 4px;
            font-size: 14px;
            font-weight: 800;
        }

        .login-toast-message {
            display: block;
            font-size: 13px;
            font-weight: 500;
            line-height: 1.5;
        }

        .login-toast-close {
            border: none;
            background: transparent;
            color: #ffffff;
            padding: 0;
            font-size: 23px;
            line-height: 1;
            cursor: pointer;
        }

        @@media (max-width: 1100px) {
            .left-side {
                display: none;
            }

            .right-side {
                width: 100%;
            }

            .login-container {
                height: auto;
                min-height: 720px;
            }

            .social-buttons {
                flex-direction: column;
            }
        }

        @@media (max-width: 600px) {
            body {
                padding: 10px;
            }

            .right-side {
                padding: 30px 22px;
            }

            .form-wrapper {
                margin-top: 70px;
            }

            .form-wrapper h2 {
                font-size: 32px;
            }

            .signin-btn-top {
                top: 22px;
                right: 22px;
            }

            .remember-row {
                align-items: flex-start;
                gap: 12px;
            }

            .login-toast-container {
                top: 15px;
                right: 15px;
                left: 15px;
            }

            .login-toast {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <!-- Login-specific toast container -->
    <div id="loginToastContainer"
         class="login-toast-container"
         aria-live="polite"
         aria-atomic="true">
    </div>

    <div class="login-container">

        <div class="left-side">

            <div class="brand">

                <div class="brand-icon">
                    <i class="fas fa-store"></i>
                </div>

                <span>Realnest</span>

            </div>

            <div class="left-content">

                <h1>
                    Shop Smart <br />
                    Across Your City
                </h1>

                <p>
                    Discover trusted local stores, fast delivery,
                    and thousands of products in one marketplace.
                </p>

                <div class="dots">
                    <div class="dot active"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>

            </div>

        </div>

        <div class="right-side">

            <div class="signin-btn-top">
                <button type="button">
                    Sign in
                </button>
            </div>

            <div class="form-wrapper">

                <h2>Welcome Back to Realnest!</h2>

                <p class="subtitle">
                    Sign in to continue shopping from your favorite stores
                </p>

                <form method="post"
                      asp-route-returnUrl="@Model.ReturnUrl">

                    <div asp-validation-summary="All"
                         class="text-danger">
                    </div>

                    <div class="form-group">

                        <label asp-for="Input.Email">
                            Email Address
                        </label>

                        <input asp-for="Input.Email"
                               id="loginEmail"
                               class="form-control"
                               placeholder="Enter your email"
                               autocomplete="email" />

                        <span asp-validation-for="Input.Email"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="form-group">

                        <label asp-for="Input.Password">
                            Password
                        </label>

                        <input asp-for="Input.Password"
                               id="loginPassword"
                               class="form-control"
                               type="password"
                               placeholder="Enter password"
                               autocomplete="current-password" />

                        <span asp-validation-for="Input.Password"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="remember-row">

                        <label class="remember-label">
                            <input asp-for="Input.RememberMe" />
                            Remember Me
                        </label>

                        <a asp-page="./ForgotPassword"
                           id="forgotPasswordLink">
                            Forgot Password?
                        </a>

                    </div>

                    <button type="submit"
                            class="login-btn">
                        Login
                    </button>

                </form>

                <div class="divider">
                    Instant Login
                </div>

                @if (Model.ExternalLogins != null &&
                     Model.ExternalLogins.Count > 0)
                {
                    <form asp-page="./Login"
                          asp-page-handler="ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        <div class="social-buttons">

                            @foreach (var provider in Model.ExternalLogins)
                            {
                                if (provider.Name == "Google")
                                {
                                    <button type="submit"
                                            class="social-btn google-btn"
                                            name="provider"
                                            value="@provider.Name">

                                        <i class="fab fa-google"></i>
                                        Continue with Google
                                    </button>
                                }

                                if (provider.Name == "Facebook")
                                {
                                    <button type="submit"
                                            class="social-btn facebook-btn"
                                            name="provider"
                                            value="@provider.Name">

                                        <i class="fab fa-facebook"></i>
                                        Continue with Facebook
                                    </button>
                                }
                            }

                        </div>
                    </form>
                }
                else
                {
                    <div class="social-buttons">

                        <button type="button"
                                class="social-btn google-btn"
                                disabled>

                            <i class="fab fa-google"></i>
                            Google Not Configured
                        </button>

                        <button type="button"
                                class="social-btn facebook-btn"
                                disabled>

                            <i class="fab fa-facebook"></i>
                            Facebook Not Configured
                        </button>

                    </div>
                }

                <div class="register-link">

                    Don’t have any account?

                    <a asp-page="./Register">
                        Register
                    </a>

                </div>

            </div>

        </div>

    </div>

    <script>
        function showLoginToast(message) {
            const container =
                document.getElementById("loginToastContainer");

            if (!container || !message) {
                return;
            }

            const existingToast =
                container.querySelector(".login-toast");

            if (existingToast) {
                existingToast.remove();
            }

            const toast =
                document.createElement("div");

            toast.className =
                "login-toast";

            toast.setAttribute("role", "status");

            const icon =
                document.createElement("span");

            icon.className =
                "login-toast-icon";

            icon.textContent =
                "!";

            const content =
                document.createElement("div");

            content.className =
                "login-toast-content";

            const title =
                document.createElement("span");

            title.className =
                "login-toast-title";

            title.textContent =
                "Password field not empty";

            const messageElement =
                document.createElement("span");

            messageElement.className =
                "login-toast-message";

            messageElement.textContent =
                message;

            const closeButton =
                document.createElement("button");

            closeButton.type =
                "button";

            closeButton.className =
                "login-toast-close";

            closeButton.setAttribute(
                "aria-label",
                "Close notification");

            closeButton.innerHTML =
                "&times;";

            content.appendChild(title);
            content.appendChild(messageElement);

            toast.appendChild(icon);
            toast.appendChild(content);
            toast.appendChild(closeButton);

            container.appendChild(toast);

            window.requestAnimationFrame(
                function () {
                    toast.classList.add("show");
                });

            let closeTimer =
                window.setTimeout(
                    removeToast,
                    5000);

            function removeToast() {
                if (!toast.isConnected) {
                    return;
                }

                window.clearTimeout(closeTimer);

                toast.classList.remove("show");

                window.setTimeout(
                    function () {
                        toast.remove();
                    },
                    300);
            }

            closeButton.addEventListener(
                "click",
                removeToast);
        }

        document.addEventListener(
            "DOMContentLoaded",
            function () {

                const loginEmailInput =
                    document.getElementById("loginEmail");

                const loginPasswordInput =
                    document.getElementById("loginPassword");

                const forgotPasswordLink =
                    document.getElementById("forgotPasswordLink");

                if (!forgotPasswordLink) {
                    return;
                }

                forgotPasswordLink.addEventListener(
                    "click",
                    function (event) {

                        const email =
                            loginEmailInput
                                ? loginEmailInput.value.trim()
                                : "";

                        const password =
                            loginPasswordInput
                                ? loginPasswordInput.value
                                : "";

                        if (password.length > 0) {
                            event.preventDefault();

                            showLoginToast(
                                "Please clear the password field before using Forgot Password."
                            );

                            if (loginPasswordInput) {
                                loginPasswordInput.focus();
                            }

                            return;
                        }

                        if (email.length > 0) {
                            event.preventDefault();

                            window.location.href =
                                "/Identity/Account/ForgotPassword?email=" +
                                encodeURIComponent(email);
                        }
                    });
            });
    </script>

    <partial name="_ValidationScriptsPartial" />

</body>

</html>

