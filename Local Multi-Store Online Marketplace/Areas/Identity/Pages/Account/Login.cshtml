@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>Login | realnest</title>

    <!-- Google Fonts & FontAwesome Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --bg-color: #fdfbf7; /* Cozy warm white canvas */
            --card-bg: #ffffff;
            --border-color: #f3ece3; /* Soft warm borders */
            --text-primary: #1c1917; /* Slate dark brown/black */
            --text-secondary: #78716c; /* Elegant muted stone gray */
            /* Smooth Warm Palette */
            --accent-color: #ff6b35; /* Radiant bright orange */
            --accent-hover: #f05a22;
            --accent-light: #fff1eb;
            --accent-gradient: linear-gradient(135deg, #ffa47a 0%, #ff6b35 100%); /* Softer, sunset peach gradient */

            --success-color: #10b981;
            --error-color: #ea580c; /* Deep readable orange-red for error messages */
            --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --shadow-sm: 0 4px 12px rgba(255, 107, 53, 0.04);
            --shadow-md: 0 10px 30px rgba(255, 107, 53, 0.08);
            --shadow-lg: 0 20px 40px rgba(255, 107, 53, 0.12);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: var(--font-family);
            background: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
            color: var(--text-primary);
        }

        .login-container {
            width: 1280px;
            max-width: 100%;
            height: 780px;
            background: var(--card-bg);
            border-radius: 28px;
            overflow: hidden;
            display: flex;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-color);
        }

        /* LEFT BRAND PANEL (Smooth Soft Sunset-Apricot Gradient Overlay) */
        .left-side {
            width: 50%;
            position: relative;
            background: linear-gradient(135deg, rgba(253, 251, 247, 0.85) 0%, rgba(255, 222, 204, 0.95) 100%), url('/images/marketplace-login.jpg');
            background-size: cover;
            background-position: center;
            color: var(--text-primary); /* Soft readable dark text for a warmer, calmer feel */
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--accent-gradient);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
            box-shadow: 0 4px 12px rgba(255, 107, 53, 0.25);
        }

        .brand span {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--text-primary);
        }

        .left-content {
            margin-top: auto;
        }

            .left-content h1 {
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 48px;
                line-height: 1.15;
                margin-bottom: 16px;
                font-weight: 800;
                letter-spacing: -1.5px;
                color: var(--text-primary);
            }

            .left-content p {
                font-size: 16px;
                opacity: 0.9;
                line-height: 1.6;
                max-width: 460px;
                font-weight: 500;
                color: var(--text-secondary);
            }

        .dots {
            margin-top: 28px;
            display: flex;
            gap: 8px;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(28, 25, 23, 0.15);
            transition: all 0.3s ease;
        }

            .dot.active {
                width: 24px;
                border-radius: 10px;
                background: var(--accent-color);
            }

        /* FORM SIDE PANEL */
        .right-side {
            width: 50%;
            padding: 64px;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #ffffff;
            overflow-y: auto;
        }

        .signin-btn-top {
            position: absolute;
            top: 40px;
            right: 40px;
        }

            .signin-btn-top button {
                border: 1px solid var(--border-color);
                background: var(--bg-color);
                color: var(--text-primary);
                padding: 10px 24px;
                border-radius: 50px;
                font-weight: 700;
                font-size: 13px;
                cursor: pointer;
                transition: all 0.25s ease;
            }

                .signin-btn-top button:hover {
                    border-color: var(--accent-color);
                    color: var(--accent-color);
                    background: var(--accent-light);
                }

        .form-wrapper {
            max-width: 440px;
            width: 100%;
            margin: auto;
        }

            .form-wrapper h2 {
                font-size: 32px;
                font-weight: 800;
                color: var(--text-primary);
                margin-bottom: 8px;
                letter-spacing: -0.8px;
            }

        .subtitle {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 36px;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-size: 13px;
                color: var(--text-primary);
                font-weight: 700;
            }

        .form-control {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid var(--border-color);
            border-radius: 14px;
            font-size: 14px;
            background-color: var(--bg-color);
            font-family: var(--font-family);
            color: var(--text-primary);
            outline: none;
            transition: all 0.25s ease;
        }

            .form-control:focus {
                background-color: #ffffff;
                border-color: var(--accent-color);
                box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
            }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            font-size: 13px;
            width: 100%;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
        }

            .remember-label input[type="checkbox"] {
                accent-color: var(--accent-color);
                width: 16px;
                height: 16px;
                cursor: pointer;
            }

        #forgotPasswordLink {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 700;
            cursor: pointer;
            transition: color 0.2s ease;
        }

            #forgotPasswordLink:hover {
                color: var(--accent-color);
                text-decoration: underline;
            }

        /* Beautiful Terracotta-Orange Submit Button */
        .login-btn {
            width: 100%;
            border: none;
            background: var(--accent-gradient);
            color: white;
            padding: 16px;
            border-radius: 50px;
            font-size: 15px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.2);
        }

            .login-btn:hover {
                opacity: 0.95;
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(255, 107, 53, 0.3);
            }

        .divider {
            margin: 28px 0;
            position: relative;
            text-align: center;
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 700;
        }

            .divider::before,
            .divider::after {
                content: "";
                position: absolute;
                top: 50%;
                width: 32%;
                height: 1px;
                background: var(--border-color);
            }

            .divider::before {
                left: 0;
            }

            .divider::after {
                right: 0;
            }

        /* SOCIAL MEDIA BUTTONS */
        .social-buttons {
            display: flex;
            gap: 12px;
        }

        .social-btn {
            flex: 1;
            border: 1px solid var(--border-color);
            background: #ffffff;
            padding: 12px 16px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.25s ease;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--text-primary);
            box-shadow: var(--shadow-sm);
        }

            .social-btn:hover:not(:disabled) {
                background: var(--accent-light);
                border-color: var(--accent-color);
                color: var(--accent-color);
            }

            .social-btn:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                background: #fafaf9;
            }

        .google-btn i {
            color: #db4437;
        }

        .facebook-btn i {
            color: #1877f2;
        }

        .register-link {
            text-align: center;
            margin-top: 36px;
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 600;
        }

            .register-link a {
                color: var(--accent-color);
                font-weight: 800;
                text-decoration: none;
                transition: color 0.15s ease;
            }

                .register-link a:hover {
                    color: var(--accent-hover);
                    text-decoration: underline;
                }

        .text-danger {
            color: var(--error-color);
            font-size: 12px;
            font-weight: 700;
            margin-top: 4px;
            display: block;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 10px;
            background: #fff5f5;
            border: 1px solid #ffd1cc;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        /* RESPONSIVE RENDERS */
        @@media(max-width: 1100px) {
            .left-side {
                display: none;
            }

            .right-side {
                width: 100%;
                padding: 40px;
            }

            .login-container {
                height: auto;
                border-radius: 20px;
            }

            .social-buttons {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>

    <div class="login-container">

        <!-- BRANDING PANEL -->
        <div class="left-side">

            <div class="brand">
                <div class="brand-icon">
                    <i class="fas fa-store"></i>
                </div>
                <span>realnest</span>
            </div>

            <div class="left-content">
                <h1>
                    Shop Smart <br />
                    Across Your City
                </h1>

                <p>
                    Discover trusted local stores, fast delivery,
                    and thousands of products in one marketplace.
                </p>

                <div class="dots">
                    <div class="dot active"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>
            </div>

        </div>

        <!-- FORM PANEL -->
        <div class="right-side">

            <div class="signin-btn-top">
                <button type="button" onclick="location.reload();">Sign in</button>
            </div>

            <div class="form-wrapper">

                <h2>Welcome Back!</h2>

                <p class="subtitle">
                    Sign in to continue shopping from your favorite local stores.
                </p>

                <form method="post" asp-route-returnUrl="@Model.ReturnUrl">

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email">Email Address</label>
                        <input asp-for="Input.Email"
                               id="loginEmail"
                               class="form-control"
                               placeholder="Enter your email" />
                        <span asp-validation-for="Input.Email"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password">Password</label>
                        <input asp-for="Input.Password"
                               id="loginPassword"
                               class="form-control"
                               type="password"
                               placeholder="Enter password" />
                        <span asp-validation-for="Input.Password"
                              class="text-danger"></span>
                    </div>

                    <div class="remember-row">
                        <label class="remember-label">
                            <input asp-for="Input.RememberMe" />
                            Remember Me
                        </label>

                        <a asp-page="./ForgotPassword"
                           id="forgotPasswordLink">
                            Forgot Password?
                        </a>
                    </div>

                    <button type="submit" class="login-btn">
                        Login
                    </button>

                </form>

                <div class="divider">
                    Instant Login
                </div>

                @if (Model.ExternalLogins != null && Model.ExternalLogins.Count > 0)
                {
                    <form asp-page="./Login"
                          asp-page-handler="ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        <div class="social-buttons">

                            @foreach (var provider in Model.ExternalLogins)
                            {
                                if (provider.Name == "Google")
                                {
                                    <button type="submit"
                                            class="social-btn google-btn"
                                            name="provider"
                                            value="@provider.Name">
                                        <i class="fab fa-google"></i>
                                        Continue with Google
                                    </button>
                                }

                                if (provider.Name == "Facebook")
                                {
                                    <button type="submit"
                                            class="social-btn facebook-btn"
                                            name="provider"
                                            value="@provider.Name">
                                        <i class="fab fa-facebook"></i>
                                        Continue with Facebook
                                    </button>
                                }
                            }

                        </div>

                    </form>
                }
                else
                {
                    <div class="social-buttons">

                        <button type="button" class="social-btn google-btn" disabled>
                            <i class="fab fa-google"></i>
                            Google Unavailable
                        </button>

                        <button type="button" class="social-btn facebook-btn" disabled>
                            <i class="fab fa-facebook"></i>
                            Facebook Unavailable
                        </button>

                    </div>
                }

                <div class="register-link">
                    Don't have an account?
                    <a asp-page="./Register">
                        Register
                    </a>
                </div>

            </div>

        </div>

    </div>

    <!-- CORE SCRIPTS -->
    <script>
        const loginEmailInput = document.getElementById("loginEmail");
        const loginPasswordInput = document.getElementById("loginPassword");
        const forgotPasswordLink = document.getElementById("forgotPasswordLink");

        if (forgotPasswordLink) {
            forgotPasswordLink.addEventListener("click", function (e) {
                const email = loginEmailInput ? loginEmailInput.value.trim() : "";
                const password = loginPasswordInput ? loginPasswordInput.value.trim() : "";

                if (password.length > 0) {
                    e.preventDefault();
                    alert("Please clear the password field before using Forgot Password.");
                    return;
                }

                if (email.length > 0) {
                    e.preventDefault();
                    window.location.href =
                        "/Identity/Account/ForgotPassword?email=" + encodeURIComponent(email);
                }
            });
        }
    </script>

    <partial name="_ValidationScriptsPartial" />

</body>

</html>