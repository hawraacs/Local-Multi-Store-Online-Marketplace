@page
@model ResetPasswordConfirmationModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <title>Password Reset</title>

    <style>

        body {
            background: #1f1f1f;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial;
        }

        .box {
            background: white;
            width: 450px;
            padding: 50px;
            border-radius: 15px;
            text-align: center;
        }

        h1 {
            color: #1f2b6c;
            margin-bottom: 20px;
        }

        p {
            color: gray;
            line-height: 1.7;
        }

        a {
            display: inline-block;
            margin-top: 25px;
            background: #1f2b6c;
            color: white;
            padding: 12px 25px;
            border-radius: 10px;
            text-decoration: none;
        }

    </style>

</head>

<body>

    <div class="box">

        <h1>Password Updated</h1>

        <p>
            Your password has been reset successfully.
        </p>

        <a asp-page="./Login">
            Login
        </a>

    </div>

</body>
</html>