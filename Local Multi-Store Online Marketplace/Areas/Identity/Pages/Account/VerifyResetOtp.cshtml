@page
@model VerifyResetOtpModel

@{
    ViewData["Title"] = "Verify OTP";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Verify OTP | Realnest</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: Poppins, Arial, sans-serif;
            background: #1f1f1f;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #111827;
        }

        .card {
            width: 500px;
            max-width: 100%;
            background: white;
            border-radius: 18px;
            padding: 42px;
            box-shadow: 0 25px 70px rgba(0,0,0,0.40);
        }

        h1 {
            color: #222260;
            font-size: 34px;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #777;
            font-size: 14px;
            line-height: 1.7;
            margin-bottom: 28px;
        }

        label {
            display: block;
            margin-bottom: 9px;
            font-size: 14px;
            font-weight: 600;
            color: #444;
        }

        .form-control {
            width: 100%;
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #dcdcdc;
            font-family: inherit;
            font-size: 14px;
            margin-bottom: 18px;
        }

        .btn-submit {
            width: 100%;
            margin-top: 8px;
            padding: 15px;
            background: #181818;
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
        }

            .btn-submit:hover {
                background: #ff6b35;
            }

        .text-danger {
            color: #b91c1c;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #777;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="card">

        <h1>Verify OTP</h1>

        <p class="subtitle">
            Enter the OTP to continue resetting your password.
        </p>

        <form method="post">

            <div asp-validation-summary="All" class="text-danger"></div>

            <label asp-for="Input.Identifier">Email or Phone</label>
            <input asp-for="Input.Identifier"
                   class="form-control"
                   readonly />

            <label asp-for="Input.Otp">OTP Code</label>
            <input asp-for="Input.Otp"
                   class="form-control"
                   placeholder="Enter 6-digit OTP"
                   maxlength="6" />

            <button type="submit" class="btn-submit">
                Verify OTP
            </button>

        </form>

        <a href="/Identity/Account/Login" class="back-link">
            Back to Login
        </a>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>